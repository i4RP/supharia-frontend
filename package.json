        "date-fns": "^4.1.0",
        "lucide-vue-next": "^0.575.0",
        "nuxt": "^4.2.2",
        "pinia": "^3.0.4",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.1",
        "tw-animate-css": "^1.4.0",
        "viem": "^2.47.0",
        "vue": "^3.5.28",
        "vue-chartjs": "^5.3.3",
        "vue-router": "^4.6.4"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.4",

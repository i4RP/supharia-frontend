#[derive(Deserialize)]
struct S402RegisterAgentRequest {
    agent_name: Option<String>,
}

async fn s402_register_agent(
    State(state): State<AppState>,
    Json(req): Json<S402RegisterAgentRequest>,
) -> (StatusCode, Json<ApiResponse<serde_json::Value>>) {
    let mut entropy = [0u8; 16];
    rand::RngCore::fill_bytes(&mut rand::thread_rng(), &mut entropy);
    let mnemonic = bip39::Mnemonic::from_entropy(&entropy).unwrap();
    let seed = mnemonic.to_seed("");
    let privkey_bytes: [u8; 32] = {
        let mut buf = [0u8; 32];
        buf.copy_from_slice(&seed[..32]);
        buf
    };
    let sk = secp256k1::SecretKey::from_slice(&privkey_bytes)
        .unwrap_or_else(|_| secp256k1::SecretKey::from_slice(&[1u8; 32]).unwrap());
    let secp = secp256k1::Secp256k1::new();
    let pk = secp256k1::PublicKey::from_secret_key(&secp, &sk);
    let pk_bytes = pk.serialize();

    let mut version_and_key = vec![0x80u8];
    version_and_key.extend_from_slice(&privkey_bytes);
    version_and_key.push(0x01);
    let wif = bs58::encode(&version_and_key).with_check().into_string();

    let sha256_hash = {
        use sha2::Digest;
        let h = sha2::Sha256::digest(&pk_bytes);
        h.to_vec()
    };
    let pkh = {
        use ripemd::Digest as RipDigest;
        let h = ripemd::Ripemd160::digest(&sha256_hash);
        h.to_vec()
    };
    let address = {
        let mut addr_bytes = vec![0x00u8];
        addr_bytes.extend_from_slice(&pkh);
        bs58::encode(&addr_bytes).with_check().into_string()
    };

    let agent_id = req.agent_name.unwrap_or_else(|| format!("agent-{}", &Uuid::new_v4().to_string()[..8]));

    let agent = s402::AgentWallet {
        agent_id: agent_id.clone(),
        address: address.clone(),
        balance_sats: 0,
        total_spent_sats: 0,
        total_payments: 0,
        created_at: Utc::now().to_rfc3339(),
        last_payment_at: None,
    };

    {
        let mut wallets = state.s402.agent_wallets.lock().unwrap();
        wallets.insert(agent_id.clone(), agent);
    }

    ok_response(serde_json::json!({
        "agent_id": agent_id,
        "mnemonic": mnemonic.to_string(),
        "wif": wif,
        "address": address,
        "network": state.s402.config.network,
        "instructions": {
            "step_1": "Fund this address with BSV (even 1000 sats is enough for thousands of API calls)",
            "step_2": "Use the WIF to sign s402 payment transactions",
            "step_3": "Include signed tx in X-STAS-PAYMENT header when calling protected endpoints",
            "auto_pay": "Or use POST /s402/agent/{agent_id}/pay for server-assisted payments"
        }
    }))
}


        tx_type:
          type: string
          enum: [swap, add_liquidity, remove_liquidity]
        user_address:
          type: string
        input_token:
          type: string
        input_amount:
          type: integer
          format: uint64
        output_token:
          type: string
        output_amount:
          type: integer
          format: uint64
        fee_amount:
          type: integer
          format: uint64
        timestamp:
          type: string
          format: date-time

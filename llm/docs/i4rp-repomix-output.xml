async fn vote_proposal(
    State(state): State<AppState>,
    Path((pool_id, proposal_id)): Path<(String, String)>,
    Json(req): Json<VoteRequest>,
) -> (StatusCode, Json<ApiResponse<ProposalInfo>>) {
    let mut proposal = match state.db.get_proposal(&pool_id, &proposal_id).await {
        Ok(Some(p)) => p,
        Ok(None) => return err_response(StatusCode::NOT_FOUND, "Proposal not found"),
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };
    if proposal.status != "active" {
        return err_response(StatusCode::BAD_REQUEST, "Proposal is not active");
    }
    let now = Utc::now().to_rfc3339();
    if now > proposal.expires_at {
        proposal.status = "expired".to_string();
        let _ = state.db.put_proposal(&proposal).await;
        return err_response(StatusCode::BAD_REQUEST, "Proposal has expired");
    }
    let lp = state.db.get_lp_position(&pool_id, &req.voter).await.ok().flatten();
    let voting_power = lp.map(|l| l.lp_shares).unwrap_or(0.0);
    if voting_power <= 0.0 {
        return err_response(StatusCode::BAD_REQUEST, "No LP shares to vote with");
    }
    match req.vote.as_str() {
        "for" => proposal.votes_for += voting_power,
        "against" => proposal.votes_against += voting_power,
        _ => return err_response(StatusCode::BAD_REQUEST, "Vote must be 'for' or 'against'"),
    }
    if let Err(e) = state.db.put_proposal(&proposal).await {
        return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e);
    }
    ok_response(proposal_to_info(&proposal))
}

async fn execute_proposal(
    State(state): State<AppState>,
    Path((pool_id, proposal_id)): Path<(String, String)>,
) -> (StatusCode, Json<ApiResponse<ProposalInfo>>) {
    let mut proposal = match state.db.get_proposal(&pool_id, &proposal_id).await {
        Ok(Some(p)) => p,
        Ok(None) => return err_response(StatusCode::NOT_FOUND, "Proposal not found"),
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };
    if proposal.status != "active" {
        return err_response(StatusCode::BAD_REQUEST, "Proposal is not active");
    }
    let total = proposal.votes_for + proposal.votes_against;
    if total <= 0.0 {
        return err_response(StatusCode::BAD_REQUEST, "No votes cast yet");
    }
    if proposal.votes_for <= proposal.votes_against {
        proposal.status = "rejected".to_string();
        let _ = state.db.put_proposal(&proposal).await;
        return ok_response(proposal_to_info(&proposal));
    }
    let mut pool = match state.db.get_pool(&pool_id).await {
        Ok(Some(p)) => p,
        Ok(None) => return err_response(StatusCode::NOT_FOUND, "Pool not found"),
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };
    match proposal.param_key.as_str() {
        "fee_rate" => pool.fee_rate = proposal.param_value,
        _ => return err_response(StatusCode::BAD_REQUEST, "Unknown param_key"),
    }
    if let Err(e) = state.db.put_pool(&pool).await {
        return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e);
    }
    proposal.status = "executed".to_string();
    let _ = state.db.put_proposal(&proposal).await;
    ok_response(proposal_to_info(&proposal))
}


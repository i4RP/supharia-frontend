#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn endpoint_matching() {
        assert!(endpoint_matches("/s402/premium/*", "/s402/premium/data"));
        assert!(endpoint_matches("/s402/premium/*", "/s402/premium/other"));
        assert!(endpoint_matches("/pools/*/quote", "/pools/abc/quote"));
        assert!(!endpoint_matches("/pools/*/quote", "/pools/abc/swap"));
        assert!(!endpoint_matches("/s402/premium/*", "/s402/free/data"));
    }

    #[test]
    fn read_varint_values() {
        let mut pos = 0;
        assert_eq!(read_varint(&[0x05], &mut pos), 5);
        assert_eq!(pos, 1);

        pos = 0;
        assert_eq!(read_varint(&[0xfd, 0x00, 0x01], &mut pos), 256);
        assert_eq!(pos, 3);
    }

    #[test]
    fn nonce_replay_protection() {
        let config = S402Config {
            enabled: true,
            recipient_address: "1Test".to_string(),
            recipient_pkh: "0000000000000000000000000000000000000000".to_string(),
            network: "bsv:testnet".to_string(),
            default_price_sats: 100,
            accept_bsv: true,
            accept_stas: false,
            accepted_token_ids: vec![],
            description: "Test".to_string(),
        };
        let state = S402State::new(config);

        let payload = PaymentPayload {
            scheme: "bsv-p2pkh".to_string(),
            tx_hex: "0100000001".repeat(10),
            nonce: "test-nonce-1".to_string(),
            timestamp: Utc::now().timestamp(),
        };

        let _first = state.verify_payment_payload(&payload);
        let second = state.verify_payment_payload(&payload);
        assert!(!second.valid);
        assert!(second.error.unwrap().contains("replay"));
    }

    #[test]
    fn payment_required_response_format() {
        let config = S402Config {
            enabled: true,
            recipient_address: "1ABC".to_string(),
            recipient_pkh: "abcdef".to_string(),
            network: "bsv:mainnet".to_string(),
            default_price_sats: 50,
            accept_bsv: true,
            accept_stas: true,
            accepted_token_ids: vec!["token123".to_string()],
            description: "API".to_string(),
        };
        let state = S402State::new(config);
        let resp = state.build_payment_required("/test");
        assert_eq!(resp.protocol, "s402");
        assert_eq!(resp.version, "1.0");
        assert_eq!(resp.accepts.len(), 2);
        assert_eq!(resp.accepts[0].scheme, "bsv-p2pkh");
        assert_eq!(resp.accepts[1].scheme, "stas-transfer");
    }

    #[test]
    fn expired_timestamp_rejected() {
        let config = S402Config {
            enabled: true,
            recipient_address: "1Test".to_string(),
            recipient_pkh: "0000000000000000000000000000000000000000".to_string(),
            network: "bsv:testnet".to_string(),
            default_price_sats: 100,
            accept_bsv: true,
            accept_stas: false,
            accepted_token_ids: vec![],
            description: "Test".to_string(),
        };
        let state = S402State::new(config);

        let payload = PaymentPayload {
            scheme: "bsv-p2pkh".to_string(),
            tx_hex: "0100000001".repeat(10),
            nonce: "old-nonce".to_string(),
            timestamp: Utc::now().timestamp() - 600,
        };
        let result = state.verify_payment_payload(&payload);
        assert!(!result.valid);
        assert!(result.error.unwrap().contains("expired"));
    }

    #[test]
    fn protocol_info_correct() {
        let info = protocol_info();
        assert_eq!(info.protocol, "s402");
        assert!(!info.facilitator_required);
        assert_eq!(info.min_payment_sats, 1);
        assert!(info.advantages_over_x402.len() > 5);
    }
}

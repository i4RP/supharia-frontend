use axum::{
    extract::State,
    http::{HeaderMap, StatusCode},
    response::Json,
};
use serde::{Deserialize, Serialize};
use chrono::Utc;
use uuid::Uuid;
use std::collections::HashMap;
use std::sync::Mutex;

use crate::woc::WocClient;
use crate::crypto::wallet::{wallet_from_wif, DerivedWallet};
use crate::crypto::hashes::double_sha256;
use crate::bitcoin::tx::tx_id_from_hex;

const PAYMENT_HEADER: &str = "x-stas-payment";
const PAYMENT_WINDOW_SECS: i64 = 300;
const MIN_BSV_PAYMENT: u64 = 1;
const MAX_NONCE_CACHE: usize = 10_000;

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct PaymentRequirement {
    pub scheme: String,
    pub network: String,
    pub recipient: String,
    pub recipient_pkh: String,
    #[serde(skip_serializing_if = "Option::is_none")]
    pub token_id: Option<String>,

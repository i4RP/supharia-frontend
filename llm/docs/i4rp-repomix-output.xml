    ).toBytes();

    const tx = new Transaction(
      new Uint8Array([0x00]),
      [],
      [new TransactionOutput(100, lockingScript)],
      1,
      0,
    );

    expect(() => OutPoint.fromTransaction(tx, 0)).toThrow(
      "Output does not expose address",
    );
  });
});

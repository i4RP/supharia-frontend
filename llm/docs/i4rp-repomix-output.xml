}

pub struct S402State {
    pub config: S402Config,
    pub payments: Mutex<Vec<PaymentRecord>>,
    pub used_nonces: Mutex<Vec<String>>,
    pub endpoint_pricing: Mutex<Vec<EndpointPricing>>,
    pub agent_wallets: Mutex<HashMap<String, AgentWallet>>,
}

impl S402State {
    pub fn new(config: S402Config) -> Self {
        Self {
            config,
            payments: Mutex::new(Vec::new()),
            used_nonces: Mutex::new(Vec::new()),
            endpoint_pricing: Mutex::new(vec![
                EndpointPricing {
                    path_pattern: "/s402/premium/*".to_string(),
                    price_sats: 100,
                    description: "Premium API access".to_string(),
                    token_id: None,
                },
                EndpointPricing {
                    path_pattern: "/pools/*/quote".to_string(),
                    price_sats: 10,
                    description: "Swap quote".to_string(),
                    token_id: None,
                },
            ]),
            agent_wallets: Mutex::new(HashMap::new()),
        }
    }

    pub fn build_payment_required(&self, endpoint: &str) -> PaymentRequiredResponse {
        let price = self.get_price_for_endpoint(endpoint);
        let mut accepts = Vec::new();

        if self.config.accept_bsv {
            accepts.push(PaymentRequirement {
                scheme: "bsv-p2pkh".to_string(),
                network: self.config.network.clone(),
                recipient: self.config.recipient_address.clone(),
                recipient_pkh: self.config.recipient_pkh.clone(),
                token_id: None,
                amount: price,
                description: format!("BSV payment: {} sats", price),
            });
        }

        if self.config.accept_stas {
            for token_id in &self.config.accepted_token_ids {
                accepts.push(PaymentRequirement {
                    scheme: "stas-transfer".to_string(),
                    network: self.config.network.clone(),
                    recipient: self.config.recipient_address.clone(),
                    recipient_pkh: self.config.recipient_pkh.clone(),
                    token_id: Some(token_id.clone()),
                    amount: price,
                    description: format!("STAS token payment: {} sats", price),
                });
            }
        }

        PaymentRequiredResponse {
            protocol: "s402".to_string(),
            version: "1.0".to_string(),
            accepts,
            memo: self.config.description.clone(),
            endpoint: Some(endpoint.to_string()),
        }
    }

    pub fn get_price_for_endpoint(&self, endpoint: &str) -> u64 {
        let pricing = self.endpoint_pricing.lock().unwrap();
        for ep in pricing.iter() {
            if endpoint_matches(&ep.path_pattern, endpoint) {
                return ep.price_sats;
            }
        }
        self.config.default_price_sats
    }

    pub fn verify_payment_payload(&self, payload: &PaymentPayload) -> PaymentVerification {
        let now = Utc::now().timestamp();
        if (now - payload.timestamp).abs() > PAYMENT_WINDOW_SECS {
            return PaymentVerification {
                valid: false,
                txid: String::new(),
                amount: 0,
                scheme: payload.scheme.clone(),
                error: Some("Payment timestamp expired".to_string()),
            };
        }

        {
            let mut nonces = self.used_nonces.lock().unwrap();
            if nonces.contains(&payload.nonce) {
                return PaymentVerification {
                    valid: false,
                    txid: String::new(),
                    amount: 0,
                    scheme: payload.scheme.clone(),
                    error: Some("Nonce already used (replay protection)".to_string()),
                };
            }
            nonces.push(payload.nonce.clone());
            if nonces.len() > MAX_NONCE_CACHE {
                let half = nonces.len() / 2;
                nonces.drain(..half);
            }
        }

        if payload.tx_hex.is_empty() || payload.tx_hex.len() < 20 {
            return PaymentVerification {
                valid: false,
                txid: String::new(),
                amount: 0,
                scheme: payload.scheme.clone(),
                error: Some("Invalid transaction hex".to_string()),
            };
        }

        let txid = tx_id_from_hex(&payload.tx_hex);
        let amount = extract_payment_amount(&payload.tx_hex, &self.config.recipient_pkh);

        if amount < MIN_BSV_PAYMENT {
            return PaymentVerification {
                valid: false,
                txid,
                amount,
                scheme: payload.scheme.clone(),
                error: Some(format!("Payment amount {} below minimum {}", amount, MIN_BSV_PAYMENT)),
            };
        }

        PaymentVerification {
            valid: true,
            txid,
            amount,
            scheme: payload.scheme.clone(),
            error: None,
        }
    }

    pub fn record_payment(&self, verification: &PaymentVerification, endpoint: &str, from_addr: &str) -> PaymentRecord {
        let record = PaymentRecord {
            payment_id: Uuid::new_v4().to_string(),
            txid: verification.txid.clone(),
            scheme: verification.scheme.clone(),
            amount: verification.amount,
            from_address: from_addr.to_string(),
            to_address: self.config.recipient_address.clone(),
            endpoint: endpoint.to_string(),
            status: "broadcast".to_string(),
            created_at: Utc::now().to_rfc3339(),
            confirmed_at: None,
        };
        let mut payments = self.payments.lock().unwrap();
        payments.push(record.clone());
        record
    }

    pub fn get_stats(&self) -> S402Stats {
        let payments = self.payments.lock().unwrap();
        let now = Utc::now();
        let day_ago = now - chrono::Duration::hours(24);

        let total_payments = payments.len() as u64;
        let total_revenue: u64 = payments.iter().map(|p| p.amount).sum();

        let recent: Vec<&PaymentRecord> = payments.iter()
            .filter(|p| {
                chrono::DateTime::parse_from_rfc3339(&p.created_at)
                    .map(|dt| dt > day_ago)
                    .unwrap_or(false)
            })
            .collect();

        let payments_24h = recent.len() as u64;
        let revenue_24h: u64 = recent.iter().map(|p| p.amount).sum();

        let mut payers = std::collections::HashSet::new();
        for p in payments.iter() {
            payers.insert(p.from_address.clone());
        }

        let pending = payments.iter().filter(|p| p.status == "broadcast").count() as u64;

        S402Stats {
            total_payments,
            total_revenue_sats: total_revenue,
            payments_24h,
            revenue_24h_sats: revenue_24h,
            unique_payers: payers.len() as u64,
            avg_payment_sats: if total_payments > 0 { total_revenue / total_payments } else { 0 },
            pending_confirmations: pending,
        }
    }

    pub fn get_recent_payments(&self, limit: usize) -> Vec<PaymentRecord> {
        let payments = self.payments.lock().unwrap();
        payments.iter().rev().take(limit).cloned().collect()
    }
}

fn endpoint_matches(pattern: &str, path: &str) -> bool {
    let pattern_parts: Vec<&str> = pattern.split('/').collect();
    let path_parts: Vec<&str> = path.split('/').collect();

    if pattern_parts.len() != path_parts.len() {
        if pattern.ends_with("/*") {
            let prefix = &pattern[..pattern.len() - 2];
            return path.starts_with(prefix);
        }
        return false;
    }

    for (pp, tp) in pattern_parts.iter().zip(path_parts.iter()) {
        if *pp == "*" {
            continue;
        }
        if pp != tp {
            return false;
        }
    }
    true
}

fn extract_payment_amount(tx_hex: &str, recipient_pkh: &str) -> u64 {
    let bytes = match hex::decode(tx_hex) {
        Ok(b) => b,
        Err(_) => return 0,
    };
    if bytes.len() < 10 {
        return 0;
    }

    let pkh_bytes = match hex::decode(recipient_pkh) {
        Ok(b) => b,
        Err(_) => return 0,
    };
    if pkh_bytes.len() != 20 {
        return 0;
    }

    let mut total = 0u64;
    let mut i = 4;

    let input_count = if i < bytes.len() { read_varint(&bytes, &mut i) } else { return 0 };
    for _ in 0..input_count {
        if i + 36 > bytes.len() { return 0; }
        i += 36;
        let script_len = read_varint(&bytes, &mut i) as usize;
        if i + script_len + 4 > bytes.len() { return 0; }
        i += script_len + 4;
    }

    let output_count = read_varint(&bytes, &mut i);
    for _ in 0..output_count {
        if i + 8 > bytes.len() { return 0; }
        let value = u64::from_le_bytes([
            bytes[i], bytes[i+1], bytes[i+2], bytes[i+3],
            bytes[i+4], bytes[i+5], bytes[i+6], bytes[i+7],
        ]);
        i += 8;
        let script_len = read_varint(&bytes, &mut i) as usize;
        if i + script_len > bytes.len() { return 0; }
        let script = &bytes[i..i+script_len];
        i += script_len;

        if script_len == 25
            && script[0] == 0x76
            && script[1] == 0xa9
            && script[2] == 0x14
            && script[script_len - 2] == 0x88
            && script[script_len - 1] == 0xac
        {
            if &script[3..23] == pkh_bytes.as_slice() {
                total += value;
            }
        }
    }

    total
}

fn read_varint(data: &[u8], pos: &mut usize) -> u64 {
    if *pos >= data.len() { return 0; }
    let first = data[*pos];
    *pos += 1;
    match first {
        0..=0xfc => first as u64,
        0xfd => {
            if *pos + 2 > data.len() { return 0; }
            let v = u16::from_le_bytes([data[*pos], data[*pos + 1]]) as u64;
            *pos += 2;
            v
        }
        0xfe => {
            if *pos + 4 > data.len() { return 0; }
            let v = u32::from_le_bytes([data[*pos], data[*pos+1], data[*pos+2], data[*pos+3]]) as u64;
            *pos += 4;
            v
        }
        0xff => {
            if *pos + 8 > data.len() { return 0; }
            let v = u64::from_le_bytes([
                data[*pos], data[*pos+1], data[*pos+2], data[*pos+3],
                data[*pos+4], data[*pos+5], data[*pos+6], data[*pos+7],
            ]);
            *pos += 8;
            v
        }
    }
}

pub fn parse_payment_header(headers: &HeaderMap) -> Option<PaymentPayload> {
    let raw = headers.get(PAYMENT_HEADER)?.to_str().ok()?;
    let decoded = general_purpose::STANDARD.decode(raw).ok()
        .or_else(|| Some(raw.as_bytes().to_vec()))?;
    serde_json::from_slice(&decoded).ok()
}


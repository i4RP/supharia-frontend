async fn get_portfolio(
    State(state): State<AppState>,
    Path(address): Path<String>,
) -> (StatusCode, Json<ApiResponse<PortfolioSummary>>) {
    let pools = match state.db.list_pools().await { Ok(p) => p, Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e) };
    let mut tokens = Vec::new();
    let mut lp_positions = Vec::new();
    let mut total_token_value = 0.0;
    let mut total_lp_value = 0.0;
    let mut tx_count: u32 = 0;
    for pool in &pools {
        if let Ok(Some(lp)) = state.db.get_lp_position(&pool.pool_id, &address).await {
            let total_shares = pool.total_lp_shares;
            let share = if total_shares > 0.0 { lp.lp_shares / total_shares } else { 0.0 };
            let va = (share * pool.reserve_a as f64) as u64;
            let vb = (share * pool.reserve_b as f64) as u64;
            let val = va as f64 + vb as f64;
            total_lp_value += val;
            lp_positions.push(PortfolioLpPosition {
                pool_id: pool.pool_id.clone(),
                pool_name: format!("{}/{}", pool.token_a_symbol, pool.token_b_symbol),
                lp_shares: lp.lp_shares,
                share_of_pool: share * 100.0,
                value_token_a: va,
                value_token_b: vb,
                total_value_usd: val,
                pending_rewards: lp.lp_shares * 0.01 / 365.0,
                apy: 5.0,
            });
        }
        if let Ok(txs) = state.db.list_transactions_by_pool(&pool.pool_id).await {
            tx_count += txs.iter().filter(|t| t.user_address == address).count() as u32;
        }
    }
    tokens.push(PortfolioToken {
        token_id: "5fd9dad93eb7db84dccf1a4f48bff9d0668da88a".to_string(),
        symbol: "wBTC".to_string(), balance: 0, value_usd: 0.0, price: 1.0, change_24h: 0.5,
    });
    tokens.push(PortfolioToken {
        token_id: "114111bc1659e68aef1d60736a0f12d1309e3d19".to_string(),
        symbol: "wUSDC".to_string(), balance: 0, value_usd: 0.0, price: 1.0, change_24h: -0.1,
    });
    let total_token_value: f64 = tokens.iter().map(|t| t.value_usd).sum();
    let total = total_token_value + total_lp_value;
    ok_response(PortfolioSummary {
        address,
        total_value_usd: total,
        tokens,
        lp_positions,
        total_lp_value_usd: total_lp_value,
        total_token_value_usd: total_token_value,
        pnl_24h: total * 0.005,
        pnl_24h_percent: 0.5,
        tx_count,
    })
}

async fn get_notifications(
    State(state): State<AppState>,
    Path(address): Path<String>,
    Query(params): Query<NotificationQuery>,
) -> (StatusCode, Json<ApiResponse<NotificationSummary>>) {
    let limit = params.limit.unwrap_or(50) as usize;
    let unread_only = params.unread_only.unwrap_or(false);
    let mut notifs: Vec<Notification> = Vec::new();
    let pools = state.db.list_pools().await.unwrap_or_default();
    for pool in &pools {
        if let Ok(txs) = state.db.list_transactions_by_pool(&pool.pool_id).await {
            for tx in txs.iter().filter(|t| t.user_address == address).take(10) {
                notifs.push(Notification {
                    id: format!("n-{}", tx.tx_id),
                    ntype: "swap".to_string(),
                    title: "Swap Executed".to_string(),
                    message: format!("{} {} -> {} on {}/{}", tx.input_amount, tx.input_token.chars().take(8).collect::<String>(), tx.output_amount, pool.token_a_symbol, pool.token_b_symbol),
                    timestamp: tx.timestamp.clone(),
                    read: true,
                    address: address.clone(),
                    pool_id: Some(pool.pool_id.clone()),
                    tx_id: Some(tx.tx_id.clone()),
                });
            }
        }
        if let Ok(Some(lp)) = state.db.get_lp_position(&pool.pool_id, &address).await {
            notifs.push(Notification {
                id: format!("n-lp-{}", pool.pool_id),
                ntype: "lp".to_string(),
                title: "LP Position Active".to_string(),
                message: format!("{:.2} shares in {}/{}", lp.lp_shares, pool.token_a_symbol, pool.token_b_symbol),
                timestamp: chrono::Utc::now().to_rfc3339(),
                read: false,
                address: address.clone(),
                pool_id: Some(pool.pool_id.clone()),
                tx_id: None,
            });
        }
    }
    notifs.sort_by(|a, b| b.timestamp.cmp(&a.timestamp));
    if unread_only { notifs.retain(|n| !n.read); }
    let unread = notifs.iter().filter(|n| !n.read).count();
    let total = notifs.len();
    notifs.truncate(limit);
    ok_response(NotificationSummary { total, unread, notifications: notifs })
}


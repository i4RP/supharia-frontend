<file path="wallet-extension/background/service-worker.js">
/**
 * DXS Wallet - Background Service Worker
 *
 * Handles key management, transaction signing, and message routing
 * between the popup UI and content scripts.
 *
 * Security features:
 * - AES-GCM encryption of private keys using password-derived key (PBKDF2)
 * - Auto-lock after configurable inactivity timeout
 * - AI mode for programmatic access with API key authentication
 */

import { getPublicKey, utils as secpUtils } from "../vendor/secp256k1.js";
import { sha256 } from "../vendor/hashes/sha2.js";
import { ripemd160 } from "../vendor/hashes/legacy.js";
import { base58check } from "../vendor/scure-base.js";

// ---- Storage Keys ----
const STORAGE_KEY = "dxs-wallet-data";
const CONNECTED_SITES_KEY = "dxs-wallet-connected-sites";
const SETTINGS_KEY = "dxs-wallet-settings";
const TX_HISTORY_KEY = "dxs-wallet-tx-history";
const AI_MODE_KEY = "dxs-wallet-ai-mode";

// ---- Defaults ----
const DEFAULT_SETTINGS = {
  autoLockMinutes: 15,
  currency: "BSV",
};
const MAX_TX_HISTORY = 50;

// ---- In-memory state ----
let decryptedWif = null;
const autoLockAlarmName = "dxs-wallet-auto-lock";

// ---- Crypto helpers (AES-GCM + PBKDF2) ----

async function deriveEncryptionKey(password, salt) {
  const enc = new TextEncoder();
  const keyMaterial = await crypto.subtle.importKey(
    "raw",
    enc.encode(password),
    "PBKDF2",
    false,
    ["deriveKey"],
  );
  return crypto.subtle.deriveKey(
    { name: "PBKDF2", salt, iterations: 600000, hash: "SHA-256" },
    keyMaterial,
    { name: "AES-GCM", length: 256 },
    false,
    ["encrypt", "decrypt"],
  );
}

async function encryptData(plaintext, password) {
  const enc = new TextEncoder();
  const salt = crypto.getRandomValues(new Uint8Array(16));
  const iv = crypto.getRandomValues(new Uint8Array(12));
  const key = await deriveEncryptionKey(password, salt);
  const ciphertext = await crypto.subtle.encrypt(
    { name: "AES-GCM", iv },
    key,
    enc.encode(plaintext),
  );
  return {
    salt: arrayToBase64(salt),
    iv: arrayToBase64(iv),
    data: arrayToBase64(new Uint8Array(ciphertext)),
  };
}

async function decryptData(encrypted, password) {
  const salt = base64ToArray(encrypted.salt);
  const iv = base64ToArray(encrypted.iv);
  const data = base64ToArray(encrypted.data);
  const key = await deriveEncryptionKey(password, salt);
  const plainBuf = await crypto.subtle.decrypt(
    { name: "AES-GCM", iv },
    key,
    data,
  );
  return new TextDecoder().decode(plainBuf);
}

function arrayToBase64(arr) {
  let bin = "";
  for (const b of arr) bin += String.fromCharCode(b);
  return btoa(bin);
}

function base64ToArray(b64) {
  const bin = atob(b64);
  const arr = new Uint8Array(bin.length);
  for (let i = 0; i < bin.length; i++) arr[i] = bin.charCodeAt(i);
  return arr;
}

// ---- BSV crypto helpers ----

const b58c = base58check(sha256);

function hash160(bytes) {
  return ripemd160(sha256(bytes));
}

function encodeWif(privateKey, network, compressed = true) {
  const prefix = network === "testnet" ? 0xef : 0x80;
  if (!secpUtils.isValidSecretKey(privateKey)) {
    throw new Error("Invalid private key");
  }
  if (compressed) {
    const payload = new Uint8Array(1 + 32 + 1);
    payload[0] = prefix;
    payload.set(privateKey, 1);
    payload[payload.length - 1] = 0x01;
    return b58c.encode(payload);
  }
  const payload = new Uint8Array(1 + 32);
  payload[0] = prefix;
  payload.set(privateKey, 1);
  return b58c.encode(payload);
}

function decodeWif(wif) {
  const decoded = b58c.decode(wif);
  const version = decoded[0];
  if (version !== 0x80 && version !== 0xef) {
    throw new Error("Invalid WIF version byte");
  }
  let keyBytes;
  let compressed = false;
  if (decoded.length === 34 && decoded[33] === 0x01) {
    keyBytes = decoded.slice(1, 33);
    compressed = true;
  } else if (decoded.length === 33) {
    keyBytes = decoded.slice(1, 33);
    compressed = false;
  } else {
    throw new Error("Invalid WIF format");
  }
  const network = version === 0xef ? "testnet" : "mainnet";
  if (!secpUtils.isValidSecretKey(keyBytes)) {
    throw new Error("Invalid private key");
  }
  return { privateKey: keyBytes, compressed, network };
}

function deriveAddress(privateKey, network, compressed = true) {
  const pubKey = getPublicKey(privateKey, compressed);
  const h160 = hash160(pubKey);
  const addrPrefix = network === "testnet" ? 0x6f : 0x00;
  const payload = new Uint8Array(1 + h160.length);
  payload[0] = addrPrefix;
  payload.set(h160, 1);
  return b58c.encode(payload);
}

// ---- Storage helpers ----

async function getWalletData() {
  const result = await chrome.storage.local.get(STORAGE_KEY);
  return result[STORAGE_KEY] || null;
}

async function saveWalletData(data) {
  await chrome.storage.local.set({ [STORAGE_KEY]: data });
}

async function getConnectedSites() {
  const result = await chrome.storage.local.get(CONNECTED_SITES_KEY);
  return result[CONNECTED_SITES_KEY] || [];
}

async function saveConnectedSites(sites) {
  await chrome.storage.local.set({ [CONNECTED_SITES_KEY]: sites });
}

async function isSiteConnected(origin) {
  const sites = await getConnectedSites();
  return sites.includes(origin);
}

async function addConnectedSite(origin) {
  const sites = await getConnectedSites();
  if (!sites.includes(origin)) {
    sites.push(origin);
    await saveConnectedSites(sites);
  }
}

async function removeConnectedSite(origin) {
  const sites = await getConnectedSites();
  await saveConnectedSites(sites.filter((s) => s !== origin));
}

async function getSettings() {
  const result = await chrome.storage.local.get(SETTINGS_KEY);
  return { ...DEFAULT_SETTINGS, ...(result[SETTINGS_KEY] || {}) };
}

async function saveSettings(settings) {
  await chrome.storage.local.set({ [SETTINGS_KEY]: settings });
}

async function getTxHistory() {
  const result = await chrome.storage.local.get(TX_HISTORY_KEY);
  return result[TX_HISTORY_KEY] || [];
}

async function saveTxHistory(history) {
  await chrome.storage.local.set({
    [TX_HISTORY_KEY]: history.slice(0, MAX_TX_HISTORY),
  });
}

async function addTxRecord(record) {
  const history = await getTxHistory();
  history.unshift({ ...record, timestamp: Date.now() });
  await saveTxHistory(history);
}

async function getAiMode() {
  const result = await chrome.storage.local.get(AI_MODE_KEY);
  return result[AI_MODE_KEY] || { enabled: false, apiKey: "" };
}

async function saveAiMode(data) {
  await chrome.storage.local.set({ [AI_MODE_KEY]: data });
}

// ---- Balance fetch ----

async function fetchBalance(address, network) {
  const base =
    network === "testnet"
      ? "https://api.whatsonchain.com/v1/bsv/test"
      : "https://api.whatsonchain.com/v1/bsv/main";
  try {
    const res = await fetch(`${base}/address/${address}/balance`);
    if (!res.ok) return 0;
    const data = await res.json();
    return ((data.confirmed || 0) + (data.unconfirmed || 0)) / 1e8;
  } catch {
    return 0;
  }
}

// ---- Transaction history fetch ----

async function fetchTxHistory(address, network) {
  const base =
    network === "testnet"
      ? "https://api.whatsonchain.com/v1/bsv/test"
      : "https://api.whatsonchain.com/v1/bsv/main";
  try {
    const res = await fetch(`${base}/address/${address}/history`);
    if (!res.ok) return [];
    const txs = await res.json();
    return (txs || []).slice(0, 20).map((tx) => ({
      txid: tx.tx_hash,
      height: tx.height || 0,
    }));
  } catch {
    return [];
  }
}

// ---- Auto-lock ----

function touchActivity() {
  resetAutoLockAlarm();
}

async function resetAutoLockAlarm() {
  const settings = await getSettings();
  const minutes = settings.autoLockMinutes;
  if (minutes <= 0) return;
  try {
    await chrome.alarms.clear(autoLockAlarmName);
    await chrome.alarms.create(autoLockAlarmName, {
      delayInMinutes: minutes,
    });
  } catch {
    // alarms API may not be available
  }
}

if (chrome.alarms && chrome.alarms.onAlarm) {
  chrome.alarms.onAlarm.addListener(async (alarm) => {
    if (alarm.name === autoLockAlarmName) {
      const wallet = await getWalletData();
      if (wallet && !wallet.locked) {
        wallet.locked = true;
        await saveWalletData(wallet);
        decryptedWif = null;
        notifyAllTabs("disconnect", {});
      }
    }
  });
}

// ---- Message routing ----

chrome.runtime.onMessage.addListener((message, sender, sendResponse) => {
  if (message.type === "DXS_WALLET_INTERNAL") {
    touchActivity();
    handleInternalMessage(message, sender)
      .then(sendResponse)
      .catch((err) => sendResponse({ error: err.message }));
    return true;
  }
});

// ---- Core message handler ----

async function handleInternalMessage(message, _sender) {
  const { action, payload } = message;

  switch (action) {
    case "getState": {
      const wallet = await getWalletData();
      const sites = await getConnectedSites();
      const settings = await getSettings();
      const aiMode = await getAiMode();
      return {
        hasWallet: !!wallet,
        locked: wallet ? wallet.locked : true,
        address: wallet ? wallet.address : null,
        network: wallet ? wallet.network || "mainnet" : "mainnet",
        connectedSites: sites,
        settings,
        aiMode: { enabled: aiMode.enabled },
        hasPassword: wallet ? !!wallet.hasPassword : false,
      };
    }

    case "createWallet": {
      const network = payload.network || "mainnet";
      const password = payload.password;
      const privateKey = secpUtils.randomSecretKey();
      const wif = encodeWif(privateKey, network, true);
      const address = deriveAddress(privateKey, network, true);

      const walletData = {
        address,
        network,
        locked: false,
        createdAt: Date.now(),
      };

      if (password) {
        walletData.encrypted = await encryptData(wif, password);
        walletData.hasPassword = true;
      } else {
        walletData.wif = wif;
        walletData.hasPassword = false;
      }

      await saveWalletData(walletData);
      decryptedWif = wif;
      resetAutoLockAlarm();
      return { success: true, address, wif, network };
    }

    case "importWallet": {
      const wifInput = payload.wif;
      if (!wifInput) return { error: "Missing WIF" };
      const password = payload.password;
      const decoded = decodeWif(wifInput);
      const network = payload.network || decoded.network || "mainnet";
      const wif = encodeWif(decoded.privateKey, network, decoded.compressed);
      const address = deriveAddress(
        decoded.privateKey,
        network,
        decoded.compressed,
      );

      const walletData = {
        address,
        network,
        locked: false,
        createdAt: Date.now(),
      };

      if (password) {
        walletData.encrypted = await encryptData(wif, password);
        walletData.hasPassword = true;
      } else {
        walletData.wif = wif;
        walletData.hasPassword = false;
      }

      await saveWalletData(walletData);
      decryptedWif = wif;
      resetAutoLockAlarm();
      return { success: true, address, network };
    }

    case "lock": {
      const wallet = await getWalletData();
      if (wallet) {
        wallet.locked = true;
        await saveWalletData(wallet);
        decryptedWif = null;
      }
      return { success: true };
    }

    case "unlock": {
      const wallet = await getWalletData();
      if (!wallet) return { error: "No wallet" };

      if (wallet.hasPassword && wallet.encrypted) {
        const password = payload && payload.password;
        if (!password) return { error: "Password required" };
        try {
          decryptedWif = await decryptData(wallet.encrypted, password);
        } catch {
          return { error: "Wrong password" };
        }
      } else if (wallet.wif) {
        decryptedWif = wallet.wif;
      } else {
        return { error: "No key data" };
      }
      wallet.locked = false;
      await saveWalletData(wallet);
      resetAutoLockAlarm();
      return { success: true };
    }

    case "getBalance": {
      const wallet = await getWalletData();
      if (!wallet || wallet.locked) return { error: "Wallet is locked" };
      const balance = await fetchBalance(wallet.address, wallet.network);
      return { balance };
    }

    case "deleteWallet": {
      decryptedWif = null;
      await chrome.storage.local.remove(STORAGE_KEY);
      await chrome.storage.local.remove(CONNECTED_SITES_KEY);
      await chrome.storage.local.remove(TX_HISTORY_KEY);
      return { success: true };
    }

    case "switchNetwork": {
      const wallet = await getWalletData();
      if (!wallet) return { error: "No wallet" };
      const network = payload.network;
      if (network !== "mainnet" && network !== "testnet")
        return { error: "Invalid network" };

      const currentWif = decryptedWif || wallet.wif;
      if (currentWif) {
        try {
          const decoded = decodeWif(currentWif);
          wallet.network = network;
          const newWif = encodeWif(
            decoded.privateKey,
            network,
            decoded.compressed,
          );
          wallet.address = deriveAddress(
            decoded.privateKey,
            network,
            decoded.compressed,
          );
          if (wallet.hasPassword && wallet.encrypted && decryptedWif) {
            decryptedWif = newWif;
          } else {
            wallet.wif = newWif;
          }
        } catch {
          wallet.network = network;
        }
      } else {
        wallet.network = network;
      }

      await saveWalletData(wallet);
      notifyAllTabs("networkChanged", { network });
      return { success: true, network, address: wallet.address };
    }

    case "getSettings": {
      return await getSettings();
    }

    case "updateSettings": {
      const current = await getSettings();
      const updated = { ...current, ...payload };
      await saveSettings(updated);
      resetAutoLockAlarm();
      return { success: true, settings: updated };
    }

    case "getTxHistory": {
      const wallet = await getWalletData();
      if (!wallet) return { error: "No wallet" };
      const cached = await getTxHistory();
      if (payload && payload.refresh) {
        const fresh = await fetchTxHistory(wallet.address, wallet.network);
        if (fresh.length > 0) {
          await saveTxHistory(fresh);
          return { history: fresh };
        }
      }
      return { history: cached };
    }

    case "exportWallet": {
      const wallet = await getWalletData();
      if (!wallet || wallet.locked) return { error: "Wallet is locked" };
      const wif = decryptedWif || wallet.wif;
      if (!wif)
        return { error: "Cannot export: wallet is encrypted and locked" };
      return {
        wif,
        address: wallet.address,
        network: wallet.network,
        createdAt: wallet.createdAt,
      };
    }

    case "getAiMode": {
      return await getAiMode();
    }

    case "setAiMode": {
      const enabled = payload.enabled;
      const apiKey = payload.apiKey;
      await saveAiMode({
        enabled: !!enabled,
        apiKey: apiKey || "",
      });
      return { success: true };
    }

    case "aiRequest": {
      const aiMode = await getAiMode();
      if (!aiMode.enabled) return { error: "AI mode is not enabled" };
      if (!payload.apiKey || payload.apiKey !== aiMode.apiKey)
        return { error: "Invalid AI API key" };

      const wallet = await getWalletData();
      if (!wallet) return { error: "No wallet" };

      if (wallet.locked && wallet.wif) {
        decryptedWif = wallet.wif;
      }

      const wif = decryptedWif || wallet.wif;
      if (!wif) return { error: "Wallet encrypted, AI cannot decrypt" };

      const subAction = payload.action;
      if (subAction === "getAddress") {
        return { address: wallet.address, network: wallet.network };
      }
      if (subAction === "getWif") {
        return { wif };
      }
      if (subAction === "getBalance") {
        const balance = await fetchBalance(wallet.address, wallet.network);
        return { balance };
      }
      if (subAction === "signTransaction") {
        return { wif, approved: true };
      }
      return { error: "Unknown AI sub-action: " + subAction };
    }

    case "setPassword": {
      const wallet = await getWalletData();
      if (!wallet || wallet.locked) return { error: "Wallet is locked" };
      const password = payload.password;
      if (!password) return { error: "Password required" };

      const wif = decryptedWif || wallet.wif;
      if (!wif) return { error: "No key available" };

      wallet.encrypted = await encryptData(wif, password);
      wallet.hasPassword = true;
      delete wallet.wif;
      decryptedWif = wif;
      await saveWalletData(wallet);
      return { success: true };
    }

    case "changePassword": {
      const wallet = await getWalletData();
      if (!wallet || wallet.locked) return { error: "Wallet is locked" };

      const currentPassword = payload.currentPassword;
      const newPassword = payload.newPassword;
      if (!newPassword) return { error: "New password required" };

      let wif = decryptedWif;
      if (!wif && wallet.encrypted && currentPassword) {
        try {
          wif = await decryptData(wallet.encrypted, currentPassword);
        } catch {
          return { error: "Current password is wrong" };
        }
      }
      if (!wif && wallet.wif) wif = wallet.wif;
      if (!wif) return { error: "Cannot access key" };

      wallet.encrypted = await encryptData(wif, newPassword);
      wallet.hasPassword = true;
      delete wallet.wif;
      decryptedWif = wif;
      await saveWalletData(wallet);
      return { success: true };
    }

    // ---- dApp requests ----
    case "dapp_connect": {
      const origin = payload.origin;
      const wallet = await getWalletData();
      if (!wallet) return { error: "No wallet configured" };
      if (wallet.locked) return { error: "Wallet is locked" };
      await addConnectedSite(origin);
      await addTxRecord({
        type: "connect",
        origin,
        address: wallet.address,
      });
      return {
        address: wallet.address,
        network: wallet.network || "mainnet",
      };
    }

    case "dapp_disconnect": {
      await removeConnectedSite(payload.origin);
      return { success: true };
    }

    case "dapp_get_address": {
      const wallet = await getWalletData();
      if (!wallet || wallet.locked) return { error: "Wallet is locked" };
      const connected = await isSiteConnected(payload.origin);
      if (!connected) return { error: "Site not connected" };
      return { address: wallet.address };
    }

    case "dapp_get_wif": {
      const wallet = await getWalletData();
      if (!wallet || wallet.locked) return { error: "Wallet is locked" };
      const connected = await isSiteConnected(payload.origin);
      if (!connected) return { error: "Site not connected" };
      const wif = decryptedWif || wallet.wif;
      if (!wif) return { error: "Key not available" };
      return { wif };
    }

    case "dapp_get_balance": {
      const wallet = await getWalletData();
      if (!wallet || wallet.locked) return { error: "Wallet is locked" };
      const connected = await isSiteConnected(payload.origin);
      if (!connected) return { error: "Site not connected" };
      const balance = await fetchBalance(wallet.address, wallet.network);
      return { balance };
    }

    case "dapp_sign_transaction": {
      const wallet = await getWalletData();
      if (!wallet || wallet.locked) return { error: "Wallet is locked" };
      const connected = await isSiteConnected(payload.origin);
      if (!connected) return { error: "Site not connected" };
      const wif = decryptedWif || wallet.wif;
      if (!wif) return { error: "Key not available" };
      await addTxRecord({
        type: "sign",
        origin: payload.origin,
        address: wallet.address,
      });
      return { wif, approved: true };
    }

    case "dapp_ping": {
      const wallet = await getWalletData();
      if (!wallet) return { error: "No wallet" };
      const connected = await isSiteConnected(payload.origin);
      return { connected, locked: wallet.locked };
    }

    case "disconnectSite": {
      await removeConnectedSite(payload.origin);
      return { success: true };
    }

    default:
      return { error: "Unknown action: " + action };
  }
}

// ---- Notify all tabs ----

async function notifyAllTabs(eventAction, eventPayload) {
  try {
    const tabs = await chrome.tabs.query({});
    for (const tab of tabs) {
      if (tab.id) {
        chrome.tabs
          .sendMessage(tab.id, {
            type: "DXS_WALLET_BROADCAST",
            action: eventAction,
            payload: eventPayload,
          })
          .catch(() => {});
      }
    }
  } catch {
    // Ignore
  }
}

// ---- On install ----

chrome.runtime.onInstalled.addListener(() => {
  console.log("DXS Wallet extension installed");
  resetAutoLockAlarm();
});

<file path="scripts/mainnet-swap.ts">
import { Wallet } from "../src/bitcoin/wallet";
import { OutPoint } from "../src/bitcoin/out-point";
import { ScriptType } from "../src/bitcoin/script-type";
import { TokenScheme } from "../src/bitcoin/token-scheme";
import { Transaction } from "../src/bitcoin/transaction";
import { TransactionReader } from "../src/transaction/read/transaction-reader";
import {
  BuildDstasIssueTxs,
  BuildDstasTransferTx,
  BuildDstasTransferSwapTx,
  BuildDstasSwapFlowTx,
  TDstasSwapDestination,
} from "../src/dstas-factory";
import { FeeRate } from "../src/transaction-factory";
import { toHex, fromHex, Bytes } from "../src/bytes";
import { hash160 } from "../src/hashes";
import { sha256 } from "../src/hashes";
import {
  evaluateTransactionHex,
  createPrevOutputResolverFromTransactions,
} from "../src/script/eval/script-evaluator";
import { buildSwapActionData } from "../src/script/stas3-second-field";
import { ScriptBuilder } from "../src/script/build/script-builder";
import {
  buildStas3Flags,
  buildStas3FreezeMultisigTokens,
} from "../src/script/build/stas3-freeze-multisig-builder";

const MNEMONIC =
  "prison hollow urban senior crawl stove mom hurry crowd crush ten bless";
const WOC_BASE = "https://api.whatsonchain.com/v1/bsv/main";

const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));

const broadcast = async (txHex: string, label: string): Promise<string> => {
  console.log(`\nBroadcasting ${label}...`);
  const res = await fetch(`${WOC_BASE}/tx/raw`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ txhex: txHex }),
  });
  const text = await res.text();
  if (!res.ok) {
    console.error(`  FAILED (${res.status}): ${text}`);
    throw new Error(`Broadcast failed for ${label}: ${text}`);
  }
  const txid = text.replace(/"/g, "");
  console.log(`  SUCCESS: ${txid}`);
  return txid;
};

const getTxHex = async (txid: string): Promise<string> => {
  const res = await fetch(`${WOC_BASE}/tx/${txid}/hex`);
  if (!res.ok) throw new Error(`Failed to fetch tx ${txid}`);
  return res.text();
};

const getUtxos = async (address: string): Promise<any[]> => {
  const res = await fetch(`${WOC_BASE}/address/${address}/unspent`);
  if (!res.ok) return [];
  const data = await res.json();
  return Array.isArray(data) ? data : [];
};

const buildDstasLockingScriptForOwnerField = ({
  ownerField,
  tokenIdHex,
  freezable,
  authorityServiceField,
  frozen = false,
}: {
  ownerField: Bytes;
  tokenIdHex: string;
  freezable: boolean;
  authorityServiceField: Bytes;
  frozen?: boolean;
}) => {
  const tokens = buildStas3FreezeMultisigTokens({
    owner: ownerField,
    actionData: null,
    redemptionPkh: fromHex(tokenIdHex),
    frozen,
    flags: buildStas3Flags({ freezable }),
    serviceFields: freezable ? [authorityServiceField] : [],
    optionalData: [],
  });
  return ScriptBuilder.fromTokens(tokens, ScriptType.dstas);
};

const computeStas30RequestedScriptHash = (
  lockingScript: ScriptBuilder,
): Bytes => {
  const tokens = lockingScript._tokens;
  if (tokens.length < 3) {
    throw new Error(
      "Divisible STAS locking script must include owner + second field",
    );
  }
  const tail = ScriptBuilder.fromTokens(tokens.slice(2), ScriptType.unknown);
  return sha256(tail.toBytes());
};

async function main() {
  console.log("=== Mainnet Swap Test ===\n");

  const master = Wallet.fromMnemonic(MNEMONIC);
  const wallets: Wallet[] = [];
  for (let i = 0; i < 6; i++) {
    wallets.push(master.deriveWallet(`m/44'/236'/0'/0/${i}`));
  }

  const addr0 = wallets[0];
  const addr1 = wallets[1];

  console.log("Wallets:");
  wallets.forEach((w, i) => console.log(`  [${i}] ${w.Address.Value}`));

  console.log("\n--- Step 1: Check current UTXOs ---");
  for (let i = 0; i < 5; i++) {
    const utxos = await getUtxos(wallets[i].Address.Value);
    if (utxos.length > 0) {
      console.log(`  wallet[${i}] (${wallets[i].Address.Value}):`);
      for (const u of utxos) {
        console.log(`    ${u.tx_hash}:${u.tx_pos} = ${u.value} sats`);
      }
    }
  }

  const DSTAS_ISSUE_TX =
    "3f13332cae5b1bccced13be6e4f8a31c8bc2325bb32750714c7b6feb55c294a0";
  const STAS_ISSUE_TX =
    "535c5d4cb0430cac21a83e6be0a49e3158c58d2723bff42432b6a111a9810471";
  const SPLIT_TX =
    "915e1edf878c0ac16941f87094fbd0c7578b4b4899e048054602fa1d2c8ea462";
  const TRANSFER_4000_TX =
    "28458ac7417181090a6f2c281e367052e9a800725e5ad129a02f495deb0e38ac";

  const DSTAS_TOKEN_ID = "5fd9dad93eb7db84dccf1a4f48bff9d0668da88a";
  const STAS_TOKEN_ID = "7c2213b39e2c56015bfab68ede552d147b4780c2";

  const dstasScheme = new TokenScheme(
    "DSTAS Token",
    DSTAS_TOKEN_ID,
    "DSTAS",
    1,
    {
      freeze: true,
      confiscation: true,
      isDivisible: true,
      authority: { m: 1, publicKeys: [toHex(wallets[1].PublicKey)] },
    },
  );

  const stasScheme = new TokenScheme("STAS Token", STAS_TOKEN_ID, "STAS", 1, {
    freeze: true,
    confiscation: true,
    isDivisible: true,
    authority: { m: 1, publicKeys: [toHex(wallets[5].PublicKey)] },
  });

  console.log("\n--- Step 2: Fetch source transactions ---");
  const splitTxHex = await getTxHex(SPLIT_TX);
  const splitTx = TransactionReader.readHex(splitTxHex);
  console.log(`  Split TX: ${splitTx.Id} (${splitTx.Outputs.length} outputs)`);

  const stasIssueTxHex = await getTxHex(STAS_ISSUE_TX);
  const stasIssueTx = TransactionReader.readHex(stasIssueTxHex);
  console.log(
    `  STAS Issue TX: ${stasIssueTx.Id} (${stasIssueTx.Outputs.length} outputs)`,
  );
  console.log(
    `  STAS output[0]: ${stasIssueTx.Outputs[0].Satoshis} sats, type=${stasIssueTx.Outputs[0].ScriptType}`,
  );

  const transfer4000TxHex = await getTxHex(TRANSFER_4000_TX);
  const transfer4000Tx = TransactionReader.readHex(transfer4000TxHex);
  console.log(`  Transfer 4000 TX: ${transfer4000Tx.Id}`);

  console.log("\n--- Step 3: Transfer STAS to wallets[4] for swap ---");
  const stasOP = new OutPoint(
    stasIssueTx.Id,
    0,
    stasIssueTx.Outputs[0].LockignScript,
    stasIssueTx.Outputs[0].Satoshis,
    addr0.Address,
    ScriptType.dstas,
  );
  stasOP.Transaction = stasIssueTx;

  const feeOP = new OutPoint(
    transfer4000Tx.Id,
    1,
    transfer4000Tx.Outputs[1].LockignScript,
    transfer4000Tx.Outputs[1].Satoshis,
    addr0.Address,
    ScriptType.p2pkh,
  );

  const transferStasHex = BuildDstasTransferTx({
    stasPayment: { OutPoint: stasOP, Owner: addr0 },
    feePayment: { OutPoint: feeOP, Owner: addr0 },
    Scheme: stasScheme,
    destination: { Satoshis: 10000, To: wallets[4].Address },
  });
  const transferStasTx = TransactionReader.readHex(transferStasHex);
  console.log(`  Transfer STAS TX: ${transferStasTx.Id}`);
  console.log(
    `  Outputs: ${transferStasTx.Outputs.map((o, i) => `[${i}] ${o.Satoshis} sats type=${o.ScriptType}`).join(", ")}`,
  );

  const txMap1 = new Map<string, Transaction>();
  txMap1.set(stasIssueTx.Id, stasIssueTx);
  txMap1.set(transfer4000Tx.Id, transfer4000Tx);
  const resolver1 = createPrevOutputResolverFromTransactions(txMap1);
  const evalTransfer = evaluateTransactionHex(transferStasHex, resolver1, {
    allowOpReturn: true,
  });
  console.log(`  Local eval: ${evalTransfer.success ? "PASS" : "FAIL"}`);
  if (!evalTransfer.success) {
    evalTransfer.inputs.forEach((r) =>
      console.log(`    Input ${r.inputIndex}: ${r.success ? "OK" : r.error}`),
    );
    return;
  }

  await broadcast(transferStasHex, "Transfer STAS to wallets[4]");
  await sleep(3000);

  console.log("\n--- Step 4: Build swap action data ---");
  const authorityDSTAS = hash160(wallets[1].PublicKey);
  const authorityStas = hash160(wallets[5].PublicKey);

  const sampleStasTail = buildDstasLockingScriptForOwnerField({
    ownerField: addr0.Address.Hash160,
    tokenIdHex: STAS_TOKEN_ID,
    freezable: true,
    authorityServiceField: authorityStas,
  });

  const sampleDstasTail = buildDstasLockingScriptForOwnerField({
    ownerField: wallets[4].Address.Hash160,
    tokenIdHex: DSTAS_TOKEN_ID,
    freezable: true,
    authorityServiceField: authorityDSTAS,
  });

  const requestedHashForDstas =
    computeStas30RequestedScriptHash(sampleStasTail);
  console.log(
    `  Requested hash for DSTAS (wants STAS): ${toHex(requestedHashForDstas)}`,
  );

  const swapActionData = buildSwapActionData({
    requestedScriptHash: requestedHashForDstas,
    requestedPkh: addr0.Address.Hash160,
    rateNumerator: 1,
    rateDenominator: 1,
  });
  console.log(
    `  Swap action data: ${toHex(swapActionData)} (${swapActionData.length} bytes)`,
  );

  console.log("\n--- Step 5: Transfer DSTAS with swap action data ---");
  const dstasOP = new OutPoint(
    splitTx.Id,
    0,
    splitTx.Outputs[0].LockignScript,
    splitTx.Outputs[0].Satoshis,
    addr0.Address,
    ScriptType.dstas,
  );
  dstasOP.Transaction = splitTx;

  const feeOP2 = new OutPoint(
    transferStasTx.Id,
    1,
    transferStasTx.Outputs[1].LockignScript,
    transferStasTx.Outputs[1].Satoshis,
    addr0.Address,
    ScriptType.p2pkh,
  );

  const transferDstasSwapHex = BuildDstasTransferTx({
    stasPayment: { OutPoint: dstasOP, Owner: addr0 },
    feePayment: { OutPoint: feeOP2, Owner: addr0 },
    Scheme: dstasScheme,
    destination: {
      Satoshis: 6000,
      To: addr0.Address,
      ActionData: swapActionData,
    },
  });
  const transferDstasSwapTx = TransactionReader.readHex(transferDstasSwapHex);
  console.log(
    `  Transfer DSTAS (with swap data) TX: ${transferDstasSwapTx.Id}`,
  );

  const txMap2 = new Map<string, Transaction>();
  txMap2.set(splitTx.Id, splitTx);
  txMap2.set(transferStasTx.Id, transferStasTx);
  const resolver2 = createPrevOutputResolverFromTransactions(txMap2);
  const evalTransfer2 = evaluateTransactionHex(
    transferDstasSwapHex,
    resolver2,
    { allowOpReturn: true },
  );
  console.log(`  Local eval: ${evalTransfer2.success ? "PASS" : "FAIL"}`);
  if (!evalTransfer2.success) {
    evalTransfer2.inputs.forEach((r) =>
      console.log(`    Input ${r.inputIndex}: ${r.success ? "OK" : r.error}`),
    );
    return;
  }

  await broadcast(transferDstasSwapHex, "Transfer DSTAS with swap action data");
  await sleep(3000);

  console.log("\n--- Step 6: Execute swap (DSTAS <-> STAS) ---");
  const swapDstasOP = new OutPoint(
    transferDstasSwapTx.Id,
    0,
    transferDstasSwapTx.Outputs[0].LockignScript,
    transferDstasSwapTx.Outputs[0].Satoshis,
    addr0.Address,
    ScriptType.dstas,
  );
  swapDstasOP.Transaction = transferDstasSwapTx;

  const swapStasOP = new OutPoint(
    transferStasTx.Id,
    0,
    transferStasTx.Outputs[0].LockignScript,
    transferStasTx.Outputs[0].Satoshis,
    wallets[4].Address,
    ScriptType.dstas,
  );
  swapStasOP.Transaction = transferStasTx;

  const swapFeeOP = new OutPoint(
    transferDstasSwapTx.Id,
    1,
    transferDstasSwapTx.Outputs[1].LockignScript,
    transferDstasSwapTx.Outputs[1].Satoshis,
    addr0.Address,
    ScriptType.p2pkh,
  );

  const swapDestinations: TDstasSwapDestination[] = [
    {
      Satoshis: swapStasOP.Satoshis,
      Owner: addr0.Address.Hash160,
      TokenIdHex: STAS_TOKEN_ID,
      Freezable: true,
      AuthorityServiceField: authorityStas,
      ActionData: null,
    },
    {
      Satoshis: swapDstasOP.Satoshis,
      Owner: wallets[4].Address.Hash160,
      TokenIdHex: DSTAS_TOKEN_ID,
      Freezable: true,
      AuthorityServiceField: authorityDSTAS,
      ActionData: null,
    },
  ];

  console.log(`  DSTAS input: ${swapDstasOP.Satoshis} sats (addr0)`);
  console.log(`  STAS input: ${swapStasOP.Satoshis} sats (wallets[4])`);
  console.log(`  Output[0]: STAS ${swapStasOP.Satoshis} -> addr0`);
  console.log(`  Output[1]: DSTAS ${swapDstasOP.Satoshis} -> wallets[4]`);

  const swapTxHex = BuildDstasSwapFlowTx({
    stasPayments: [
      { OutPoint: swapDstasOP, Owner: addr0 },
      { OutPoint: swapStasOP, Owner: wallets[4] },
    ],
    feePayment: { OutPoint: swapFeeOP, Owner: addr0 },
    destinations: swapDestinations,
    feeRate: FeeRate,
    omitChangeOutput: false,
  });

  const swapTx = TransactionReader.readHex(swapTxHex);
  console.log(`  Swap TX: ${swapTx.Id}`);
  console.log(
    `  Inputs: ${swapTx.Inputs.length}, Outputs: ${swapTx.Outputs.length}`,
  );
  swapTx.Outputs.forEach((o, i) =>
    console.log(`    [${i}] ${o.Satoshis} sats, type=${o.ScriptType}`),
  );

  const txMap3 = new Map<string, Transaction>();
  txMap3.set(transferDstasSwapTx.Id, transferDstasSwapTx);
  txMap3.set(transferStasTx.Id, transferStasTx);
  const resolver3 = createPrevOutputResolverFromTransactions(txMap3);
  const evalSwap = evaluateTransactionHex(swapTxHex, resolver3, {
    allowOpReturn: true,
  });
  console.log(`  Local eval: ${evalSwap.success ? "PASS" : "FAIL"}`);
  evalSwap.inputs.forEach((r) =>
    console.log(`    Input ${r.inputIndex}: ${r.success ? "OK" : r.error}`),
  );

  if (!evalSwap.success) {
    console.log("\n  Swap failed local eval - NOT broadcasting");
    return;
  }

  await broadcast(swapTxHex, "DSTAS <-> STAS Swap");
  console.log("\n=== Swap completed successfully! ===");
  console.log(`  Swap TX: https://whatsonchain.com/tx/${swapTx.Id}`);
  console.log(`  STAS (10000) now owned by addr0 (${addr0.Address.Value})`);
  console.log(
    `  DSTAS (6000) now owned by wallets[4] (${wallets[4].Address.Value})`,
  );
}

main().catch(console.error);
</file>


  const loadChart = async (poolId?: string) => {
    const pid = poolId || (pools.length > 0 ? pools[0].pool_id : null)
    if (!pid) return
    setChartLoading(true)
    try {
      const data = await getAdvancedChart(pid, chartInterval, 50)
      setChartData(data)
    } catch { setChartData(null) }
    finally { setChartLoading(false) }
  }

  const renderCandlestick = (candles: OhlcCandle[]) => {
    if (candles.length === 0) return <div className="chart-empty">No candle data</div>
    const prices = candles.flatMap(c => [c.high, c.low])
    const maxP = Math.max(...prices)
    const minP = Math.min(...prices)
    const range = maxP - minP || 1
    const w = 800
    const h = 300
    const cw = Math.max(4, (w - 20) / candles.length - 2)
    return (
      <svg viewBox={`0 0 ${w} ${h}`} className="chart-svg">
        {candles.map((c, i) => {
          const x = 10 + i * ((w - 20) / candles.length)
          const oY = h - 10 - ((c.open - minP) / range) * (h - 20)
          const cY = h - 10 - ((c.close - minP) / range) * (h - 20)
          const hY = h - 10 - ((c.high - minP) / range) * (h - 20)
          const lY = h - 10 - ((c.low - minP) / range) * (h - 20)
          const bull = c.close >= c.open
          const bodyTop = Math.min(oY, cY)
          const bodyH = Math.max(1, Math.abs(oY - cY))
          return (
            <g key={i}>
              <line x1={x + cw / 2} y1={hY} x2={x + cw / 2} y2={lY} stroke={bull ? '#22c55e' : '#ef4444'} strokeWidth={1} />
              <rect x={x} y={bodyTop} width={cw} height={bodyH} fill={bull ? '#22c55e' : '#ef4444'} rx={1} />
            </g>
          )
        })}
      </svg>
    )
  }

  const renderIndicatorChart = (data: AdvancedChartData) => {
    const closes = data.candles.map(c => c.close)
    if (closes.length === 0) return null
    const w = 800
    const h = 150
    const renderLine = (values: number[], color: string, label: string) => {
      const valid = values.filter(v => v > 0)
      if (valid.length === 0) return null
      const maxV = Math.max(...valid)
      const minV = Math.min(...valid)
      const rng = maxV - minV || 1
      const pts = values.map((v, i) => `${10 + i * ((w - 20) / values.length)},${h - 10 - ((v - minV) / rng) * (h - 20)}`).join(' ')
      return <polyline key={label} points={pts} fill="none" stroke={color} strokeWidth={1.5} opacity={0.8} />
    }
    if (chartIndicator === 'sma') {
      const allVals = [...closes, ...data.indicators.sma_7.filter(v => v > 0), ...data.indicators.sma_25.filter(v => v > 0)]
      const maxV = Math.max(...allVals); const minV = Math.min(...allVals); const rng = maxV - minV || 1
      const pricePts = closes.map((v, i) => `${10 + i * ((w - 20) / closes.length)},${h - 10 - ((v - minV) / rng) * (h - 20)}`).join(' ')
      const sma7Pts = data.indicators.sma_7.map((v, i) => `${10 + i * ((w - 20) / data.indicators.sma_7.length)},${h - 10 - ((v - minV) / rng) * (h - 20)}`).join(' ')
      const sma25Pts = data.indicators.sma_25.map((v, i) => `${10 + i * ((w - 20) / data.indicators.sma_25.length)},${h - 10 - ((v - minV) / rng) * (h - 20)}`).join(' ')
      return (
        <svg viewBox={`0 0 ${w} ${h}`} className="chart-svg indicator">
          <polyline points={pricePts} fill="none" stroke="#6b7280" strokeWidth={1} opacity={0.5} />
          <polyline points={sma7Pts} fill="none" stroke="#3b82f6" strokeWidth={1.5} />
          <polyline points={sma25Pts} fill="none" stroke="#f59e0b" strokeWidth={1.5} />
          <text x={w - 5} y={15} fill="#3b82f6" fontSize="10" textAnchor="end">SMA 7</text>
          <text x={w - 5} y={28} fill="#f59e0b" fontSize="10" textAnchor="end">SMA 25</text>
        </svg>
      )
    }
    if (chartIndicator === 'ema') {
      const allVals = [...closes, ...data.indicators.ema_12, ...data.indicators.ema_26]
      const maxV = Math.max(...allVals); const minV = Math.min(...allVals); const rng = maxV - minV || 1
      const pricePts = closes.map((v, i) => `${10 + i * ((w - 20) / closes.length)},${h - 10 - ((v - minV) / rng) * (h - 20)}`).join(' ')
      const ema12Pts = data.indicators.ema_12.map((v, i) => `${10 + i * ((w - 20) / data.indicators.ema_12.length)},${h - 10 - ((v - minV) / rng) * (h - 20)}`).join(' ')
      const ema26Pts = data.indicators.ema_26.map((v, i) => `${10 + i * ((w - 20) / data.indicators.ema_26.length)},${h - 10 - ((v - minV) / rng) * (h - 20)}`).join(' ')
      return (
        <svg viewBox={`0 0 ${w} ${h}`} className="chart-svg indicator">
          <polyline points={pricePts} fill="none" stroke="#6b7280" strokeWidth={1} opacity={0.5} />
          <polyline points={ema12Pts} fill="none" stroke="#8b5cf6" strokeWidth={1.5} />
          <polyline points={ema26Pts} fill="none" stroke="#ec4899" strokeWidth={1.5} />
          <text x={w - 5} y={15} fill="#8b5cf6" fontSize="10" textAnchor="end">EMA 12</text>
          <text x={w - 5} y={28} fill="#ec4899" fontSize="10" textAnchor="end">EMA 26</text>
        </svg>
      )
    }
    if (chartIndicator === 'bb') {
      const allVals = [...data.indicators.bollinger_upper.filter(v => v > 0), ...data.indicators.bollinger_lower.filter(v => v > 0), ...closes]
      const maxV = Math.max(...allVals); const minV = Math.min(...allVals); const rng = maxV - minV || 1
      const scale = (v: number, i: number, arr: number[]) => `${10 + i * ((w - 20) / arr.length)},${h - 10 - ((v - minV) / rng) * (h - 20)}`
      return (
        <svg viewBox={`0 0 ${w} ${h}`} className="chart-svg indicator">
          <polyline points={closes.map((v, i, a) => scale(v, i, a)).join(' ')} fill="none" stroke="#e5e7eb" strokeWidth={1.5} />
          <polyline points={data.indicators.bollinger_upper.map((v, i, a) => scale(v, i, a)).join(' ')} fill="none" stroke="#22c55e" strokeWidth={1} strokeDasharray="4" />
          <polyline points={data.indicators.bollinger_middle.map((v, i, a) => scale(v, i, a)).join(' ')} fill="none" stroke="#6366f1" strokeWidth={1} />
          <polyline points={data.indicators.bollinger_lower.map((v, i, a) => scale(v, i, a)).join(' ')} fill="none" stroke="#ef4444" strokeWidth={1} strokeDasharray="4" />
          <text x={w - 5} y={15} fill="#6366f1" fontSize="10" textAnchor="end">Bollinger Bands (20, 2)</text>
        </svg>
      )
    }
    if (chartIndicator === 'rsi') {
      return (
        <svg viewBox={`0 0 ${w} ${h}`} className="chart-svg indicator">
          <line x1={10} y1={h - 10 - (70 / 100) * (h - 20)} x2={w - 10} y2={h - 10 - (70 / 100) * (h - 20)} stroke="#ef4444" strokeWidth={0.5} strokeDasharray="4" />
          <line x1={10} y1={h - 10 - (30 / 100) * (h - 20)} x2={w - 10} y2={h - 10 - (30 / 100) * (h - 20)} stroke="#22c55e" strokeWidth={0.5} strokeDasharray="4" />
          <line x1={10} y1={h - 10 - (50 / 100) * (h - 20)} x2={w - 10} y2={h - 10 - (50 / 100) * (h - 20)} stroke="#6b7280" strokeWidth={0.5} strokeDasharray="2" />
          {renderLine(data.indicators.rsi_14, '#f59e0b', 'RSI')}
          <text x={w - 5} y={15} fill="#f59e0b" fontSize="10" textAnchor="end">RSI (14)</text>
          <text x={15} y={h - 10 - (70 / 100) * (h - 20) - 3} fill="#ef4444" fontSize="9">70</text>
          <text x={15} y={h - 10 - (30 / 100) * (h - 20) - 3} fill="#22c55e" fontSize="9">30</text>
        </svg>
      )
    }
    if (chartIndicator === 'macd') {
      const allVals = [...data.indicators.macd_line, ...data.indicators.macd_signal, ...data.indicators.macd_histogram]
      const maxV = Math.max(...allVals); const minV = Math.min(...allVals); const rng = maxV - minV || 1
      const scale = (v: number, i: number, arr: number[]) => `${10 + i * ((w - 20) / arr.length)},${h - 10 - ((v - minV) / rng) * (h - 20)}`
      return (
        <svg viewBox={`0 0 ${w} ${h}`} className="chart-svg indicator">
          {data.indicators.macd_histogram.map((v, i) => {
            const x = 10 + i * ((w - 20) / data.indicators.macd_histogram.length)
            const bw = Math.max(2, (w - 20) / data.indicators.macd_histogram.length - 1)
            const zero = h - 10 - ((0 - minV) / rng) * (h - 20)
            const top = h - 10 - ((v - minV) / rng) * (h - 20)
            return <rect key={i} x={x} y={Math.min(zero, top)} width={bw} height={Math.abs(top - zero)} fill={v >= 0 ? '#22c55e80' : '#ef444480'} />
          })}
          <polyline points={data.indicators.macd_line.map((v, i, a) => scale(v, i, a)).join(' ')} fill="none" stroke="#3b82f6" strokeWidth={1.5} />
          <polyline points={data.indicators.macd_signal.map((v, i, a) => scale(v, i, a)).join(' ')} fill="none" stroke="#ef4444" strokeWidth={1.5} />
          <text x={w - 5} y={15} fill="#3b82f6" fontSize="10" textAnchor="end">MACD</text>
          <text x={w - 5} y={28} fill="#ef4444" fontSize="10" textAnchor="end">Signal</text>
        </svg>
      )
    }
    return null
  }


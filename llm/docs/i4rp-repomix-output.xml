use serde::{Serialize, Deserialize};

pub const FEE_RATE: f64 = 0.01;

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct PoolState {
    pub reserve_a: u64,
    pub reserve_b: u64,
    pub k: f64,
    pub total_lp_shares: f64,
    pub fee_rate: f64,
}

impl PoolState {
    pub fn new(reserve_a: u64, reserve_b: u64) -> Self {
        let k = (reserve_a as f64) * (reserve_b as f64);
        Self {
            reserve_a,
            reserve_b,
            k,
            total_lp_shares: 0.0,
            fee_rate: FEE_RATE,
        }
    }

    pub fn quote_swap(&self, input_token_is_a: bool, input_amount: u64) -> SwapQuote {
        let input_after_fee = (input_amount as f64) * (1.0 - self.fee_rate);
        let fee_amount = input_amount - (input_after_fee as u64);

        let (reserve_in, reserve_out) = if input_token_is_a {
            (self.reserve_a as f64, self.reserve_b as f64)
        } else {
            (self.reserve_b as f64, self.reserve_a as f64)
        };

        let new_reserve_in = reserve_in + input_after_fee;
        let new_reserve_out = (reserve_in * reserve_out) / new_reserve_in;
        let output_amount = (reserve_out - new_reserve_out) as u64;

        let spot_price = reserve_out / reserve_in;
        let effective_price = output_amount as f64 / input_amount as f64;
        let price_impact = ((spot_price - effective_price) / spot_price).abs() * 100.0;

        SwapQuote {
            input_amount,
            output_amount,
            fee_amount,
            price_impact,
            new_reserve_in: new_reserve_in as u64,
            new_reserve_out: new_reserve_out as u64,
        }
    }

    pub fn apply_swap(&mut self, input_token_is_a: bool, quote: &SwapQuote) {
        if input_token_is_a {
            self.reserve_a = quote.new_reserve_in;
            self.reserve_b = quote.new_reserve_out;
        } else {
            self.reserve_b = quote.new_reserve_in;
            self.reserve_a = quote.new_reserve_out;
        }
        self.k = (self.reserve_a as f64) * (self.reserve_b as f64);
    }

    pub fn calculate_lp_shares(&self, amount_a: u64, amount_b: u64) -> LpMintResult {
        if self.total_lp_shares == 0.0 {
            let shares = ((amount_a as f64) * (amount_b as f64)).sqrt();
            return LpMintResult {
                shares_minted: shares,
                amount_a_used: amount_a,
                amount_b_used: amount_b,
            };
        }

        let ratio_a = amount_a as f64 / self.reserve_a as f64;
        let ratio_b = amount_b as f64 / self.reserve_b as f64;
        let ratio = ratio_a.min(ratio_b);

        let actual_a = (self.reserve_a as f64 * ratio) as u64;
        let actual_b = (self.reserve_b as f64 * ratio) as u64;
        let shares = self.total_lp_shares * ratio;

        LpMintResult {
            shares_minted: shares,
            amount_a_used: actual_a,
            amount_b_used: actual_b,
        }
    }

    pub fn add_liquidity(&mut self, mint: &LpMintResult) {
        self.reserve_a += mint.amount_a_used;
        self.reserve_b += mint.amount_b_used;
        self.total_lp_shares += mint.shares_minted;
        self.k = (self.reserve_a as f64) * (self.reserve_b as f64);
    }

    pub fn calculate_remove_liquidity(&self, shares: f64) -> LpBurnResult {
        let share_ratio = shares / self.total_lp_shares;
        let amount_a = (self.reserve_a as f64 * share_ratio) as u64;
        let amount_b = (self.reserve_b as f64 * share_ratio) as u64;

        LpBurnResult {
            shares_burned: shares,
            amount_a,
            amount_b,
        }
    }

    pub fn remove_liquidity(&mut self, burn: &LpBurnResult) {
        self.reserve_a -= burn.amount_a;
        self.reserve_b -= burn.amount_b;
        self.total_lp_shares -= burn.shares_burned;
        if self.reserve_a > 0 && self.reserve_b > 0 {
            self.k = (self.reserve_a as f64) * (self.reserve_b as f64);
        } else {
            self.k = 0.0;
        }
    }

    pub fn price_a_in_b(&self) -> f64 {
        if self.reserve_a == 0 { return 0.0; }
        self.reserve_b as f64 / self.reserve_a as f64
    }

    pub fn price_b_in_a(&self) -> f64 {
        if self.reserve_b == 0 { return 0.0; }
        self.reserve_a as f64 / self.reserve_b as f64
    }

    pub fn tvl(&self) -> u64 {
        self.reserve_a + self.reserve_b
    }
}

#[derive(Debug, Serialize, Deserialize)]
pub struct SwapQuote {
    pub input_amount: u64,
    pub output_amount: u64,
    pub fee_amount: u64,
    pub price_impact: f64,
    pub new_reserve_in: u64,
    pub new_reserve_out: u64,
}

#[derive(Debug, Serialize, Deserialize)]
pub struct LpMintResult {
    pub shares_minted: f64,
    pub amount_a_used: u64,
    pub amount_b_used: u64,
}

#[derive(Debug, Serialize, Deserialize)]
pub struct LpBurnResult {
    pub shares_burned: f64,
    pub amount_a: u64,
    pub amount_b: u64,
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn new_pool_state() {
        let ps = PoolState::new(1000, 50000);
        assert_eq!(ps.reserve_a, 1000);
        assert_eq!(ps.reserve_b, 50000);
        assert_eq!(ps.k, 1000.0 * 50000.0);
        assert_eq!(ps.fee_rate, FEE_RATE);
        assert_eq!(ps.total_lp_shares, 0.0);
    }

    #[test]
    fn swap_a_to_b_constant_product() {
        let ps = PoolState::new(10_000, 500_000);
        let q = ps.quote_swap(true, 1000);
        assert!(q.output_amount > 0);
        assert!(q.output_amount < 500_000);
        assert_eq!(q.fee_amount, 10);
        let new_k = (q.new_reserve_in as f64) * (q.new_reserve_out as f64);
        assert!(new_k >= ps.k * 0.999);
    }

    #[test]
    fn swap_b_to_a() {
        let ps = PoolState::new(10_000, 500_000);
        let q = ps.quote_swap(false, 5000);
        assert!(q.output_amount > 0);
        assert!(q.output_amount < 10_000);
    }

    #[test]
    fn apply_swap_updates_reserves() {
        let mut ps = PoolState::new(10_000, 500_000);
        let q = ps.quote_swap(true, 1000);
        ps.apply_swap(true, &q);
        assert_eq!(ps.reserve_a, q.new_reserve_in);
        assert_eq!(ps.reserve_b, q.new_reserve_out);
        assert!((ps.k - (ps.reserve_a as f64) * (ps.reserve_b as f64)).abs() < 1.0);
    }

    #[test]
    fn initial_lp_shares_sqrt() {
        let ps = PoolState::new(0, 0);
        let mint = ps.calculate_lp_shares(10_000, 500_000);
        let expected = ((10_000f64) * (500_000f64)).sqrt();
        assert!((mint.shares_minted - expected).abs() < 0.01);
        assert_eq!(mint.amount_a_used, 10_000);
        assert_eq!(mint.amount_b_used, 500_000);
    }

    #[test]
    fn proportional_lp_shares() {
        let mut ps = PoolState::new(0, 0);
        let mint1 = ps.calculate_lp_shares(10_000, 500_000);
        ps.add_liquidity(&mint1);
        let mint2 = ps.calculate_lp_shares(5_000, 250_000);
        assert!((mint2.shares_minted - mint1.shares_minted / 2.0).abs() < 1.0);
    }

    #[test]
    fn add_liquidity_updates_pool() {
        let mut ps = PoolState::new(0, 0);
        let mint = ps.calculate_lp_shares(10_000, 500_000);
        ps.add_liquidity(&mint);
        assert_eq!(ps.reserve_a, 10_000);
        assert_eq!(ps.reserve_b, 500_000);
        assert!(ps.total_lp_shares > 0.0);
    }

    #[test]
    fn remove_all_liquidity() {
        let mut ps = PoolState::new(0, 0);
        let mint = ps.calculate_lp_shares(10_000, 500_000);
        ps.add_liquidity(&mint);
        let burn = ps.calculate_remove_liquidity(ps.total_lp_shares);
        assert_eq!(burn.amount_a, 10_000);
        assert_eq!(burn.amount_b, 500_000);
        ps.remove_liquidity(&burn);
        assert_eq!(ps.reserve_a, 0);
        assert_eq!(ps.reserve_b, 0);
        assert_eq!(ps.k, 0.0);
    }

    #[test]
    fn remove_partial_liquidity() {
        let mut ps = PoolState::new(0, 0);
        let mint = ps.calculate_lp_shares(10_000, 500_000);
        ps.add_liquidity(&mint);
        let half = ps.total_lp_shares / 2.0;
        let burn = ps.calculate_remove_liquidity(half);
        assert_eq!(burn.amount_a, 5_000);
        assert_eq!(burn.amount_b, 250_000);
    }

    #[test]
    fn price_calculations() {
        let ps = PoolState::new(10_000, 500_000);
        assert!((ps.price_a_in_b() - 50.0).abs() < 0.001);
        assert!((ps.price_b_in_a() - 0.02).abs() < 0.001);
    }

    #[test]
    fn price_zero_reserves() {
        let ps = PoolState::new(0, 0);
        assert_eq!(ps.price_a_in_b(), 0.0);
        assert_eq!(ps.price_b_in_a(), 0.0);
    }

    #[test]
    fn tvl_sum_of_reserves() {
        let ps = PoolState::new(10_000, 500_000);
        assert_eq!(ps.tvl(), 510_000);
    }

    #[test]
    fn fee_reduces_output() {
        let ps = PoolState::new(100_000, 5_000_000);
        let q = ps.quote_swap(true, 10_000);
        assert!(q.fee_amount > 0);
        let no_fee_output = (5_000_000f64 - (100_000f64 * 5_000_000f64) / (100_000f64 + 10_000f64)) as u64;
        assert!(q.output_amount < no_fee_output, "Fee should reduce output vs zero-fee swap");
    }

    #[test]
    fn large_swap_high_price_impact() {
        let ps = PoolState::new(100_000, 5_000_000);
        let small = ps.quote_swap(true, 100);
        let large = ps.quote_swap(true, 50_000);
        assert!(large.price_impact > small.price_impact);
    }

    #[test]
    fn swap_roundtrip_loses_to_fees() {
        let mut ps = PoolState::new(100_000, 5_000_000);
        let q1 = ps.quote_swap(true, 10_000);
        ps.apply_swap(true, &q1);
        let q2 = ps.quote_swap(false, q1.output_amount);
        assert!(q2.output_amount < 10_000);
    }
}

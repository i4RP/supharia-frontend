    results.push({
      test: "Transfer/Split/Merge",
      token: "DSTAS",
      status: "FAILED",
      error: e.message,
    });
  }

  // ========== TEST 5: FREEZE ==========
  console.log("\n--- Test 5: DXS Freeze ---");
  try {
    const dxsInfo = ISSUED_TOKENS.DXS;
    const dxsScheme = makeScheme(dxsInfo, "DXS Utility", "DXS");
    const authorityWallet = wallets[dxsInfo.authorityPath];

    const stasOP = await makeStasOutPoint(
      dxsInfo.issueTxId,
      dxsInfo.stasVout,
      dxsInfo.stasSats,
      addr0,
    );
    const feeOP = await makeFeeOutPoint(
      dxsInfo.issueTxId,
      dxsInfo.feeVout,
      dxsInfo.feeSats,
      wallets[dxsInfo.issuerPath],
    );

    const freezeTxHex = BuildDstasFreezeTx({
      stasPayments: [{ OutPoint: stasOP, Owner: authorityWallet }],
      feePayment: { OutPoint: feeOP, Owner: wallets[dxsInfo.issuerPath] },
      Scheme: dxsScheme,
      destinations: [
        { Satoshis: dxsInfo.stasSats, To: addr0.Address, Frozen: true },
      ],
    });

    const freezeTx = TransactionReader.readHex(freezeTxHex);
    console.log(`  Freeze TX: ${freezeTx.Id}`);
    await broadcast(freezeTxHex, "DXS Freeze");
    await sleep(1500);

    results.push({
      test: "Freeze",
      token: "DXS",
      txId: freezeTx.Id,
      status: "SUCCESS",
    });

    // ========== TEST 6: UNFREEZE ==========
    console.log("\n--- Test 6: DXS Unfreeze ---");
    const frozenStasOP = new OutPoint(
      freezeTx.Id,
      0,
      freezeTx.Outputs[0].LockignScript,
      freezeTx.Outputs[0].Satoshis,
      addr0.Address,
      ScriptType.dstas,
    );
    frozenStasOP.Transaction = freezeTx;

    const unfreezeeFeeOP = new OutPoint(
      freezeTx.Id,
      1,
      freezeTx.Outputs[1].LockignScript,
      freezeTx.Outputs[1].Satoshis,
      wallets[dxsInfo.issuerPath].Address,
      ScriptType.p2pkh,
    );

    const unfreezeTxHex = BuildDstasUnfreezeTx({
      stasPayments: [{ OutPoint: frozenStasOP, Owner: authorityWallet }],
      feePayment: {
        OutPoint: unfreezeeFeeOP,
        Owner: wallets[dxsInfo.issuerPath],
      },
      Scheme: dxsScheme,
      destinations: [
        { Satoshis: dxsInfo.stasSats, To: addr0.Address, Frozen: false },
      ],
    });

    const unfreezeTx = TransactionReader.readHex(unfreezeTxHex);
    console.log(`  Unfreeze TX: ${unfreezeTx.Id}`);
    await broadcast(unfreezeTxHex, "DXS Unfreeze");
    await sleep(1500);

    results.push({
      test: "Unfreeze",
      token: "DXS",
      txId: unfreezeTx.Id,
      status: "SUCCESS",
    });
  } catch (e: any) {
    console.error(`  ERROR: ${e.message}`);
    results.push({
      test: "Freeze/Unfreeze",
      token: "DXS",
      status: "FAILED",
      error: e.message,
    });
  }

  // ========== TEST 7: SWAP (GOLD ↔ USD) ==========
  console.log("\n--- Test 7: Swap (GOLD ↔ USD) ---");
  try {
    const goldInfo = ISSUED_TOKENS.GOLD;
    const usdInfo = ISSUED_TOKENS.USD;

    const goldStasOP = await makeStasOutPoint(
      goldInfo.issueTxId,
      goldInfo.stasVout,
      goldInfo.stasSats,
      addr0,
    );
    const usdStasOP = await makeStasOutPoint(
      usdInfo.issueTxId,
      usdInfo.stasVout,
      usdInfo.stasSats,
      addr0,
    );

    const goldFeeOP = await makeFeeOutPoint(
      goldInfo.issueTxId,
      goldInfo.feeVout,
      goldInfo.feeSats,
      wallets[goldInfo.issuerPath],
    );

    const goldLockReader = LockingScriptReader.read(goldStasOP.LockignScript);
    const usdLockReader = LockingScriptReader.read(usdStasOP.LockignScript);

    const goldServiceField =
      goldLockReader.Dstas?.ServiceFields?.[0] ?? new Uint8Array(0);
    const usdServiceField =
      usdLockReader.Dstas?.ServiceFields?.[0] ?? new Uint8Array(0);

    const swapTxHex = BuildDstasSwapFlowTx({
      stasPayments: [
        { OutPoint: goldStasOP, Owner: addr0 },
        { OutPoint: usdStasOP, Owner: addr0 },
      ],
      feePayment: { OutPoint: goldFeeOP, Owner: wallets[goldInfo.issuerPath] },
      destinations: [
        {
          Satoshis: goldInfo.stasSats,
          Owner: addr0.Address.Hash160,
          TokenIdHex: goldInfo.tokenId,
          Freezable: false,
          AuthorityServiceField: goldServiceField,
        },
        {
          Satoshis: usdInfo.stasSats,
          Owner: addr0.Address.Hash160,
          TokenIdHex: usdInfo.tokenId,
          Freezable: false,
          AuthorityServiceField: usdServiceField,
        },
      ],
      mode: "transfer-swap",
    });

    const swapTx = TransactionReader.readHex(swapTxHex);
    console.log(`  Swap TX: ${swapTx.Id}`);
    console.log(
      `  Outputs: ${swapTx.Outputs.map((o, i) => `[${i}] ${o.Satoshis} sats (type ${o.ScriptType})`).join(", ")}`,
    );
    await broadcast(swapTxHex, "GOLD↔USD Swap");
    await sleep(1500);

    results.push({
      test: "Swap",
      tokens: "GOLD↔USD",
      txId: swapTx.Id,
      status: "SUCCESS",
    });
  } catch (e: any) {
    console.error(`  ERROR: ${e.message}`);
    results.push({
      test: "Swap",
      tokens: "GOLD↔USD",
      status: "FAILED",
      error: e.message,
    });
  }

  console.log("\n\n=== テスト結果サマリ ===\n");
  for (const r of results) {
    const status = r.status === "SUCCESS" ? "✓" : "✗";
    console.log(
      `  ${status} ${r.test} (${r.token || r.tokens}): ${r.status}${r.txId ? ` - ${r.txId}` : ""}${r.error ? ` - ${r.error}` : ""}`,
    );
  }

  console.log(
    `\n  合計: ${results.filter((r) => r.status === "SUCCESS").length}/${results.length} 成功`,
  );
  console.log("\n=== 完了 ===");
}

main().catch(console.error);

async fn get_analytics(
    State(state): State<AppState>,
) -> (StatusCode, Json<ApiResponse<AnalyticsOverview>>) {
    let pools = match state.db.list_pools().await {
        Ok(p) => p,
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };

    let now = Utc::now();
    let cutoff_24h = (now - chrono::Duration::hours(24)).to_rfc3339();

    let mut pool_analytics = Vec::new();
    let mut total_tvl: u64 = 0;
    let mut total_volume_24h: u64 = 0;
    let mut total_fees_24h: u64 = 0;
    let mut total_transactions: u64 = 0;

    for pool in &pools {
        let ps = PoolState::new(pool.reserve_a, pool.reserve_b);
        let tvl = ps.tvl();
        total_tvl += tvl;

        let txs = state.db.list_transactions_by_pool(&pool.pool_id).await.unwrap_or_default();
        let tx_count = txs.len() as u64;
        total_transactions += tx_count;

        let recent_txs: Vec<&SwapTransaction> = txs.iter()
            .filter(|t| t.timestamp.as_str() >= cutoff_24h.as_str())
            .collect();

        let vol_24h: u64 = recent_txs.iter().map(|t| t.input_amount + t.output_amount).sum();
        let fees_24h: u64 = recent_txs.iter().map(|t| t.fee_amount).sum();
        total_volume_24h += vol_24h;
        total_fees_24h += fees_24h;

        let snapshots = state.db.list_price_history(&pool.pool_id, Some(200)).await.unwrap_or_default();
        let price_change = if snapshots.len() >= 2 {
            let oldest = snapshots.first().map(|s| s.price_a_in_b).unwrap_or(0.0);
            let latest = snapshots.last().map(|s| s.price_a_in_b).unwrap_or(0.0);
            if oldest > 0.0 { ((latest - oldest) / oldest) * 100.0 } else { 0.0 }
        } else {
            0.0
        };

        pool_analytics.push(PoolAnalytics {
            pool_id: pool.pool_id.clone(),
            pair: format!("{}/{}", pool.token_a_symbol, pool.token_b_symbol),
            tvl,
            volume_24h: vol_24h,
            fees_24h,
            price: ps.price_a_in_b(),
            price_change_24h: price_change,
            tx_count,
            reserve_a: pool.reserve_a,
            reserve_b: pool.reserve_b,
        });
    }

    pool_analytics.sort_by(|a, b| b.tvl.cmp(&a.tvl));

    ok_response(AnalyticsOverview {
        total_pools: pools.len() as u64,
        total_tvl,
        total_volume_24h,
        total_fees_24h,
        total_transactions,
        pools: pool_analytics,
    })
}

async fn create_proposal(
    State(state): State<AppState>,
    Path(pool_id): Path<String>,
    Json(req): Json<CreateProposalRequest>,
) -> (StatusCode, Json<ApiResponse<ProposalInfo>>) {
    let valid_keys = ["fee_rate"];
    if !valid_keys.contains(&req.param_key.as_str()) {
        return err_response(StatusCode::BAD_REQUEST, &format!("Invalid param_key. Valid: {:?}", valid_keys));
    }
    if req.param_key == "fee_rate" && (req.param_value < 0.0 || req.param_value > 0.1) {
        return err_response(StatusCode::BAD_REQUEST, "fee_rate must be between 0 and 0.1 (10%)");
    }
    let now = Utc::now();
    let expires = now + chrono::Duration::days(3);
    let proposal = Proposal {
        proposal_id: Uuid::new_v4().to_string(),
        pool_id: pool_id.clone(),
        proposer: req.proposer,
        title: req.title,
        description: req.description,
        param_key: req.param_key,
        param_value: req.param_value,
        status: "active".to_string(),
        votes_for: 0.0,
        votes_against: 0.0,
        created_at: now.to_rfc3339(),
        expires_at: expires.to_rfc3339(),
    };
    if let Err(e) = state.db.put_proposal(&proposal).await {
        return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e);
    }
    ok_response(proposal_to_info(&proposal))
}


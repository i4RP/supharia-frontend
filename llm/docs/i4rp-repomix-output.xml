pub fn eth_wallet_from_private_key(hex_key: &str) -> Result<EthWallet, String> {
    let clean = hex_key.trim_start_matches("0x");
    let key_bytes = hex::decode(clean).map_err(|e| format!("hex decode: {}", e))?;
    let secret_key = SecretKey::from_slice(&key_bytes)
        .map_err(|e| format!("invalid secret key: {}", e))?;
    let secp = Secp256k1::new();
    let public_key = PublicKey::from_secret_key(&secp, &secret_key);
    let pub_uncompressed = public_key.serialize_uncompressed();
    let mut hasher = Keccak256::new();
    hasher.update(&pub_uncompressed[1..]);
    let hash = hasher.finalize();
    let address = format!("0x{}", hex::encode(&hash[12..]));
    Ok(EthWallet {
        address: to_checksum_address(&address),
        private_key: secret_key,
    })
}

fn to_checksum_address(address: &str) -> String {
    let addr_lower = address.trim_start_matches("0x").to_lowercase();
    let mut hasher = Keccak256::new();
    hasher.update(addr_lower.as_bytes());
    let hash = hex::encode(hasher.finalize());
    let mut checksummed = String::from("0x");
    for (i, c) in addr_lower.chars().enumerate() {
        if c.is_ascii_digit() {
            checksummed.push(c);
        } else {
            let hash_char = hash.chars().nth(i).unwrap_or('0');
            let hash_val = u8::from_str_radix(&hash_char.to_string(), 16).unwrap_or(0);
            if hash_val >= 8 {
                checksummed.push(c.to_ascii_uppercase());
            } else {
                checksummed.push(c);
            }
        }
    }
    checksummed
}

fn rlp_encode_u128(val: u128) -> Vec<u8> {
    if val == 0 {
        return vec![0x80];
    }
    let bytes = val.to_be_bytes();
    let trimmed: Vec<u8> = bytes.iter().skip_while(|&&b| b == 0).cloned().collect();
    if trimmed.len() == 1 && trimmed[0] < 0x80 {
        return trimmed;
    }
    let mut out = vec![0x80 + trimmed.len() as u8];
    out.extend_from_slice(&trimmed);
    out
}

fn rlp_encode_u64(val: u64) -> Vec<u8> {
    rlp_encode_u128(val as u128)
}

fn rlp_encode_bytes(data: &[u8]) -> Vec<u8> {
    if data.is_empty() {
        return vec![0x80];
    }
    if data.len() == 1 && data[0] < 0x80 {
        return data.to_vec();
    }
    if data.len() < 56 {
        let mut out = vec![0x80 + data.len() as u8];
        out.extend_from_slice(data);
        return out;
    }
    let len_bytes = {
        let b = data.len().to_be_bytes();
        let trimmed: Vec<u8> = b.iter().skip_while(|&&x| x == 0).cloned().collect();
        trimmed
    };
    let mut out = vec![0xb7 + len_bytes.len() as u8];
    out.extend_from_slice(&len_bytes);
    out.extend_from_slice(data);
    out
}

fn rlp_encode_list(items: &[Vec<u8>]) -> Vec<u8> {
    let mut payload = Vec::new();
    for item in items {
        payload.extend_from_slice(item);
    }
    if payload.len() < 56 {
        let mut out = vec![0xc0 + payload.len() as u8];
        out.extend_from_slice(&payload);
        return out;
    }
    let len_bytes = {
        let b = payload.len().to_be_bytes();
        let trimmed: Vec<u8> = b.iter().skip_while(|&&x| x == 0).cloned().collect();
        trimmed
    };
    let mut out = vec![0xf7 + len_bytes.len() as u8];
    out.extend_from_slice(&len_bytes);
    out.extend_from_slice(&payload);
    out
}

fn rlp_encode_address(addr: &str) -> Vec<u8> {
    let clean = addr.trim_start_matches("0x");
    let bytes = hex::decode(clean).unwrap_or_default();
    rlp_encode_bytes(&bytes)
}

pub fn build_eth_transfer_tx(
    nonce: u64,
    gas_price: u128,
    gas_limit: u64,
    to: &str,
    value_wei: u128,
    private_key: &SecretKey,
    chain_id: u64,
) -> Result<String, String> {
    let items = vec![
        rlp_encode_u64(nonce),
        rlp_encode_u128(gas_price),
        rlp_encode_u64(gas_limit),
        rlp_encode_address(to),
        rlp_encode_u128(value_wei),
        rlp_encode_bytes(&[]),
        rlp_encode_u64(chain_id),
        rlp_encode_u128(0),
        rlp_encode_u128(0),
    ];
    let unsigned_rlp = rlp_encode_list(&items);

    let mut hasher = Keccak256::new();
    hasher.update(&unsigned_rlp);
    let hash = hasher.finalize();

    let secp = Secp256k1::new();
    let msg = Message::from_digest_slice(&hash).map_err(|e| format!("msg: {}", e))?;
    let recoverable_sig: RecoverableSignature = secp.sign_ecdsa_recoverable(&msg, private_key);
    let (recovery_id, sig) = recoverable_sig.serialize_compact();

    let v: u64 = recovery_id.to_i32() as u64 + chain_id * 2 + 35;
    let r = &sig[..32];
    let s = &sig[32..];

    let r_trimmed: Vec<u8> = r.iter().skip_while(|&&b| b == 0).cloned().collect();
    let s_trimmed: Vec<u8> = s.iter().skip_while(|&&b| b == 0).cloned().collect();

    let signed_items = vec![
        rlp_encode_u64(nonce),
        rlp_encode_u128(gas_price),
        rlp_encode_u64(gas_limit),
        rlp_encode_address(to),
        rlp_encode_u128(value_wei),
        rlp_encode_bytes(&[]),
        rlp_encode_u64(v),
        rlp_encode_bytes(&r_trimmed),
        rlp_encode_bytes(&s_trimmed),
    ];
    let signed_rlp = rlp_encode_list(&signed_items);
    Ok(hex::encode(signed_rlp))
}

pub fn build_erc20_transfer_tx(
    nonce: u64,
    gas_price: u128,
    gas_limit: u64,
    contract: &str,
    to: &str,
    amount: u128,
    private_key: &SecretKey,
    chain_id: u64,
) -> Result<String, String> {
    let mut data = Vec::new();
    let selector = hex::decode("a9059cbb").unwrap();
    data.extend_from_slice(&selector);

    let to_clean = to.trim_start_matches("0x");
    let to_bytes = hex::decode(to_clean).map_err(|e| format!("to addr: {}", e))?;
    let mut to_padded = vec![0u8; 32];
    to_padded[12..].copy_from_slice(&to_bytes);
    data.extend_from_slice(&to_padded);

    let amount_bytes = amount.to_be_bytes();
    let mut amount_padded = vec![0u8; 16];
    amount_padded.extend_from_slice(&amount_bytes);
    data.extend_from_slice(&amount_padded);

    let items = vec![
        rlp_encode_u64(nonce),
        rlp_encode_u128(gas_price),
        rlp_encode_u64(gas_limit),
        rlp_encode_address(contract),
        rlp_encode_u128(0),
        rlp_encode_bytes(&data),
        rlp_encode_u64(chain_id),
        rlp_encode_u128(0),
        rlp_encode_u128(0),
    ];
    let unsigned_rlp = rlp_encode_list(&items);

    let mut hasher = Keccak256::new();
    hasher.update(&unsigned_rlp);
    let hash = hasher.finalize();

    let secp = Secp256k1::new();
    let msg = Message::from_digest_slice(&hash).map_err(|e| format!("msg: {}", e))?;
    let recoverable_sig: RecoverableSignature = secp.sign_ecdsa_recoverable(&msg, private_key);
    let (recovery_id, sig) = recoverable_sig.serialize_compact();

    let v: u64 = recovery_id.to_i32() as u64 + chain_id * 2 + 35;
    let r = &sig[..32];
    let s = &sig[32..];

    let r_trimmed: Vec<u8> = r.iter().skip_while(|&&b| b == 0).cloned().collect();
    let s_trimmed: Vec<u8> = s.iter().skip_while(|&&b| b == 0).cloned().collect();

    let signed_items = vec![
        rlp_encode_u64(nonce),
        rlp_encode_u128(gas_price),
        rlp_encode_u64(gas_limit),
        rlp_encode_address(contract),
        rlp_encode_u128(0),
        rlp_encode_bytes(&data),
        rlp_encode_u64(v),
        rlp_encode_bytes(&r_trimmed),
        rlp_encode_bytes(&s_trimmed),
    ];
    let signed_rlp = rlp_encode_list(&signed_items);
    Ok(hex::encode(signed_rlp))
}

pub struct BridgeService {
    pub eth_client: EthClient,
    pub bridge_wallet: EthWallet,
    local_nonce: AtomicU64,
}

impl BridgeService {
    pub fn new(eth_client: EthClient, bridge_wallet: EthWallet) -> Self {
        Self { eth_client, bridge_wallet, local_nonce: AtomicU64::new(0) }
    }

    async fn next_nonce(&self) -> Result<u64, String> {
        let rpc_nonce = self.eth_client.get_nonce(&self.bridge_wallet.address).await?;
        let local = self.local_nonce.load(Ordering::SeqCst);
        let nonce = std::cmp::max(rpc_nonce, local);
        self.local_nonce.store(nonce + 1, Ordering::SeqCst);
        Ok(nonce)
    }

    pub fn get_deposit_info(&self, token: &str) -> DepositInfo {
        match token {
            "ETH" => DepositInfo {
                deposit_address: self.bridge_wallet.address.clone(),
                token: "ETH".to_string(),
                min_amount: format_wei(MIN_ETH_WRAP),
                max_amount: format_wei(MAX_ETH_WRAP),
                required_confirmations: self.eth_client.network.required_confirmations(),
                wrap_fee_percent: WRAP_FEE_PERCENT,
            },
            _ => DepositInfo {
                deposit_address: self.bridge_wallet.address.clone(),
                token: self.eth_client.network.stablecoin_symbol().to_string(),
                min_amount: format_stablecoin(MIN_STABLECOIN_WRAP, self.eth_client.network.stablecoin_symbol()),
                max_amount: format_stablecoin(MAX_STABLECOIN_WRAP, self.eth_client.network.stablecoin_symbol()),
                required_confirmations: self.eth_client.network.required_confirmations(),
                wrap_fee_percent: WRAP_FEE_PERCENT,
            },
        }
    }

    pub async fn check_eth_deposit(
        &self,
        from_block: u64,
        depositor_address: &str,
    ) -> Result<Vec<EthTransfer>, String> {
        let transfers = self.eth_client.get_eth_transfers(
            &self.bridge_wallet.address,
            from_block,
        ).await?;

        let filtered: Vec<EthTransfer> = transfers.into_iter()
            .filter(|t| {
                t.from.to_lowercase() == depositor_address.to_lowercase()
                    && !t.is_error
                    && t.confirmations >= self.eth_client.network.required_confirmations()
            })
            .collect();
        Ok(filtered)
    }

    pub async fn check_usdc_deposit(
        &self,
        from_block: u64,
        depositor_address: &str,
    ) -> Result<Vec<Erc20Transfer>, String> {
        let transfers = self.eth_client.get_erc20_transfers(
            &self.bridge_wallet.address,
            self.eth_client.network.stablecoin_contract(),
            from_block,
        ).await?;

        let filtered: Vec<Erc20Transfer> = transfers.into_iter()
            .filter(|t| {
                t.to.to_lowercase() == self.bridge_wallet.address.to_lowercase()
                    && t.from.to_lowercase() == depositor_address.to_lowercase()
                    && t.confirmations >= self.eth_client.network.required_confirmations()
            })
            .collect();
        Ok(filtered)
    }

    pub async fn send_eth(
        &self,
        to_address: &str,
        amount_wei: u128,
    ) -> Result<String, String> {
        let nonce = self.next_nonce().await?;
        let gas_price = self.eth_client.get_gas_price().await?;
        let gas_limit: u64 = 21_000;

        let gas_cost = gas_price * gas_limit as u128;
        let total_needed = amount_wei + gas_cost;
        let balance = self.eth_client.get_eth_balance(&self.bridge_wallet.address).await?;
        if balance < total_needed {
            return Err(format!(
                "Insufficient bridge ETH balance: have {} wei, need {} (amount {} + gas {})",
                balance, total_needed, amount_wei, gas_cost
            ));
        }

        let tx_hex = build_eth_transfer_tx(
            nonce,
            gas_price,
            gas_limit,
            to_address,
            amount_wei,
            &self.bridge_wallet.private_key,
            self.eth_client.network.chain_id(),
        )?;

        self.eth_client.send_raw_transaction(&tx_hex).await
    }

    pub async fn send_usdc(
        &self,
        to_address: &str,
        amount_raw: u128,
    ) -> Result<String, String> {
        let nonce = self.next_nonce().await?;
        let gas_price = self.eth_client.get_gas_price().await?;
        let gas_limit: u64 = 65_000;

        let tx_hex = build_erc20_transfer_tx(
            nonce,
            gas_price,
            gas_limit,
            self.eth_client.network.stablecoin_contract(),
            to_address,
            amount_raw,
            &self.bridge_wallet.private_key,
            self.eth_client.network.chain_id(),
        )?;

        self.eth_client.send_raw_transaction(&tx_hex).await
    }

    pub async fn get_bridge_balance(&self) -> Result<EthBalance, String> {
        let eth_wei = self.eth_client.get_eth_balance(&self.bridge_wallet.address).await?;
        let usdc_raw = self.eth_client.get_stablecoin_balance(&self.bridge_wallet.address).await?;

        Ok(EthBalance {
            eth_wei: eth_wei.to_string(),
            eth_display: format_wei(eth_wei as u64),
            usdc_raw: usdc_raw.to_string(),
            usdc_display: format_stablecoin(usdc_raw as u64, self.eth_client.network.stablecoin_symbol()),
        })
    }

    pub fn calculate_wrap_fee(&self, amount: u128) -> u128 {
        (amount as f64 * WRAP_FEE_PERCENT / 100.0) as u128
    }

    pub fn calculate_unwrap_fee(&self, amount: u128) -> u128 {
        (amount as f64 * UNWRAP_FEE_PERCENT / 100.0) as u128
    }

    pub async fn estimate_gas_cost_eth(&self) -> Result<u128, String> {
        let gas_price = self.eth_client.get_gas_price().await?;
        Ok(gas_price * 21_000)
    }

    pub async fn estimate_gas_cost_usdc(&self) -> Result<u128, String> {
        let gas_price = self.eth_client.get_gas_price().await?;
        Ok(gas_price * 65_000)
    }
}

fn format_wei(wei: u64) -> String {
    let eth = wei as f64 / 1_000_000_000_000_000_000.0;
    format!("{:.6} ETH", eth)
}

fn format_stablecoin(raw: u64, symbol: &str) -> String {
    let amt = raw as f64 / 10f64.powi(STABLECOIN_DECIMALS as i32);
    format!("{:.2} {}", amt, symbol)
}



pub fn wrap_fee_percent() -> f64 {
    WRAP_FEE_PERCENT
}

pub fn unwrap_fee_percent() -> f64 {
    UNWRAP_FEE_PERCENT
}


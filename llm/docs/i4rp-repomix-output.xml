    relatedPools: PoolInfo[];
  };
};

function withTimeout<T>(
  promise: Promise<T>,
  ms: number,
  fallback: T,
): Promise<T> {
  return Promise.race([
    promise,
    new Promise<T>((resolve) => setTimeout(() => resolve(fallback), ms)),
  ]);
}

async function wocFetch<T>(path: string): Promise<T | null> {
  try {
    const ctrl = new AbortController();
    const timer = setTimeout(() => ctrl.abort(), 10000);
    const resp = await fetch(`${WOC_BASE}${path}`, {
      headers: { Accept: "application/json" },
      signal: ctrl.signal,
    });
    clearTimeout(timer);
    if (!resp.ok) return null;
    return resp.json();
  } catch {
    return null;
  }
}

export async function wocGetTx(txid: string): Promise<WocTxInfo | null> {
  return wocFetch<WocTxInfo>(`/tx/hash/${txid}`);
}

export async function wocGetAddressInfo(
  address: string,
): Promise<WocAddressInfo | null> {
  const resp = await wocFetch<{ confirmed: number; unconfirmed: number }>(
    `/address/${address}/balance`,
  );
  if (!resp) return null;
  return {
    address,
    balance: resp.confirmed + resp.unconfirmed,
    totalReceived: 0,
    totalSent: 0,
    unconfirmedBalance: resp.unconfirmed,
    txCount: 0,
  };
}

export async function wocGetUtxos(address: string): Promise<WocUtxo[]> {
  return (await wocFetch<WocUtxo[]>(`/address/${address}/unspent`)) || [];
}

export async function wocGetAddressHistory(
  address: string,
): Promise<WocAddressHistory[]> {
  return (
    (await wocFetch<WocAddressHistory[]>(`/address/${address}/history`)) || []
  );
}

export async function explorerSearchTx(
  txid: string,
): Promise<ExplorerSearchResult> {
  const [wocTx, pools] = await Promise.all([
    wocGetTx(txid),
    withTimeout(
      listPools().catch(() => [] as PoolInfo[]),
      8000,
      [] as PoolInfo[],
    ),
  ]);

  const poolSwaps: TransactionInfo[] = [];
  const relatedPools: PoolInfo[] = [];
  const poolResults = await withTimeout(
    seqPoolQueries(pools, async (pool) => {
      const txs = await listTransactions(pool.pool_id);
      return txs;
    }),
    60000,
    [] as { pool: PoolInfo; result: TransactionInfo[] | null }[],
  );
  for (const r of poolResults) {
    if (!r.result) continue;
    const match = r.result.filter(
      (t: TransactionInfo) =>
        t.tx_id === txid ||
        (t.onchain_tx_ids && t.onchain_tx_ids.includes(txid)),
    );
    if (match.length > 0) {
      poolSwaps.push(...match);
      relatedPools.push(r.pool);
    }
  }

  const [bridgeResult, s402Result] = await Promise.allSettled([
    withTimeout(listBridgeTransactions(), 5000, [] as BridgeTransaction[]),
    withTimeout(getS402Payments(), 5000, [] as Record<string, unknown>[]),
  ]);

  let bridgeTxs: BridgeTransaction[] = [];
  if (bridgeResult.status === "fulfilled") {
    bridgeTxs = bridgeResult.value.filter(
      (bt: BridgeTransaction) =>
        bt.bsv_tx_id === txid || bt.bridge_tx_id === txid,
    );
  }

  let s402Payments: Record<string, unknown>[] = [];
  if (s402Result.status === "fulfilled") {
    s402Payments = (s402Result.value as Record<string, unknown>[]).filter(
      (p: Record<string, unknown>) => p.tx_hex === txid || p.nonce === txid,
    );
  }

  return {
    type: "tx",
    query: txid,
    tx: wocTx,
    appContext: {
      poolSwaps,
      lpPositions: [],
      s402Payments,
      bridgeTxs,
      relatedPools,
    },
  };
}

async function seqPoolQueries<T>(
  pools: PoolInfo[],
  fn: (pool: PoolInfo) => Promise<T>,
): Promise<{ pool: PoolInfo; result: T | null }[]> {
  const results: { pool: PoolInfo; result: T | null }[] = [];
  for (const pool of pools) {
    try {
      const result = await fn(pool);
      results.push({ pool, result });
    } catch {
      results.push({ pool, result: null });
    }
  }
  return results;
}

export async function explorerSearchAddress(
  address: string,
): Promise<ExplorerSearchResult> {
  const [addrInfo, utxos, history, pools] = await Promise.all([
    wocGetAddressInfo(address),
    wocGetUtxos(address),
    wocGetAddressHistory(address),
    withTimeout(
      listPools().catch(() => [] as PoolInfo[]),
      10000,
      [] as PoolInfo[],
    ),
  ]);

  const poolSwaps: TransactionInfo[] = [];
  const lpPositions: {
    pool_id: string;
    lp_shares: number;
    deposited_a: number;
    deposited_b: number;
  }[] = [];
  const relatedPools: PoolInfo[] = [];

  const poolResults = await withTimeout(
    seqPoolQueries(pools, async (pool) => {
      const txs = await listTransactions(pool.pool_id).catch(
        () => [] as TransactionInfo[],
      );
      const lp = await getLpInfo(pool.pool_id, address).catch(() => null);
      return { txs, lp };
    }),
    60000,
    [] as {
      pool: PoolInfo;
      result: { txs: TransactionInfo[]; lp: LpInfo | null } | null;
    }[],
  );
  for (const r of poolResults) {
    if (!r.result) continue;
    const { txs, lp } = r.result;
    const match = txs.filter(
      (t: TransactionInfo) => t.user_address === address,
    );
    if (match.length > 0) {
      poolSwaps.push(...match);
      if (!relatedPools.find((rp) => rp.pool_id === r.pool.pool_id))
        relatedPools.push(r.pool);
    }
    if (lp && lp.lp_shares > 0) {
      lpPositions.push({
        pool_id: r.pool.pool_id,
        lp_shares: lp.lp_shares,
        deposited_a: lp.deposited_a,
        deposited_b: lp.deposited_b,
      });
      if (!relatedPools.find((rp) => rp.pool_id === r.pool.pool_id))
        relatedPools.push(r.pool);
    }
  }

  const matchedPool = pools.find((p) => p.pool_address === address);
  if (
    matchedPool &&
    !relatedPools.find((rp) => rp.pool_id === matchedPool.pool_id)
  ) {
    relatedPools.push(matchedPool);
  }

  const [bridgeResult, s402Result] = await Promise.allSettled([
    withTimeout(listBridgeTransactions(), 5000, [] as BridgeTransaction[]),
    withTimeout(getS402Payments(), 5000, [] as Record<string, unknown>[]),
  ]);

  let bridgeTxs: BridgeTransaction[] = [];
  if (bridgeResult.status === "fulfilled") {
    bridgeTxs = bridgeResult.value.filter(
      (bt: BridgeTransaction) =>
        bt.from_address === address || bt.to_address === address,
    );
  }

  let s402Payments: Record<string, unknown>[] = [];
  if (s402Result.status === "fulfilled") {
    s402Payments = (s402Result.value as Record<string, unknown>[]).filter(
      (p: Record<string, unknown>) => p.payer_address === address,
    );
  }

  return {
    type: "address",
    query: address,
    addressInfo: addrInfo,
    utxos,
    history,
    appContext: {
      poolSwaps,
      lpPositions,
      s402Payments,
      bridgeTxs,
      relatedPools,
    },
  };
}

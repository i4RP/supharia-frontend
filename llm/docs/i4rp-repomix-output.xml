                <span>You burn: {bridgeAmount} w{bridgeToken}</span>
                <span>Unwrap fee: {(parseFloat(bridgeAmount || '0') * 0.003).toFixed(isStableBridge ? 2 : 6)} {bridgeToken}</span>
                <span>Gas estimate: ~{isStableBridge ? `5-15 ${stablecoinSymbol}` : '0.001-0.005 ETH'}</span>
                <span>You receive: ~{(parseFloat(bridgeAmount || '0') * 0.997).toFixed(isStableBridge ? 2 : 6)} {bridgeToken}</span>

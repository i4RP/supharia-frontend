    pub async fn get_eth_balance(&self, address: &str) -> Result<u128, String> {
        let body = serde_json::json!({
            "jsonrpc": "2.0",
            "method": "eth_getBalance",
            "params": [address, "latest"],
            "id": 1
        });
        let resp: serde_json::Value = self.client.post(self.network.rpc_url())
            .json(&body)
            .send().await
            .map_err(|e| format!("eth rpc balance error: {}", e))?
            .json().await
            .map_err(|e| format!("eth rpc parse: {}", e))?;
        let hex = resp.get("result").and_then(|v| v.as_str()).unwrap_or("0x0");
        u128::from_str_radix(hex.trim_start_matches("0x"), 16)
            .map_err(|e| format!("parse balance: {}", e))
    }

    pub async fn get_stablecoin_balance(&self, address: &str) -> Result<u128, String> {
        let addr_clean = address.trim_start_matches("0x");
        let data = format!("0x70a08231000000000000000000000000{}", addr_clean);
        let body = serde_json::json!({
            "jsonrpc": "2.0",
            "method": "eth_call",
            "params": [{
                "to": self.network.stablecoin_contract(),
                "data": data
            }, "latest"],
            "id": 1
        });
        let resp: serde_json::Value = self.client.post(self.network.rpc_url())
            .json(&body)
            .send().await
            .map_err(|e| format!("rpc stablecoin balance error: {}", e))?
            .json().await
            .map_err(|e| format!("rpc parse error: {}", e))?;
        let hex = resp.get("result").and_then(|v| v.as_str()).unwrap_or("0x0");
        u128::from_str_radix(hex.trim_start_matches("0x"), 16)
            .map_err(|e| format!("parse stablecoin balance: {}", e))
    }

    pub async fn get_tx_receipt(&self, tx_hash: &str) -> Result<EthTxReceipt, String> {
        let body = serde_json::json!({
            "jsonrpc": "2.0",
            "method": "eth_getTransactionReceipt",
            "params": [tx_hash],
            "id": 1
        });
        let resp: serde_json::Value = self.client.post(self.network.rpc_url())
            .json(&body)
            .send().await
            .map_err(|e| format!("eth rpc error: {}", e))?
            .json().await
            .map_err(|e| format!("eth rpc parse: {}", e))?;

        let result = resp.get("result").ok_or("no result in receipt")?;
        if result.is_null() {
            return Ok(EthTxReceipt {
                tx_hash: tx_hash.to_string(),
                status: "pending".to_string(),
                block_number: None,
                confirmations: 0,
            });
        }

        let status_hex = result.get("status").and_then(|v| v.as_str()).unwrap_or("0x0");
        let status = if status_hex == "0x1" { "success" } else { "failed" };
        let block_hex = result.get("blockNumber").and_then(|v| v.as_str()).unwrap_or("0x0");
        let block_number = u64::from_str_radix(block_hex.trim_start_matches("0x"), 16).ok();

        let current_block = self.get_block_number().await.unwrap_or(0);
        let confirmations = block_number.map_or(0, |b| current_block.saturating_sub(b));

        Ok(EthTxReceipt {
            tx_hash: tx_hash.to_string(),
            status: status.to_string(),
            block_number,
            confirmations,
        })
    }

    pub async fn get_block_number(&self) -> Result<u64, String> {

#[derive(Deserialize)]
struct S402VerifyRequest {
    tx_hex: String,
    nonce: String,
    scheme: Option<String>,
}

async fn s402_verify_payment(
    State(state): State<AppState>,
    headers: HeaderMap,
    body: Option<Json<S402VerifyRequest>>,
) -> (StatusCode, Json<ApiResponse<s402::PaymentVerification>>) {
    let payload = if let Some(parsed) = parse_payment_header(&headers) {
        parsed
    } else if let Some(Json(req)) = body {
        PaymentPayload {
            scheme: req.scheme.unwrap_or_else(|| "bsv-p2pkh".to_string()),
            tx_hex: req.tx_hex,
            nonce: req.nonce,
            timestamp: chrono::Utc::now().timestamp(),
        }
    } else {
        return err_response(StatusCode::BAD_REQUEST, "No payment payload: use X-STAS-PAYMENT header or JSON body");
    };

    let verification = state.s402.verify_payment_payload(&payload);

    if verification.valid {
        state.s402.record_payment(&verification, "/s402/verify", "unknown");

        if !payload.tx_hex.is_empty() && payload.tx_hex.len() > 20 {
            let woc = state.woc.clone();
            let tx_hex = payload.tx_hex.clone();
            tokio::spawn(async move {
                match woc.broadcast(&tx_hex).await {
                    Ok(txid) => tracing::info!(txid = %txid, "s402 payment broadcast OK"),
                    Err(e) => tracing::warn!(error = %e, "s402 payment broadcast failed"),
                }
            });
        }
    }

    if verification.valid {
        ok_response(verification)
    } else {
        let error_msg = verification.error.clone().unwrap_or_else(|| "Verification failed".to_string());
        (StatusCode::PAYMENT_REQUIRED, Json(ApiResponse {
            success: false,
            data: Some(verification),
            error: Some(error_msg),
        }))
    }
}


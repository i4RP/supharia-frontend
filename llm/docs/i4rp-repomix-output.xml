#[derive(Deserialize)]
struct S402AgentPayRequest {
    agent_wif: String,
    endpoint: Option<String>,
}

async fn s402_agent_pay(
    State(state): State<AppState>,
    Path(agent_id): Path<String>,
    Json(req): Json<S402AgentPayRequest>,
) -> (StatusCode, Json<ApiResponse<serde_json::Value>>) {
    let agent_wallet = match wallet_from_wif(&req.agent_wif) {
        Ok(w) => w,
        Err(e) => return err_response(StatusCode::BAD_REQUEST, &format!("Invalid agent WIF: {}", e)),
    };

    let endpoint = req.endpoint.unwrap_or_else(|| "/s402/premium/example".to_string());
    let price = state.s402.get_price_for_endpoint(&endpoint);
    let requirements = state.s402.build_payment_required(&endpoint);

    let balance = match state.woc.get_balance(&agent_wallet.address).await {
        Ok(b) => b,
        Err(e) => return err_response(StatusCode::BAD_GATEWAY, &format!("Cannot check balance: {}", e)),
    };

    if balance < price + 200 {
        return err_response(StatusCode::PAYMENT_REQUIRED, &format!(
            "Insufficient balance: {} sats available, need {} + fees. Fund address: {}",
            balance, price, agent_wallet.address
        ));
    }

    {
        let mut wallets = state.s402.agent_wallets.lock().unwrap();
        if let Some(agent) = wallets.get_mut(&agent_id) {
            agent.balance_sats = balance;
            agent.total_spent_sats += price;
            agent.total_payments += 1;
            agent.last_payment_at = Some(Utc::now().to_rfc3339());
        }
    }

    let verification = s402::PaymentVerification {
        valid: true,
        txid: format!("agent-pay-{}", Uuid::new_v4()),
        amount: price,
        scheme: "bsv-p2pkh".to_string(),
        error: None,
    };
    state.s402.record_payment(&verification, &endpoint, &agent_wallet.address);

    ok_response(serde_json::json!({
        "paid": true,
        "amount_sats": price,
        "endpoint": endpoint,
        "agent_id": agent_id,
        "remaining_balance": balance - price,
        "payment_id": verification.txid,
        "requirements": requirements,
    }))
}

async fn s402_premium_example(
    State(state): State<AppState>,
    headers: HeaderMap,
) -> (StatusCode, Json<ApiResponse<serde_json::Value>>) {
    if let Some(payload) = parse_payment_header(&headers) {
        let verification = state.s402.verify_payment_payload(&payload);
        if verification.valid {
            state.s402.record_payment(&verification, "/s402/premium/example", "header-client");
            return ok_response(serde_json::json!({
                "message": "Premium content unlocked via s402 payment",
                "payment_txid": verification.txid,
                "amount_paid": verification.amount,
                "data": {
                    "premium_analytics": {
                        "total_volume_24h": 1234567,
                        "top_pools": ["BSV/STAS1", "BSV/STAS2"],
                        "market_depth": { "bids": 42, "asks": 38 }
                    }
                }
            }));
        }
    }

    let requirements = state.s402.build_payment_required("/s402/premium/example");
    (StatusCode::PAYMENT_REQUIRED, Json(ApiResponse {
        success: false,
        data: Some(serde_json::json!({
            "protocol": "s402",
            "message": "Payment required to access this endpoint",
            "requirements": requirements,
            "how_to_pay": {
                "option_1": "Include X-STAS-PAYMENT header with base64-encoded payment payload",
                "option_2": "POST to /s402/agent/{agent_id}/pay with your agent WIF",
                "option_3": "POST to /s402/verify with tx_hex and nonce in JSON body",
            },
            "comparison_vs_x402": {

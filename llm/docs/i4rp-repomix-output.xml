            apy: LP_REWARD_RATE_ANNUAL * 100.0,
        });
    }
    ok_response(PoolRewardsSummary {
        pool_id,
        total_lp_providers: positions.len() as u64,
        total_lp_shares: pool.total_lp_shares,
        reward_rate_annual: LP_REWARD_RATE_ANNUAL * 100.0,
        total_distributed_a: total_dist_a,
        total_distributed_b: total_dist_b,
        providers,
    })

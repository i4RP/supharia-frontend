<file path="frontend/src/wallet-connect/provider.ts">
/**
 * DXS Wallet Provider
 *
 * Provides the dApp-side interface for communicating with the
 * DXS Wallet browser extension via window.postMessage.
 */

import type {
  ConnectionState,
  WalletAccount,
  WalletMessage,
  WalletProviderEvents,
  IDxsWalletProvider,
  ExtensionInfo,
} from "./types";
import { SessionManager } from "./session";

type EventMap = {
  [K in keyof WalletProviderEvents]: Set<WalletProviderEvents[K]>;
};

const REQUEST_TIMEOUT_MS = 30_000;

function generateId(): string {
  return `${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;
}

export class DxsWalletProvider implements IDxsWalletProvider {
  private state: ConnectionState = "disconnected";
  private account: WalletAccount | null = null;
  private listeners: EventMap = {
    connect: new Set(),
    disconnect: new Set(),
    accountChanged: new Set(),
    networkChanged: new Set(),
    error: new Set(),
  };
  private pendingRequests = new Map<
    string,
    {
      resolve: (v: Record<string, unknown>) => void;
      reject: (e: Error) => void;
    }
  >();
  private sessionManager = new SessionManager();
  private messageHandler: ((event: MessageEvent) => void) | null = null;

  constructor() {
    this.setupMessageListener();
    this.tryRestoreSession();
  }

  /** Check if the DXS Wallet extension is installed */
  isAvailable(): boolean {
    return typeof window !== "undefined" && window.dxsWallet !== undefined;
  }

  /** Detect extension info */
  detectExtension(): ExtensionInfo {
    if (this.isAvailable()) {
      return { installed: true, version: "1.0.0", name: "DXS Wallet" };
    }
    return { installed: false, name: "DXS Wallet" };
  }

  /** Connect to the wallet extension */
  async connect(): Promise<WalletAccount> {
    if (this.state === "connected" && this.account) {
      return this.account;
    }

    this.state = "connecting";

    try {
      const response = await this.sendRequest("connect", {});
      const account: WalletAccount = {
        address: response.address as string,
        publicKey: response.publicKey as string | undefined,
        network: (response.network as "mainnet" | "testnet") || "mainnet",
      };

      this.account = account;
      this.state = "connected";
      this.sessionManager.saveSession({
        id: generateId(),
        providerType: "extension",
        account,
        connectedAt: Date.now(),
        lastActiveAt: Date.now(),
        origin: window.location.origin,
      });

      this.emit("connect", account);
      return account;
    } catch (error) {
      this.state = "error";
      const err = error instanceof Error ? error : new Error(String(error));
      this.emit("error", err);
      throw err;
    }
  }

  /** Disconnect from the wallet */
  async disconnect(): Promise<void> {
    try {
      await this.sendRequest("disconnect", {});
    } catch {
      // Ignore disconnect errors
    }
    this.account = null;
    this.state = "disconnected";
    this.sessionManager.clearSession();
    this.emit("disconnect");
  }

  /** Get the currently connected account */
  getAccount(): WalletAccount | null {
    return this.account;
  }

  /** Get the BSV address */
  async getAddress(): Promise<string> {
    if (this.account) return this.account.address;
    const response = await this.sendRequest("get_address", {});
    return response.address as string;
  }

  /** Get WIF for transaction signing (extension returns securely) */
  async getWif(): Promise<string> {
    const response = await this.sendRequest("get_wif", {});
    return response.wif as string;
  }

  /** Get BSV balance */
  async getBalance(): Promise<number> {
    const response = await this.sendRequest("get_balance", {});
    return response.balance as number;
  }

  /** Sign a raw transaction hex */
  async signTransaction(txHex: string): Promise<string> {
    const response = await this.sendRequest("sign_transaction", { txHex });
    return response.signedTxHex as string;
  }

  /** Sign a message */
  async signMessage(message: string): Promise<string> {
    const response = await this.sendRequest("sign_message", { message });
    return response.signature as string;
  }

  /** Get connection state */
  getState(): ConnectionState {
    return this.state;
  }

  /** Add event listener */
  on<K extends keyof WalletProviderEvents>(
    event: K,
    listener: WalletProviderEvents[K],
  ): void {
    this.listeners[event].add(listener as never);
  }

  /** Remove event listener */
  off<K extends keyof WalletProviderEvents>(
    event: K,
    listener: WalletProviderEvents[K],
  ): void {
    this.listeners[event].delete(listener as never);
  }

  /** Clean up listeners */
  destroy(): void {
    if (this.messageHandler) {
      window.removeEventListener("message", this.messageHandler);
      this.messageHandler = null;
    }
    for (const [, { reject }] of this.pendingRequests) {
      reject(new Error("Provider destroyed"));
    }
    this.pendingRequests.clear();
  }

  // --- Private ---

  private emit<K extends keyof WalletProviderEvents>(
    event: K,
    ...args: Parameters<WalletProviderEvents[K]>
  ): void {
    for (const listener of this.listeners[event]) {
      try {
        (listener as (...a: Parameters<WalletProviderEvents[K]>) => void)(
          ...args,
        );
      } catch (e) {
        console.error(`DxsWalletProvider: error in ${event} listener`, e);
      }
    }
  }

  private setupMessageListener(): void {
    this.messageHandler = (event: MessageEvent) => {
      if (event.source !== window) return;
      const data = event.data as WalletMessage | undefined;
      if (!data || data.source !== "dxs-wallet-extension") return;

      if (data.type === "DXS_WALLET_RESPONSE") {
        const pending = this.pendingRequests.get(data.id);
        if (pending) {
          this.pendingRequests.delete(data.id);
          if (data.payload.error) {
            pending.reject(new Error(data.payload.error as string));
          } else {
            pending.resolve(data.payload);
          }
        }
      } else if (data.type === "DXS_WALLET_EVENT") {
        this.handleWalletEvent(data);
      }
    };
    window.addEventListener("message", this.messageHandler);
  }

  private handleWalletEvent(data: WalletMessage): void {
    switch (data.action) {
      case "accountChanged": {
        const newAccount: WalletAccount = {
          address: data.payload.address as string,
          publicKey: data.payload.publicKey as string | undefined,
          network: (data.payload.network as "mainnet" | "testnet") || "mainnet",
        };
        this.account = newAccount;
        this.emit("accountChanged", newAccount);
        break;
      }
      case "networkChanged":
        this.emit(
          "networkChanged",
          data.payload.network as "mainnet" | "testnet",
        );
        break;
      case "disconnect":
        this.account = null;
        this.state = "disconnected";
        this.sessionManager.clearSession();
        this.emit("disconnect");
        break;
    }
  }

  private sendRequest(
    action: string,
    payload: Record<string, unknown>,
  ): Promise<Record<string, unknown>> {
    return new Promise((resolve, reject) => {
      const id = generateId();
      const message: WalletMessage = {
        type: "DXS_WALLET_REQUEST",
        action,
        id,
        payload,
        source: "dxs-dapp",
      };

      this.pendingRequests.set(id, { resolve, reject });

      const timeout = setTimeout(() => {
        this.pendingRequests.delete(id);
        reject(new Error(`Request ${action} timed out`));
      }, REQUEST_TIMEOUT_MS);

      const originalResolve = resolve;
      const originalReject = reject;
      this.pendingRequests.set(id, {
        resolve: (v) => {
          clearTimeout(timeout);
          originalResolve(v);
        },
        reject: (e) => {
          clearTimeout(timeout);
          originalReject(e);
        },
      });

      window.postMessage(message, "*");
    });
  }

  private tryRestoreSession(): void {
    const session = this.sessionManager.getSession();
    if (session && session.providerType === "extension") {
      if (this.isAvailable()) {
        this.account = session.account;
        this.state = "connected";
        // Verify the session is still valid
        this.sendRequest("ping", {})
          .then(() => {
            this.sessionManager.updateLastActive();
            this.emit("connect", session.account);
          })
          .catch(() => {
            this.account = null;
            this.state = "disconnected";
            this.sessionManager.clearSession();
          });
      }
    }
  }
}

/** Singleton provider instance */
let providerInstance: DxsWalletProvider | null = null;

export function getDxsWalletProvider(): DxsWalletProvider {
  if (!providerInstance) {
    providerInstance = new DxsWalletProvider();
  }
  return providerInstance;
}
</file>

<file path="frontend/src/wallet-connect/session.ts">
/**
 * DXS Wallet Session Manager
 *
 * Manages persistent wallet connection sessions in localStorage.
 */

import type { WalletSession } from "./types";

const SESSION_KEY = "dxs-wallet-session";
const SESSION_TIMEOUT_MS = 24 * 60 * 60 * 1000; // 24 hours

export class SessionManager {
  /** Save a new session */
  saveSession(session: WalletSession): void {
    try {
      localStorage.setItem(SESSION_KEY, JSON.stringify(session));
    } catch (e) {
      console.warn("Failed to save wallet session:", e);
    }
  }

  /** Get the current session if still valid */
  getSession(): WalletSession | null {
    try {
      const raw = localStorage.getItem(SESSION_KEY);
      if (!raw) return null;
      const session: WalletSession = JSON.parse(raw);
      if (Date.now() - session.lastActiveAt > SESSION_TIMEOUT_MS) {
        this.clearSession();
        return null;
      }
      return session;
    } catch {
      this.clearSession();
      return null;
    }
  }

  /** Update the last active timestamp */
  updateLastActive(): void {
    const session = this.getSession();
    if (session) {
      session.lastActiveAt = Date.now();
      this.saveSession(session);
    }
  }

  /** Clear the stored session */
  clearSession(): void {
    try {
      localStorage.removeItem(SESSION_KEY);
    } catch {
      // Ignore
    }
  }

  /** Check if a session exists */
  hasSession(): boolean {
    return this.getSession() !== null;
  }
}
</file>

<file path="frontend/src/wallet-connect/types.ts">
/**
 * DXS WalletConnect Protocol Types
 *
 * Defines the communication protocol between the DXS Swap dApp
 * and external wallet providers (browser extension, etc.).
 */

/** Connection states */
export type ConnectionState =
  | "disconnected"
  | "connecting"
  | "connected"
  | "error";

/** Supported wallet provider types */
export type WalletProviderType = "extension" | "mnemonic" | "wif";

/** Wallet account info returned after connection */
export interface WalletAccount {
  address: string;
  publicKey?: string;
  network: "mainnet" | "testnet";
}

/** Transaction request sent from dApp to wallet */
export interface TransactionRequest {
  id: string;
  type: "sign_transaction" | "sign_message" | "get_address" | "get_balance";
  payload: Record<string, unknown>;
  origin: string;
  timestamp: number;
}

/** Transaction response sent from wallet to dApp */
export interface TransactionResponse {
  id: string;
  success: boolean;
  data?: Record<string, unknown>;
  error?: string;
}

/** Session persisted in localStorage */
export interface WalletSession {
  id: string;
  providerType: WalletProviderType;
  account: WalletAccount;
  connectedAt: number;
  lastActiveAt: number;
  origin: string;
}

/** Events emitted by the wallet provider */
export interface WalletProviderEvents {
  connect: (account: WalletAccount) => void;
  disconnect: () => void;
  accountChanged: (account: WalletAccount) => void;
  networkChanged: (network: "mainnet" | "testnet") => void;
  error: (error: Error) => void;
}

/** Message format for window.postMessage communication */
export interface WalletMessage {
  type: "DXS_WALLET_REQUEST" | "DXS_WALLET_RESPONSE" | "DXS_WALLET_EVENT";
  action: string;
  id: string;
  payload: Record<string, unknown>;
  source: "dxs-dapp" | "dxs-wallet-extension";
}

/** Extension detection info */
export interface ExtensionInfo {
  installed: boolean;
  version?: string;
  name: string;
}

/** Wallet provider interface that the dApp uses */
export interface IDxsWalletProvider {
  /** Check if the extension is available */
  isAvailable(): boolean;
  /** Connect to the wallet */
  connect(): Promise<WalletAccount>;
  /** Disconnect from the wallet */
  disconnect(): Promise<void>;
  /** Get the currently connected account */
  getAccount(): WalletAccount | null;
  /** Get the BSV address */
  getAddress(): Promise<string>;
  /** Get the WIF key for signing (extension handles securely) */
  getWif(): Promise<string>;
  /** Get BSV balance */
  getBalance(): Promise<number>;
  /** Sign a raw transaction hex */
  signTransaction(txHex: string): Promise<string>;
  /** Sign a message */
  signMessage(message: string): Promise<string>;
  /** Get connection state */
  getState(): ConnectionState;
  /** Listen for events */
  on<K extends keyof WalletProviderEvents>(
    event: K,
    listener: WalletProviderEvents[K],
  ): void;
  /** Remove event listener */
  off<K extends keyof WalletProviderEvents>(
    event: K,
    listener: WalletProviderEvents[K],
  ): void;
}

/** Global window augmentation for the wallet extension */
declare global {
  interface Window {
    dxsWallet?: IDxsWalletProvider;
  }
}
</file>


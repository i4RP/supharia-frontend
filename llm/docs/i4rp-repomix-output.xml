  --text: #e8ecf1;
  --text-secondary: #8b95a5;
  --accent: #4f8cff;
  --accent-hover: #3a75e8;
  --accent-bg: rgba(79, 140, 255, 0.12);
  --danger: #ff5c5c;
  --danger-bg: rgba(255, 92, 92, 0.12);
  --success: #2ecc71;
  --success-bg: rgba(46, 204, 113, 0.12);
  --warning: #f1c40f;
  --warning-bg: rgba(241, 196, 15, 0.12);
  --radius: 10px;
  --radius-sm: 6px;
  --font: "Inter", "Segoe UI", system-ui, -apple-system, sans-serif;
  --mono: "SF Mono", "Fira Code", "Consolas", monospace;
  --shadow: 0 2px 12px rgba(0, 0, 0, 0.35);
  --transition: 0.2s ease;
}

html,
body {
  width: 360px;
  min-height: 540px;
  max-height: 600px;
  overflow-y: auto;
  background: var(--bg);
  color: var(--text);
  font-family: var(--font);
  font-size: 13px;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

body::-webkit-scrollbar {
  width: 4px;
}

body::-webkit-scrollbar-thumb {
  background: var(--border);
  border-radius: 4px;
}

#app {
  display: flex;
  flex-direction: column;
  min-height: 540px;
}

/* ---- View system ---- */
.view {
  display: flex;
  flex-direction: column;
  padding: 20px;
  animation: fadeIn 0.25s ease;
}

.hidden {
  display: none !important;
}

/* ---- Animations ---- */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-10px); }
  to   { opacity: 1; transform: translateY(0); }
}

.fade-in {
  animation: fadeIn 0.3s ease;
}

/* ---- Loading ---- */
#view-loading {
  align-items: center;
  justify-content: center;
  min-height: 540px;
}

.loading-spinner {
  width: 36px;
  height: 36px;
  border: 3px solid var(--border);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-text {
  margin-top: 12px;
  color: var(--text-secondary);
  font-size: 13px;
}

/* ---- Logo ---- */
.logo {
  font-size: 22px;
  font-weight: 700;
  letter-spacing: -0.5px;
  background: linear-gradient(135deg, var(--accent) 0%, #a78bfa 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.logo-sm {
  font-size: 15px;
  font-weight: 700;
  background: linear-gradient(135deg, var(--accent) 0%, #a78bfa 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ---- Setup View ---- */
.setup-header {
  text-align: center;
  margin-bottom: 28px;
  padding-top: 32px;
}

.setup-subtitle {
  margin-top: 6px;
  color: var(--text-secondary);
  font-size: 13px;
}

.setup-options {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

/* ---- Buttons ---- */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 12px 18px;
  border: none;
  border-radius: var(--radius);
  font-family: var(--font);
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: all var(--transition);
  outline: none;
}

.btn:active {
  transform: scale(0.97);
}

.btn-primary {
  background: var(--accent);
  color: #fff;
}

.btn-primary:hover {
  background: var(--accent-hover);
}

.btn-secondary {
  background: var(--bg-input);
  color: var(--text);
  border: 1px solid var(--border);
}

.btn-secondary:hover {
  background: var(--bg-hover);
  border-color: var(--accent);
}

.btn-sm {
  padding: 8px 12px;
  font-size: 12px;
  border-radius: var(--radius-sm);
}

.btn-icon {
  font-size: 16px;
  line-height: 1;
}

.btn-icon-only {
  width: 32px;
  height: 32px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text-secondary);
  cursor: pointer;
  font-size: 15px;
  transition: all var(--transition);
}

.btn-icon-only:hover {
  background: var(--bg-hover);
  color: var(--text);
  border-color: var(--accent);
}

.btn-text {
  background: none;
  border: none;
  color: var(--accent);
  cursor: pointer;
  font-size: 12px;
  font-family: var(--font);
  font-weight: 500;
  padding: 4px 8px;
  border-radius: var(--radius-sm);
  transition: all var(--transition);
}

.btn-text:hover {
  background: var(--accent-bg);
}

.btn-danger {
  background: var(--danger-bg);
  color: var(--danger);
  border: 1px solid rgba(255, 92, 92, 0.25);
  padding: 8px 14px;
  border-radius: var(--radius-sm);
  font-family: var(--font);
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  transition: all var(--transition);
}

.btn-danger:hover {
  background: rgba(255, 92, 92, 0.2);
}

.btn-copy {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  background: var(--bg-hover);
  border: 1px solid var(--border);
  color: var(--text-secondary);
  padding: 4px 10px;
  border-radius: var(--radius-sm);
  font-size: 11px;
  font-family: var(--font);
  cursor: pointer;
  margin-top: 6px;
  transition: all var(--transition);
}

.btn-copy:hover {
  color: var(--accent);
  border-color: var(--accent);
}

.btn-row {
  display: flex;
  gap: 8px;
  margin-top: 8px;
}

/* ---- Inputs ---- */
.input-field {
  width: 100%;
  padding: 10px 14px;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text);
  font-family: var(--font);
  font-size: 13px;
  outline: none;
  transition: border-color var(--transition);
  margin-top: 8px;
}

.input-field:focus {
  border-color: var(--accent);
}

.input-field::placeholder {
  color: var(--text-secondary);
}

.input-area {
  width: 100%;
  padding: 10px 14px;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text);
  font-family: var(--mono);
  font-size: 12px;
  outline: none;
  resize: vertical;
  transition: border-color var(--transition);
  margin-top: 8px;
}

.input-area:focus {
  border-color: var(--accent);
}

.input-select {
  padding: 6px 10px;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text);
  font-family: var(--font);
  font-size: 12px;
  outline: none;
  cursor: pointer;
}

.mono {
  font-family: var(--mono);
  font-size: 11px;
}

/* ---- Banners ---- */
.info-banner {
  background: var(--accent-bg);
  border: 1px solid rgba(79, 140, 255, 0.2);
  border-radius: var(--radius-sm);
  padding: 10px 14px;
  font-size: 12px;
  color: var(--accent);
  margin-bottom: 12px;
}

.warning-banner {
  background: var(--warning-bg);
  border: 1px solid rgba(241, 196, 15, 0.25);
  border-radius: var(--radius-sm);
  padding: 10px 14px;
  font-size: 12px;
  color: var(--warning);
  margin-bottom: 12px;
}

/* ---- Field group ---- */
.field-group {
  margin-bottom: 12px;
}

.field-group label {
  display: block;
  font-size: 11px;
  font-weight: 600;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 4px;
}

.field-value {
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 8px 12px;
  word-break: break-all;
  font-size: 12px;
  line-height: 1.5;
  user-select: all;
}

/* ---- Wallet Header ---- */
.wallet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 0;
  border-bottom: 1px solid var(--border);
  margin-bottom: 4px;
}

.wallet-header-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.wallet-header-right {
  display: flex;
  gap: 6px;
}

.network-select {
  padding: 4px 8px;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text);
  font-size: 11px;
  font-family: var(--font);
  outline: none;
  cursor: pointer;
}

/* ---- Tab Bar ---- */
.tab-bar {
  display: flex;
  border-bottom: 1px solid var(--border);
}

.tab-btn {
  flex: 1;
  padding: 10px 0;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  color: var(--text-secondary);
  font-family: var(--font);
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: all var(--transition);
}

.tab-btn:hover {
  color: var(--text);
}

.tab-btn.active {
  color: var(--accent);
  border-bottom-color: var(--accent);
}

.tab-content {
  padding: 16px 0;
  animation: fadeIn 0.2s ease;
}

/* ---- Account Card ---- */
.account-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 18px;
  text-align: center;
  margin-bottom: 14px;
}

.account-address {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--text-secondary);
  word-break: break-all;
  cursor: pointer;
  padding: 6px 8px;
  border-radius: var(--radius-sm);
  transition: background var(--transition);
}

.account-address:hover {
  background: var(--bg-hover);
}

.account-balance {
  margin-top: 14px;
  font-size: 28px;
  font-weight: 700;
  letter-spacing: -0.5px;
}

.balance-unit {
  font-size: 14px;
  font-weight: 400;
  color: var(--text-secondary);
  margin-left: 4px;
}

.account-actions {
  display: flex;
  justify-content: center;
  gap: 12px;
  margin-top: 12px;
}

.actions-row {
  display: flex;
  gap: 8px;
}

.actions-row .btn {
  flex: 1;
}

/* ---- Section ---- */
.section {
  margin-bottom: 14px;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}

.section-title {
  font-size: 14px;
  font-weight: 600;
}

/* ---- Transaction List ---- */
.tx-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.tx-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 12px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: background var(--transition);
}

.tx-item:hover {
  background: var(--bg-hover);
}

.tx-item-left {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 0;
}

.tx-id {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 200px;
}

.tx-type {
  font-size: 12px;
  font-weight: 600;
  text-transform: capitalize;
}

.tx-time {
  font-size: 11px;
  color: var(--text-secondary);
}

/* ---- Sites List ---- */
.sites-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.site-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 12px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
}

.site-origin {
  font-family: var(--mono);
  font-size: 12px;
  color: var(--text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 220px;
}

.site-disconnect {
  background: none;
  border: none;
  color: var(--danger);
  font-size: 11px;
  font-family: var(--font);
  cursor: pointer;
  padding: 4px 8px;
  border-radius: var(--radius-sm);
  transition: background var(--transition);
}

.site-disconnect:hover {
  background: var(--danger-bg);
}

.empty-state {
  text-align: center;
  padding: 28px 14px;
  color: var(--text-secondary);
  font-size: 13px;
}

/* ---- Footer ---- */
.footer-actions {
  padding: 12px 0;
  border-top: 1px solid var(--border);
  margin-top: auto;
  text-align: center;
}

/* ---- Locked View ---- */
#view-locked {
  align-items: center;
  justify-content: center;
  min-height: 540px;
  gap: 12px;
}

.lock-icon {
  font-size: 48px;
  margin-bottom: 8px;
  animation: pulse 2s ease infinite;
}

.lock-text {
  color: var(--text-secondary);
  font-size: 14px;
}

#unlock-password-section {
  width: 100%;
  max-width: 260px;
}

/* ---- Settings View ---- */
.settings-header {
  display: flex;
  align-items: center;
  gap: 10px;
  padding-bottom: 14px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 16px;
}

.settings-group {
  margin-bottom: 20px;
}

.settings-label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.6px;
  color: var(--text-secondary);
  margin-bottom: 10px;
}

.settings-desc {
  font-size: 12px;
  color: var(--text-secondary);
  margin-bottom: 10px;
  line-height: 1.5;
}

.settings-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 0;
  border-bottom: 1px solid var(--border);
  font-size: 13px;
}

/* ---- Toggle Switch ---- */
.toggle {
  position: relative;
  display: inline-block;
  width: 40px;
  height: 22px;
}

.toggle input {
  opacity: 0;
  width: 0;
  height: 0;
}

.toggle-slider {
  position: absolute;
  cursor: pointer;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--border);
  border-radius: 22px;
  transition: var(--transition);
}

.toggle-slider::before {
  content: "";
  position: absolute;
  height: 16px;
  width: 16px;
  left: 3px;
  bottom: 3px;
  background: var(--text);
  border-radius: 50%;
  transition: var(--transition);
}

.toggle input:checked + .toggle-slider {
  background: var(--accent);
}

.toggle input:checked + .toggle-slider::before {
  transform: translateX(18px);
}

/* ---- Badge ---- */
.badge {
  font-size: 11px;
  font-weight: 600;
  padding: 2px 8px;
  border-radius: 10px;
}

.badge-on {
  background: var(--success-bg);
  color: var(--success);
}

.badge-off {
  background: var(--bg-hover);
  color: var(--text-secondary);
}

/* ---- Modal ---- */
.modal {
  position: fixed;
  inset: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(4px);
}

.modal-content {
  position: relative;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px;
  width: 320px;
  max-height: 500px;
  overflow-y: auto;
  box-shadow: var(--shadow);
  animation: slideUp 0.25s ease;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

/* ---- QR Code ---- */
#qr-canvas {
  display: block;
  margin: 0 auto 12px;
  border-radius: var(--radius-sm);
  background: #fff;
  padding: 8px;
}

.qr-address-text {
  text-align: center;
  word-break: break-all;
  font-size: 11px;
  color: var(--text-secondary);
  padding: 8px;
}

/* ---- Toast ---- */
.toast {
  position: fixed;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 10px 20px;
  font-size: 13px;
  font-weight: 500;
  color: var(--text);
  box-shadow: var(--shadow);
  z-index: 200;
  animation: slideUp 0.25s ease;
  pointer-events: none;
}

.toast.toast-success {
  border-color: var(--success);
  color: var(--success);
}

.toast.toast-error {
  border-color: var(--danger);
  color: var(--danger);
}

/* ---- Responsive refinements ---- */
@media (max-width: 360px) {
  body {
    font-size: 12px;
  }
  .account-balance {
    font-size: 24px;
  }
}
</file>

<file path="wallet-extension/popup/popup.html">
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=360">
  <title>DXS Wallet</title>
  <link rel="stylesheet" href="popup.css">
</head>
<body>
  <div id="app">
    <!-- Loading State -->
    <div id="view-loading" class="view">
      <div class="loading-spinner"></div>
      <p class="loading-text">Loading...</p>
    </div>

    <!-- Setup View (No Wallet) -->
    <div id="view-setup" class="view hidden">
      <div class="setup-header">
        <div class="logo">DXS Wallet</div>
        <p class="setup-subtitle">BSV Wallet for DXS Swap</p>
      </div>
      <div id="setup-buttons" class="setup-options">
        <button id="btn-create" class="btn btn-primary">
          <span class="btn-icon">&#43;</span>
          Create New Wallet
        </button>
        <button id="btn-import-toggle" class="btn btn-secondary">
          <span class="btn-icon">&#8615;</span>
          Import Wallet (WIF)
        </button>
      </div>

      <!-- Password setup for new wallet -->
      <div id="password-setup" class="hidden fade-in">
        <div class="info-banner">Set a password to encrypt your wallet (recommended)</div>
        <input id="setup-password" type="password" class="input-field" placeholder="Password (optional)">
        <input id="setup-password-confirm" type="password" class="input-field" placeholder="Confirm password">
        <button id="btn-create-confirm" class="btn btn-primary">Create Wallet</button>
        <button id="btn-create-skip" class="btn-text" style="margin-top:8px">Skip (no password)</button>
      </div>

      <div id="import-section" class="hidden fade-in">
        <textarea id="import-wif" class="input-area" placeholder="Enter your WIF private key (starts with K, L, or 5)..." rows="3"></textarea>
        <input id="import-password" type="password" class="input-field" placeholder="Password to encrypt (optional)">
        <button id="btn-import" class="btn btn-primary">Import</button>
      </div>
      <div id="create-result" class="hidden fade-in">
        <div class="warning-banner">Save your keys securely! They cannot be recovered.</div>
        <div class="field-group">
          <label>Address</label>
          <div class="field-value mono" id="created-address"></div>
        </div>
        <div class="field-group">
          <label>WIF Private Key</label>
          <div class="field-value mono" id="created-wif"></div>
          <button class="btn-copy" id="btn-copy-wif">Copy WIF</button>
        </div>
        <button id="btn-use-created" class="btn btn-primary">Use This Wallet</button>
      </div>
    </div>

    <!-- Main Wallet View -->
    <div id="view-main" class="view hidden">
      <div class="wallet-header">
        <div class="wallet-header-left">
          <div class="logo-sm">DXS</div>
          <select id="network-select" class="network-select">
            <option value="mainnet">Mainnet</option>
            <option value="testnet">Testnet</option>
          </select>
        </div>
        <div class="wallet-header-right">
          <button id="btn-settings" class="btn-icon-only" title="Settings">&#9881;</button>
          <button id="btn-lock" class="btn-icon-only" title="Lock Wallet">&#128274;</button>
        </div>
      </div>

      <!-- Tab navigation -->
      <div class="tab-bar">
        <button class="tab-btn active" data-tab="tab-wallet">Wallet</button>
        <button class="tab-btn" data-tab="tab-history">History</button>
        <button class="tab-btn" data-tab="tab-sites">Sites</button>
      </div>

      <!-- Wallet Tab -->
      <div id="tab-wallet" class="tab-content active">
        <div class="account-card">
          <div class="account-address" id="display-address" title="Click to copy">Loading...</div>
          <div class="account-balance">
            <span id="display-balance">--</span>
            <span class="balance-unit">BSV</span>
          </div>
          <div class="account-actions">
            <button id="btn-refresh-balance" class="btn-text">Refresh</button>
            <button id="btn-show-qr" class="btn-text">QR Code</button>
          </div>
        </div>

        <div class="actions-row">
          <button id="btn-copy-address" class="btn btn-secondary btn-sm">Copy</button>
          <button id="btn-explorer" class="btn btn-secondary btn-sm">Explorer</button>
          <button id="btn-export" class="btn btn-secondary btn-sm">Export</button>
        </div>
      </div>

      <!-- History Tab -->
      <div id="tab-history" class="tab-content hidden">
        <div class="section">
          <div class="section-header">
            <div class="section-title">Transaction History</div>

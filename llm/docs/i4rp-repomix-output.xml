async fn get_farming_summary(
    State(state): State<AppState>,
    Path(pool_id): Path<String>,
) -> (StatusCode, Json<ApiResponse<FarmingSummary>>) {
    let stakes = state.db.list_farming_stakes(&pool_id).await.unwrap_or_default();
    let total_staked: f64 = stakes.iter().map(|s| s.staked_lp_shares).sum();
    let stakers: Vec<FarmingStakeInfo> = stakes.iter().map(|s| stake_to_info(s)).collect();

<file path="frontend/src/App.css">
.app {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* Header */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 24px;
  border-bottom: 1px solid var(--border);
}
.header-left {
  display: flex;
  align-items: center;
  gap: 24px;
}
.logo-text {
  font-size: 20px;
  font-weight: 700;
  background: linear-gradient(90deg, var(--pink), var(--accent));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: -0.5px;
}
.nav-links {
  display: flex;
  gap: 4px;
  align-items: center;
}
.nav-link {
  padding: 8px 16px;
  border-radius: var(--radius);
  font-size: 14px;
  font-weight: 500;
  color: var(--text-secondary);
  background: none;
  border: none;
  cursor: pointer;
  transition: all 0.15s;
}
.nav-link:hover {
  color: var(--text-primary);
  background: var(--accent-dim);
}
.nav-link.active {
  color: var(--text-primary);
  background: var(--accent-dim);
}
.nav-group {
  position: relative;
}
.nav-group .nav-link {
  display: flex;
  align-items: center;
  gap: 4px;
}
.nav-chevron {
  font-size: 10px;
  opacity: 0.6;
}
.nav-dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  min-width: 180px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
  z-index: 50;
  padding: 4px;
  animation: fadeIn 0.15s ease;
}
.nav-dropdown-item {
  display: block;
  width: 100%;
  padding: 10px 14px;
  border: none;
  background: none;
  color: var(--text-secondary);
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  border-radius: calc(var(--radius) - 2px);
  text-align: left;
  transition: all 0.15s;
}
.nav-dropdown-item:hover {
  color: var(--text-primary);
  background: var(--accent-dim);
}
.nav-dropdown-item.active {
  color: var(--accent);
  background: var(--accent-dim);
}
.hamburger-btn {
  display: none;
  width: 36px;
  height: 36px;
  border-radius: var(--radius);
  background: none;
  border: 1px solid var(--border);
  color: var(--text-primary);
  font-size: 18px;
  cursor: pointer;
  align-items: center;
  justify-content: center;
  transition: all 0.15s;
}
.hamburger-btn:hover {
  background: var(--accent-dim);
}
.wallet-btn {
  padding: 8px 16px;
  border-radius: var(--radius);
  font-size: 14px;
  font-weight: 600;
  color: var(--accent);
  background: var(--accent-dim);
  border: none;
  cursor: pointer;
  transition: all 0.2s;
}
.wallet-btn:hover {
  background: rgba(76, 130, 251, 0.2);
}
.wallet-btn.connected {
  color: var(--text-primary);
  background: var(--bg-secondary);
  border: 1px solid var(--border);
}

/* Main */
.main {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48px 16px;
}
.main-title {
  font-size: 52px;
  font-weight: 700;
  text-align: center;
  margin-bottom: 8px;
  letter-spacing: -1.5px;
  line-height: 1.1;
}
.main-title .gradient {
  background: linear-gradient(90deg, var(--pink), var(--accent));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}
.main-subtitle {
  font-size: 16px;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 32px;
}

/* Swap Card */
.swap-card {
  width: 100%;
  max-width: 480px;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border);
  padding: 12px;
  box-shadow: var(--shadow);
  animation: fadeIn 0.3s ease;
}
.swap-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 4px 8px 12px;
}
.swap-title {
  font-size: 16px;
  font-weight: 500;
}
.settings-btn {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  background: none;
  border: none;
  color: var(--text-secondary);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  transition: all 0.15s;
}
.settings-btn:hover {
  color: var(--text-primary);
  background: var(--accent-dim);
}

/* Token Input */
.token-input-container {
  background: var(--bg-input);
  border-radius: var(--radius);
  padding: 16px;
  border: 1px solid transparent;
  transition: border-color 0.2s;
}
.token-input-container:focus-within {
  border-color: var(--border);
}
.token-input-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}
.amount-input {
  flex: 1;
  font-size: 28px;
  font-weight: 500;
  background: none;
  border: none;
  outline: none;
  color: var(--text-primary);
  width: 0;
  min-width: 0;
}
.amount-input::placeholder {
  color: var(--text-muted);
}
.token-select {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 12px 6px 8px;
  border-radius: 20px;
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  cursor: pointer;
  transition: all 0.15s;
  flex-shrink: 0;
  user-select: none;
}
.token-select:hover {
  background: var(--border);
}
.token-icon {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}
.token-name {
  font-size: 16px;
  font-weight: 600;
  white-space: nowrap;
}
.token-chevron {
  font-size: 12px;
  color: var(--text-secondary);
  margin-left: 2px;
}
.token-info-row {
  display: flex;
  justify-content: space-between;
  margin-top: 8px;
  font-size: 13px;
  color: var(--text-secondary);
}
.balance-text {
  cursor: pointer;
}
.balance-text:hover {
  color: var(--text-primary);
}

/* Swap Divider */
.swap-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: -6px 0;
  position: relative;
  z-index: 2;
}
.swap-arrow-btn {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: var(--bg-card);
  border: 4px solid var(--bg-input);
  color: var(--text-secondary);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  transition: all 0.2s;
}
.swap-arrow-btn:hover {
  color: var(--text-primary);
  background: var(--border);
}

/* Rate Display */
.rate-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 12px;
  margin: 8px 0;
  border-radius: var(--radius);
  font-size: 13px;
  color: var(--text-secondary);
  cursor: pointer;
  transition: all 0.15s;
}
.rate-display:hover {
  color: var(--text-primary);
}
.rate-icon {
  display: flex;
  align-items: center;
  gap: 6px;
}

/* Swap Button */
.swap-btn {
  width: 100%;
  padding: 16px;
  border-radius: var(--radius);
  font-size: 18px;
  font-weight: 600;
  border: none;
  cursor: pointer;
  transition: all 0.2s;
  margin-top: 4px;
}
.swap-btn.connect {
  background: var(--accent-dim);
  color: var(--accent);
}
.swap-btn.connect:hover {
  background: rgba(76, 130, 251, 0.2);
}
.swap-btn.ready {
  background: var(--accent);
  color: #fff;
}
.swap-btn.ready:hover {
  background: var(--accent-hover);
}
.swap-btn.disabled {
  background: var(--accent-dim);
  color: var(--text-muted);
  cursor: not-allowed;
}
.swap-btn.loading {
  background: var(--accent-dim);
  color: var(--accent);
  cursor: wait;
}

/* Swap Progress */
.swap-progress {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px;
  margin-top: 8px;
  background: var(--accent-dim);
  border-radius: var(--radius);
  font-size: 13px;
  color: var(--accent);
  animation: fadeIn 0.2s ease;
}
.progress-spinner {
  width: 16px;
  height: 16px;
  border: 2px solid var(--accent);
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Details Panel */
.details-panel {
  margin-top: 8px;
  background: var(--bg-input);
  border-radius: var(--radius);
  padding: 12px;
  animation: fadeIn 0.2s ease;
}
.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 6px 0;
  font-size: 13px;
}
.detail-label {
  color: var(--text-secondary);
}
.detail-value {
  color: var(--text-primary);
  font-weight: 500;
}

/* Token Modal */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  backdrop-filter: blur(4px);
}
.modal {
  width: 420px;
  max-height: 80vh;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border);
  box-shadow: var(--shadow);
  overflow: hidden;
  animation: fadeIn 0.2s ease;
}
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  border-bottom: 1px solid var(--border);
}
.modal-title {
  font-size: 16px;
  font-weight: 600;
}
.modal-close {
  width: 28px;
  height: 28px;
  border-radius: 8px;
  background: none;
  border: none;
  color: var(--text-secondary);
  cursor: pointer;
  font-size: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-close:hover {
  color: var(--text-primary);
  background: var(--accent-dim);
}
.modal-search {
  padding: 12px 20px;
}
.modal-search input {
  width: 100%;
  padding: 12px 16px;
  border-radius: var(--radius);
  background: var(--bg-input);
  border: 1px solid var(--border);
  color: var(--text-primary);
  font-size: 14px;
  outline: none;
  transition: border-color 0.2s;
}
.modal-search input:focus {
  border-color: var(--accent);
}
.modal-search input::placeholder {
  color: var(--text-muted);
}
.popular-tokens {
  display: flex;
  gap: 8px;
  padding: 0 20px 12px;
  flex-wrap: wrap;
}
.popular-token {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 6px 12px;
  border-radius: 20px;
  background: var(--bg-input);
  border: 1px solid var(--border);
  cursor: pointer;
  font-size: 14px;
  font-weight: 500;
  color: var(--text-primary);
  transition: all 0.15s;
}
.popular-token:hover {
  background: var(--border);
}
.popular-token .token-icon {
  width: 24px;
  height: 24px;
  font-size: 11px;
}
.token-list {
  max-height: 380px;
  overflow-y: auto;
  padding: 8px 0;
}
.token-list-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 20px;
  cursor: pointer;
  transition: all 0.15s;
}
.token-list-item:hover {
  background: var(--accent-dim);
}
.token-list-item .token-icon {
  width: 36px;
  height: 36px;
  font-size: 15px;
}
.token-list-info {
  flex: 1;
}
.token-list-name {
  font-size: 15px;
  font-weight: 600;
}
.token-list-fullname {
  font-size: 12px;
  color: var(--text-secondary);
}
.token-list-balance {
  text-align: right;
  font-size: 14px;
  font-weight: 500;
}

/* Wallet Modal */
.wallet-modal-content {
  padding: 20px;
}
.wallet-tab-bar {
  display: flex;
  gap: 4px;
  margin-bottom: 16px;
  background: var(--bg-secondary);
  border-radius: var(--radius);
  padding: 4px;
}
.wallet-tab {
  flex: 1;
  padding: 10px 16px;
  border-radius: calc(var(--radius) - 2px);
  font-size: 14px;
  font-weight: 600;
  color: var(--text-secondary);
  background: none;
  border: none;
  cursor: pointer;
  transition: all 0.15s;
}
.wallet-tab:hover {
  color: var(--text-primary);
}
.wallet-tab.active {
  color: var(--text-primary);
  background: var(--bg-tertiary);
}
.wallet-option {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  border-radius: var(--radius);
  background: var(--bg-input);
  border: 1px solid var(--border);
  cursor: pointer;
  margin-bottom: 8px;
  transition: all 0.15s;
}
.wallet-option:hover {
  border-color: var(--accent);
  background: var(--accent-dim);
}
.wallet-option-icon {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
}
.wallet-option-info {
  flex: 1;
}
.wallet-option-name {
  font-size: 15px;
  font-weight: 600;
}
.wallet-option-desc {
  font-size: 12px;
  color: var(--text-secondary);
}
.mnemonic-input {
  width: 100%;
  padding: 12px;
  border-radius: var(--radius);
  background: var(--bg-input);
  border: 1px solid var(--border);
  color: var(--text-primary);
  font-size: 14px;
  font-family: 'Inter', monospace;
  resize: vertical;
  min-height: 80px;
  outline: none;
  margin-top: 12px;
}
.mnemonic-input:focus {
  border-color: var(--accent);
}
.mnemonic-actions {
  display: flex;
  gap: 8px;
  margin-top: 12px;
}
.mnemonic-actions button {
  flex: 1;
  padding: 12px;
  border-radius: var(--radius);
  font-size: 14px;
  font-weight: 600;
  border: none;
  cursor: pointer;
  transition: all 0.15s;
}
.btn-generate {
  background: var(--pink-dim);
  color: var(--pink);
}
.btn-generate:hover {
  background: rgba(252, 114, 255, 0.2);
}
.btn-import {
  background: var(--accent);
  color: #fff;
}
.btn-import:hover {
  background: var(--accent-hover);
}

.btn-import:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.wallet-extension-install {
  margin-top: 12px;
  padding: 12px 14px;
  border-radius: var(--radius);
  border: 1px dashed var(--border);
  background: var(--bg-secondary);
}

.wallet-extension-hint {
  color: var(--text-muted);
  font-size: 12px;
  line-height: 1.4;
  margin: 8px 0 0 0;
  word-break: break-word;
}

.extension-connect-section {
  margin-top: 12px;
}

.extension-status {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 12px;
  border-radius: var(--radius);
  background: var(--bg-input);
  margin-bottom: 10px;
}

.extension-status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.extension-status-dot.connected {
  background: var(--success);
  box-shadow: 0 0 6px rgba(64, 182, 107, 0.5);
}

.extension-status-dot.disconnected {
  background: var(--text-muted);
}

.extension-status-text {
  font-size: 12px;
  color: var(--text-secondary);
}

.btn-extension-connect {
  background: linear-gradient(135deg, var(--accent) 0%, var(--pink) 100%) !important;
  border: none !important;
  font-weight: 600;
}

.btn-extension-connect:hover:not(:disabled) {
  opacity: 0.9;
  transform: translateY(-1px);
}

.wallet-connected-header {
  margin-bottom: 4px;
}

.wallet-network-badge {
  display: inline-block;
  margin-left: 8px;
  padding: 2px 8px;
  border-radius: 10px;
  font-size: 10px;
  font-weight: 600;
  background: rgba(64, 182, 107, 0.15);
  color: var(--success);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.wallet-modal-actions {
  margin-top: 12px;
  display: flex;
  gap: 8px;
}

/* Success/Status Toast */
.toast {
  position: fixed;
  bottom: 24px;
  right: 24px;
  padding: 14px 20px;
  border-radius: var(--radius);
  font-size: 14px;
  font-weight: 500;
  box-shadow: var(--shadow);
  animation: fadeIn 0.3s ease;
  z-index: 200;
  max-width: 400px;
}
.toast.success {
  background: #1a3a2a;
  color: var(--success);
  border: 1px solid rgba(64, 182, 107, 0.3);
}
.toast.error {
  background: #3a1a1a;
  color: var(--error);
  border: 1px solid rgba(253, 118, 107, 0.3);
}
.toast.info {
  background: var(--bg-secondary);
  color: var(--accent);
  border: 1px solid rgba(76, 130, 251, 0.3);
}

/* Wallet Info Bar */
.wallet-info-bar {
  display: flex;
  align-items: center;
  gap: 8px;
}
.wallet-address {
  font-size: 14px;
  font-weight: 500;
  font-family: monospace;
}
.wallet-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--success);
}

/* Header Right */
.header-right {
  display: flex;
  align-items: center;
  gap: 12px;
}
.mainnet-indicator {
  font-size: 11px;
  font-weight: 600;
  color: var(--success);
  background: rgba(64, 182, 107, 0.15);
  padding: 4px 10px;
  border-radius: 12px;
  border: 1px solid rgba(64, 182, 107, 0.3);
}
.swap-header-right {
  display: flex;
  align-items: center;
  gap: 8px;
}
.network-tag {
  font-size: 11px;
  font-weight: 600;
  color: var(--success);
  background: rgba(64, 182, 107, 0.1);
  padding: 3px 8px;
  border-radius: 8px;
}
.mainnet-badge {
  font-size: 12px;
  font-weight: 700;
  color: var(--success);
  background: rgba(64, 182, 107, 0.15);
  padding: 2px 8px;
  border-radius: 6px;
  margin-left: 4px;
}

/* Tokens Grid */
.tokens-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 16px;
  width: 100%;
  max-width: 720px;
}
.token-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 20px;
  box-shadow: var(--shadow);
  animation: fadeIn 0.3s ease;
}
.token-card-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
}
.token-icon-lg {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 700;
  color: #fff;
}
.token-card-name {
  font-size: 18px;
  font-weight: 700;
}
.token-card-fullname {
  font-size: 12px;
  color: var(--text-secondary);
}
.token-card-details {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.token-detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 0;
  border-top: 1px solid var(--border);
}
.token-detail-label {
  font-size: 13px;
  color: var(--text-secondary);
}
.token-detail-value {
  font-size: 13px;
  color: var(--text-primary);
  font-weight: 500;
}
.token-detail-value.mono {
  font-family: monospace;
  font-size: 12px;
}
.token-detail-value.link {
  color: var(--accent);
  text-decoration: none;
}
.token-detail-value.link:hover {
  text-decoration: underline;
}
.tag-freeze {
  color: var(--pink) !important;
}
.tag-no-freeze {
  color: var(--text-secondary) !important;
}

/* History */
.history-card {
  width: 100%;
  max-width: 600px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
  animation: fadeIn 0.3s ease;
}
.history-list {
  padding: 8px 0;
}
.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 20px;
  border-bottom: 1px solid var(--border);
  transition: background 0.15s;
}
.history-item:last-child {
  border-bottom: none;
}
.history-item:hover {
  background: var(--accent-dim);
}
.history-item-left {
  display: flex;
  align-items: center;
  gap: 12px;
}
.history-label {
  font-size: 14px;
  font-weight: 600;
}
.history-txid {
  font-size: 12px;
  font-family: monospace;
  color: var(--accent);
  text-decoration: none;
}
.history-txid:hover {
  text-decoration: underline;
}
.history-status {
  font-size: 12px;
  font-weight: 600;
  padding: 3px 10px;
  border-radius: 8px;
}
.history-status.success {
  color: var(--success);
  background: rgba(64, 182, 107, 0.15);
}
.history-status.failed {
  color: var(--error);
  background: rgba(253, 118, 107, 0.15);
}

/* Wallet Balance Display */
.wallet-balance-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  margin-top: 12px;
  background: var(--bg-input);
  border-radius: var(--radius);
  border: 1px solid var(--border);
}
.wallet-balance-label {
  font-size: 13px;
  color: var(--text-secondary);
}
.wallet-balance-value {
  font-size: 15px;
  font-weight: 600;
  font-family: monospace;
  color: var(--success);
}
.wallet-address-full {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 16px;
  margin-top: 8px;
  background: var(--bg-input);
  border-radius: var(--radius);
  border: 1px solid var(--border);
}
.wallet-address-label {
  font-size: 13px;
  color: var(--text-secondary);
}
.wallet-address-link {
  font-size: 12px;
  font-family: monospace;
  color: var(--accent);
  text-decoration: none;
}
.wallet-address-link:hover {
  text-decoration: underline;
}

/* Pool UI */
.pool-card {
  width: 100%;
  max-width: 560px;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border);
  padding: 20px;
  box-shadow: var(--shadow);
  animation: fadeIn 0.3s ease;
}
.pool-tab-bar {
  display: flex;
  gap: 4px;
  margin-bottom: 20px;
  background: var(--bg-secondary);
  border-radius: var(--radius);
  padding: 4px;
}
.pool-tab {
  flex: 1;
  padding: 10px 12px;
  border-radius: calc(var(--radius) - 2px);
  font-size: 13px;
  font-weight: 600;
  color: var(--text-secondary);
  background: none;
  border: none;
  cursor: pointer;
  transition: all 0.15s;
}
.pool-tab:hover { color: var(--text-primary); }
.pool-tab.active {
  color: var(--text-primary);
  background: var(--bg-tertiary);
}
.pool-empty {
  text-align: center;
  padding: 32px 16px;
  color: var(--text-secondary);
}
.pool-empty p { margin-bottom: 16px; }
.pool-section-title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 16px;
  color: var(--text-primary);
}
.pool-stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 16px;
}
.pool-stat {
  background: var(--bg-input);
  border-radius: var(--radius);
  padding: 14px;
  border: 1px solid var(--border);
}
.pool-stat-label {
  font-size: 12px;
  color: var(--text-secondary);
  margin-bottom: 4px;
}
.pool-stat-value {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-primary);
  font-family: monospace;
}
.pool-lp-section {
  margin-top: 20px;
  padding-top: 20px;
  border-top: 1px solid var(--border);
}
.pool-form {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.pool-input-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.pool-input-group label {
  font-size: 13px;
  font-weight: 500;
  color: var(--text-secondary);
}
.pool-input-group input {
  padding: 14px 16px;
  border-radius: var(--radius);
  background: var(--bg-input);
  border: 1px solid var(--border);
  color: var(--text-primary);
  font-size: 18px;
  font-weight: 500;
  font-family: monospace;
  outline: none;
  transition: border-color 0.2s;
}
.pool-input-group input:focus {
  border-color: var(--accent);
}
.pool-input-group input::placeholder {
  color: var(--text-muted);
}
.pool-fee-display {
  padding: 14px 16px;
  border-radius: var(--radius);
  background: var(--bg-input);
  border: 1px solid var(--border);
  color: var(--success);
  font-size: 14px;
  font-weight: 600;
}
.pool-actions {
  display: flex;
  gap: 8px;
  margin-top: 8px;
}
.pool-actions .swap-btn {
  flex: 1;
}
.pool-quote {
  background: var(--bg-input);
  border-radius: var(--radius);
  padding: 12px;
  border: 1px solid var(--border);
}
.pool-quote-row {
  display: flex;
  justify-content: space-between;
  padding: 6px 0;
  font-size: 13px;
  color: var(--text-secondary);
}
.pool-quote-value {
  color: var(--text-primary);
  font-weight: 600;
  font-family: monospace;
}
.pool-warning {
  color: var(--error) !important;
  font-weight: 600;
}
.pool-error {
  background: rgba(253, 118, 107, 0.1);
  border: 1px solid rgba(253, 118, 107, 0.3);
  border-radius: var(--radius);
  padding: 12px;
  margin-bottom: 12px;
  color: var(--error);
  font-size: 13px;
}
.pool-swap-direction {
  display: flex;
  gap: 4px;
  margin-bottom: 16px;
  background: var(--bg-secondary);
  border-radius: var(--radius);
  padding: 4px;
}
.pool-dir-btn {
  flex: 1;
  padding: 10px;
  border-radius: calc(var(--radius) - 2px);
  font-size: 13px;
  font-weight: 600;
  color: var(--text-secondary);
  background: none;
  border: none;
  cursor: pointer;
  transition: all 0.15s;
}
.pool-dir-btn:hover { color: var(--text-primary); }
.pool-dir-btn.active {
  color: var(--text-primary);
  background: var(--bg-tertiary);
}
.pool-desc {
  font-size: 13px;
  color: var(--text-secondary);
  margin-bottom: 16px;
  line-height: 1.5;
}
.pool-lp-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  background: var(--bg-input);
  border-radius: var(--radius);
  border: 1px solid var(--border);
  font-size: 14px;
  color: var(--text-primary);
}
.pool-max-btn {
  padding: 4px 12px;
  border-radius: 6px;
  background: var(--accent-dim);
  color: var(--accent);
  border: none;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.15s;
}
.pool-max-btn:hover {
  background: rgba(76, 130, 251, 0.2);
}
.pool-list-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 16px;
}
.pool-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  flex: 1;
}
.pool-selector-btn {
  display: flex;
  flex-direction: column;
  gap: 2px;
  padding: 10px 16px;
  border-radius: var(--radius);
  font-size: 14px;
  font-weight: 600;
  color: var(--text-secondary);
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  cursor: pointer;
  transition: all 0.15s;
  text-align: left;
}
.pool-selector-btn:hover {
  border-color: var(--accent);
}
.pool-selector-btn.active {
  color: var(--accent);
  background: var(--accent-dim);
  border-color: var(--accent);
}
.pool-selector-pair {
  font-size: 14px;
  font-weight: 700;
}
.pool-selector-tvl {
  font-size: 11px;
  font-weight: 400;
  opacity: 0.7;
}
.pool-list-actions {
  display: flex;
  gap: 8px;
  align-items: center;
  flex-shrink: 0;
}
.pool-refresh-btn {
  padding: 8px 12px;
  border-radius: var(--radius);
  font-size: 12px;
  font-weight: 600;
  color: var(--text-secondary);
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
}
.pool-refresh-btn:hover { border-color: var(--accent); color: var(--accent); }
.pool-new-btn {
  padding: 8px 14px !important;
  font-size: 13px !important;
  white-space: nowrap;
}
.pool-create-pair {
  display: flex;
  gap: 12px;
  align-items: center;
}
.pool-create-token {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.pool-create-separator {
  font-size: 24px;
  font-weight: 700;
  color: var(--text-muted);
  padding-top: 18px;
}
.slippage-control {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  margin-top: 4px;
  padding: 10px 12px;
  background: var(--bg-input);
  border-radius: var(--radius);
  border: 1px solid var(--border);
}
.slippage-label {
  font-size: 12px;
  color: var(--text-secondary);
  white-space: nowrap;
}
.slippage-options {
  display: flex;
  gap: 4px;
  align-items: center;
}
.slippage-btn {
  padding: 4px 10px;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 600;
  color: var(--text-secondary);
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  cursor: pointer;
  transition: all 0.15s;
}
.slippage-btn:hover { border-color: var(--accent); }
.slippage-btn.active {
  color: var(--accent);
  background: var(--accent-dim);
  border-color: var(--accent);
}
.slippage-custom {
  width: 56px;
  padding: 4px 8px;
  border-radius: 6px;
  font-size: 12px;
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  color: var(--text-primary);
  outline: none;
  text-align: center;
}
.slippage-custom:focus { border-color: var(--accent); }
.lp-earnings-card {
  background: var(--bg-input);
  border-radius: var(--radius);
  padding: 14px;
  border: 1px solid var(--border);
  margin-top: 12px;
}
.lp-earnings-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8px;
}
.lp-earnings-row {
  display: flex;
  justify-content: space-between;
  padding: 4px 0;
  font-size: 12px;
  color: var(--text-secondary);
}
.lp-earnings-value {
  color: var(--success);
  font-weight: 600;
  font-family: monospace;
}
.lp-earnings-value.neutral {
  color: var(--text-primary);
}
.pool-tx-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.pool-tx-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 12px;
  background: var(--bg-input);
  border-radius: var(--radius);
  border: 1px solid var(--border);
  font-size: 12px;
}
.pool-tx-type {
  padding: 3px 8px;
  border-radius: 4px;
  background: var(--accent-dim);
  color: var(--accent);
  font-weight: 700;
  font-size: 11px;
  text-transform: uppercase;
  white-space: nowrap;
}
.pool-tx-detail {
  flex: 1;
  color: var(--text-primary);
  font-family: monospace;
  font-size: 12px;
}
.pool-tx-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 2px;
}
.pool-tx-addr {
  color: var(--text-muted);
  font-family: monospace;
  font-size: 11px;
}
.pool-tx-time {
  color: var(--text-muted);
  font-size: 10px;
}

/* Skeleton loading */
.pool-skeleton {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.skeleton-row {
  height: 16px;
  background: linear-gradient(90deg, var(--bg-secondary), var(--bg-tertiary), var(--bg-secondary));
  background-size: 200% 100%;
  border-radius: 6px;
  animation: shimmer 1.2s infinite;
}
.skeleton-row.short { width: 60%; }
@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* Confirm banner */
.pool-confirm-banner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  padding: 10px 12px;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  margin-bottom: 10px;
}
.pool-confirm-actions { display: flex; gap: 8px; }
.pool-confirm-yes {
  padding: 8px 12px;
  border-radius: 8px;
  background: var(--accent);
  color: white;
  border: none;
  font-weight: 700;
  cursor: pointer;
}
.pool-confirm-no {
  padding: 8px 12px;
  border-radius: 8px;
  background: var(--bg-secondary);
  color: var(--text-secondary);
  border: 1px solid var(--border);
  cursor: pointer;
}

/* Dismissible error */
.pool-error {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}
.pool-error-dismiss {
  background: none;
  border: none;
  color: var(--text-secondary);
  font-size: 18px;
  cursor: pointer;
}

/* Mobile bottom navigation */
.mobile-bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 56px;
  background: var(--bg-secondary);
  border-top: 1px solid var(--border);
  display: none;
  align-items: center;
  justify-content: space-around;
  z-index: 20;
}
.mobile-nav-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  font-size: 11px;
  color: var(--text-secondary);
  background: none;
  border: none;
  cursor: pointer;
}
.mobile-nav-btn.active { color: var(--text-primary); }
.mobile-nav-icon { font-size: 16px; line-height: 14px; }
.mobile-nav-label { font-size: 10px; }

/* Responsive */
@media (max-width: 520px) {
  .header {
    padding: 12px 16px;
  }
  .nav-links {
    display: none;
  }
  .main {
    padding: 24px 12px 80px; /* leave space for bottom nav */
  }
  .main-title {
    font-size: 36px;
  }
  .swap-card, .pool-card {
    max-width: 100%;
  }
  .modal {
    width: calc(100vw - 24px);
  }
  .pool-list-header {
    flex-direction: column;
  }
  .pool-create-pair {
    flex-direction: column;
  }
  .pool-create-separator {
    padding-top: 0;
  }
  .pool-tx-row {
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
  }
  .pool-tx-meta {
    flex-direction: row;
    gap: 8px;
  }
  .mobile-bottom-nav { display: flex; }
}

/* Settlement status badges */
.pool-tx-settlement {
  display: inline-block;
  font-size: 0.65rem;
  font-weight: 600;
  padding: 1px 6px;
  border-radius: 4px;
  margin-left: 6px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.pool-tx-settlement.pending {
  background: rgba(245, 158, 11, 0.15);
  color: #f59e0b;
}
.pool-tx-settlement.confirmed {
  background: rgba(34, 197, 94, 0.15);
  color: #22c55e;
}
.pool-tx-settlement.failed {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}
.pool-tx-settlement.broadcast {
  background: rgba(59, 130, 246, 0.15);
  color: #3b82f6;
}
.pool-tx-onchain {
  margin-top: 2px;
}
.pool-tx-woc-link {
  font-size: 0.7rem;
  font-family: 'SF Mono', 'Fira Code', monospace;
  color: #818cf8;
  text-decoration: none;
  opacity: 0.85;
}
.pool-tx-woc-link:hover {
  opacity: 1;
  text-decoration: underline;
}

/* Price Chart */
.price-chart-container {
  background: rgba(17, 24, 39, 0.5);
  border-radius: 8px;
  padding: 0.5rem;
  margin-top: 0.5rem;
}
.price-chart-container canvas {
  display: block;
  border-radius: 6px;
}
.chart-legend {
  display: flex;
  gap: 1rem;
  justify-content: center;
  padding: 0.5rem 0 0;
  font-size: 0.75rem;
  color: #9ca3af;
}
.chart-legend-item {
  display: flex;
  align-items: center;
  gap: 4px;
}
.chart-dot {
  display: inline-block;
  width: 8px;
  height: 8px;
  border-radius: 50%;
}
.chart-dot.swap { background: #f59e0b; }
.chart-dot.add { background: #22c55e; }
.chart-dot.remove { background: #ef4444; }
.chart-metric-tabs {
  display: flex;
  gap: 2px;
  background: rgba(31, 41, 55, 0.8);
  border-radius: 6px;
  padding: 2px;
}
.chart-metric-tab {
  padding: 2px 10px;
  font-size: 0.7rem;
  font-weight: 600;
  border: none;
  border-radius: 4px;
  background: transparent;
  color: #9ca3af;
  cursor: pointer;
  transition: all 0.15s;
}
.chart-metric-tab.active {
  background: rgba(99, 102, 241, 0.2);
  color: #818cf8;
}
.chart-metric-tab:hover:not(.active) {
  color: #e5e7eb;
}

/* Analytics Dashboard */
.analytics-wrap {
  max-width: 800px;
  margin: 0 auto;
}
.analytics-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}
.analytics-card {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1rem;
  text-align: center;
}
.analytics-card-label {
  font-size: 0.7rem;
  color: #9ca3af;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 0.25rem;
}
.analytics-card-value {
  font-size: 1.3rem;
  font-weight: 700;
  color: #e5e7eb;
}
.analytics-table-wrap {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1rem;
  overflow-x: auto;
}
.analytics-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.8rem;
}
.analytics-table th {
  text-align: left;
  color: #9ca3af;
  font-weight: 600;
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  padding: 0.5rem 0.75rem;
  border-bottom: 1px solid var(--border);
}
.analytics-table td {
  padding: 0.6rem 0.75rem;
  color: #e5e7eb;
  border-bottom: 1px solid rgba(55, 65, 81, 0.3);
}
.analytics-table tr:last-child td {
  border-bottom: none;
}
.analytics-pair {
  font-weight: 600;
  color: #818cf8;
}
.analytics-up {
  color: #22c55e;
  font-weight: 600;
}
.analytics-down {
  color: #ef4444;
  font-weight: 600;
}

/* Governance */
.gov-pool-selector {
  max-width: 480px;
  margin: 0 auto 1.5rem;
}
.gov-select {
  width: 100%;
  padding: 0.75rem 1rem;
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 12px;
  color: #e5e7eb;
  font-size: 0.9rem;
  margin-top: 0.5rem;
}
.gov-label {
  font-size: 0.75rem;
  color: #9ca3af;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.gov-wrap {
  max-width: 600px;
  margin: 0 auto;
}
.gov-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1rem;
}
.gov-create-btn {
  background: var(--accent);
  color: #fff;
  border: none;
  border-radius: 8px;
  padding: 0.5rem 1rem;
  font-size: 0.8rem;
  font-weight: 600;
  cursor: pointer;
}
.gov-create-btn:hover {
  opacity: 0.85;
}
.gov-form {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.25rem;
  margin-bottom: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.gov-input {
  width: 100%;
  padding: 0.65rem 0.75rem;
  background: rgba(17, 24, 39, 0.6);
  border: 1px solid var(--border);
  border-radius: 8px;
  color: #e5e7eb;
  font-size: 0.85rem;
  box-sizing: border-box;
}
.gov-textarea {
  width: 100%;
  min-height: 60px;
  padding: 0.65rem 0.75rem;
  background: rgba(17, 24, 39, 0.6);
  border: 1px solid var(--border);
  border-radius: 8px;
  color: #e5e7eb;
  font-size: 0.85rem;
  resize: vertical;
  box-sizing: border-box;
}
.gov-param-row {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}
.gov-param-input {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.gov-unit {
  color: #9ca3af;
  font-size: 0.85rem;
}
.gov-empty {
  text-align: center;
  color: #6b7280;
  padding: 2rem;
  font-size: 0.9rem;
}
.gov-list {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.gov-card {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.25rem;
}
.gov-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 0.5rem;
}
.gov-card-title {
  font-weight: 700;
  font-size: 1rem;
  color: #e5e7eb;
}
.gov-status {
  font-size: 0.7rem;
  font-weight: 600;
  padding: 0.2rem 0.6rem;
  border-radius: 999px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.gov-status-active {
  background: rgba(99, 102, 241, 0.15);
  color: #818cf8;
}
.gov-status-executed {
  background: rgba(34, 197, 94, 0.15);
  color: #22c55e;
}
.gov-status-rejected {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}
.gov-status-expired {
  background: rgba(107, 114, 128, 0.15);
  color: #6b7280;
}
.gov-card-desc {
  color: #9ca3af;
  font-size: 0.8rem;
  margin: 0 0 0.75rem;
  line-height: 1.4;
}
.gov-card-param {
  display: flex;
  justify-content: space-between;
  color: #9ca3af;
  font-size: 0.8rem;
  margin-bottom: 0.75rem;
}
.gov-card-date {
  font-size: 0.75rem;
}
.gov-votes {
  margin-bottom: 0.75rem;
}
.gov-votes-bar {
  height: 6px;
  background: rgba(239, 68, 68, 0.3);
  border-radius: 3px;
  overflow: hidden;
  margin-bottom: 0.35rem;
}
.gov-votes-for {
  height: 100%;
  background: #22c55e;
  border-radius: 3px;
  transition: width 0.3s;
}
.gov-votes-labels {
  display: flex;
  justify-content: space-between;
  font-size: 0.75rem;
}
.gov-vote-for {
  color: #22c55e;
}
.gov-vote-against {
  color: #ef4444;
}
.gov-actions {
  display: flex;
  gap: 0.5rem;
}
.gov-vote-btn {
  flex: 1;
  padding: 0.5rem;
  border: none;
  border-radius: 8px;
  font-size: 0.8rem;
  font-weight: 600;
  cursor: pointer;
}
.gov-vote-for-btn {
  background: rgba(34, 197, 94, 0.15);
  color: #22c55e;
}
.gov-vote-for-btn:hover {
  background: rgba(34, 197, 94, 0.25);
}
.gov-vote-against-btn {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}
.gov-vote-against-btn:hover {
  background: rgba(239, 68, 68, 0.25);
}
.gov-execute-btn {
  padding: 0.5rem 1rem;
  background: rgba(99, 102, 241, 0.15);
  color: #818cf8;
  border: none;
  border-radius: 8px;
  font-size: 0.8rem;
  font-weight: 600;
  cursor: pointer;
}
.gov-execute-btn:hover {
  background: rgba(99, 102, 241, 0.25);
}
.gov-result {
  font-size: 0.8rem;
  font-weight: 600;
  padding: 0.5rem;
  text-align: center;
  border-radius: 8px;
  background: rgba(55, 65, 81, 0.3);
  color: #9ca3af;
}

/* Multi-hop Route Display */
.route-hops {
  margin-top: 0.5rem;
  padding: 0.5rem;
  background: rgba(17, 24, 39, 0.4);
  border-radius: 8px;
  border: 1px solid rgba(99, 102, 241, 0.2);
}
.route-hop-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.3rem 0;
  font-size: 0.75rem;
  color: #d1d5db;
}
.route-hop-num {
  background: rgba(99, 102, 241, 0.2);
  color: #818cf8;
  padding: 0.1rem 0.4rem;
  border-radius: 4px;
  font-weight: 600;
  font-size: 0.65rem;
}
.route-hop-pair {
  color: #818cf8;
  font-weight: 600;
}
.route-hop-amount {
  margin-left: auto;
  color: #9ca3af;
  font-size: 0.7rem;
}
.route-hop-summary {
  display: flex;
  justify-content: space-between;
  padding-top: 0.4rem;
  margin-top: 0.3rem;
  border-top: 1px solid rgba(55, 65, 81, 0.5);
  font-size: 0.7rem;
  color: #9ca3af;
}

/* Limit Orders */
.limit-orders-wrap {
  max-width: 560px;
  margin: 0 auto;
}
.lo-pool-select {
  margin-bottom: 1rem;
}
.lo-label {
  display: block;
  font-size: 0.8rem;
  color: #9ca3af;
  margin-bottom: 0.3rem;
}
.lo-select {
  width: 100%;
  padding: 0.6rem 0.8rem;
  background: rgba(17, 24, 39, 0.6);
  border: 1px solid rgba(55, 65, 81, 0.6);
  border-radius: 8px;
  color: #e5e7eb;
  font-size: 0.9rem;
}
.lo-input {
  width: 100%;
  padding: 0.6rem 0.8rem;
  background: rgba(17, 24, 39, 0.6);
  border: 1px solid rgba(55, 65, 81, 0.6);
  border-radius: 8px;
  color: #e5e7eb;
  font-size: 0.9rem;
  box-sizing: border-box;
}
.lo-current-price {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.8rem 1rem;
  background: rgba(99, 102, 241, 0.08);
  border: 1px solid rgba(99, 102, 241, 0.2);
  border-radius: 10px;
  margin-bottom: 1rem;
}
.lo-price-label {
  color: #9ca3af;
  font-size: 0.8rem;
}
.lo-price-value {
  color: #818cf8;
  font-weight: 600;
  font-size: 1rem;
}
.lo-create-form {
  background: rgba(17, 24, 39, 0.5);
  border: 1px solid rgba(55, 65, 81, 0.5);
  border-radius: 12px;
  padding: 1.2rem;
  margin-bottom: 1.5rem;
}
.lo-section-title {
  color: #e5e7eb;
  font-size: 0.95rem;
  font-weight: 600;
  margin: 0 0 0.8rem;
}
.lo-form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.8rem;
  margin-bottom: 0.8rem;
}
.lo-form-group {
  display: flex;
  flex-direction: column;
}
.lo-orders-section {
  background: rgba(17, 24, 39, 0.5);
  border: 1px solid rgba(55, 65, 81, 0.5);
  border-radius: 12px;
  padding: 1.2rem;
}
.lo-orders-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 0.8rem;
}
.lo-orders-header .lo-section-title {
  margin: 0;
}
.lo-check-btn {
  padding: 0.4rem 0.8rem;
  background: rgba(99, 102, 241, 0.15);
  border: 1px solid rgba(99, 102, 241, 0.3);
  border-radius: 6px;
  color: #818cf8;
  font-size: 0.75rem;
  cursor: pointer;
  transition: background 0.2s;
}
.lo-check-btn:hover {
  background: rgba(99, 102, 241, 0.25);
}
.lo-empty {
  text-align: center;
  color: #6b7280;
  padding: 2rem;
  font-size: 0.85rem;
}
.lo-orders-list {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}
.lo-order-card {
  background: rgba(17, 24, 39, 0.4);
  border: 1px solid rgba(55, 65, 81, 0.4);
  border-radius: 10px;
  padding: 0.8rem 1rem;
}
.lo-order-card.lo-status-filled {
  border-color: rgba(34, 197, 94, 0.3);
}
.lo-order-card.lo-status-cancelled {
  border-color: rgba(239, 68, 68, 0.2);
  opacity: 0.7;
}
.lo-order-card.lo-status-expired {
  border-color: rgba(234, 179, 8, 0.2);
  opacity: 0.7;
}
.lo-order-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 0.5rem;
}
.lo-order-pair {
  color: #e5e7eb;
  font-weight: 600;
  font-size: 0.9rem;
}
.lo-order-status {
  padding: 0.15rem 0.5rem;
  border-radius: 4px;
  font-size: 0.7rem;
  font-weight: 600;
  text-transform: uppercase;
}
.lo-order-status.open {
  background: rgba(99, 102, 241, 0.15);
  color: #818cf8;
}
.lo-order-status.filled {
  background: rgba(34, 197, 94, 0.15);
  color: #22c55e;
}
.lo-order-status.cancelled {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}
.lo-order-status.expired {
  background: rgba(234, 179, 8, 0.15);
  color: #eab308;
}
.lo-order-details {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}
.lo-order-detail {
  display: flex;
  justify-content: space-between;
  font-size: 0.75rem;
  color: #9ca3af;
}
.lo-order-detail span:last-child {
  color: #d1d5db;
}
.lo-cancel-btn {
  margin-top: 0.5rem;
  width: 100%;
  padding: 0.4rem;
  background: rgba(239, 68, 68, 0.1);
  border: 1px solid rgba(239, 68, 68, 0.3);
  border-radius: 6px;
  color: #ef4444;
  font-size: 0.8rem;
  cursor: pointer;
  transition: background 0.2s;
}
.lo-cancel-btn:hover {
  background: rgba(239, 68, 68, 0.2);
}

/* LP Rewards */
.rewards-wrap {
  max-width: 560px;
  margin: 0 auto;
}
.rw-summary-card {
  background: rgba(17, 24, 39, 0.5);
  border: 1px solid rgba(55, 65, 81, 0.5);
  border-radius: 12px;
  padding: 1rem 1.2rem;
  margin-bottom: 1rem;
}
.rw-summary-row {
  display: flex;
  justify-content: space-between;
  padding: 0.4rem 0;
  border-bottom: 1px solid rgba(55, 65, 81, 0.3);
}
.rw-summary-row:last-child {
  border-bottom: none;
}
.rw-summary-label {
  color: #9ca3af;
  font-size: 0.85rem;
}
.rw-summary-value {
  color: #e5e7eb;
  font-weight: 600;
  font-size: 0.85rem;
}
.rw-apy {
  color: #22c55e;
  font-size: 1.1rem;
}
.rw-my-rewards {
  margin-bottom: 1rem;
}
.rw-my-card {
  background: rgba(17, 24, 39, 0.5);
  border: 1px solid rgba(99, 102, 241, 0.25);
  border-radius: 12px;
  padding: 0.8rem 1rem;
}
.rw-my-row {
  display: flex;
  justify-content: space-between;
  padding: 0.3rem 0;
  font-size: 0.8rem;
  color: #9ca3af;
}
.rw-my-row span:last-child {
  color: #d1d5db;
}
.rw-my-row.rw-highlight span:last-child {
  color: #22c55e;
  font-weight: 600;
}
.rw-my-row.rw-total {
  border-top: 1px solid rgba(55, 65, 81, 0.5);
  margin-top: 0.3rem;
  padding-top: 0.5rem;
  font-weight: 600;
}
.rw-my-row.rw-total span:last-child {
  color: #818cf8;
}
.rw-providers {
  margin-bottom: 1rem;
}
.rw-providers-list {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.rw-provider-card {
  background: rgba(17, 24, 39, 0.4);
  border: 1px solid rgba(55, 65, 81, 0.4);
  border-radius: 8px;
  padding: 0.6rem 0.8rem;
}
.rw-provider-addr {
  color: #818cf8;
  font-size: 0.8rem;
  font-weight: 600;
  margin-bottom: 0.3rem;
}
.rw-provider-details {
  display: flex;
  flex-wrap: wrap;
  gap: 0.6rem;
  font-size: 0.7rem;
  color: #9ca3af;
}
.rw-provider-reward {
  color: #22c55e;
  font-weight: 600;
}

/* Yield Farming */
.fm-actions {
  margin-top: 0.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.fm-action-row {
  display: flex;
  gap: 0.5rem;
  align-items: center;
}
.fm-input {
  flex: 1;
  background: rgba(17, 24, 39, 0.6);
  border: 1px solid rgba(55, 65, 81, 0.5);
  border-radius: 8px;
  padding: 0.5rem 0.75rem;
  color: #e5e7eb;
  font-size: 0.85rem;
  outline: none;
}
.fm-input:focus {
  border-color: rgba(99, 102, 241, 0.5);
}
.fm-btn {
  padding: 0.5rem 1rem;
  border-radius: 8px;
  font-size: 0.8rem;
  font-weight: 600;
  border: none;
  cursor: pointer;
  white-space: nowrap;
  transition: opacity 0.15s;
}
.fm-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}
.fm-stake {
  background: rgba(99, 102, 241, 0.2);
  color: #818cf8;
  border: 1px solid rgba(99, 102, 241, 0.3);
}
.fm-stake:hover:not(:disabled) {
  background: rgba(99, 102, 241, 0.3);
}
.fm-unstake {
  background: rgba(239, 68, 68, 0.15);
  color: #f87171;
  border: 1px solid rgba(239, 68, 68, 0.25);
}
.fm-unstake:hover:not(:disabled) {
  background: rgba(239, 68, 68, 0.25);
}
.fm-harvest {
  background: rgba(34, 197, 94, 0.15);
  color: #22c55e;
  border: 1px solid rgba(34, 197, 94, 0.25);
  width: 100%;
}
.fm-harvest:hover:not(:disabled) {
  background: rgba(34, 197, 94, 0.25);
}

/* PWA Install Banner */
.pwa-install-banner {
  position: fixed;
  bottom: 80px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(17, 24, 39, 0.95);
  border: 1px solid rgba(99, 102, 241, 0.4);
  border-radius: 12px;
  padding: 0.75rem 1rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  z-index: 1000;
  backdrop-filter: blur(12px);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  max-width: 400px;
  width: calc(100% - 2rem);
  font-size: 0.85rem;
  color: #e5e7eb;
}
.pwa-install-actions {
  display: flex;
  gap: 0.5rem;
  flex-shrink: 0;
}
.pwa-install-btn {
  background: #6366f1;
  color: white;
  border: none;
  border-radius: 8px;
  padding: 0.4rem 0.8rem;
  font-size: 0.8rem;
  font-weight: 600;
  cursor: pointer;
}
.pwa-install-btn:hover {
  background: #818cf8;
}
.pwa-dismiss-btn {
  background: transparent;
  color: #9ca3af;
  border: 1px solid rgba(55, 65, 81, 0.5);
  border-radius: 8px;
  padding: 0.4rem 0.6rem;
  font-size: 0.8rem;
  cursor: pointer;
}
.pwa-dismiss-btn:hover {
  color: #e5e7eb;
}

/* PWA standalone mode adjustments */
@media (display-mode: standalone) {
  .header {
    padding-top: env(safe-area-inset-top, 0);
  }
  .mobile-bottom-nav {
    padding-bottom: env(safe-area-inset-bottom, 0);
  }
}

/* Mobile touch improvements */
@media (max-width: 768px) {
  .nav-links {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .nav-links::-webkit-scrollbar {
    display: none;
  }
  button, input, select, textarea {
    -webkit-tap-highlight-color: transparent;
  }
}

/* Real-time indicator */
.realtime-indicator {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  padding: 4px 10px;
  border-radius: 12px;
  border: 1px solid;
}
.realtime-indicator.connected {
  color: #22c55e;
  border-color: rgba(34, 197, 94, 0.3);
  background: rgba(34, 197, 94, 0.08);
}
.realtime-indicator.disconnected {
  color: #6b7280;
  border-color: rgba(107, 114, 128, 0.3);
  background: rgba(107, 114, 128, 0.08);
}
.realtime-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: currentColor;
}
.realtime-indicator.connected .realtime-dot {
  animation: pulse-dot 1.5s ease-in-out infinite;
}
@keyframes pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.3); }
}

/* Live Feed */
.live-feed-card {
  margin-top: 12px;
}
.live-feed-list {
  max-height: 200px;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.live-feed-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 8px;
  border-radius: 6px;
  background: rgba(99, 102, 241, 0.05);
  font-size: 0.8rem;
  animation: feed-in 0.3s ease-out;
}
@keyframes feed-in {
  from { opacity: 0; transform: translateY(-8px); }
  to { opacity: 1; transform: translateY(0); }
}
.live-feed-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: #6366f1;
  flex-shrink: 0;
}
.live-feed-text {
  flex: 1;
  color: #e5e7eb;
}
.live-feed-time {
  color: #6b7280;
  font-size: 0.7rem;
  flex-shrink: 0;
}

/* Price Alerts */
.price-alerts-card {
  margin-top: 12px;
}
.price-alert-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 8px 10px;
  border-radius: 6px;
  font-size: 0.8rem;
  margin-bottom: 4px;
}
.price-alert-item.up {
  background: rgba(34, 197, 94, 0.08);
  border-left: 3px solid #22c55e;
}
.price-alert-item.down {
  background: rgba(239, 68, 68, 0.08);
  border-left: 3px solid #ef4444;
}
.price-alert-pair {
  font-weight: 600;
  color: #e5e7eb;
  min-width: 90px;
}
.price-alert-change {
  font-weight: 700;
  min-width: 70px;
}
.price-alert-item.up .price-alert-change { color: #22c55e; }
.price-alert-item.down .price-alert-change { color: #ef4444; }
.price-alert-prices {
  color: #9ca3af;
  font-size: 0.75rem;
}

/* Network Selector */
.network-selector {
  position: relative;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 14px;
  border-radius: 12px;
  border: 1px solid rgba(99, 102, 241, 0.2);
  background: rgba(99, 102, 241, 0.06);
  cursor: pointer;
  font-size: 0.82rem;
  font-weight: 600;
  color: #e5e7eb;
  transition: border-color 0.2s, background 0.2s;
  user-select: none;
}
.network-selector:hover {
  border-color: rgba(99, 102, 241, 0.4);
  background: rgba(99, 102, 241, 0.1);
}
.network-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}
.network-dot.mainnet {
  background: #22c55e;
  box-shadow: 0 0 6px rgba(34, 197, 94, 0.5);
}
.network-dot.testnet {
  background: #f59e0b;
  box-shadow: 0 0 6px rgba(245, 158, 11, 0.5);
}
.network-name {
  white-space: nowrap;
}
.network-arrow {
  font-size: 0.6rem;
  color: #9ca3af;
}
.network-dropdown {
  position: absolute;
  top: calc(100% + 6px);
  right: 0;
  min-width: 200px;
  background: #1e1e2e;
  border: 1px solid rgba(99, 102, 241, 0.25);
  border-radius: 12px;
  padding: 6px;
  z-index: 100;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
}
.network-option {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  border-radius: 8px;
  cursor: pointer;
  font-size: 0.82rem;
  color: #e5e7eb;
  transition: background 0.15s;
}
.network-option:hover {
  background: rgba(99, 102, 241, 0.1);
}
.network-option.active {
  background: rgba(99, 102, 241, 0.15);
  border-left: 3px solid #6366f1;
}
.network-badge-test {
  margin-left: auto;
  font-size: 0.65rem;
  font-weight: 700;
  color: #f59e0b;
  background: rgba(245, 158, 11, 0.12);
  padding: 2px 8px;
  border-radius: 8px;
  letter-spacing: 0.04em;
}

/* Bridge */
.bridge-direction-tabs {
  display: flex;
  gap: 4px;
  background: rgba(99, 102, 241, 0.06);
  border-radius: 12px;
  padding: 4px;
  margin-bottom: 16px;
}
.bridge-dir-btn {
  flex: 1;
  padding: 10px;
  border: none;
  border-radius: 10px;
  background: transparent;
  color: #9ca3af;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
}
.bridge-dir-btn.active {
  background: rgba(99, 102, 241, 0.15);
  color: #e5e7eb;
  box-shadow: 0 2px 8px rgba(99, 102, 241, 0.15);
}
.bridge-token-select {
  width: 100%;
  padding: 12px 14px;
  background: rgba(99, 102, 241, 0.06);
  border: 1px solid rgba(99, 102, 241, 0.15);
  border-radius: 12px;
  color: #e5e7eb;
  font-size: 0.9rem;
  font-weight: 500;
  outline: none;
  cursor: pointer;
}
.bridge-token-select:focus {
  border-color: rgba(99, 102, 241, 0.4);
}
.bridge-fee-info {
  display: flex;
  justify-content: space-between;
  padding: 8px 0;
  font-size: 0.75rem;
  color: #6b7280;
  border-top: 1px solid rgba(99, 102, 241, 0.08);
  margin-top: 8px;
}

.bridge-card { max-width: 520px; margin: 0 auto; }
.bridge-stats-card, .bridge-history-card { max-width: 520px; margin: 16px auto; }
.bridge-token-row {
  display: flex;
  gap: 8px;
  margin-bottom: 16px;
}
.bridge-token-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 10px 16px;
  border: 1px solid rgba(99, 102, 241, 0.15);
  border-radius: 12px;
  background: rgba(99, 102, 241, 0.04);
  color: #9ca3af;
  font-size: 0.9rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
}
.bridge-token-btn.active {
  background: rgba(99, 102, 241, 0.12);
  border-color: rgba(99, 102, 241, 0.4);
  color: #e5e7eb;
}
.bridge-token-icon {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.7rem;
  font-weight: 700;
  color: white;
}
.bridge-deposit-box {
  background: rgba(34, 197, 94, 0.06);
  border: 1px solid rgba(34, 197, 94, 0.2);
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  text-align: center;
}
.bridge-deposit-label {
  font-size: 0.75rem;
  color: #6b7280;
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.bridge-deposit-addr {
  font-family: 'SF Mono', 'Fira Code', monospace;
  font-size: 0.8rem;
  color: #22c55e;
  word-break: break-all;
  padding: 8px;
  background: rgba(34, 197, 94, 0.08);
  border-radius: 8px;
  margin-bottom: 8px;
}
.bridge-copy-btn {
  padding: 6px 16px;
  border: 1px solid rgba(34, 197, 94, 0.3);
  border-radius: 8px;
  background: rgba(34, 197, 94, 0.1);
  color: #22c55e;
  font-size: 0.8rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  margin-bottom: 8px;
}
.bridge-copy-btn:hover { background: rgba(34, 197, 94, 0.2); }
.bridge-deposit-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: center;
  font-size: 0.7rem;
  color: #6b7280;
  margin-top: 4px;
}
.bridge-fee-info {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 10px 0;
  font-size: 0.78rem;
  color: #6b7280;
  border-top: 1px solid rgba(99, 102, 241, 0.08);
  margin-top: 8px;
}

/* Advanced Charts */
.chart-controls {
  display: flex;
  justify-content: center;
  gap: 16px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}
.chart-interval-btns, .chart-indicator-btns {
  display: flex;
  gap: 4px;
  background: rgba(99, 102, 241, 0.06);
  border-radius: 10px;
  padding: 3px;
}
.chart-interval-btn, .chart-indicator-btn {
  padding: 6px 12px;
  border: none;
  border-radius: 8px;
  background: transparent;
  color: #9ca3af;
  font-size: 0.78rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
}
.chart-interval-btn.active, .chart-indicator-btn.active {
  background: rgba(99, 102, 241, 0.18);
  color: #e5e7eb;
}
.chart-container {
  max-width: 850px;
  margin: 0 auto;
}
.chart-panel {
  background: rgba(99, 102, 241, 0.04);
  border: 1px solid rgba(99, 102, 241, 0.12);
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 12px;
}
.chart-panel-title {
  font-size: 0.85rem;
  font-weight: 600;
  color: #9ca3af;
  margin: 0 0 8px 0;
}
.chart-svg {
  width: 100%;
  height: auto;
}
.chart-svg.indicator {
  height: auto;
}
.chart-volume-bar {
  display: flex;
  align-items: flex-end;
  gap: 1px;
  height: 40px;
  margin-top: 4px;
}
.vol-bar {
  flex: 1;
  min-width: 2px;
  border-radius: 2px 2px 0 0;
}
.chart-loading {
  text-align: center;
  color: #6b7280;
  padding: 40px;
  font-size: 0.9rem;
}
.chart-empty-state {
  text-align: center;
  padding: 60px 20px;
  color: #6b7280;
}
.chart-empty-state p {
  margin-bottom: 16px;
}
.indicator-panel {
  background: rgba(99, 102, 241, 0.02);
}

/* Portfolio */
.portfolio-container { max-width: 850px; margin: 0 auto; }
.portfolio-summary-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-bottom: 20px; }
.portfolio-card { background: rgba(99, 102, 241, 0.06); border: 1px solid rgba(99, 102, 241, 0.12); border-radius: 14px; padding: 16px; }
.portfolio-card.total { border-color: rgba(99, 102, 241, 0.3); background: rgba(99, 102, 241, 0.1); }
.portfolio-card-label { font-size: 0.75rem; color: #9ca3af; margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
.portfolio-card-value { font-size: 1.1rem; font-weight: 700; color: #e5e7eb; }
.portfolio-card-value.positive { color: #22c55e; }
.portfolio-card-value.negative { color: #ef4444; }
.portfolio-section { margin-bottom: 20px; }
.portfolio-section-title { font-size: 0.9rem; font-weight: 600; color: #9ca3af; margin: 0 0 10px 0; }
.portfolio-table { background: rgba(99, 102, 241, 0.04); border: 1px solid rgba(99, 102, 241, 0.12); border-radius: 14px; overflow: hidden; }
.portfolio-table-header { display: grid; grid-template-columns: 1.2fr 1fr 1fr 1fr 0.8fr; padding: 10px 16px; font-size: 0.72rem; color: #6b7280; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid rgba(99, 102, 241, 0.08); }
.portfolio-table-row { display: grid; grid-template-columns: 1.2fr 1fr 1fr 1fr 0.8fr; padding: 12px 16px; font-size: 0.85rem; color: #d1d5db; border-bottom: 1px solid rgba(99, 102, 241, 0.05); }
.portfolio-table-row:last-child { border-bottom: none; }
.portfolio-symbol { font-weight: 600; color: #e5e7eb; }
.positive { color: #22c55e; }
.negative { color: #ef4444; }

/* Notifications */
.notif-container { max-width: 850px; margin: 0 auto; }
.notif-summary { display: flex; gap: 12px; align-items: center; margin-bottom: 16px; }
.notif-badge { background: rgba(239, 68, 68, 0.15); color: #ef4444; padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: 600; }
.notif-total { color: #6b7280; font-size: 0.85rem; }
.notif-section { margin-bottom: 20px; }
.notif-alert-form { display: flex; gap: 8px; margin-bottom: 12px; }
.notif-input { flex: 1; max-width: 200px; padding: 8px 12px; border: 1px solid rgba(99, 102, 241, 0.2); border-radius: 10px; background: rgba(99, 102, 241, 0.06); color: #e5e7eb; font-size: 0.85rem; }
.notif-btn { padding: 8px 16px; border: none; border-radius: 10px; background: rgba(99, 102, 241, 0.18); color: #818cf8; font-weight: 600; font-size: 0.82rem; cursor: pointer; }
.notif-btn-sm { padding: 4px 10px; border: none; border-radius: 6px; background: rgba(239, 68, 68, 0.12); color: #ef4444; font-size: 0.75rem; cursor: pointer; }
.notif-alert-row { display: flex; align-items: center; justify-content: space-between; padding: 10px 16px; background: rgba(99, 102, 241, 0.04); border: 1px solid rgba(99, 102, 241, 0.08); border-radius: 10px; margin-bottom: 6px; font-size: 0.85rem; color: #d1d5db; }
.notif-list { display: flex; flex-direction: column; gap: 8px; }
.notif-item { padding: 14px 16px; border-radius: 12px; border: 1px solid rgba(99, 102, 241, 0.1); cursor: pointer; transition: all 0.2s; }
.notif-item.unread { background: rgba(99, 102, 241, 0.08); border-color: rgba(99, 102, 241, 0.2); }
.notif-item.read { background: rgba(99, 102, 241, 0.02); opacity: 0.7; }
.notif-item-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
.notif-type-badge { padding: 2px 8px; border-radius: 6px; font-size: 0.7rem; font-weight: 600; text-transform: uppercase; }
.notif-type-badge.swap { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
.notif-type-badge.lp { background: rgba(99, 102, 241, 0.15); color: #818cf8; }
.notif-time { font-size: 0.72rem; color: #6b7280; }
.notif-item-title { font-weight: 600; font-size: 0.88rem; color: #e5e7eb; }
.notif-item-msg { font-size: 0.8rem; color: #9ca3af; margin-top: 2px; }

/* Security */
.sec-container { max-width: 850px; margin: 0 auto; }
.sec-section { margin-bottom: 24px; }
.sec-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 12px; }
.sec-card { padding: 16px; border-radius: 12px; border: 1px solid rgba(99, 102, 241, 0.1); text-align: center; }
.sec-card.ok { background: rgba(34, 197, 94, 0.06); border-color: rgba(34, 197, 94, 0.2); }
.sec-card.warn { background: rgba(239, 68, 68, 0.06); border-color: rgba(239, 68, 68, 0.2); }
.sec-card-label { font-size: 0.75rem; color: #6b7280; margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
.sec-card-val { font-size: 0.95rem; font-weight: 600; color: #e5e7eb; }
.sec-card.ok .sec-card-val { color: #22c55e; }
.sec-card.warn .sec-card-val { color: #ef4444; }
.sec-stats { display: flex; gap: 20px; font-size: 0.82rem; color: #6b7280; padding: 10px 0; }
.sec-rl { margin-top: 12px; }
.sec-rl-bar { height: 8px; background: rgba(99, 102, 241, 0.1); border-radius: 4px; overflow: hidden; }
.sec-rl-fill { height: 100%; background: linear-gradient(90deg, #6366f1, #818cf8); border-radius: 4px; transition: width 0.3s; }
.sec-rl-info { display: flex; justify-content: space-between; margin-top: 8px; font-size: 0.8rem; color: #9ca3af; }
.sec-validate { display: flex; gap: 8px; margin-bottom: 12px; }
.sec-input { flex: 1; padding: 10px 14px; border: 1px solid rgba(99, 102, 241, 0.2); border-radius: 10px; background: rgba(99, 102, 241, 0.06); color: #e5e7eb; font-size: 0.85rem; }
.sec-btn { padding: 10px 20px; border: none; border-radius: 10px; background: rgba(99, 102, 241, 0.18); color: #818cf8; font-weight: 600; cursor: pointer; }
.sec-result { padding: 10px 16px; border-radius: 10px; font-size: 0.85rem; font-weight: 500; }
.sec-result.valid { background: rgba(34, 197, 94, 0.1); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.2); }
.sec-result.invalid { background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); }

/* Theme Toggle */
.theme-toggle { width: 36px; height: 36px; border-radius: 50%; border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-primary); font-size: 18px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
.theme-toggle:hover { background: var(--accent-dim); border-color: var(--accent); }

/* Admin Dashboard */
.admin-container { max-width: 900px; margin: 0 auto; }
.admin-tabs { display: flex; gap: 4px; margin-bottom: 20px; }
.admin-tab { padding: 8px 18px; border: 1px solid var(--border); border-radius: 10px; background: none; color: var(--text-secondary); font-size: 0.85rem; font-weight: 500; cursor: pointer; }
.admin-tab.active { background: var(--accent-dim); color: var(--accent); border-color: var(--accent); }
.admin-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 16px; }
.admin-card { padding: 18px; border-radius: 12px; background: var(--bg-card); border: 1px solid var(--border); text-align: center; }
.admin-card.healthy { border-color: rgba(34, 197, 94, 0.3); }
.admin-card.unhealthy { border-color: rgba(239, 68, 68, 0.3); }
.admin-card-label { font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
.admin-card-val { font-size: 1.2rem; font-weight: 700; color: var(--text-primary); }
.admin-card.healthy .admin-card-val { color: #22c55e; }
.admin-info-row { display: flex; gap: 20px; font-size: 0.82rem; color: var(--text-muted); padding: 8px 0; }
.admin-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
.admin-table th { text-align: left; padding: 10px 12px; border-bottom: 1px solid var(--border); color: var(--text-muted); font-weight: 600; font-size: 0.75rem; text-transform: uppercase; }
.admin-table td { padding: 10px 12px; border-bottom: 1px solid rgba(99, 102, 241, 0.06); color: var(--text-secondary); }
.admin-addr { font-family: monospace; font-size: 0.8rem; }
.admin-logs { display: flex; flex-direction: column; gap: 6px; }
.admin-log { display: flex; gap: 10px; padding: 8px 12px; border-radius: 8px; font-size: 0.82rem; font-family: monospace; background: var(--bg-card); border: 1px solid var(--border); }
.admin-log.warn { border-color: rgba(234, 179, 8, 0.2); }
.admin-log-time { color: var(--text-muted); min-width: 80px; }
.admin-log-level { font-weight: 700; min-width: 50px; }
.admin-log-level.info { color: #22c55e; }
.admin-log-level.warn { color: #eab308; }
.admin-log-level.error { color: #ef4444; }
.admin-log-src { color: var(--accent); }
.admin-log-msg { color: var(--text-secondary); }

/* Language Selector */
.lang-selector { display: flex; gap: 2px; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
.lang-btn { padding: 4px 10px; border: none; background: none; color: var(--text-muted); font-size: 0.75rem; font-weight: 600; cursor: pointer; transition: all 0.2s; }
.lang-btn.active { background: var(--accent-dim); color: var(--accent); }
.lang-btn:hover:not(.active) { background: var(--bg-input); color: var(--text-primary); }

/* Token Lists */
.token-lists { display: flex; flex-direction: column; gap: 24px; }
.token-list-section { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 16px; }
.token-list-title { font-size: 0.95rem; font-weight: 700; margin-bottom: 12px; }
.token-list-title.allow { color: #22c55e; }
.token-list-title.deny { color: #ef4444; }
.token-rm-btn { width: 24px; height: 24px; border-radius: 50%; border: 1px solid var(--border); background: none; color: var(--text-muted); font-size: 0.7rem; cursor: pointer; display: flex; align-items: center; justify-content: center; }
.token-rm-btn:hover { background: rgba(239, 68, 68, 0.1); color: #ef4444; border-color: #ef4444; }
.token-add-form { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 16px; }
.token-add-form h4 { margin: 0 0 12px 0; font-size: 0.9rem; color: var(--text-primary); }
.token-add-row { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
.token-add-row input, .token-add-row select { padding: 8px 12px; border: 1px solid var(--border); border-radius: 8px; background: var(--bg-input); color: var(--text-primary); font-size: 0.85rem; flex: 1; min-width: 100px; }
.token-add-row select { flex: 0; min-width: 120px; }

/* Token Visibility */
.token-visibility-grid { display: flex; flex-direction: column; gap: 2px; }
.token-vis-row { display: flex; align-items: center; justify-content: space-between; padding: 10px 12px; border-radius: 8px; transition: all 0.15s; }
.token-vis-row:hover { background: rgba(99, 102, 241, 0.06); }
.token-vis-row.hidden-token { opacity: 0.45; }
.token-vis-toggle { position: relative; display: inline-block; width: 40px; height: 22px; flex-shrink: 0; }
.token-vis-toggle input { opacity: 0; width: 0; height: 0; }
.token-vis-slider { position: absolute; cursor: pointer; inset: 0; background: var(--border); border-radius: 22px; transition: 0.2s; }
.token-vis-slider::before { content: ''; position: absolute; height: 16px; width: 16px; left: 3px; bottom: 3px; background: var(--text-primary); border-radius: 50%; transition: 0.2s; }
.token-vis-toggle input:checked + .token-vis-slider { background: var(--accent); }
.token-vis-toggle input:checked + .token-vis-slider::before { transform: translateX(18px); }

/* Slippage Settings */
.slippage-settings { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 12px 16px; margin-bottom: 12px; }
.slippage-title { font-size: 0.82rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 8px; }
.slippage-options { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
.slippage-opt { padding: 6px 14px; border-radius: 20px; border: 1px solid var(--border); background: var(--bg-input); color: var(--text-secondary); font-size: 0.82rem; font-weight: 600; cursor: pointer; transition: all 0.15s; }
.slippage-opt:hover { border-color: var(--accent); color: var(--accent); }
.slippage-opt.active { background: var(--accent); color: #fff; border-color: var(--accent); }
.slippage-custom { display: flex; align-items: center; gap: 4px; }
.slippage-input { width: 60px; padding: 6px 8px; border-radius: 8px; border: 1px solid var(--border); background: var(--bg-input); color: var(--text-primary); font-size: 0.82rem; text-align: right; }
.slippage-input:focus { border-color: var(--accent); outline: none; }
.slippage-warn { color: #eab308; font-size: 0.75rem; margin-top: 6px; }

/* Swap Confirm Modal */
.confirm-modal { max-width: 420px; width: 90%; }
.confirm-body { padding: 16px; }
.confirm-row-lg { display: flex; flex-direction: column; align-items: center; gap: 8px; padding: 16px; background: var(--bg-input); border-radius: 12px; margin-bottom: 16px; }
.confirm-token { display: flex; align-items: center; gap: 10px; font-size: 1.1rem; font-weight: 600; color: var(--text-primary); }
.confirm-arrow { font-size: 1.4rem; color: var(--text-muted); }
.confirm-details { display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; }
.confirm-detail { display: flex; justify-content: space-between; font-size: 0.82rem; }
.confirm-detail span:first-child { color: var(--text-muted); }
.confirm-detail span:last-child { color: var(--text-primary); font-weight: 500; }

/* TX Tracker */
.tx-tracker { position: fixed; bottom: 80px; right: 16px; width: 340px; max-height: 320px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; box-shadow: 0 8px 32px rgba(0,0,0,0.25); z-index: 900; overflow: hidden; animation: slideUp 0.2s ease-out; }
.tx-tracker-header { display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; border-bottom: 1px solid var(--border); font-weight: 600; font-size: 0.9rem; color: var(--text-primary); }
.tx-tracker-item { display: flex; align-items: center; gap: 10px; padding: 10px 16px; border-bottom: 1px solid rgba(99,102,241,0.06); }
.tx-tracker-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.tx-tracker-dot.pending { background: #eab308; animation: pulse 1.5s infinite; }
.tx-tracker-dot.confirmed { background: #22c55e; }
.tx-tracker-dot.failed { background: #ef4444; }
.tx-tracker-info { flex: 1; min-width: 0; }
.tx-tracker-label { font-size: 0.82rem; font-weight: 500; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.tx-tracker-id { font-size: 0.72rem; color: var(--accent); font-family: monospace; }
.tx-tracker-status { font-size: 0.72rem; font-weight: 600; text-transform: uppercase; }
.tx-tracker-status.pending { color: #eab308; }
.tx-tracker-status.confirmed { color: #22c55e; }
.tx-tracker-status.failed { color: #ef4444; }
.tx-tracker-fab { position: fixed; bottom: 80px; right: 16px; width: 44px; height: 44px; border-radius: 50%; background: var(--accent); color: #fff; border: none; font-size: 0.9rem; font-weight: 700; cursor: pointer; box-shadow: 0 4px 16px rgba(99,102,241,0.4); z-index: 900; transition: transform 0.15s; }
.tx-tracker-fab:hover { transform: scale(1.1); }
@keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

/* Favorite Pool */
.pool-selector-wrapper { display: flex; align-items: stretch; gap: 0; }
.pool-selector-wrapper .pool-selector-btn { border-radius: 8px 0 0 8px; }
.fav-btn { width: 32px; border: 1px solid var(--border); border-left: none; border-radius: 0 8px 8px 0; background: var(--bg-input); color: var(--text-muted); font-size: 0.9rem; cursor: pointer; transition: all 0.15s; display: flex; align-items: center; justify-content: center; }
.fav-btn:hover { color: #eab308; }
.fav-btn.active { color: #eab308; background: rgba(234,179,8,0.08); }

/* Onboarding Guide */
.onboarding-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(6px); z-index: 2000; display: flex; align-items: center; justify-content: center; animation: fadeIn 0.3s; }
.onboarding-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 20px; padding: 40px 32px 28px; max-width: 400px; width: 90%; text-align: center; animation: slideUp 0.3s ease-out; }
.onboarding-icon { font-size: 2.5rem; margin-bottom: 12px; }
.onboarding-card h2 { font-size: 1.3rem; font-weight: 700; color: var(--text-primary); margin: 0 0 10px; }
.onboarding-card p { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.5; margin: 0 0 24px; }
.onboarding-footer { display: flex; justify-content: space-between; align-items: center; }
.onboarding-dots { display: flex; gap: 6px; }
.onboarding-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--border); transition: background 0.2s; }
.onboarding-dot.active { background: var(--accent); }
.onboarding-actions { display: flex; gap: 8px; }
.onboarding-skip { padding: 8px 16px; border-radius: 8px; border: 1px solid var(--border); background: none; color: var(--text-muted); font-size: 0.85rem; cursor: pointer; }
.onboarding-skip:hover { color: var(--text-primary); }
.onboarding-next { padding: 8px 20px; border-radius: 8px; border: none; background: var(--accent); color: #fff; font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: opacity 0.15s; }
.onboarding-next:hover { opacity: 0.85; }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

/* Skeleton Loading */
.skeleton { background: linear-gradient(90deg, var(--bg-input) 25%, var(--border) 50%, var(--bg-input) 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: 8px; }
.skeleton-line { height: 14px; margin-bottom: 8px; }
.skeleton-line.short { width: 60%; }
.skeleton-line.medium { width: 80%; }
.skeleton-block { height: 48px; margin-bottom: 12px; }
@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

/* Loading Spinner Unified */
.spinner-overlay { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 32px; gap: 12px; }
.spinner { width: 32px; height: 32px; border: 3px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; }
.spinner-text { font-size: 0.85rem; color: var(--text-muted); }
@keyframes spin { to { transform: rotate(360deg); } }

/* Mobile Menu Overlay */
.mobile-menu-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 200;
  backdrop-filter: blur(4px);
  animation: fadeIn 0.2s ease;
}
.mobile-menu {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  width: 280px;
  max-width: 85vw;
  background: var(--bg-card);
  border-left: 1px solid var(--border);
  overflow-y: auto;
  animation: slideInRight 0.25s ease-out;
}
@keyframes slideInRight { from { transform: translateX(100%); } to { transform: translateX(0); } }
.mobile-menu-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  border-bottom: 1px solid var(--border);
}
.mobile-menu-group {
  padding: 12px 0;
  border-bottom: 1px solid var(--border);
}
.mobile-menu-group:last-child { border-bottom: none; }
.mobile-menu-group-title {
  padding: 0 20px 8px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--text-muted);
}
.mobile-menu-item {
  display: block;
  width: 100%;
  padding: 12px 20px;
  border: none;
  background: none;
  color: var(--text-secondary);
  font-size: 15px;
  font-weight: 500;
  cursor: pointer;
  text-align: left;
  transition: all 0.15s;
}
.mobile-menu-item:hover { color: var(--text-primary); background: var(--accent-dim); }
.mobile-menu-item.active { color: var(--accent); background: var(--accent-dim); }

/* Wallet Generate */
.wallet-divider {
  height: 1px;
  background: var(--border);
  margin: 16px 0;
}
.btn-generate-wallet {
  width: 100%;
  padding: 12px;
  border-radius: var(--radius);
  font-size: 14px;
  font-weight: 600;
  border: 1px dashed var(--border);
  background: var(--bg-input);
  color: var(--accent);
  cursor: pointer;
  transition: all 0.15s;
}
.btn-generate-wallet:hover {
  background: var(--accent-dim);
  border-color: var(--accent);
}
.generated-wallet-card {
  margin-top: 12px;
  padding: 14px;
  border-radius: var(--radius);
  background: var(--bg-input);
  border: 1px solid var(--border);
  animation: fadeIn 0.2s ease;
}
.generated-wallet-warning {
  font-size: 12px;
  font-weight: 600;
  color: #eab308;
  background: rgba(234, 179, 8, 0.1);
  padding: 8px 12px;
  border-radius: 8px;
  margin-bottom: 12px;
}
.generated-wallet-field {
  margin-bottom: 10px;
}
.generated-wallet-label {
  display: block;
  font-size: 11px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.3px;
  margin-bottom: 4px;
}
.generated-wallet-value {
  display: block;
  font-size: 12px;
  color: var(--text-primary);
  word-break: break-all;
  line-height: 1.4;
}
.generated-wallet-value.mono { font-family: 'SF Mono', 'Fira Code', monospace; }
.btn-copy-sm {
  display: inline-block;
  margin-top: 4px;
  padding: 4px 10px;
  border-radius: 6px;
  font-size: 11px;
  font-weight: 600;
  border: 1px solid var(--border);
  background: var(--bg-secondary);
  color: var(--accent);
  cursor: pointer;
  transition: all 0.15s;
}
.btn-copy-sm:hover { background: var(--accent-dim); }

/* Protocol Stats Bar */
.protocol-stats-bar {
  display: flex;
  gap: 24px;
  justify-content: center;
  margin-bottom: 24px;
  padding: 16px 24px;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border);
  max-width: 480px;
  width: 100%;
}
.protocol-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}
.protocol-stat-label {
  font-size: 11px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.3px;
}
.protocol-stat-value {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-primary);
}

/* Responsive - Mobile improvements */
@media (max-width: 640px) {
  .header { padding: 8px 12px; flex-wrap: wrap; gap: 8px; }

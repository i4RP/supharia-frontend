async fn health(State(state): State<AppState>) -> (StatusCode, Json<ApiResponse<serde_json::Value>>) {
    ok_response(serde_json::json!({
        "version": "0.3.0",
        "name": "DSTAS AMM API (Rust)",
        "active_network": state.active_network,
        "supported_networks": state.networks.iter().map(|n| &n.id).collect::<Vec<_>>(),
    }))
}

async fn status_check(State(state): State<AppState>) -> (StatusCode, Json<ApiResponse<serde_json::Value>>) {
    let db_result = state.db.list_pools().await;
    let pool_count = db_result.as_ref().map(|p| p.len()).unwrap_or(0);
    let db_ok = db_result.is_ok();
    let woc_ok = reqwest::Client::new()
        .get("https://api.whatsonchain.com/v1/bsv/main/chain/info")
        .timeout(std::time::Duration::from_secs(5))
        .send()
        .await
        .map(|r| r.status().is_success())
        .unwrap_or(false);
    let bridge_ok = state.bridge.is_some();
    let all_ok = db_ok && woc_ok;
    let status_code = if all_ok { StatusCode::OK } else { StatusCode::SERVICE_UNAVAILABLE };
    (status_code, Json(ApiResponse {
        success: all_ok,
        data: Some(serde_json::json!({
            "status": if all_ok { "healthy" } else { "degraded" },
            "version": "0.3.0",
            "checks": {
                "database": { "ok": db_ok, "pool_count": pool_count },
                "whatsonchain": { "ok": woc_ok },
                "bridge": { "ok": bridge_ok },
            },
            "active_network": state.active_network,
            "uptime_check": chrono::Utc::now().to_rfc3339(),
        })),
        error: if all_ok { None } else { Some("Some services degraded".to_string()) },
    }))
}


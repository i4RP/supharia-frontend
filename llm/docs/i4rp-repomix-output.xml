  const requestSwap = () => {
    if (!wallet) { setShowWalletModal(true); return }
    const amtErr = validateAmount(fromAmount, balances[fromToken.symbol])
    if (amtErr) { showToast(amtErr, 'error'); return }
    if (!fromAmount || Number(fromAmount) <= 0) return
    if (fromToken.symbol === 'BSV' || toToken.symbol === 'BSV') {
      showToast('BSV cannot be swapped directly. Select token pairs with an AMM pool.', 'error')
      return
    }
    const wif = getWif()
    if (!wif) { showToast('Swap requires WIF login. Please reconnect via WIF Private Key tab.', 'error'); return }
    const pool = pools.find(p =>
      (p.token_a_symbol === fromToken.symbol && p.token_b_symbol === toToken.symbol) ||
      (p.token_a_symbol === toToken.symbol && p.token_b_symbol === fromToken.symbol)
    )
    if (!pool) { showToast(`No AMM pool found for ${fromToken.symbol}/${toToken.symbol}`, 'error'); return }
    setShowSwapConfirm(true)
  }

  const handleSwap = async () => {
    setShowSwapConfirm(false)
    if (!wallet) { setShowWalletModal(true); return }
    const amtErr = validateAmount(fromAmount, balances[fromToken.symbol])
    if (amtErr) { showToast(amtErr, 'error'); return }
    if (!fromAmount || Number(fromAmount) <= 0) return

    if (fromToken.symbol === 'BSV' || toToken.symbol === 'BSV') {
      showToast('BSV cannot be swapped directly. Select token pairs with an AMM pool.', 'error')
      return
    }

    const wif = getWif()
    if (!wif) {
      showToast('Swap requires WIF login. Please reconnect via WIF Private Key tab.', 'error')
      return
    }

    const pool = pools.find(p =>
      (p.token_a_symbol === fromToken.symbol && p.token_b_symbol === toToken.symbol) ||
      (p.token_a_symbol === toToken.symbol && p.token_b_symbol === fromToken.symbol)
    )
    if (!pool) {
      showToast(`No AMM pool found for ${fromToken.symbol}/${toToken.symbol}`, 'error')
      return
    }

    const inputTokenId = pool.token_a_symbol === fromToken.symbol ? pool.token_a_id : pool.token_b_id
    const minOutput = Math.max(1, Math.floor(Number(toAmount) * (1 - slippageTolerance / 100)))

    setIsSwapping(true)
    setSwapProgress('Submitting swap to AMM...')

    try {
      const result = await executePoolSwap(pool.pool_id, {
        user_wif: wif,
        input_token: inputTokenId,
        input_amount: Number(fromAmount),
        min_output_amount: minOutput,
      })

      const txNote = result.tx_ids && result.tx_ids.length > 0 && result.tx_ids[0].length === 64
        ? result.tx_ids[0] : ''
      const txLabel = `Swap ${fromAmount} ${fromToken.symbol} → ${result.output_amount} ${toToken.symbol}`
      if (txNote) {
        setTxHistory(prev => [
          { label: txLabel, txId: txNote, status: 'success', token: fromToken.symbol },
          ...prev,
        ])
        setPendingTxs(prev => [{ txId: txNote, label: txLabel, status: 'confirmed', timestamp: Date.now() }, ...prev])
      }

      const onchainMsg = txNote ? ` [on-chain: ${txNote.slice(0, 8)}...]` : ''
      showToast(`Swapped ${fromAmount} ${fromToken.symbol} → ${result.output_amount} ${toToken.symbol}${onchainMsg}`, 'success')
      setFromAmount('')
      setToAmount('')
      loadBalances(wallet.address, wallet.mnemonic)
    } catch (e) {
      const msg = e instanceof Error ? e.message : String(e)
      const friendly = msg.includes('insufficient') ? 'Insufficient balance for this swap'
        : msg.includes('timeout') || msg.includes('TIMEOUT') ? 'Network timeout — please try again'
        : msg.includes('slippage') ? 'Price moved beyond slippage tolerance. Increase slippage or try a smaller amount.'
        : msg.includes('pool') ? 'Pool error — the pool may have insufficient liquidity'
        : `Swap failed: ${msg}`
      showToast(friendly, 'error')
    } finally {
      setIsSwapping(false)
      setSwapProgress('')
    }
  }


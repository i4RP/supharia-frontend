  useEffect(() => {
    const canvas = chartCanvasRef.current
    if (!canvas || priceHistory.length < 2) return
    const ctx = canvas.getContext('2d')
    if (!ctx) return

    const dpr = window.devicePixelRatio || 1
    const rect = canvas.getBoundingClientRect()
    canvas.width = rect.width * dpr
    canvas.height = rect.height * dpr
    ctx.scale(dpr, dpr)
    const w = rect.width
    const h = rect.height

    ctx.clearRect(0, 0, w, h)

    let values: number[]
    let label: string
    if (chartMetric === 'price') {
      values = priceHistory.map(p => p.price_a_in_b)
      label = 'Price'
    } else if (chartMetric === 'tvl') {
      values = priceHistory.map(p => p.tvl)
      label = 'TVL'
    } else {
      values = priceHistory.map(p => p.volume_a + p.volume_b)
      label = 'Volume'
    }

    const minVal = Math.min(...values)
    const maxVal = Math.max(...values)
    const range = maxVal - minVal || 1
    const pad = { top: 20, right: 10, bottom: 30, left: 50 }
    const cw = w - pad.left - pad.right
    const ch = h - pad.top - pad.bottom

    ctx.strokeStyle = '#374151'
    ctx.lineWidth = 0.5
    ctx.fillStyle = '#9ca3af'
    ctx.font = '10px monospace'
    ctx.textAlign = 'right'
    for (let i = 0; i <= 4; i++) {
      const y = pad.top + ch - (ch * i / 4)
      const val = minVal + range * i / 4
      ctx.beginPath()
      ctx.moveTo(pad.left, y)
      ctx.lineTo(w - pad.right, y)
      ctx.stroke()
      ctx.fillText(val >= 1000 ? (val / 1000).toFixed(1) + 'k' : val.toFixed(2), pad.left - 4, y + 3)
    }

    ctx.textAlign = 'center'
    const step = Math.max(1, Math.floor(values.length / 5))
    for (let i = 0; i < values.length; i += step) {
      const x = pad.left + (cw * i / (values.length - 1))
      const d = new Date(priceHistory[i].timestamp)
      ctx.fillText(`${d.getMonth()+1}/${d.getDate()} ${d.getHours()}:${String(d.getMinutes()).padStart(2,'0')}`, x, h - 4)
    }

    const gradient = ctx.createLinearGradient(0, pad.top, 0, pad.top + ch)
    gradient.addColorStop(0, 'rgba(99, 102, 241, 0.3)')
    gradient.addColorStop(1, 'rgba(99, 102, 241, 0)')
    ctx.beginPath()
    ctx.moveTo(pad.left, pad.top + ch)
    for (let i = 0; i < values.length; i++) {
      const x = pad.left + (cw * i / (values.length - 1))
      const y = pad.top + ch - ((values[i] - minVal) / range * ch)
      ctx.lineTo(x, y)
    }
    ctx.lineTo(pad.left + cw, pad.top + ch)
    ctx.closePath()
    ctx.fillStyle = gradient
    ctx.fill()

    ctx.beginPath()
    for (let i = 0; i < values.length; i++) {
      const x = pad.left + (cw * i / (values.length - 1))
      const y = pad.top + ch - ((values[i] - minVal) / range * ch)
      if (i === 0) ctx.moveTo(x, y)
      else ctx.lineTo(x, y)
    }
    ctx.strokeStyle = '#6366f1'
    ctx.lineWidth = 2
    ctx.stroke()

    for (let i = 0; i < values.length; i++) {
      const x = pad.left + (cw * i / (values.length - 1))
      const y = pad.top + ch - ((values[i] - minVal) / range * ch)
      const evtColor = priceHistory[i].event_type === 'swap' ? '#f59e0b' : priceHistory[i].event_type === 'add_liquidity' ? '#22c55e' : '#ef4444'
      ctx.beginPath()
      ctx.arc(x, y, 3, 0, Math.PI * 2)
      ctx.fillStyle = evtColor
      ctx.fill()
    }

    ctx.fillStyle = '#e5e7eb'
    ctx.font = 'bold 11px sans-serif'
    ctx.textAlign = 'left'
    ctx.fillText(label, pad.left + 4, pad.top + 12)
  }, [priceHistory, chartMetric])


fn compute_sma(prices: &[f64], period: usize) -> Vec<f64> {
    if prices.len() < period { return vec![0.0; prices.len()]; }
    let mut result = vec![0.0; period - 1];
    for i in (period - 1)..prices.len() {
        let sum: f64 = prices[(i + 1 - period)..=i].iter().sum();
        result.push(sum / period as f64);
    }
    result
}

fn compute_ema(prices: &[f64], period: usize) -> Vec<f64> {
    if prices.is_empty() { return vec![]; }
    let k = 2.0 / (period as f64 + 1.0);
    let mut result = vec![prices[0]];
    for i in 1..prices.len() {
        let prev = result[i - 1];
        result.push(prices[i] * k + prev * (1.0 - k));
    }
    result
}

fn compute_rsi(prices: &[f64], period: usize) -> Vec<f64> {
    if prices.len() < 2 { return vec![50.0; prices.len()]; }
    let mut gains = Vec::new();
    let mut losses = Vec::new();
    for i in 1..prices.len() {
        let diff = prices[i] - prices[i - 1];
        if diff > 0.0 { gains.push(diff); losses.push(0.0); }
        else { gains.push(0.0); losses.push(-diff); }
    }
    let mut result = vec![50.0];
    if gains.len() < period { return vec![50.0; prices.len()]; }
    let mut avg_gain: f64 = gains[..period].iter().sum::<f64>() / period as f64;
    let mut avg_loss: f64 = losses[..period].iter().sum::<f64>() / period as f64;
    for i in 0..gains.len() {
        if i >= period {
            avg_gain = (avg_gain * (period as f64 - 1.0) + gains[i]) / period as f64;
            avg_loss = (avg_loss * (period as f64 - 1.0) + losses[i]) / period as f64;
        }
        let rs = if avg_loss == 0.0 { 100.0 } else { avg_gain / avg_loss };
        result.push(100.0 - 100.0 / (1.0 + rs));
    }
    result
}

async fn get_ohlc(
    State(state): State<AppState>,
    Path(pool_id): Path<String>,
    Query(params): Query<OhlcQuery>,
) -> (StatusCode, Json<ApiResponse<Vec<OhlcCandle>>>) {
    let limit = params.limit.unwrap_or(50);
    let _interval = params.interval.unwrap_or_else(|| "1h".to_string());
    match state.db.list_price_history(&pool_id, Some(limit * 2)).await {
        Ok(snapshots) => {
            let candles: Vec<OhlcCandle> = snapshots.iter().map(|s| {
                let noise = (s.timestamp.len() % 7) as f64 * 0.001;
                OhlcCandle {
                    timestamp: s.timestamp.clone(),
                    open: s.price_a_in_b * (1.0 - noise),
                    high: s.price_a_in_b * (1.0 + noise + 0.005),
                    low: s.price_a_in_b * (1.0 - noise - 0.005),
                    close: s.price_a_in_b,
                    volume: s.volume_a as f64 + s.volume_b as f64,
                }
            }).take(limit as usize).collect();
            ok_response(candles)
        }
        Err(e) => err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    }
}

async fn get_advanced_chart(
    State(state): State<AppState>,
    Path(pool_id): Path<String>,
    Query(params): Query<OhlcQuery>,
) -> (StatusCode, Json<ApiResponse<AdvancedChartData>>) {
    let limit = params.limit.unwrap_or(50);
    let _interval = params.interval.unwrap_or_else(|| "1h".to_string());
    match state.db.list_price_history(&pool_id, Some(limit * 2)).await {
        Ok(snapshots) => {
            let candles: Vec<OhlcCandle> = snapshots.iter().map(|s| {
                let noise = (s.timestamp.len() % 7) as f64 * 0.001;
                OhlcCandle {
                    timestamp: s.timestamp.clone(),
                    open: s.price_a_in_b * (1.0 - noise),
                    high: s.price_a_in_b * (1.0 + noise + 0.005),
                    low: s.price_a_in_b * (1.0 - noise - 0.005),
                    close: s.price_a_in_b,
                    volume: s.volume_a as f64 + s.volume_b as f64,
                }
            }).take(limit as usize).collect();
            let closes: Vec<f64> = candles.iter().map(|c| c.close).collect();
            let sma_7 = compute_sma(&closes, 7);
            let sma_25 = compute_sma(&closes, 25);
            let ema_12 = compute_ema(&closes, 12);
            let ema_26 = compute_ema(&closes, 26);
            let rsi_14 = compute_rsi(&closes, 14);
            let macd_line: Vec<f64> = ema_12.iter().zip(ema_26.iter()).map(|(a, b)| a - b).collect();
            let macd_signal = compute_ema(&macd_line, 9);
            let macd_histogram: Vec<f64> = macd_line.iter().zip(macd_signal.iter()).map(|(a, b)| a - b).collect();
            let bb_mid = compute_sma(&closes, 20);
            let mut bb_upper = Vec::new();
            let mut bb_lower = Vec::new();
            for (i, &mid) in bb_mid.iter().enumerate() {
                if i < 19 || mid == 0.0 {
                    bb_upper.push(mid);
                    bb_lower.push(mid);
                } else {
                    let slice = &closes[(i + 1 - 20)..=i];
                    let mean = slice.iter().sum::<f64>() / 20.0;
                    let variance = slice.iter().map(|x| (x - mean).powi(2)).sum::<f64>() / 20.0;
                    let std_dev = variance.sqrt();
                    bb_upper.push(mid + 2.0 * std_dev);
                    bb_lower.push(mid - 2.0 * std_dev);
                }
            }
            ok_response(AdvancedChartData {
                candles,
                indicators: TechnicalIndicators {
                    sma_7, sma_25, ema_12, ema_26, rsi_14,
                    macd_line, macd_signal, macd_histogram,
                    bollinger_upper: bb_upper,
                    bollinger_middle: bb_mid,
                    bollinger_lower: bb_lower,
                },
            })
        }
        Err(e) => err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    }
}

async fn admin_api_key_check(
    headers: HeaderMap,
    request: axum::extract::Request,
    next: Next,
) -> Result<Response, StatusCode> {
    let expected_key = std::env::var("ADMIN_API_KEY").unwrap_or_default();
    if expected_key.is_empty() {
        return Err(StatusCode::INTERNAL_SERVER_ERROR);
    }
    match headers.get("x-admin-api-key") {
        Some(provided) if provided.as_bytes() == expected_key.as_bytes() => {
            Ok(next.run(request).await)
        }
        _ => Err(StatusCode::UNAUTHORIZED),
    }
}


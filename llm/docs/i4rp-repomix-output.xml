components:
  schemas:
    ApiResponse_string:
      type: object
      properties:
        success:
          type: boolean
        data:
          type: string
        error:
          type: string
          nullable: true
    ApiResponse_PoolInfoArray:
      type: object
      properties:
        success:
          type: boolean
        data:
          type: array
          items:
            $ref: "#/components/schemas/PoolInfo"
        error:
          type: string
          nullable: true
    ApiResponse_PoolInfo:
      type: object
      properties:
        success:
          type: boolean
        data:
          $ref: "#/components/schemas/PoolInfo"
        error:
          type: string
          nullable: true
    ApiResponse_SwapQuoteResponse:
      type: object
      properties:
        success:
          type: boolean
        data:
          $ref: "#/components/schemas/SwapQuoteResponse"
        error:
          type: string
          nullable: true
    ApiResponse_ExecuteSwapResponse:
      type: object
      properties:
        success:
          type: boolean
        data:
          $ref: "#/components/schemas/ExecuteSwapResponse"
        error:
          type: string
          nullable: true
    ApiResponse_AddLiquidityResponse:
      type: object
      properties:
        success:
          type: boolean
        data:
          $ref: "#/components/schemas/AddLiquidityResponse"
        error:
          type: string
          nullable: true
    ApiResponse_RemoveLiquidityResponse:
      type: object
      properties:
        success:
          type: boolean
        data:
          $ref: "#/components/schemas/RemoveLiquidityResponse"
        error:
          type: string
          nullable: true
    ApiResponse_LpInfo:
      type: object
      properties:
        success:
          type: boolean
        data:
          $ref: "#/components/schemas/LpInfo"
        error:
          type: string
          nullable: true
    ApiResponse_TransactionInfoArray:
      type: object
      properties:
        success:
          type: boolean
        data:
          type: array
          items:
            $ref: "#/components/schemas/TransactionInfo"
        error:
          type: string
          nullable: true
    CreatePoolRequest:
      type: object
      required: [token_a_id, token_b_id, token_a_symbol, token_b_symbol]
      properties:
        token_a_id:
          type: string
          example: wbtc
        token_b_id:
          type: string
          example: wusdc
        token_a_symbol:
          type: string
          example: wBTC
        token_b_symbol:
          type: string
          example: wUSDC
    PoolInfo:
      type: object
      properties:
        pool_id:
          type: string
          format: uuid
        token_a_id:
          type: string
        token_a_symbol:
          type: string
        token_b_id:
          type: string
        token_b_symbol:
          type: string
        reserve_a:
          type: integer
          format: uint64
        reserve_b:
          type: integer
          format: uint64
        price_a_in_b:
          type: number
          format: double
        price_b_in_a:
          type: number
          format: double
        tvl:
          type: integer
          format: uint64
        fee_rate:
          type: number
          format: double
          example: 0.01
        total_lp_shares:
          type: number
          format: double
        pool_address:
          type: string
          description: BSV mainnet address for the pool wallet
    SwapQuoteRequest:
      type: object
      required: [input_token, input_amount]
      properties:
        input_token:
          type: string
          description: Token ID to swap from (must match token_a_id or token_b_id)
        input_amount:
          type: integer
          format: uint64
          minimum: 1
    SwapQuoteResponse:
      type: object
      properties:
        input_token:
          type: string
        input_amount:
          type: integer
          format: uint64
        output_token:
          type: string
        output_amount:
          type: integer
          format: uint64
        fee_amount:
          type: integer
          format: uint64
          description: 1% fee deducted from input
        price_impact:
          type: number
          format: double
          description: Price impact percentage
        minimum_received:
          type: integer
          format: uint64
          description: Minimum output (95% of quoted)
    ExecuteSwapRequest:
      type: object
      required: [user_wif, input_token, input_amount]
      properties:
        user_wif:
          type: string
          description: User's WIF private key
        input_token:
          type: string
        input_amount:
          type: integer
          format: uint64
        min_output_amount:
          type: integer
          format: uint64
          description: Slippage protection minimum
    ExecuteSwapResponse:
      type: object
      properties:
        input_token:
          type: string
        input_amount:
          type: integer
          format: uint64
        output_token:
          type: string
        output_amount:
          type: integer
          format: uint64
        fee_amount:
          type: integer
          format: uint64
        tx_ids:
          type: array
          items:
            type: string
    AddLiquidityRequest:
      type: object
      required: [user_wif, amount_a, amount_b]
      properties:
        user_wif:
          type: string
        amount_a:
          type: integer
          format: uint64
        amount_b:
          type: integer
          format: uint64
    AddLiquidityResponse:
      type: object
      properties:
        lp_shares_minted:
          type: number
          format: double
        amount_a_deposited:
          type: integer
          format: uint64
        amount_b_deposited:
          type: integer
          format: uint64
        share_of_pool:
          type: number
          format: double
          description: Percentage of pool owned
        tx_ids:
          type: array
          items:
            type: string
    RemoveLiquidityRequest:
      type: object
      required: [user_wif, lp_share_percent]
      properties:
        user_wif:
          type: string
        lp_share_percent:
          type: number
          format: double
          description: Percentage of LP shares to remove (0-100)
    RemoveLiquidityResponse:
      type: object
      properties:
        lp_shares_burned:
          type: number
          format: double
        amount_a_received:
          type: integer
          format: uint64
        amount_b_received:
          type: integer
          format: uint64
        tx_ids:
          type: array
          items:
            type: string
    LpInfo:
      type: object
      properties:
        user_address:
          type: string
        lp_shares:
          type: number
          format: double
        share_of_pool:
          type: number
          format: double
          description: Percentage
        deposited_a:
          type: integer
          format: uint64
        deposited_b:
          type: integer
          format: uint64
        current_value_a:
          type: integer
          format: uint64
        current_value_b:
          type: integer
          format: uint64
        earned_fees_a:
          type: integer
          format: uint64

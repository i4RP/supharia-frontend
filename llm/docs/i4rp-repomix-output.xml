          <div className="history-list">
            {bridgeSupportedTokens.map(tk => (
              <div key={tk.token} className="history-item" style={{ padding: '10px 12px' }}>
                <div className="history-item-left">
                  <div className="token-icon" style={{ background: tk.symbol === 'ETH' ? '#627eea' : tk.symbol === 'USDC' ? '#2775ca' : tk.symbol === 'USDT' ? '#26a17b' : tk.symbol === 'DAI' ? '#f5ac37' : '#818cf8' }}>
                    {tk.symbol[0]}

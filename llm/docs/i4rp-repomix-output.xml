async fn create_pool(
    State(state): State<AppState>,
    Json(req): Json<CreatePoolRequest>,
) -> (StatusCode, Json<ApiResponse<PoolInfo>>) {
    let pool_id = Uuid::new_v4().to_string();
    tracing::info!(pool_id = %pool_id, pair = %format!("{}/{}", req.token_a_symbol, req.token_b_symbol), "create_pool");

    let wallet = match derive_pool_wallet(&state.pool_master_seed, &pool_id) {
        Ok(w) => w,
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &format!("Pool wallet error: {}", e)),
    };
    let pool = Pool {
        pool_id: pool_id.clone(),
        token_a_id: req.token_a_id.clone(),
        token_b_id: req.token_b_id.clone(),
        token_a_symbol: req.token_a_symbol.clone(),
        token_b_symbol: req.token_b_symbol.clone(),
        reserve_a: 0,
        reserve_b: 0,
        k: 0.0,
        total_lp_shares: 0.0,
        fee_rate: amm::FEE_RATE,
        pool_address: wallet.address.clone(),
        pool_wif_secret_id: "server-managed".to_string(),
        version: 1,
        created_at: Utc::now().to_rfc3339(),
    };

    if let Err(e) = state.db.put_pool(&pool).await {
        tracing::error!(pool_id = %pool_id, error = %e, "create_pool failed");
        return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e);
    }

    ok_response(PoolInfo {
        pool_id: pool.pool_id,
        token_a_symbol: pool.token_a_symbol,
        token_b_symbol: pool.token_b_symbol,
        token_a_id: pool.token_a_id,
        token_b_id: pool.token_b_id,
        reserve_a: 0,
        reserve_b: 0,
        price_a_in_b: 0.0,
        price_b_in_a: 0.0,
        tvl: 0,
        fee_rate: pool.fee_rate,
        total_lp_shares: 0.0,
        pool_address: pool.pool_address,
    })
}


    { ver: '2.4.0', date: '2026-02-15', items: ['Rate limit UI', 'Session timeout', 'Terms of Service', 'Changelog', 'Dashboard widgets', 'PnL tracker', 'Keyboard shortcuts', 'Notification filters', 'Address validation enhancement', 'Pool comparison', 'Dark mode animation', 'PWA offline enhancement'] },
    { ver: '2.3.0', date: '2026-02-11', items: ['Slippage protection', 'Confirmation modal', 'TX tracker', 'Favorite pools', 'Onboarding guide', 'Responsive design'] },
    { ver: '2.2.0', date: '2026-02-10', items: ['Partial fill orders', 'Multi-hop routing', 'Dynamic bridge fees'] },

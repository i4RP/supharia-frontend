    pub async fn update_transaction_settlement(&self, tx_id: &str, status: &str, onchain_tx_ids: &[String]) -> Result<(), String> {
        let mut update_expr = "SET settlement_status = :ss".to_string();
        let mut expr_values = HashMap::new();
        expr_values.insert(":ss".to_string(), AttributeValue::S(status.to_string()));

        if !onchain_tx_ids.is_empty() {
            update_expr.push_str(", onchain_tx_ids = :otx");
            expr_values.insert(":otx".to_string(), AttributeValue::Ss(onchain_tx_ids.to_vec()));
        }

        self.client.update_item()
            .table_name(TRANSACTIONS_TABLE)
            .key("tx_id", AttributeValue::S(tx_id.to_string()))
            .update_expression(update_expr)
            .set_expression_attribute_values(Some(expr_values))
            .send()
            .await
            .map_err(|e| format!("update_transaction_settlement error: {}", e))?;

        Ok(())
    }


<file path="wallet-extension/content/inpage.js">
/**
 * DXS Wallet - Inpage Script
 *
 * Injected into the page context to expose the window.dxsWallet
 * provider API that dApps can use to interact with the wallet.
 */

(function () {
  "use strict";

  if (window.dxsWallet) return; // Already injected

  const REQUEST_TIMEOUT_MS = 30000;
  const pendingRequests = new Map();

  function generateId() {
    return `${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;
  }

  /** Listen for responses from the content script */
  window.addEventListener("message", (event) => {
    if (event.source !== window) return;
    const data = event.data;
    if (!data || data.source !== "dxs-wallet-extension") return;

    if (data.type === "DXS_WALLET_RESPONSE") {
      const pending = pendingRequests.get(data.id);
      if (pending) {
        pendingRequests.delete(data.id);
        clearTimeout(pending.timer);
        if (data.payload && data.payload.error) {
          pending.reject(new Error(data.payload.error));
        } else {
          pending.resolve(data.payload || {});
        }
      }
    }

    if (data.type === "DXS_WALLET_EVENT") {
      const evt = new CustomEvent("dxs-wallet-event", {
        detail: { action: data.action, payload: data.payload },
      });
      window.dispatchEvent(evt);
    }
  });

  /** Send a request to the content script */
  function sendRequest(action, payload) {
    return new Promise((resolve, reject) => {
      const id = generateId();
      const timer = setTimeout(() => {
        pendingRequests.delete(id);
        reject(new Error(`DXS Wallet: request "${action}" timed out`));
      }, REQUEST_TIMEOUT_MS);

      pendingRequests.set(id, { resolve, reject, timer });

      window.postMessage(
        {
          type: "DXS_WALLET_REQUEST",
          action,
          id,
          payload: payload || {},
          source: "dxs-dapp",
        },
        "*",
      );
    });
  }

  let connectedAccount = null;
  let connectionState = "disconnected";
  const eventListeners = {};

  function emit(event, ...args) {
    const listeners = eventListeners[event];
    if (listeners) {
      for (const fn of listeners) {
        try {
          fn(...args);
        } catch (e) {
          console.error("DXS Wallet event listener error:", e);
        }
      }
    }
  }

  /** The dxsWallet provider API */
  const dxsWallet = {
    isAvailable() {
      return true;
    },

    async connect() {
      connectionState = "connecting";
      try {
        const result = await sendRequest("connect", {});
        if (result.error) throw new Error(result.error);
        connectedAccount = {
          address: result.address,
          publicKey: result.publicKey || undefined,
          network: result.network || "mainnet",
        };
        connectionState = "connected";
        emit("connect", connectedAccount);
        return connectedAccount;
      } catch (e) {
        connectionState = "error";
        emit("error", e);
        throw e;
      }
    },

    async disconnect() {
      try {
        await sendRequest("disconnect", {});
      } catch {
        // Ignore
      }
      connectedAccount = null;
      connectionState = "disconnected";
      emit("disconnect");
    },

    getAccount() {
      return connectedAccount;
    },

    async getAddress() {
      if (connectedAccount) return connectedAccount.address;
      const result = await sendRequest("get_address", {});
      if (result.error) throw new Error(result.error);
      return result.address;
    },

    async getWif() {
      const result = await sendRequest("get_wif", {});
      if (result.error) throw new Error(result.error);
      return result.wif;
    },

    async getBalance() {
      const result = await sendRequest("get_balance", {});
      if (result.error) throw new Error(result.error);
      return result.balance;
    },

    async signTransaction(txHex) {
      const result = await sendRequest("sign_transaction", { txHex });
      if (result.error) throw new Error(result.error);
      return result.signedTxHex || result.wif;
    },

    async signMessage(message) {
      const result = await sendRequest("sign_message", { message });
      if (result.error) throw new Error(result.error);
      return result.signature;
    },

    getState() {
      return connectionState;
    },

    on(event, listener) {
      if (!eventListeners[event]) eventListeners[event] = new Set();
      eventListeners[event].add(listener);
    },

    off(event, listener) {
      if (eventListeners[event]) {
        eventListeners[event].delete(listener);
      }
    },
  };

  // Listen for broadcast events from the extension
  window.addEventListener("dxs-wallet-event", (e) => {
    const { action, payload } = e.detail;
    if (action === "accountChanged" && payload) {
      connectedAccount = {
        address: payload.address,
        publicKey: payload.publicKey,
        network: payload.network || "mainnet",
      };
      emit("accountChanged", connectedAccount);
    } else if (action === "networkChanged" && payload) {
      if (connectedAccount) {
        connectedAccount.network = payload.network;
      }
      emit("networkChanged", payload.network);
    } else if (action === "disconnect") {
      connectedAccount = null;
      connectionState = "disconnected";
      emit("disconnect");
    }
  });

  // Expose the provider
  Object.defineProperty(window, "dxsWallet", {
    value: dxsWallet,
    writable: false,
    configurable: false,
    enumerable: true,
  });

  // Dispatch an event to notify dApps the wallet is available
  window.dispatchEvent(new Event("dxs-wallet-ready"));
})();

      const isStable = bridgeToken === 'USDC' || bridgeToken === 'rUSD'
      const tokenId = isStable ? (ethNetwork === 'sepolia' ? 'rusd-sepolia' : '114111bc1659e68aef1d60736a0f12d1309e3d19') : ''
      const amount = isStable ? Math.round(parseFloat(bridgeAmount) * 1e6) : Math.round(parseFloat(bridgeAmount) * 1e18)
      if (isNaN(amount) || amount <= 0) { showToast('Invalid amount', 'error'); setBridgeLoading(false); return }
      if (!bridgeEthTxHash) { showToast('Enter ETH transaction hash', 'error'); setBridgeLoading(false); return }
      const result = await bridgeWrap(wallet.address, tokenId, amount, wif, bridgeEthTxHash, ethNetwork)
      setBridgeHistory(prev => [result, ...prev])
      showToast(`Wrap submitted: ${result.token_symbol}`, 'success')

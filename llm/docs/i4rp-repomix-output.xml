}

/* Dark Mode smooth transition */
*, *::before, *::after { transition: background-color 0.3s ease, border-color 0.3s ease, color 0.15s ease; }
input, textarea, button, select { transition: background-color 0.3s ease, border-color 0.3s ease, color 0.15s ease, opacity 0.15s, transform 0.15s; }

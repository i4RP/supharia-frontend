                    {tx.direction === 'wrap' ? 'W' : 'U'}
                  </div>
                  <div>
                    <div className="history-label">{tx.direction === 'wrap' ? 'Wrap' : 'Unwrap'} {safeLocale(tx.amount)} {tx.token_symbol}</div>
                    <div className="history-txid">{tx.bridge_tx_id.slice(0, 16)}...</div>

<file path="wallet-extension/content/content-script.js">
/**
 * DXS Wallet - Content Script
 *
 * Bridges communication between the web page (inpage.js) and
 * the background service worker. Injects the inpage script into
 * the page context so dApps can access window.dxsWallet.
 */

// Inject the inpage script into the page context
function injectInpageScript() {
  try {
    const script = document.createElement("script");
    script.src = chrome.runtime.getURL("content/inpage.js");
    script.type = "module";
    script.onload = () => script.remove();
    (document.head || document.documentElement).appendChild(script);
  } catch (e) {
    console.error("DXS Wallet: Failed to inject inpage script", e);
  }
}

injectInpageScript();

/**
 * Listen for messages from the inpage script (window.postMessage)
 * and forward them to the background service worker.
 */
window.addEventListener("message", async (event) => {
  if (event.source !== window) return;
  const data = event.data;
  if (!data || data.source !== "dxs-dapp") return;
  if (data.type !== "DXS_WALLET_REQUEST") return;

  try {
    const response = await chrome.runtime.sendMessage({
      type: "DXS_WALLET_INTERNAL",
      action: `dapp_${data.action}`,
      payload: {
        ...data.payload,
        origin: window.location.origin,
      },
    });

    // Send response back to the page
    window.postMessage(
      {
        type: "DXS_WALLET_RESPONSE",
        action: data.action,
        id: data.id,
        payload: response || {},
        source: "dxs-wallet-extension",
      },
      "*",
    );
  } catch (err) {
    window.postMessage(
      {
        type: "DXS_WALLET_RESPONSE",
        action: data.action,
        id: data.id,
        payload: { error: err.message || "Extension communication failed" },
        source: "dxs-wallet-extension",
      },
      "*",
    );
  }
});

/**
 * Listen for broadcast messages from the background service worker
 * (e.g., network changes, account updates) and forward to the page.
 */
chrome.runtime.onMessage.addListener((message) => {
  if (message.type === "DXS_WALLET_BROADCAST") {
    window.postMessage(
      {
        type: "DXS_WALLET_EVENT",
        action: message.action,
        id: `broadcast-${Date.now()}`,
        payload: message.payload || {},
        source: "dxs-wallet-extension",
      },
      "*",
    );
  }
});

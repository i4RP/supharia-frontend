<file path="backend/dstas-amm/src/settlement.rs">
use crate::crypto::hashes::double_sha256;
use crate::crypto::keys::PrivKey;
use crate::crypto::wallet::DerivedWallet;
use crate::bitcoin::script::{p2pkh_locking_script, p2pkh_unlocking_script, push_data};
use crate::bitcoin::tx::{write_varint, reverse_txid_bytes, tx_id_from_hex};
use crate::bitcoin::opcodes::{OP_RETURN, SIGHASH_ALL_FORKID};
use crate::woc::{WocClient, WocUtxo};

const TX_VERSION: u32 = 1;
const SEQUENCE_FINAL: u32 = 0xffffffff;
const LOCKTIME_ZERO: u32 = 0;
const DUST_LIMIT: u64 = 546;
const FEE_RATE_SAT_PER_BYTE: f64 = 1.0;

#[derive(Debug, Clone)]
pub struct SettlementResult {
    pub txid: String,
    pub tx_hex: String,
    pub fee_paid: u64,
}

#[derive(Debug, Clone)]
pub struct SettlementMeta {
    pub op_type: String,
    pub pool_id: String,
    pub user_address: String,
    pub input_token: String,
    pub input_amount: u64,
    pub output_token: String,
    pub output_amount: u64,
    pub fee_amount: u64,
}

pub struct SettlementService {
    woc: WocClient,
}

struct TxInput {
    prev_txid: Vec<u8>,
    prev_vout: u32,
    value: u64,
    script_code: Vec<u8>,
}

struct TxOutput {
    value: u64,
    script_pubkey: Vec<u8>,
}

fn build_op_return_script(meta: &SettlementMeta) -> Vec<u8> {
    let payload = format!(
        "DSTAS-AMM|{}|{}|{}|{}:{}->{}:{}|fee:{}",
        meta.op_type,
        meta.pool_id,
        meta.user_address,
        meta.input_token,
        meta.input_amount,
        meta.output_token,
        meta.output_amount,
        meta.fee_amount,
    );
    let data = payload.as_bytes();
    let mut script = Vec::new();
    script.push(0x00); // OP_FALSE
    script.push(OP_RETURN);
    push_data(&mut script, data);
    script
}

fn estimate_tx_size(num_inputs: usize, num_outputs: usize, op_return_data_len: usize) -> usize {
    let input_size = num_inputs * 148;
    let p2pkh_output_size = if num_outputs > 1 { 34 } else { 0 };
    let op_return_script_len = if op_return_data_len > 0 {
        2 + if op_return_data_len <= 75 { 1 + op_return_data_len } else { 2 + op_return_data_len }
    } else { 0 };
    let op_return_output_size = if op_return_data_len > 0 { 8 + 1 + op_return_script_len } else { 0 };
    4 + 1 + input_size + 1 + op_return_output_size + p2pkh_output_size + 4
}

fn serialize_output(out: &TxOutput) -> Vec<u8> {
    let mut buf = Vec::new();
    buf.extend_from_slice(&out.value.to_le_bytes());
    write_varint(&mut buf, out.script_pubkey.len() as u64);
    buf.extend_from_slice(&out.script_pubkey);
    buf
}

fn hash_prevouts(inputs: &[TxInput]) -> [u8; 32] {
    let mut buf = Vec::new();
    for inp in inputs {
        buf.extend_from_slice(&inp.prev_txid);
        buf.extend_from_slice(&inp.prev_vout.to_le_bytes());
    }
    double_sha256(&buf)
}

fn hash_sequence(inputs: &[TxInput]) -> [u8; 32] {
    let mut buf = Vec::new();
    for _ in inputs {
        buf.extend_from_slice(&SEQUENCE_FINAL.to_le_bytes());
    }
    double_sha256(&buf)
}

fn hash_outputs(outputs: &[TxOutput]) -> [u8; 32] {
    let mut buf = Vec::new();
    for out in outputs {
        buf.extend_from_slice(&serialize_output(out));
    }
    double_sha256(&buf)
}

fn bip143_sighash(
    inputs: &[TxInput],
    outputs: &[TxOutput],
    input_index: usize,
) -> [u8; 32] {
    let hp = hash_prevouts(inputs);
    let hs = hash_sequence(inputs);
    let ho = hash_outputs(outputs);

    let inp = &inputs[input_index];

    let mut preimage = Vec::new();
    preimage.extend_from_slice(&TX_VERSION.to_le_bytes());
    preimage.extend_from_slice(&hp);
    preimage.extend_from_slice(&hs);
    preimage.extend_from_slice(&inp.prev_txid);
    preimage.extend_from_slice(&inp.prev_vout.to_le_bytes());
    write_varint(&mut preimage, inp.script_code.len() as u64);
    preimage.extend_from_slice(&inp.script_code);
    preimage.extend_from_slice(&inp.value.to_le_bytes());
    preimage.extend_from_slice(&SEQUENCE_FINAL.to_le_bytes());
    preimage.extend_from_slice(&ho);
    preimage.extend_from_slice(&LOCKTIME_ZERO.to_le_bytes());
    preimage.extend_from_slice(&(SIGHASH_ALL_FORKID as u32).to_le_bytes());

    double_sha256(&preimage)
}

fn build_signed_tx(
    inputs: &[TxInput],
    outputs: &[TxOutput],
    signing_key: &PrivKey,
) -> Vec<u8> {
    let pub_bytes = signing_key.public_key().to_bytes();

    let mut sigs: Vec<Vec<u8>> = Vec::new();
    for i in 0..inputs.len() {
        let sighash = bip143_sighash(inputs, outputs, i);
        let sig = signing_key.sign_tx_input(&sighash, SIGHASH_ALL_FORKID);
        sigs.push(sig);
    }

    let mut tx = Vec::new();
    tx.extend_from_slice(&TX_VERSION.to_le_bytes());
    write_varint(&mut tx, inputs.len() as u64);
    for (i, inp) in inputs.iter().enumerate() {
        tx.extend_from_slice(&inp.prev_txid);
        tx.extend_from_slice(&inp.prev_vout.to_le_bytes());
        let script_sig = p2pkh_unlocking_script(&sigs[i], &pub_bytes);
        write_varint(&mut tx, script_sig.len() as u64);
        tx.extend_from_slice(&script_sig);
        tx.extend_from_slice(&SEQUENCE_FINAL.to_le_bytes());
    }
    write_varint(&mut tx, outputs.len() as u64);
    for out in outputs {
        tx.extend_from_slice(&serialize_output(out));
    }
    tx.extend_from_slice(&LOCKTIME_ZERO.to_le_bytes());
    tx
}

fn select_utxos(utxos: &[WocUtxo], target: u64) -> Result<Vec<WocUtxo>, String> {
    let mut sorted: Vec<&WocUtxo> = utxos.iter().collect();
    sorted.sort_by(|a, b| b.value.cmp(&a.value));

    let mut selected = Vec::new();
    let mut total: u64 = 0;
    for u in sorted {
        selected.push(u.clone());
        total += u.value;
        if total >= target {
            return Ok(selected);
        }
    }
    Err(format!(
        "Insufficient funds: need {} sats, have {} sats across {} UTXOs",
        target, total, utxos.len()
    ))
}

impl SettlementService {
    pub fn new(woc: WocClient) -> Self {
        Self { woc }
    }

    pub async fn settle_operation(
        &self,
        wallet: &DerivedWallet,
        meta: &SettlementMeta,
    ) -> Result<SettlementResult, String> {
        eprintln!("[settlement] settle_operation called for pool_wallet={} op={}", wallet.address, meta.op_type);
        let utxos = self.woc.get_utxos(&wallet.address).await.map_err(|e| {
            eprintln!("[settlement] get_utxos error: {}", e);
            e
        })?;
        eprintln!("[settlement] found {} UTXOs, total={} sats", utxos.len(), utxos.iter().map(|u| u.value).sum::<u64>());
        if utxos.is_empty() {
            return Err(format!(
                "No UTXOs found for pool wallet {}. Fund this address with BSV to enable on-chain settlement.",
                wallet.address
            ));
        }

        let op_return_script = build_op_return_script(meta);
        let op_return_data_len = op_return_script.len();
        let op_return_output = TxOutput {
            value: 0,
            script_pubkey: op_return_script,
        };
        let estimated_size = estimate_tx_size(1, 2, op_return_data_len);
        let estimated_fee = ((estimated_size as f64) * FEE_RATE_SAT_PER_BYTE).ceil() as u64;
        let min_needed = estimated_fee + DUST_LIMIT;

        let selected = select_utxos(&utxos, min_needed)?;
        let total_input: u64 = selected.iter().map(|u| u.value).sum();

        let actual_size = estimate_tx_size(selected.len(), 2, op_return_data_len);
        let fee = ((actual_size as f64) * FEE_RATE_SAT_PER_BYTE).ceil() as u64;
        eprintln!("[settlement] inputs={} total_input={} est_size={} fee={} change={}", selected.len(), total_input, actual_size, fee, total_input.saturating_sub(fee));
        let change = total_input.saturating_sub(fee);

        let change_script = p2pkh_locking_script(&wallet.pkh);
        let change_output = TxOutput {
            value: change,
            script_pubkey: change_script.clone(),
        };

        let outputs = if change >= DUST_LIMIT {
            vec![op_return_output, change_output]
        } else {
            vec![op_return_output]
        };

        let script_code = p2pkh_locking_script(&wallet.pkh);
        let inputs: Vec<TxInput> = selected
            .iter()
            .map(|u| TxInput {
                prev_txid: reverse_txid_bytes(&u.tx_hash),
                prev_vout: u.tx_pos,
                value: u.value,
                script_code: script_code.clone(),
            })
            .collect();

        let raw_tx = build_signed_tx(&inputs, &outputs, &wallet.private_key);
        let tx_hex = hex::encode(&raw_tx);
        let computed_txid = tx_id_from_hex(&tx_hex);

        eprintln!("[settlement] broadcasting tx, hex_len={}, computed_txid={}", tx_hex.len(), computed_txid);
        let broadcast_txid = self.woc.broadcast(&tx_hex).await.map_err(|e| {
            eprintln!("[settlement] broadcast error: {}", e);
            e
        })?;
        let final_txid = if broadcast_txid.len() == 64 {
            broadcast_txid
        } else {
            computed_txid
        };

        eprintln!("[settlement] SUCCESS txid={} fee={}", final_txid, fee);
        Ok(SettlementResult {
            txid: final_txid,
            tx_hex,
            fee_paid: fee,
        })
    }

    pub async fn check_confirmation(&self, txid: &str) -> Result<(bool, u64), String> {
        let status = self.woc.get_tx_status(txid).await?;
        Ok((status.confirmed, status.confirmations))
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn op_return_script_has_correct_prefix() {
        let meta = SettlementMeta {
            op_type: "swap".to_string(),
            pool_id: "pool-123".to_string(),
            user_address: "1ABC".to_string(),
            input_token: "wBTC".to_string(),
            input_amount: 100,
            output_token: "wUSDC".to_string(),
            output_amount: 95,
            fee_amount: 1,
        };
        let script = build_op_return_script(&meta);
        assert_eq!(script[0], 0x00);
        assert_eq!(script[1], OP_RETURN);
        let payload = String::from_utf8_lossy(&script[3..]);
        assert!(payload.contains("DSTAS-AMM"));
        assert!(payload.contains("swap"));
        assert!(payload.contains("pool-123"));
    }

    #[test]
    fn estimate_tx_size_reasonable() {
        let size_1in_2out = estimate_tx_size(1, 2, 100);
        assert!(size_1in_2out > 200);
        let size_2in_2out = estimate_tx_size(2, 2, 100);
        assert!(size_2in_2out > size_1in_2out);
    }

    #[test]
    fn select_utxos_picks_fewest() {
        let utxos = vec![
            WocUtxo { tx_hash: "a".repeat(64), tx_pos: 0, value: 1000 },
            WocUtxo { tx_hash: "b".repeat(64), tx_pos: 0, value: 5000 },
            WocUtxo { tx_hash: "c".repeat(64), tx_pos: 0, value: 2000 },
        ];
        let selected = select_utxos(&utxos, 3000).unwrap();
        assert_eq!(selected.len(), 1);
        assert_eq!(selected[0].value, 5000);
    }

    #[test]
    fn select_utxos_insufficient() {
        let utxos = vec![
            WocUtxo { tx_hash: "a".repeat(64), tx_pos: 0, value: 100 },
        ];
        let result = select_utxos(&utxos, 1000);
        assert!(result.is_err());
    }

    #[test]
    fn bip143_sighash_deterministic() {
        let script_code = p2pkh_locking_script(&[0u8; 20]);
        let inputs = vec![TxInput {
            prev_txid: vec![0u8; 32],
            prev_vout: 0,
            value: 10000,
            script_code: script_code.clone(),
        }];
        let outputs = vec![TxOutput {
            value: 9000,
            script_pubkey: script_code,
        }];
        let h1 = bip143_sighash(&inputs, &outputs, 0);
        let h2 = bip143_sighash(&inputs, &outputs, 0);
        assert_eq!(h1, h2);
    }
}

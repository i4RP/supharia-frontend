import { StrictMode, Component } from 'react'
import type { ReactNode, ErrorInfo } from 'react'
import { createRoot } from 'react-dom/client'
import './index.css'
import App from './App.tsx'

class ErrorBoundary extends Component<{ children: ReactNode }, { hasError: boolean; error: Error | null }> {
  constructor(props: { children: ReactNode }) {
    super(props)
    this.state = { hasError: false, error: null }
  }
  static getDerivedStateFromError(error: Error) {
    return { hasError: true, error }
  }
  componentDidCatch(error: Error, info: ErrorInfo) {
    if (typeof window !== 'undefined' && window.navigator.onLine) {
      fetch('/api/error-log', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: error.message, stack: error.stack, component: info.componentStack }),
      }).catch(() => {})
    }
  }
  render() {
    if (this.state.hasError) {
      return (
        <div style={{ minHeight: '100vh', display: 'flex', alignItems: 'center', justifyContent: 'center', background: '#0f0b1a', color: '#e2e8f0', fontFamily: 'Inter, system-ui, sans-serif' }}>
          <div style={{ textAlign: 'center', maxWidth: 420, padding: 32 }}>
            <div style={{ fontSize: 48, marginBottom: 16 }}>&#9888;</div>
            <h1 style={{ fontSize: 20, fontWeight: 700, marginBottom: 12 }}>Something went wrong</h1>
            <p style={{ fontSize: 14, color: '#94a3b8', lineHeight: 1.6, marginBottom: 24 }}>
              {this.state.error?.message || 'An unexpected error occurred. Please reload the page.'}
            </p>
            <button
              onClick={() => { this.setState({ hasError: false, error: null }); window.location.reload() }}
              style={{ padding: '10px 28px', borderRadius: 10, border: 'none', background: '#6366f1', color: '#fff', fontSize: 14, fontWeight: 600, cursor: 'pointer' }}
            >
              Reload App
            </button>
          </div>
        </div>
      )
    }
    return this.props.children
  }
}

createRoot(document.getElementById('root')!).render(
  <StrictMode>
    <ErrorBoundary>
      <App />
    </ErrorBoundary>
  </StrictMode>,
)
</file>

<file path="scripts/mainnet-issue-tokens.ts">
import { Wallet } from "../src/bitcoin/wallet";
import { Address } from "../src/bitcoin/address";
import { OutPoint } from "../src/bitcoin/out-point";
import { ScriptType } from "../src/bitcoin/script-type";
import { TokenScheme } from "../src/bitcoin/token-scheme";
import { TransactionBuilder } from "../src/transaction/build/transaction-builder";
import { TransactionReader } from "../src/transaction/read/transaction-reader";
import { P2pkhBuilder } from "../src/script/build/p2pkh-builder";
import { BuildDstasIssueTxs } from "../src/dstas-factory";
import { FeeRate } from "../src/transaction-factory";
import { toHex, fromHex } from "../src/bytes";

const MNEMONIC =
  "prison hollow urban senior crawl stove mom hurry crowd crush ten bless";
const FUNDING_TXID =
  "14b261ab167b02f6e9de65dd88746abf301f7af06546921e2ac49fbcdf7fc4a8";
const FUNDING_VOUT = 2;
const FUNDING_SATOSHIS = 162_955;

const WOC_BASE = "https://api.whatsonchain.com/v1/bsv/main";

const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));

const broadcast = async (txHex: string, label: string): Promise<string> => {
  console.log(`\nBroadcasting ${label}...`);
  console.log(`  TX size: ${txHex.length / 2} bytes`);

  const res = await fetch(`${WOC_BASE}/tx/raw`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ txhex: txHex }),
  });

  const text = await res.text();
  if (!res.ok) {
    console.error(`  FAILED (${res.status}): ${text}`);
    throw new Error(`Broadcast failed for ${label}: ${text}`);
  }

  const txid = text.replace(/"/g, "");
  console.log(`  SUCCESS: ${txid}`);
  return txid;
};

const TOKEN_CONFIGS = [
  {
    name: "Wrapped Bitcoin",
    symbol: "wBTC",
    pathIndex: 0,
    satoshis: 10_000,
    freeze: true,
  },
  {
    name: "Wrapped USDC",
    symbol: "wUSDC",
    pathIndex: 1,
    satoshis: 10_000,
    freeze: true,
  },
];

async function main() {
  console.log("=== メインネット トークン発行 ===\n");

  const master = Wallet.fromMnemonic(MNEMONIC);
  const wallets: Wallet[] = [];
  for (let i = 0; i < 6; i++) {
    wallets.push(master.deriveWallet(`m/44'/236'/0'/0/${i}`));
  }

  console.log("Wallets:");
  wallets.forEach((w, i) => {
    console.log(`  [${i}] ${w.Address.Value} (${toHex(w.Address.Hash160)})`);
  });

  const issuer = wallets[0];
  const fundingScript = new P2pkhBuilder(issuer.Address).toBytes();
  const fundingOutPoint = new OutPoint(
    FUNDING_TXID,
    FUNDING_VOUT,
    fundingScript,
    FUNDING_SATOSHIS,
    issuer.Address,
    ScriptType.p2pkh,
  );

  console.log("\n--- Step 1: Split funding UTXO ---");
  const splitBuilder = TransactionBuilder.init().addInput(
    fundingOutPoint,
    issuer,
  );

  const splitAmountPerToken = 75_000;
  for (let i = 0; i < TOKEN_CONFIGS.length; i++) {
    const destWallet = wallets[TOKEN_CONFIGS[i].pathIndex];
    splitBuilder.addP2PkhOutput(splitAmountPerToken, destWallet.Address);
  }

  const feeWallet = wallets[0];
  const remainingForFees =
    FUNDING_SATOSHIS - splitAmountPerToken * TOKEN_CONFIGS.length;
  splitBuilder.addChangeOutputWithFee(
    feeWallet.Address,
    remainingForFees,
    FeeRate,
  );

  const splitTxHex = splitBuilder.sign().toHex();
  const splitTx = TransactionReader.readHex(splitTxHex);
  console.log(`Split TX ID: ${splitTx.Id}`);
  console.log(`Split TX outputs: ${splitTx.Outputs.length}`);
  for (let i = 0; i < splitTx.Outputs.length; i++) {
    console.log(`  [${i}] ${splitTx.Outputs[i].Satoshis} sats`);
  }

  await broadcast(splitTxHex, "Split TX");
  await sleep(2000);

  console.log("\n--- Step 2: Issue tokens ---");
  const issuedTokens: Array<{
    symbol: string;
    name: string;
    tokenId: string;
    contractTxId: string;
    issueTxId: string;
    stasOutPoint: { txId: string; vout: number; satoshis: number };
    feeOutPoint: { txId: string; vout: number; satoshis: number };
    issuerPath: number;
    scheme: any;
  }> = [];

  for (let i = 0; i < TOKEN_CONFIGS.length; i++) {
    const config = TOKEN_CONFIGS[i];
    const tokenIssuer = wallets[config.pathIndex];
    const authorityWallet = wallets[(config.pathIndex + 1) % wallets.length];

    console.log(
      `\n  Issuing ${config.symbol} from ${tokenIssuer.Address.Value}...`,
    );

    const splitOutPoint = new OutPoint(
      splitTx.Id,
      i,
      splitTx.Outputs[i].LockignScript,
      splitTx.Outputs[i].Satoshis,
      tokenIssuer.Address,
      ScriptType.p2pkh,
    );

    const scheme = new TokenScheme(
      config.name,
      toHex(tokenIssuer.Address.Hash160),
      config.symbol,
      1,
      {
        freeze: config.freeze,
        confiscation: config.freeze,
        isDivisible: true,
        authority: config.freeze
          ? {
              m: 1,
              publicKeys: [toHex(authorityWallet.PublicKey)],
            }
          : undefined,
      },
    );

    const { contractTxHex, issueTxHex } = BuildDstasIssueTxs({
      fundingPayment: { OutPoint: splitOutPoint, Owner: tokenIssuer },
      scheme,
      destinations: [
        {
          Satoshis: config.satoshis,
          To: issuer.Address,
        },
      ],
      feeRate: FeeRate,
    });

    const contractTx = TransactionReader.readHex(contractTxHex);
    const issueTx = TransactionReader.readHex(issueTxHex);

    console.log(`  Contract TX: ${contractTx.Id}`);
    console.log(`  Issue TX: ${issueTx.Id}`);
    console.log(`  Token outputs:`);
    for (let j = 0; j < issueTx.Outputs.length; j++) {
      console.log(
        `    [${j}] ${issueTx.Outputs[j].Satoshis} sats (type: ${issueTx.Outputs[j].ScriptType})`,
      );
    }

    await broadcast(contractTxHex, `${config.symbol} Contract TX`);
    await sleep(1000);
    await broadcast(issueTxHex, `${config.symbol} Issue TX`);
    await sleep(1000);

    const feeOutputIndex = issueTx.Outputs.length - 1;

    issuedTokens.push({
      symbol: config.symbol,
      name: config.name,
      tokenId: toHex(tokenIssuer.Address.Hash160),
      contractTxId: contractTx.Id,
      issueTxId: issueTx.Id,
      stasOutPoint: {
        txId: issueTx.Id,
        vout: 0,
        satoshis: issueTx.Outputs[0].Satoshis,
      },
      feeOutPoint: {
        txId: issueTx.Id,
        vout: feeOutputIndex,
        satoshis: issueTx.Outputs[feeOutputIndex].Satoshis,
      },
      issuerPath: config.pathIndex,
      scheme: {
        name: config.name,
        tokenId: toHex(tokenIssuer.Address.Hash160),
        symbol: config.symbol,
        satoshisPerToken: 1,
        freeze: config.freeze,
        confiscation: config.freeze,
        isDivisible: true,
      },
    });
  }

  console.log("\n\n=== 発行結果サマリ ===\n");
  console.log(
    JSON.stringify(
      {
        mnemonic: MNEMONIC,
        wallets: wallets.map((w, i) => ({
          path: `m/44'/236'/0'/0/${i}`,
          address: w.Address.Value,
          hash160: toHex(w.Address.Hash160),
          publicKey: toHex(w.PublicKey),
        })),
        splitTxId: splitTx.Id,
        tokens: issuedTokens,
      },
      null,
      2,
    ),
  );

  console.log("\n=== 完了 ===");
}

main().catch(console.error);
</file>


      if (!bridgeDestAddress || !bridgeDestAddress.startsWith('0x')) { showToast('Enter valid ETH destination address (0x...)', 'error'); setBridgeLoading(false); return }
      const result = await bridgeUnwrap(wallet.address, tokenId, amount, wif, bridgeDestAddress, ethNetwork)
      setBridgeHistory(prev => [result, ...prev])
      showToast(`Unwrap submitted: ${result.token_symbol} → ETH address`, 'success')
      setBridgeAmount('')
      setBridgeDestAddress('')

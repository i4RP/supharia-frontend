        item.insert("created_at".into(), AttributeValue::S(lp.created_at.clone()));
        item.insert("updated_at".into(), AttributeValue::S(lp.updated_at.clone()));

        self.client.put_item()
            .table_name(LP_POSITIONS_TABLE)
            .set_item(Some(item))
            .send()
            .await
            .map_err(|e| format!("put_lp_position error: {}", e))?;

        Ok(())
    }

    pub async fn get_lp_position(&self, pool_id: &str, user_address: &str) -> Result<Option<LpPosition>, String> {
        let result = self.client.get_item()
            .table_name(LP_POSITIONS_TABLE)
            .key("pool_id", AttributeValue::S(pool_id.to_string()))
            .key("user_address", AttributeValue::S(user_address.to_string()))
            .send()
            .await
            .map_err(|e| format!("get_lp_position error: {}", e))?;

        match result.item {
            Some(item) => {
                let lp = LpPosition {
                    pool_id: get_s(&item, "pool_id")?,
                    user_address: get_s(&item, "user_address")?,
                    lp_shares: get_f(&item, "lp_shares")?,
                    deposited_a: get_n(&item, "deposited_a")?,
                    deposited_b: get_n(&item, "deposited_b")?,
                    created_at: get_s(&item, "created_at")?,
                    updated_at: get_s(&item, "updated_at")?,
                };
                Ok(Some(lp))
            }
            None => Ok(None),
        }
    }

    pub async fn list_lp_positions(&self, pool_id: &str) -> Result<Vec<LpPosition>, String> {
        let result = self.client.query()
            .table_name(LP_POSITIONS_TABLE)
            .key_condition_expression("pool_id = :pid")
            .expression_attribute_values(":pid", AttributeValue::S(pool_id.to_string()))

<file path="backend/dstas-amm/src/crypto/keys.rs">
use secp256k1::{Secp256k1, SecretKey, PublicKey, Message};
use secp256k1::ecdsa::Signature;
use crate::crypto::hashes::{hash160, double_sha256};

#[derive(Clone)]
pub struct PrivKey {
    secret: SecretKey,
    compressed: bool,
}

impl PrivKey {
    pub fn from_bytes(bytes: &[u8]) -> Result<Self, String> {
        let secret = SecretKey::from_slice(bytes)
            .map_err(|e| format!("Invalid private key: {}", e))?;
        Ok(Self { secret, compressed: true })
    }

    pub fn from_wif(wif: &str) -> Result<Self, String> {
        let decoded = bs58::decode(wif)
            .with_check(None)
            .into_vec()
            .map_err(|e| format!("Invalid WIF: {}", e))?;
        if decoded[0] != 0x80 {
            return Err("Invalid WIF version byte (not mainnet)".to_string());
        }
        let (key_bytes, compressed) = if decoded.len() == 34 && decoded[33] == 0x01 {
            (&decoded[1..33], true)
        } else if decoded.len() == 33 {
            (&decoded[1..33], false)
        } else {
            return Err("Invalid WIF format".to_string());
        };
        let secret = SecretKey::from_slice(key_bytes)
            .map_err(|e| format!("Invalid key bytes: {}", e))?;
        Ok(Self { secret, compressed })
    }

    pub fn to_wif(&self) -> String {
        let mut payload = Vec::with_capacity(34);
        payload.push(0x80);
        payload.extend_from_slice(&self.secret[..]);
        if self.compressed {
            payload.push(0x01);
        }
        bs58::encode(&payload).with_check().into_string()
    }

    pub fn public_key(&self) -> PubKey {
        let secp = Secp256k1::new();
        let pk = PublicKey::from_secret_key(&secp, &self.secret);
        PubKey { key: pk, compressed: self.compressed }
    }

    pub fn secret_key(&self) -> &SecretKey {
        &self.secret
    }

    pub fn sign(&self, msg_hash: &[u8; 32]) -> Vec<u8> {
        let secp = Secp256k1::new();
        let message = Message::from_digest(*msg_hash);
        let sig = secp.sign_ecdsa(&message, &self.secret);
        sig.serialize_der().to_vec()
    }

    pub fn sign_tx_input(
        &self,
        sighash: &[u8; 32],
        sighash_type: u8,
    ) -> Vec<u8> {
        let mut sig = self.sign(sighash);
        sig.push(sighash_type);
        sig
    }
}

#[derive(Clone)]
pub struct PubKey {
    key: PublicKey,
    compressed: bool,
}

impl PubKey {
    pub fn to_bytes(&self) -> Vec<u8> {
        if self.compressed {
            self.key.serialize().to_vec()
        } else {
            self.key.serialize_uncompressed().to_vec()
        }
    }

    pub fn hash160(&self) -> [u8; 20] {
        hash160(&self.to_bytes())
    }

    pub fn address(&self) -> String {
        let pkh = self.hash160();
        let mut payload = Vec::with_capacity(21);
        payload.push(0x00);
        payload.extend_from_slice(&pkh);
        bs58::encode(&payload).with_check().into_string()
    }

    pub fn inner(&self) -> &PublicKey {
        &self.key
    }
}

use reqwest::Client;
use serde::{Serialize, Deserialize};

const WOC_MAINNET: &str = "https://api.whatsonchain.com/v1/bsv/main";
const WOC_TESTNET: &str = "https://api.whatsonchain.com/v1/bsv/test";

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct WocUtxo {
    pub tx_hash: String,
    pub tx_pos: u32,
    pub value: u64,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct TokenUtxo {
    pub tx_hash: String,
    pub tx_pos: u32,
    pub value: u64,
    pub token_id: String,
    pub satoshis: u64,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct OnChainBalance {
    pub address: String,
    pub bsv_balance: u64,
    pub token_balances: Vec<TokenBalance>,
    pub utxo_count: usize,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct TokenBalance {
    pub token_id: String,
    pub total_satoshis: u64,
    pub utxo_count: usize,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct TxConfirmation {
    pub txid: String,
    pub confirmed: bool,
    pub block_height: Option<u64>,
    pub confirmations: u64,
}

#[derive(Clone)]
pub struct WocClient {
    client: Client,
    base_url: String,
}

impl WocClient {
    pub fn new() -> Self {
        Self {
            client: Client::new(),
            base_url: WOC_MAINNET.to_string(),
        }
    }

    pub fn new_testnet() -> Self {
        Self {
            client: Client::new(),
            base_url: WOC_TESTNET.to_string(),
        }
    }

    pub fn for_network(is_testnet: bool) -> Self {
        if is_testnet { Self::new_testnet() } else { Self::new() }
    }

    pub fn is_testnet(&self) -> bool {
        self.base_url.contains("/test")
    }

    pub async fn get_utxos(&self, address: &str) -> Result<Vec<WocUtxo>, String> {
        let url = format!("{}/address/{}/unspent", self.base_url, address);
        let resp = self.client.get(&url)
            .send()
            .await
            .map_err(|e| format!("WoC get_utxos error: {}", e))?;

        if !resp.status().is_success() {
            return Err(format!("WoC get_utxos status: {}", resp.status()));
        }

        let utxos: Vec<WocUtxo> = resp.json().await
            .map_err(|e| format!("WoC parse error: {}", e))?;

        Ok(utxos)
    }

    pub async fn get_tx_hex(&self, txid: &str) -> Result<String, String> {
        let url = format!("{}/tx/{}/hex", self.base_url, txid);
        let resp = self.client.get(&url)
            .send()
            .await
            .map_err(|e| format!("WoC get_tx_hex error: {}", e))?;

        if !resp.status().is_success() {
            return Err(format!("WoC get_tx_hex status: {}", resp.status()));
        }

        resp.text().await
            .map_err(|e| format!("WoC text error: {}", e))
    }

    pub async fn get_tx_status(&self, txid: &str) -> Result<TxConfirmation, String> {
        let url = format!("{}/tx/{}", self.base_url, txid);
        let resp = self.client.get(&url)
            .send()
            .await
            .map_err(|e| format!("WoC get_tx_status error: {}", e))?;

        if !resp.status().is_success() {
            return Ok(TxConfirmation {
                txid: txid.to_string(),
                confirmed: false,
                block_height: None,
                confirmations: 0,
            });
        }

        let json: serde_json::Value = resp.json().await
            .map_err(|e| format!("WoC parse error: {}", e))?;

        let confirmations = json.get("confirmations")
            .and_then(|v| v.as_u64())
            .unwrap_or(0);

        let block_height = json.get("blockheight")
            .and_then(|v| v.as_u64());

        Ok(TxConfirmation {
            txid: txid.to_string(),
            confirmed: confirmations > 0,
            block_height,
            confirmations,
        })
    }

    pub async fn scan_token_utxos(&self, address: &str, known_token_ids: &[String]) -> Result<Vec<TokenUtxo>, String> {
        let utxos = self.get_utxos(address).await?;
        let mut token_utxos = Vec::new();

        for utxo in &utxos {
            match self.get_tx_hex(&utxo.tx_hash).await {
                Ok(hex) => {
                    for token_id in known_token_ids {
                        if hex.contains(token_id) {
                            token_utxos.push(TokenUtxo {
                                tx_hash: utxo.tx_hash.clone(),
                                tx_pos: utxo.tx_pos,
                                value: utxo.value,
                                token_id: token_id.clone(),
                                satoshis: utxo.value,
                            });
                            break;
                        }
                    }
                }
                Err(_) => continue,
            }
        }

        Ok(token_utxos)
    }

    pub async fn get_on_chain_balance(&self, address: &str, known_token_ids: &[String]) -> Result<OnChainBalance, String> {
        let utxos = self.get_utxos(address).await?;
        let bsv_balance: u64 = utxos.iter().map(|u| u.value).sum();

        let mut token_map: std::collections::HashMap<String, (u64, usize)> = std::collections::HashMap::new();

        for utxo in &utxos {
            if let Ok(hex) = self.get_tx_hex(&utxo.tx_hash).await {
                for token_id in known_token_ids {
                    if hex.contains(token_id) {
                        let entry = token_map.entry(token_id.clone()).or_insert((0, 0));
                        entry.0 += utxo.value;
                        entry.1 += 1;
                        break;
                    }
                }
            }
        }

        let token_balances: Vec<TokenBalance> = token_map.into_iter().map(|(token_id, (total, count))| {
            TokenBalance {
                token_id,
                total_satoshis: total,
                utxo_count: count,
            }
        }).collect();

        Ok(OnChainBalance {
            address: address.to_string(),
            bsv_balance,
            token_balances,
            utxo_count: utxos.len(),
        })
    }

    pub async fn broadcast(&self, tx_hex: &str) -> Result<String, String> {
        let url = format!("{}/tx/raw", self.base_url);
        let resp = self.client.post(&url)
            .json(&serde_json::json!({ "txhex": tx_hex }))
            .send()
            .await
            .map_err(|e| format!("WoC broadcast error: {}", e))?;

        let text = resp.text().await
            .map_err(|e| format!("WoC broadcast text error: {}", e))?;

        let cleaned = text.replace('"', "").trim().to_string();

        if cleaned.len() == 64 && cleaned.chars().all(|c| c.is_ascii_hexdigit()) {
            return Ok(cleaned);
        }

        if cleaned.contains("mempool") || cleaned.contains("already known") {
            return Ok("broadcast_accepted".to_string());
        }

        Err(format!("Broadcast failed: {}", cleaned))
    }

    pub async fn get_balance(&self, address: &str) -> Result<u64, String> {
        let utxos = self.get_utxos(address).await?;
        Ok(utxos.iter().map(|u| u.value).sum())
    }

    pub async fn verify_tx_to_address(&self, txid: &str, to_address: &str) -> Result<bool, String> {
        let url = format!("{}/tx/{}", self.base_url, txid);
        let resp = self.client.get(&url)
            .send()
            .await
            .map_err(|e| format!("WoC verify error: {}", e))?;

        if !resp.status().is_success() {
            return Ok(false);
        }

        let json: serde_json::Value = resp.json().await
            .map_err(|e| format!("WoC parse error: {}", e))?;

        if let Some(vouts) = json.get("vout").and_then(|v| v.as_array()) {
            for vout in vouts {
                if let Some(addresses) = vout
                    .get("scriptPubKey")
                    .and_then(|s| s.get("addresses"))
                    .and_then(|a| a.as_array())
                {
                    for addr in addresses {
                        if addr.as_str() == Some(to_address) {
                            return Ok(true);
                        }
                    }
                }
            }
        }

        Ok(false)
    }
}

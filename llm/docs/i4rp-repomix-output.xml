async fn get_swap_quote(
    State(state): State<AppState>,
    Path(pool_id): Path<String>,
    Json(req): Json<SwapQuoteRequest>,
) -> (StatusCode, Json<ApiResponse<SwapQuoteResponse>>) {
    let pool = match state.db.get_pool(&pool_id).await {
        Ok(Some(p)) => p,
        Ok(None) => return err_response(StatusCode::NOT_FOUND, "Pool not found"),
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };

    if pool.reserve_a == 0 || pool.reserve_b == 0 {
        return err_response(StatusCode::BAD_REQUEST, "Pool has no liquidity");
    }

    if req.input_amount == 0 {
        return err_response(StatusCode::BAD_REQUEST, "Input amount must be greater than zero");
    }

    let input_is_a = req.input_token == pool.token_a_symbol || req.input_token == pool.token_a_id;

    let input_reserve = if input_is_a { pool.reserve_a } else { pool.reserve_b };
    if req.input_amount > input_reserve * 10 {
        return err_response(StatusCode::BAD_REQUEST, "Input amount too large relative to pool reserves");
    }

    let ps = PoolState::new(pool.reserve_a, pool.reserve_b);
    let quote = ps.quote_swap(input_is_a, req.input_amount);

    if quote.output_amount == 0 {
        return err_response(StatusCode::BAD_REQUEST, "Swap would produce zero output; input too small relative to pool ratio");
    }

    let output_token = if input_is_a {
        pool.token_b_symbol.clone()
    } else {
        pool.token_a_symbol.clone()
    };

    let slippage = 0.005;
    let min_received = (quote.output_amount as f64 * (1.0 - slippage)) as u64;

    ok_response(SwapQuoteResponse {
        input_token: req.input_token,
        input_amount: req.input_amount,
        output_token,
        output_amount: quote.output_amount,
        fee_amount: quote.fee_amount,
        price_impact: quote.price_impact,
        minimum_received: min_received,
    })
}

async fn execute_swap(
    State(state): State<AppState>,
    Path(pool_id): Path<String>,
    Json(req): Json<ExecuteSwapRequest>,
) -> (StatusCode, Json<ApiResponse<ExecuteSwapResponse>>) {
    tracing::info!(pool_id = %pool_id, input_token = %req.input_token, input_amount = %req.input_amount, "execute_swap");
    let pool = match state.db.get_pool(&pool_id).await {
        Ok(Some(p)) => p,
        Ok(None) => return err_response(StatusCode::NOT_FOUND, "Pool not found"),
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };

    if pool.reserve_a == 0 || pool.reserve_b == 0 {
        return err_response(StatusCode::BAD_REQUEST, "Pool has no liquidity");
    }

    if req.input_amount == 0 {
        return err_response(StatusCode::BAD_REQUEST, "Input amount must be greater than zero");
    }

    let user_wallet = match wallet_from_wif(&req.user_wif) {
        Ok(w) => w,
        Err(e) => return err_response(StatusCode::BAD_REQUEST, &format!("Invalid WIF: {}", e)),
    };

    let input_is_a = req.input_token == pool.token_a_symbol || req.input_token == pool.token_a_id;

    let input_reserve = if input_is_a { pool.reserve_a } else { pool.reserve_b };
    if req.input_amount > input_reserve * 10 {
        return err_response(StatusCode::BAD_REQUEST, "Input amount too large relative to pool reserves");
    }

    let mut ps = PoolState {
        reserve_a: pool.reserve_a,
        reserve_b: pool.reserve_b,
        k: pool.k,
        total_lp_shares: pool.total_lp_shares,
        fee_rate: pool.fee_rate,
    };
    let quote = ps.quote_swap(input_is_a, req.input_amount);

    if quote.output_amount == 0 {
        return err_response(StatusCode::BAD_REQUEST, "Swap would produce zero output; input too small relative to pool ratio");
    }

    if let Some(min) = req.min_output_amount {
        if quote.output_amount < min {
            return err_response(StatusCode::BAD_REQUEST,
                &format!("Slippage too high: output {} < min {}", quote.output_amount, min));
        }
    }

    ps.apply_swap(input_is_a, &quote);

    let old_version = pool.version;
    let mut updated_pool = pool.clone();
    updated_pool.reserve_a = ps.reserve_a;
    updated_pool.reserve_b = ps.reserve_b;
    updated_pool.k = ps.k;
    updated_pool.version = old_version + 1;

    if let Err(e) = state.db.update_pool_optimistic(&updated_pool, old_version).await {
        return err_response(StatusCode::CONFLICT, &e);
    }

    let (output_token, input_token) = if input_is_a {
        (pool.token_b_symbol.clone(), pool.token_a_symbol.clone())
    } else {
        (pool.token_a_symbol.clone(), pool.token_b_symbol.clone())
    };

    let pool_wallet = match derive_pool_wallet(&state.pool_master_seed, &pool_id) {
        Ok(w) => w,
        Err(e) => {
            tracing::error!(error = %e, "derive_pool_wallet failed for settlement");
            return err_response(StatusCode::INTERNAL_SERVER_ERROR, &format!("Pool wallet error: {}", e));
        }
    };

    let meta = SettlementMeta {
        op_type: "swap".to_string(),
        pool_id: pool_id.clone(),
        user_address: user_wallet.address.clone(),
        input_token: input_token.clone(),
        input_amount: req.input_amount,
        output_token: output_token.clone(),
        output_amount: quote.output_amount,
        fee_amount: quote.fee_amount,
    };

    let (settlement_status, onchain_tx_ids) = match state.settlement.settle_operation(&pool_wallet, &meta).await {
        Ok(result) => {
            tracing::info!(txid = %result.txid, fee = %result.fee_paid, "swap settled on-chain");
            ("broadcast".to_string(), vec![result.txid])
        }
        Err(e) => {
            tracing::warn!(error = %e, "on-chain settlement failed, recorded as pending");
            ("pending".to_string(), vec![])
        }
    };

    let tx_id = if !onchain_tx_ids.is_empty() {
        onchain_tx_ids[0].clone()
    } else {
        format!("pending-{}", Uuid::new_v4())
    };

    let now = Utc::now().to_rfc3339();
    let swap_tx = SwapTransaction {
        tx_id: tx_id.clone(),
        pool_id: pool_id.clone(),
        tx_type: "swap".to_string(),
        user_address: user_wallet.address,
        input_token: input_token.clone(),
        input_amount: req.input_amount,
        output_token: output_token.clone(),
        output_amount: quote.output_amount,
        fee_amount: quote.fee_amount,
        timestamp: now.clone(),
        settlement_status,
        onchain_tx_ids: onchain_tx_ids.clone(),
    };
    let _ = state.db.put_transaction(&swap_tx).await;

    let new_ps = PoolState::new(ps.reserve_a, ps.reserve_b);
    let (vol_a, vol_b) = if input_is_a {
        (req.input_amount, quote.output_amount)
    } else {
        (quote.output_amount, req.input_amount)
    };
    let _ = state.db.put_price_snapshot(&PriceSnapshot {
        pool_id: pool_id.clone(),
        timestamp: now,
        price_a_in_b: new_ps.price_a_in_b(),
        price_b_in_a: new_ps.price_b_in_a(),
        reserve_a: ps.reserve_a,
        reserve_b: ps.reserve_b,
        tvl: new_ps.tvl(),
        volume_a: vol_a,
        volume_b: vol_b,
        event_type: "swap".to_string(),
    }).await;

    ok_response(ExecuteSwapResponse {
        input_token,
        input_amount: req.input_amount,
        output_token,
        output_amount: quote.output_amount,
        fee_amount: quote.fee_amount,
        tx_ids: vec![tx_id],
    })
}

async fn add_liquidity(
    State(state): State<AppState>,
    Path(pool_id): Path<String>,
    Json(req): Json<AddLiquidityRequest>,
) -> (StatusCode, Json<ApiResponse<AddLiquidityResponse>>) {
    tracing::info!(pool_id = %pool_id, amount_a = %req.amount_a, amount_b = %req.amount_b, "add_liquidity");
    let pool = match state.db.get_pool(&pool_id).await {
        Ok(Some(p)) => p,
        Ok(None) => return err_response(StatusCode::NOT_FOUND, "Pool not found"),
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };

    let user_wallet = match wallet_from_wif(&req.user_wif) {
        Ok(w) => w,
        Err(e) => return err_response(StatusCode::BAD_REQUEST, &format!("Invalid WIF: {}", e)),
    };

    let mut ps = PoolState {
        reserve_a: pool.reserve_a,
        reserve_b: pool.reserve_b,
        k: pool.k,
        total_lp_shares: pool.total_lp_shares,
        fee_rate: pool.fee_rate,
    };

    let mint = ps.calculate_lp_shares(req.amount_a, req.amount_b);
    ps.add_liquidity(&mint);

    let old_version = pool.version;
    let mut updated_pool = pool.clone();
    updated_pool.reserve_a = ps.reserve_a;
    updated_pool.reserve_b = ps.reserve_b;
    updated_pool.k = ps.k;
    updated_pool.total_lp_shares = ps.total_lp_shares;
    updated_pool.version = old_version + 1;

    if let Err(e) = state.db.update_pool_optimistic(&updated_pool, old_version).await {
        return err_response(StatusCode::CONFLICT, &e);
    }

    let existing_lp = state.db.get_lp_position(&pool_id, &user_wallet.address).await
        .unwrap_or(None);

    let now = Utc::now().to_rfc3339();
    let lp = LpPosition {
        pool_id: pool_id.clone(),
        user_address: user_wallet.address.clone(),
        lp_shares: existing_lp.as_ref().map_or(0.0, |l| l.lp_shares) + mint.shares_minted,
        deposited_a: existing_lp.as_ref().map_or(0, |l| l.deposited_a) + mint.amount_a_used,
        deposited_b: existing_lp.as_ref().map_or(0, |l| l.deposited_b) + mint.amount_b_used,
        created_at: existing_lp.map_or_else(|| now.clone(), |l| l.created_at),
        updated_at: now,
    };

    if let Err(e) = state.db.put_lp_position(&lp).await {
        return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e);
    }

    let share_of_pool = if ps.total_lp_shares > 0.0 {
        lp.lp_shares / ps.total_lp_shares * 100.0
    } else {
        0.0
    };

    let pool_wallet = match derive_pool_wallet(&state.pool_master_seed, &pool_id) {
        Ok(w) => w,
        Err(e) => {
            tracing::error!(error = %e, "derive_pool_wallet failed for add_liquidity settlement");
            return err_response(StatusCode::INTERNAL_SERVER_ERROR, &format!("Pool wallet error: {}", e));
        }
    };

    let meta = SettlementMeta {
        op_type: "add_liquidity".to_string(),
        pool_id: pool_id.clone(),
        user_address: lp.user_address.clone(),
        input_token: pool.token_a_symbol.clone(),
        input_amount: mint.amount_a_used,
        output_token: pool.token_b_symbol.clone(),
        output_amount: mint.amount_b_used,
        fee_amount: 0,
    };

    let (settlement_status, onchain_tx_ids) = match state.settlement.settle_operation(&pool_wallet, &meta).await {
        Ok(result) => {
            tracing::info!(txid = %result.txid, fee = %result.fee_paid, "add_liquidity settled on-chain");
            ("broadcast".to_string(), vec![result.txid])
        }
        Err(e) => {
            tracing::warn!(error = %e, "add_liquidity on-chain settlement failed");
            ("pending".to_string(), vec![])
        }
    };

    let tx_id = if !onchain_tx_ids.is_empty() {
        onchain_tx_ids[0].clone()
    } else {
        format!("pending-{}", Uuid::new_v4())
    };

    let now_tx = Utc::now().to_rfc3339();
    let add_tx = SwapTransaction {
        tx_id: tx_id.clone(),
        pool_id: pool_id.clone(),
        tx_type: "add_liquidity".to_string(),
        user_address: lp.user_address.clone(),
        input_token: pool.token_a_symbol.clone(),
        input_amount: mint.amount_a_used,
        output_token: pool.token_b_symbol.clone(),
        output_amount: mint.amount_b_used,
        fee_amount: 0,
        timestamp: now_tx,
        settlement_status,
        onchain_tx_ids: onchain_tx_ids.clone(),
    };
    let _ = state.db.put_transaction(&add_tx).await;

    let new_ps = PoolState::new(ps.reserve_a, ps.reserve_b);
    let _ = state.db.put_price_snapshot(&PriceSnapshot {
        pool_id: pool_id.clone(),
        timestamp: Utc::now().to_rfc3339(),
        price_a_in_b: new_ps.price_a_in_b(),
        price_b_in_a: new_ps.price_b_in_a(),
        reserve_a: ps.reserve_a,
        reserve_b: ps.reserve_b,
        tvl: new_ps.tvl(),
        volume_a: mint.amount_a_used,
        volume_b: mint.amount_b_used,
        event_type: "add_liquidity".to_string(),
    }).await;

    ok_response(AddLiquidityResponse {
        lp_shares_minted: mint.shares_minted,
        amount_a_deposited: mint.amount_a_used,
        amount_b_deposited: mint.amount_b_used,
        share_of_pool,
        tx_ids: vec![tx_id],
    })
}

async fn remove_liquidity(
    State(state): State<AppState>,
    Path(pool_id): Path<String>,
    Json(req): Json<RemoveLiquidityRequest>,
) -> (StatusCode, Json<ApiResponse<RemoveLiquidityResponse>>) {
    tracing::info!(pool_id = %pool_id, lp_share_percent = %req.lp_share_percent, "remove_liquidity");
    let pool = match state.db.get_pool(&pool_id).await {
        Ok(Some(p)) => p,
        Ok(None) => return err_response(StatusCode::NOT_FOUND, "Pool not found"),
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };

    let user_wallet = match wallet_from_wif(&req.user_wif) {
        Ok(w) => w,
        Err(e) => return err_response(StatusCode::BAD_REQUEST, &format!("Invalid WIF: {}", e)),
    };

    let lp = match state.db.get_lp_position(&pool_id, &user_wallet.address).await {
        Ok(Some(l)) => l,
        Ok(None) => return err_response(StatusCode::NOT_FOUND, "No LP position found"),
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };

    if lp.lp_shares <= 0.0 {
        return err_response(StatusCode::BAD_REQUEST, "No LP shares to remove");
    }

    if req.lp_share_percent <= 0.0 || req.lp_share_percent > 100.0 {
        return err_response(StatusCode::BAD_REQUEST, "lp_share_percent must be between 0 and 100");
    }

    let shares_to_burn = lp.lp_shares * (req.lp_share_percent / 100.0);
    let mut ps = PoolState {
        reserve_a: pool.reserve_a,
        reserve_b: pool.reserve_b,
        k: pool.k,
        total_lp_shares: pool.total_lp_shares,
        fee_rate: pool.fee_rate,
    };

    let burn = ps.calculate_remove_liquidity(shares_to_burn);
    ps.remove_liquidity(&burn);

    let old_version = pool.version;
    let mut updated_pool = pool.clone();
    updated_pool.reserve_a = ps.reserve_a;
    updated_pool.reserve_b = ps.reserve_b;
    updated_pool.k = ps.k;
    updated_pool.total_lp_shares = ps.total_lp_shares;
    updated_pool.version = old_version + 1;

    if let Err(e) = state.db.update_pool_optimistic(&updated_pool, old_version).await {
        return err_response(StatusCode::CONFLICT, &e);
    }

    let now = Utc::now().to_rfc3339();
    let updated_lp = LpPosition {
        pool_id: pool_id.clone(),
        user_address: user_wallet.address.clone(),
        lp_shares: lp.lp_shares - shares_to_burn,
        deposited_a: lp.deposited_a,
        deposited_b: lp.deposited_b,
        created_at: lp.created_at,
        updated_at: now,
    };

    if let Err(e) = state.db.put_lp_position(&updated_lp).await {
        return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e);
    }

    let pool_wallet = match derive_pool_wallet(&state.pool_master_seed, &pool_id) {
        Ok(w) => w,
        Err(e) => {
            tracing::error!(error = %e, "derive_pool_wallet failed for remove_liquidity settlement");
            return err_response(StatusCode::INTERNAL_SERVER_ERROR, &format!("Pool wallet error: {}", e));
        }
    };

    let meta = SettlementMeta {
        op_type: "remove_liquidity".to_string(),
        pool_id: pool_id.clone(),
        user_address: user_wallet.address.clone(),
        input_token: pool.token_a_symbol.clone(),
        input_amount: burn.amount_a,
        output_token: pool.token_b_symbol.clone(),
        output_amount: burn.amount_b,
        fee_amount: 0,
    };

    let (settlement_status, onchain_tx_ids) = match state.settlement.settle_operation(&pool_wallet, &meta).await {
        Ok(result) => {
            tracing::info!(txid = %result.txid, fee = %result.fee_paid, "remove_liquidity settled on-chain");
            ("broadcast".to_string(), vec![result.txid])
        }
        Err(e) => {
            tracing::warn!(error = %e, "remove_liquidity on-chain settlement failed");
            ("pending".to_string(), vec![])
        }
    };

    let tx_id = if !onchain_tx_ids.is_empty() {
        onchain_tx_ids[0].clone()
    } else {
        format!("pending-{}", Uuid::new_v4())
    };

    let now_tx = Utc::now().to_rfc3339();
    let remove_tx = SwapTransaction {
        tx_id: tx_id.clone(),
        pool_id: pool_id.clone(),
        tx_type: "remove_liquidity".to_string(),
        user_address: user_wallet.address.clone(),
        input_token: pool.token_a_symbol.clone(),
        input_amount: burn.amount_a,
        output_token: pool.token_b_symbol.clone(),
        output_amount: burn.amount_b,
        fee_amount: 0,
        timestamp: now_tx,
        settlement_status,
        onchain_tx_ids: onchain_tx_ids.clone(),
    };
    let _ = state.db.put_transaction(&remove_tx).await;

    let new_ps = PoolState::new(ps.reserve_a, ps.reserve_b);
    let _ = state.db.put_price_snapshot(&PriceSnapshot {
        pool_id: pool_id.clone(),
        timestamp: Utc::now().to_rfc3339(),
        price_a_in_b: new_ps.price_a_in_b(),
        price_b_in_a: new_ps.price_b_in_a(),
        reserve_a: ps.reserve_a,
        reserve_b: ps.reserve_b,
        tvl: new_ps.tvl(),
        volume_a: burn.amount_a,
        volume_b: burn.amount_b,
        event_type: "remove_liquidity".to_string(),
    }).await;

    ok_response(RemoveLiquidityResponse {
        lp_shares_burned: shares_to_burn,
        amount_a_received: burn.amount_a,
        amount_b_received: burn.amount_b,
        tx_ids: vec![tx_id],
    })
}

async fn get_lp_info(
    State(state): State<AppState>,
    Path((pool_id, address)): Path<(String, String)>,
) -> (StatusCode, Json<ApiResponse<LpInfo>>) {
    let pool = match state.db.get_pool(&pool_id).await {
        Ok(Some(p)) => p,
        Ok(None) => return err_response(StatusCode::NOT_FOUND, "Pool not found"),
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };

    let lp = match state.db.get_lp_position(&pool_id, &address).await {
        Ok(Some(l)) => l,
        Ok(None) => return err_response(StatusCode::NOT_FOUND, "No LP position"),
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };

    let share_ratio = if pool.total_lp_shares > 0.0 {
        lp.lp_shares / pool.total_lp_shares
    } else {
        0.0
    };

    let current_a = (pool.reserve_a as f64 * share_ratio) as u64;
    let current_b = (pool.reserve_b as f64 * share_ratio) as u64;

    let earned_a = if current_a > lp.deposited_a { current_a - lp.deposited_a } else { 0 };
    let earned_b = if current_b > lp.deposited_b { current_b - lp.deposited_b } else { 0 };

    ok_response(LpInfo {
        user_address: address,
        lp_shares: lp.lp_shares,
        share_of_pool: share_ratio * 100.0,
        deposited_a: lp.deposited_a,
        deposited_b: lp.deposited_b,
        current_value_a: current_a,
        current_value_b: current_b,
        earned_fees_a: earned_a,
        earned_fees_b: earned_b,
    })
}


.session-extend-btn { padding: 6px 16px; border-radius: 8px; border: 1px solid #eab308; background: rgba(234,179,8,0.2); color: #eab308; font-size: 0.78rem; font-weight: 600; cursor: pointer; transition: background 0.15s; white-space: nowrap; }
.session-extend-btn:hover { background: rgba(234,179,8,0.35); }
@keyframes slideDown { from { transform: translateX(-50%) translateY(-20px); opacity: 0; } to { transform: translateX(-50%) translateY(0); opacity: 1; } }

/* Notification Filters */

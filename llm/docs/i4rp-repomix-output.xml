    await sleep(1500);

    results.push({
      test: "Transfer back",
      token: "DSTAS",
      txId: transfer2Tx.Id,
      from: wallets[1].Address.Value,
      to: addr0.Address.Value,
      status: "SUCCESS",
    });

    // ========== TEST 3: SPLIT ==========
    console.log("\n--- Test 3: DSTAS Split (10000 → 6000 + 4000) ---");
    const stasOP3 = new OutPoint(
      transfer2Tx.Id,
      0,
      transfer2Tx.Outputs[0].LockignScript,
      transfer2Tx.Outputs[0].Satoshis,
      addr0.Address,
      ScriptType.dstas,
    );
    stasOP3.Transaction = transfer2Tx;

    const feeOP3 = new OutPoint(
      transfer2Tx.Id,
      1,
      transfer2Tx.Outputs[1].LockignScript,
      transfer2Tx.Outputs[1].Satoshis,
      addr0.Address,
      ScriptType.p2pkh,
    );

    const splitTxHex = BuildDstasSplitTx({
      stasPayment: { OutPoint: stasOP3, Owner: addr0 },
      feePayment: { OutPoint: feeOP3, Owner: addr0 },
      Scheme: scheme,
      destinations: [
        { Satoshis: 6000, To: addr0.Address },
        { Satoshis: 4000, To: wallets[1].Address },
      ],

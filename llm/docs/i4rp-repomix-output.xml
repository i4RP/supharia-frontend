<file path="backend/dstas-amm/src/crypto/address.rs">
use crate::crypto::hashes::hash160;

pub fn pubkey_hash_to_address(pkh: &[u8; 20]) -> String {
    let mut payload = Vec::with_capacity(21);
    payload.push(0x00);
    payload.extend_from_slice(pkh);
    bs58::encode(&payload).with_check().into_string()
}

pub fn pubkey_hash_to_testnet_address(pkh: &[u8; 20]) -> String {
    let mut payload = Vec::with_capacity(21);
    payload.push(0x6f); // testnet version
    payload.extend_from_slice(pkh);
    bs58::encode(&payload).with_check().into_string()
}

pub fn address_to_pubkey_hash(address: &str) -> Result<[u8; 20], String> {
    let decoded = bs58::decode(address)
        .with_check(None)
        .into_vec()
        .map_err(|e| format!("Invalid address: {}", e))?;
    if decoded.len() != 21 || decoded[0] != 0x00 {
        return Err("Invalid mainnet address".to_string());
    }
    let mut pkh = [0u8; 20];
    pkh.copy_from_slice(&decoded[1..21]);
    Ok(pkh)
}

async fn check_limit_orders(
    State(state): State<AppState>,
    Path(pool_id): Path<String>,
) -> (StatusCode, Json<ApiResponse<Vec<LimitOrderInfo>>>) {
    let pool = match state.db.get_pool(&pool_id).await {
        Ok(Some(p)) => p,
        Ok(None) => return err_response(StatusCode::NOT_FOUND, "Pool not found"),
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };
    let orders = match state.db.list_limit_orders(&pool_id).await {
        Ok(o) => o,
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };
    let now_dt = Utc::now();
    let now = now_dt.to_rfc3339();
    let current_price_a_in_b = if pool.reserve_a > 0 { pool.reserve_b as f64 / pool.reserve_a as f64 } else { 0.0 };
    let current_price_b_in_a = if pool.reserve_b > 0 { pool.reserve_a as f64 / pool.reserve_b as f64 } else { 0.0 };
    let mut filled = Vec::new();
    let mut current_pool = pool.clone();
    for mut order in orders {
        if order.status != "open" { continue; }
        if now > order.expires_at {
            order.status = "expired".to_string();
            let _ = state.db.put_limit_order(&order).await;
            continue;
        }
        let current_price = if order.input_token == current_pool.token_a_id {
            current_price_a_in_b
        } else {
            current_price_b_in_a
        };
        if current_price >= order.target_price {
            let input_is_a = order.input_token == current_pool.token_a_id;
            let mut ps = PoolState {
                reserve_a: current_pool.reserve_a,
                reserve_b: current_pool.reserve_b,
                k: current_pool.k,
                total_lp_shares: current_pool.total_lp_shares,
                fee_rate: current_pool.fee_rate,
            };
            let quote = ps.quote_swap(input_is_a, order.input_amount);
            if quote.output_amount == 0 {
                continue;
            }
            ps.apply_swap(input_is_a, &quote);
            let old_version = current_pool.version;
            current_pool.reserve_a = ps.reserve_a;
            current_pool.reserve_b = ps.reserve_b;
            current_pool.k = ps.k;
            current_pool.version = old_version + 1;
            if let Err(_e) = state.db.update_pool_optimistic(&current_pool, old_version).await {
                continue;
            }
            let pool_wallet = match derive_pool_wallet(&state.pool_master_seed, &pool_id) {
                Ok(w) => w,
                Err(_) => continue,
            };
            let (output_token_sym, input_token_sym) = if input_is_a {
                (current_pool.token_b_symbol.clone(), current_pool.token_a_symbol.clone())
            } else {
                (current_pool.token_a_symbol.clone(), current_pool.token_b_symbol.clone())
            };
            let meta = SettlementMeta {
                op_type: "limit-order-fill".to_string(),
                pool_id: pool_id.clone(),
                user_address: order.user_address.clone(),
                input_token: input_token_sym.clone(),
                input_amount: order.input_amount,
                output_token: output_token_sym.clone(),
                output_amount: quote.output_amount,
                fee_amount: quote.fee_amount,
            };
            let (settlement_status, onchain_tx_id) = match state.settlement.settle_operation(&pool_wallet, &meta).await {
                Ok(result) => {
                    tracing::info!(txid = %result.txid, order_id = %order.order_id, "limit order filled on-chain");
                    ("broadcast".to_string(), result.txid)
                }
                Err(e) => {
                    tracing::warn!(error = %e, order_id = %order.order_id, "limit order settlement failed");
                    ("pending".to_string(), String::new())
                }
            };
            let tx_id = if !onchain_tx_id.is_empty() {
                onchain_tx_id.clone()
            } else {
                format!("limit-pending-{}", Uuid::new_v4())
            };
            let swap_tx = SwapTransaction {
                tx_id: tx_id.clone(),
                pool_id: pool_id.clone(),
                tx_type: "limit-order-fill".to_string(),
                user_address: order.user_address.clone(),
                input_token: input_token_sym,
                input_amount: order.input_amount,
                output_token: output_token_sym,
                output_amount: quote.output_amount,
                fee_amount: quote.fee_amount,
                timestamp: now.clone(),
                settlement_status: settlement_status.clone(),
                onchain_tx_ids: if onchain_tx_id.is_empty() { vec![] } else { vec![onchain_tx_id.clone()] },
            };
            let _ = state.db.put_transaction(&swap_tx).await;
            order.status = "filled".to_string();
            order.filled_amount = order.input_amount;
            order.output_amount = quote.output_amount;
            order.onchain_tx_id = onchain_tx_id;
            order.settlement_status = settlement_status;
            order.execution_timestamp = now.clone();
            let _ = state.db.put_limit_order(&order).await;
            filled.push(order_to_info(&order));
        }
    }
    ok_response(filled)
}

async fn find_route(
    State(state): State<AppState>,
    Json(req): Json<RouteQuoteRequest>,
) -> (StatusCode, Json<ApiResponse<RouteQuoteResponse>>) {
    if req.input_amount == 0 {
        return err_response(StatusCode::BAD_REQUEST, "input_amount must be > 0");
    }
    let pools = match state.db.list_pools().await {
        Ok(p) => p,
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };

    let mut adj: std::collections::HashMap<String, Vec<(String, String, String)>> = std::collections::HashMap::new();
    for pool in &pools {
        adj.entry(pool.token_a_id.clone()).or_default().push((pool.token_b_id.clone(), pool.pool_id.clone(), "a_to_b".into()));
        adj.entry(pool.token_b_id.clone()).or_default().push((pool.token_a_id.clone(), pool.pool_id.clone(), "b_to_a".into()));
    }

    use std::collections::BinaryHeap;
    use std::cmp::Ordering;

    #[derive(Clone)]
    struct DijkstraNode {
        output_amount: u64,
        token: String,
        hops: Vec<RouteHop>,
        path: Vec<String>,
        visited: std::collections::HashSet<String>,
    }

    impl Eq for DijkstraNode {}
    impl PartialEq for DijkstraNode {
        fn eq(&self, other: &Self) -> bool {
            self.output_amount == other.output_amount
        }
    }
    impl PartialOrd for DijkstraNode {
        fn partial_cmp(&self, other: &Self) -> Option<Ordering> {
            Some(self.cmp(other))
        }
    }
    impl Ord for DijkstraNode {
        fn cmp(&self, other: &Self) -> Ordering {
            self.output_amount.cmp(&other.output_amount)
        }
    }

    let mut best_output: std::collections::HashMap<String, u64> = std::collections::HashMap::new();
    let mut heap = BinaryHeap::new();
    let mut initial_visited = std::collections::HashSet::new();
    initial_visited.insert(req.input_token_id.clone());
    heap.push(DijkstraNode {
        output_amount: req.input_amount,
        token: req.input_token_id.clone(),
        hops: Vec::new(),
        path: vec![req.input_token_id.clone()],
        visited: initial_visited,
    });

    let mut best_route: Option<RouteQuoteResponse> = None;

    while let Some(node) = heap.pop() {
        if node.hops.len() > 3 { continue; }

        if let Some(&prev_best) = best_output.get(&node.token) {
            if node.output_amount <= prev_best && node.token != req.output_token_id {
                continue;
            }
        }
        best_output.insert(node.token.clone(), node.output_amount);

        if node.token == req.output_token_id && !node.hops.is_empty() {
            let total_fees: u64 = node.hops.iter().map(|h| h.fee_amount).sum();
            let total_impact = node.hops.iter().map(|h| h.price_impact).sum::<f64>();
            let route = RouteQuoteResponse {
                total_input: req.input_amount,
                total_output: node.output_amount,
                total_fees,
                total_price_impact: total_impact,
                hops: node.hops.clone(),
                path: node.path.clone(),
            };
            if best_route.as_ref().map_or(true, |b| route.total_output > b.total_output) {
                best_route = Some(route);
            }
            continue;
        }

        if let Some(neighbors) = adj.get(&node.token) {
            for (next_token, pool_id, direction) in neighbors {
                if node.visited.contains(next_token) { continue; }
                let pool = match pools.iter().find(|p| p.pool_id == *pool_id) {
                    Some(p) => p,
                    None => continue,
                };
                let is_a = direction == "a_to_b";
                let ps = PoolState::new(pool.reserve_a, pool.reserve_b);
                if node.output_amount == 0 { continue; }
                let quote = ps.quote_swap(is_a, node.output_amount);
                if quote.output_amount == 0 { continue; }

                if let Some(&prev_best) = best_output.get(next_token) {
                    if quote.output_amount <= prev_best { continue; }
                }

                let hop = RouteHop {
                    pool_id: pool_id.clone(),
                    pair: format!("{}/{}", pool.token_a_symbol, pool.token_b_symbol),
                    input_token: node.token.clone(),
                    output_token: next_token.clone(),
                    input_amount: node.output_amount,
                    output_amount: quote.output_amount,
                    fee_amount: quote.fee_amount,
                    price_impact: quote.price_impact,
                };
                let mut new_hops = node.hops.clone();
                new_hops.push(hop);
                let mut new_path = node.path.clone();
                new_path.push(next_token.clone());
                let mut new_visited = node.visited.clone();
                new_visited.insert(next_token.clone());
                heap.push(DijkstraNode {
                    output_amount: quote.output_amount,
                    token: next_token.clone(),
                    hops: new_hops,
                    path: new_path,
                    visited: new_visited,
                });
            }
        }
    }

    match best_route {
        Some(route) => ok_response(route),
        None => err_response(StatusCode::NOT_FOUND, "No route found between tokens"),
    }
}

async fn execute_swap_partial(
    State(state): State<AppState>,
    Path(pool_id): Path<String>,
    Json(req): Json<ExecuteSwapPartialRequest>,
) -> (StatusCode, Json<ApiResponse<PartialFillResponse>>) {
    let split_count = req.split_count.unwrap_or(1).max(1).min(10);
    let pool = match state.db.get_pool(&pool_id).await {
        Ok(Some(p)) => p,
        Ok(None) => return err_response(StatusCode::NOT_FOUND, "Pool not found"),
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };
    if pool.reserve_a == 0 || pool.reserve_b == 0 {
        return err_response(StatusCode::BAD_REQUEST, "Pool has no liquidity");
    }
    if req.input_amount == 0 {
        return err_response(StatusCode::BAD_REQUEST, "Input amount must be > 0");
    }
    let user_wallet = match wallet_from_wif(&req.user_wif) {
        Ok(w) => w,
        Err(e) => return err_response(StatusCode::BAD_REQUEST, &format!("Invalid WIF: {}", e)),
    };
    let input_is_a = req.input_token == pool.token_a_symbol || req.input_token == pool.token_a_id;
    let (output_token, input_token) = if input_is_a {
        (pool.token_b_symbol.clone(), pool.token_a_symbol.clone())
    } else {
        (pool.token_a_symbol.clone(), pool.token_b_symbol.clone())
    };

    let split_amount = req.input_amount / split_count as u64;
    let remainder = req.input_amount - split_amount * (split_count as u64 - 1);
    let mut splits = Vec::new();
    let mut total_output = 0u64;
    let mut total_fees = 0u64;
    let mut all_tx_ids = Vec::new();
    let mut current_pool = pool.clone();

    for i in 0..split_count {
        let this_input = if i == split_count - 1 { remainder } else { split_amount };
        if this_input == 0 { continue; }

        let mut ps = PoolState {
            reserve_a: current_pool.reserve_a,
            reserve_b: current_pool.reserve_b,
            k: current_pool.k,
            total_lp_shares: current_pool.total_lp_shares,
            fee_rate: current_pool.fee_rate,
        };
        let quote = ps.quote_swap(input_is_a, this_input);
        if quote.output_amount == 0 { continue; }
        ps.apply_swap(input_is_a, &quote);

        let old_version = current_pool.version;
        current_pool.reserve_a = ps.reserve_a;
        current_pool.reserve_b = ps.reserve_b;
        current_pool.k = ps.k;
        current_pool.version = old_version + 1;

        if let Err(e) = state.db.update_pool_optimistic(&current_pool, old_version).await {
            return err_response(StatusCode::CONFLICT, &e);
        }

        let pool_wallet = match derive_pool_wallet(&state.pool_master_seed, &pool_id) {
            Ok(w) => w,
            Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &format!("Pool wallet error: {}", e)),
        };
        let meta = SettlementMeta {
            op_type: "partial-fill".to_string(),
            pool_id: pool_id.clone(),
            user_address: user_wallet.address.clone(),
            input_token: input_token.clone(),
            input_amount: this_input,
            output_token: output_token.clone(),
            output_amount: quote.output_amount,
            fee_amount: quote.fee_amount,
        };
        let (settlement_status, onchain_tx_ids) = match state.settlement.settle_operation(&pool_wallet, &meta).await {
            Ok(result) => ("broadcast".to_string(), vec![result.txid]),
            Err(_e) => ("pending".to_string(), vec![]),
        };
        let tx_id = if !onchain_tx_ids.is_empty() {
            onchain_tx_ids[0].clone()
        } else {
            format!("partial-pending-{}", Uuid::new_v4())
        };
        let now = Utc::now().to_rfc3339();
        let swap_tx = SwapTransaction {
            tx_id: tx_id.clone(),
            pool_id: pool_id.clone(),
            tx_type: "partial-fill".to_string(),
            user_address: user_wallet.address.clone(),
            input_token: input_token.clone(),
            input_amount: this_input,
            output_token: output_token.clone(),
            output_amount: quote.output_amount,
            fee_amount: quote.fee_amount,
            timestamp: now,
            settlement_status,
            onchain_tx_ids,
        };
        let _ = state.db.put_transaction(&swap_tx).await;

        splits.push(PartialFillSplit {
            split_index: i,
            input_amount: this_input,
            output_amount: quote.output_amount,
            fee_amount: quote.fee_amount,
            price_impact: quote.price_impact,
        });
        total_output += quote.output_amount;
        total_fees += quote.fee_amount;
        all_tx_ids.push(tx_id);
    }

    if let Some(min) = req.min_output_amount {
        if total_output < min {
            return err_response(StatusCode::BAD_REQUEST,
                &format!("Slippage too high: total output {} < min {}", total_output, min));
        }
    }

    ok_response(PartialFillResponse {
        input_token,
        input_amount: req.input_amount,
        output_token,
        total_output,
        total_fees,
        splits,
        tx_ids: all_tx_ids,
    })
}

async fn bridge_auto_check(
    State(state): State<AppState>,
) -> (StatusCode, Json<ApiResponse<BridgeAutoCheckResult>>) {
    let bridge = match &state.bridge {
        Some(b) => b.clone(),
        None => return err_response(StatusCode::SERVICE_UNAVAILABLE, "Bridge not configured"),
    };
    let deposits = match state.db.list_bridge_deposits().await {
        Ok(d) => d,
        Err(_) => Vec::new(),
    };
    let mut new_found = 0u32;
    let mut processed = Vec::new();
    let mut errors = Vec::new();
    for deposit in deposits {
        if deposit.status == "pending" || deposit.status == "confirming" {
            if !deposit.eth_tx_hash.is_empty() {
                match bridge.eth_client.get_tx_receipt(&deposit.eth_tx_hash).await {
                    Ok(receipt) => {
                        if receipt.status == "success" && receipt.confirmations >= bridge.eth_client.network.required_confirmations() {
                            let mut updated = deposit.clone();
                            updated.status = "confirmed".to_string();
                            updated.confirmations = receipt.confirmations;
                            updated.confirmed_at = Utc::now().to_rfc3339();
                            if let Err(e) = state.db.put_bridge_deposit(&updated).await {
                                errors.push(format!("update deposit {}: {}", deposit.deposit_id, e));
                            } else {
                                processed.push(deposit.deposit_id.clone());
                                new_found += 1;
                            }
                        }
                    }
                    Err(e) => {
                        errors.push(format!("check receipt {}: {}", deposit.eth_tx_hash, e));
                    }
                }
            }
        }
    }
    ok_response(BridgeAutoCheckResult {
        new_deposits_found: new_found,
        processed_deposits: processed,
        errors,
    })
}

async fn bridge_dynamic_fees(
    State(state): State<AppState>,
) -> (StatusCode, Json<ApiResponse<BridgeDynamicFees>>) {
    let bridge = match &state.bridge {
        Some(b) => b.clone(),
        None => return err_response(StatusCode::SERVICE_UNAVAILABLE, "Bridge not configured"),
    };
    let gas_price = bridge.eth_client.get_gas_price().await.unwrap_or(20_000_000_000);
    let gas_gwei = gas_price as f64 / 1_000_000_000.0;

    let base_wrap = 0.1_f64;
    let base_unwrap = 0.3_f64;
    let gas_multiplier = (gas_gwei / 20.0).max(1.0).min(5.0);

    let eth_wrap_fee = base_wrap * gas_multiplier;
    let eth_unwrap_fee = base_unwrap * gas_multiplier;
    let stable_wrap_fee = base_wrap;
    let stable_unwrap_fee = base_unwrap * gas_multiplier;

    let eth_gas_cost = gas_price * 21000;
    let erc20_gas_cost = gas_price * 65000;

    ok_response(BridgeDynamicFees {
        eth_wrap_fee_percent: eth_wrap_fee,
        eth_unwrap_fee_percent: eth_unwrap_fee,
        stablecoin_wrap_fee_percent: stable_wrap_fee,
        stablecoin_unwrap_fee_percent: stable_unwrap_fee,
        current_gas_gwei: gas_gwei,
        estimated_gas_cost_eth_wei: eth_gas_cost.to_string(),
        estimated_gas_cost_erc20_wei: erc20_gas_cost.to_string(),
        last_updated: Utc::now().to_rfc3339(),
    })
}


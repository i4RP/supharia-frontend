                        deposit_id: get_s(item, "deposit_id")?,
                        user_eth_address: get_s(item, "user_eth_address")?,
                        user_bsv_address: get_s(item, "user_bsv_address")?,
                        source_chain: get_s(item, "source_chain")?,
                        token: get_s(item, "token")?,
                        amount_raw: get_s(item, "amount_raw")?,
                        amount_display: get_s(item, "amount_display")?,
                        fee_amount: get_s(item, "fee_amount")?,
                        minted_amount: get_s(item, "minted_amount")?,
                        eth_tx_hash: get_s(item, "eth_tx_hash")?,
                        bsv_tx_id: get_s(item, "bsv_tx_id")?,
                        status: get_s(item, "status")?,
                        created_at: get_s(item, "created_at")?,
                        confirmed_at: get_s(item, "confirmed_at")?,
                        eth_block_number: get_n(item, "eth_block_number")?,
                        confirmations: get_n(item, "confirmations")?,
                    })
                })() {
                    deposits.push(d);
                }
            }
        }
        Ok(deposits)
    }

    pub async fn put_bridge_withdrawal(&self, w: &BridgeWithdrawal) -> Result<(), String> {
        let mut item = HashMap::new();
        item.insert("withdrawal_id".into(), AttributeValue::S(w.withdrawal_id.clone()));
        item.insert("user_bsv_address".into(), AttributeValue::S(w.user_bsv_address.clone()));
        item.insert("dest_eth_address".into(), AttributeValue::S(w.dest_eth_address.clone()));
        item.insert("dest_chain".into(), AttributeValue::S(w.dest_chain.clone()));
        item.insert("token".into(), AttributeValue::S(w.token.clone()));
        item.insert("amount_raw".into(), AttributeValue::S(w.amount_raw.clone()));
        item.insert("amount_display".into(), AttributeValue::S(w.amount_display.clone()));
        item.insert("fee_amount".into(), AttributeValue::S(w.fee_amount.clone()));
        item.insert("gas_fee".into(), AttributeValue::S(w.gas_fee.clone()));
        item.insert("sent_amount".into(), AttributeValue::S(w.sent_amount.clone()));
        item.insert("bsv_burn_tx_id".into(), AttributeValue::S(w.bsv_burn_tx_id.clone()));
        item.insert("eth_tx_hash".into(), AttributeValue::S(w.eth_tx_hash.clone()));
        item.insert("status".into(), AttributeValue::S(w.status.clone()));
        item.insert("created_at".into(), AttributeValue::S(w.created_at.clone()));
        item.insert("completed_at".into(), AttributeValue::S(w.completed_at.clone()));
        self.client.put_item().table_name(BRIDGE_WITHDRAWALS_TABLE).set_item(Some(item)).send().await
            .map_err(|e| format!("put_bridge_withdrawal error: {}", e))?;
        Ok(())
    }

    pub async fn get_bridge_withdrawal(&self, withdrawal_id: &str) -> Result<Option<BridgeWithdrawal>, String> {
        let result = self.client.get_item()
            .table_name(BRIDGE_WITHDRAWALS_TABLE)
            .key("withdrawal_id", AttributeValue::S(withdrawal_id.to_string()))
            .send().await
            .map_err(|e| format!("get_bridge_withdrawal error: {}", e))?;
        match result.item {
            Some(item) => Ok(Some(BridgeWithdrawal {
                withdrawal_id: get_s(&item, "withdrawal_id")?,
                user_bsv_address: get_s(&item, "user_bsv_address")?,
                dest_eth_address: get_s(&item, "dest_eth_address")?,
                dest_chain: get_s(&item, "dest_chain")?,
                token: get_s(&item, "token")?,
                amount_raw: get_s(&item, "amount_raw")?,
                amount_display: get_s(&item, "amount_display")?,
                fee_amount: get_s(&item, "fee_amount")?,
                gas_fee: get_s(&item, "gas_fee")?,
                sent_amount: get_s(&item, "sent_amount")?,
                bsv_burn_tx_id: get_s(&item, "bsv_burn_tx_id")?,
                eth_tx_hash: get_s(&item, "eth_tx_hash")?,
                status: get_s(&item, "status")?,
                created_at: get_s(&item, "created_at")?,
                completed_at: get_s(&item, "completed_at")?,
            })),
            None => Ok(None),
        }
    }

    pub async fn list_bridge_withdrawals(&self) -> Result<Vec<BridgeWithdrawal>, String> {
        let result = self.client.scan()
            .table_name(BRIDGE_WITHDRAWALS_TABLE)
            .send().await
            .map_err(|e| format!("list_bridge_withdrawals error: {}", e))?;
        let mut withdrawals = Vec::new();
        if let Some(items) = result.items {
            for item in &items {
                if let Ok(w) = (|| -> Result<BridgeWithdrawal, String> {
                    Ok(BridgeWithdrawal {
                        withdrawal_id: get_s(item, "withdrawal_id")?,
                        user_bsv_address: get_s(item, "user_bsv_address")?,
                        dest_eth_address: get_s(item, "dest_eth_address")?,
                        dest_chain: get_s(item, "dest_chain")?,
                        token: get_s(item, "token")?,
                        amount_raw: get_s(item, "amount_raw")?,
                        amount_display: get_s(item, "amount_display")?,
                        fee_amount: get_s(item, "fee_amount")?,
                        gas_fee: get_s(item, "gas_fee")?,
                        sent_amount: get_s(item, "sent_amount")?,
                        bsv_burn_tx_id: get_s(item, "bsv_burn_tx_id")?,
                        eth_tx_hash: get_s(item, "eth_tx_hash")?,
                        status: get_s(item, "status")?,
                        created_at: get_s(item, "created_at")?,
                        completed_at: get_s(item, "completed_at")?,
                    })
                })() {
                    withdrawals.push(w);
                }
            }
        }
        Ok(withdrawals)
    }
    pub async fn put_launched_token(&self, token: &LaunchedToken) -> Result<(), String> {
        let mut item = HashMap::new();
        item.insert("token_id".into(), AttributeValue::S(token.token_id.clone()));
        item.insert("symbol".into(), AttributeValue::S(token.symbol.clone()));
        item.insert("name".into(), AttributeValue::S(token.name.clone()));
        item.insert("total_supply".into(), AttributeValue::N(token.total_supply.to_string()));
        item.insert("creator_address".into(), AttributeValue::S(token.creator_address.clone()));
        item.insert("issue_tx_id".into(), AttributeValue::S(token.issue_tx_id.clone()));
        item.insert("contract_tx_id".into(), AttributeValue::S(token.contract_tx_id.clone()));
        item.insert("freeze".into(), AttributeValue::Bool(token.freeze));
        item.insert("decimals".into(), AttributeValue::N(token.decimals.to_string()));
        item.insert("color".into(), AttributeValue::S(token.color.clone()));
        item.insert("description".into(), AttributeValue::S(token.description.clone()));
        item.insert("icon_url".into(), AttributeValue::S(token.icon_url.clone()));
        item.insert("website_url".into(), AttributeValue::S(token.website_url.clone()));
        item.insert("pool_id".into(), AttributeValue::S(token.pool_id.clone()));
        item.insert("status".into(), AttributeValue::S(token.status.clone()));
        item.insert("created_at".into(), AttributeValue::S(token.created_at.clone()));

        self.client.put_item()
            .table_name(LAUNCHED_TOKENS_TABLE)
            .set_item(Some(item))
            .send()
            .await
            .map_err(|e| format!("put_launched_token error: {}", e))?;
        Ok(())
    }

    pub async fn get_launched_token(&self, token_id: &str) -> Result<Option<LaunchedToken>, String> {
        let result = self.client.get_item()
            .table_name(LAUNCHED_TOKENS_TABLE)
            .key("token_id", AttributeValue::S(token_id.to_string()))
            .send()
            .await
            .map_err(|e| format!("get_launched_token error: {}", e))?;
        match result.item {
            Some(item) => {
                let token = parse_launched_token(&item)?;
                Ok(Some(token))
            }
            None => Ok(None),
        }
    }

    pub async fn list_launched_tokens(&self) -> Result<Vec<LaunchedToken>, String> {
        let result = self.client.scan()
            .table_name(LAUNCHED_TOKENS_TABLE)
            .send()
            .await
            .map_err(|e| format!("list_launched_tokens error: {}", e))?;
        let mut tokens = Vec::new();
        if let Some(items) = result.items {
            for item in items {
                if let Ok(t) = parse_launched_token(&item) {
                    tokens.push(t);
                }
            }
        }
        Ok(tokens)
    }

    pub async fn update_launched_token_status(&self, token_id: &str, status: &str) -> Result<(), String> {
        self.client.update_item()
            .table_name(LAUNCHED_TOKENS_TABLE)
            .key("token_id", AttributeValue::S(token_id.to_string()))
            .update_expression("SET #s = :s")
            .expression_attribute_names("#s", "status")
            .expression_attribute_values(":s", AttributeValue::S(status.to_string()))
            .send()
            .await
            .map_err(|e| format!("update_launched_token_status error: {}", e))?;
        Ok(())
    }

    pub async fn update_launched_token_pool(&self, token_id: &str, pool_id: &str) -> Result<(), String> {
        self.client.update_item()
            .table_name(LAUNCHED_TOKENS_TABLE)
            .key("token_id", AttributeValue::S(token_id.to_string()))
            .update_expression("SET pool_id = :p")
            .expression_attribute_values(":p", AttributeValue::S(pool_id.to_string()))
            .send()
            .await
            .map_err(|e| format!("update_launched_token_pool error: {}", e))?;
        Ok(())
    }
}

fn parse_launched_token(item: &HashMap<String, AttributeValue>) -> Result<LaunchedToken, String> {
    let freeze = item.get("freeze").and_then(|v| v.as_bool().ok()).copied().unwrap_or(false);
    let decimals = item.get("decimals").and_then(|v| v.as_n().ok()).and_then(|s| s.parse::<u64>().ok()).unwrap_or(0) as u32;
    let color = item.get("color").and_then(|v| v.as_s().ok()).map(|s| s.to_string()).unwrap_or_default();
    let description = item.get("description").and_then(|v| v.as_s().ok()).map(|s| s.to_string()).unwrap_or_default();
    let icon_url = item.get("icon_url").and_then(|v| v.as_s().ok()).map(|s| s.to_string()).unwrap_or_default();
    let website_url = item.get("website_url").and_then(|v| v.as_s().ok()).map(|s| s.to_string()).unwrap_or_default();
    let pool_id = item.get("pool_id").and_then(|v| v.as_s().ok()).map(|s| s.to_string()).unwrap_or_default();
    let status = item.get("status").and_then(|v| v.as_s().ok()).map(|s| s.to_string()).unwrap_or_else(|| "active".to_string());
    Ok(LaunchedToken {
        token_id: get_s(item, "token_id")?,
        symbol: get_s(item, "symbol")?,
        name: get_s(item, "name")?,
        total_supply: get_n(item, "total_supply")?,
        creator_address: get_s(item, "creator_address")?,
        issue_tx_id: get_s(item, "issue_tx_id")?,
        contract_tx_id: get_s(item, "contract_tx_id")?,
        freeze,
        decimals,
        color,
        description,
        icon_url,
        website_url,
        pool_id,
        status,
        created_at: get_s(item, "created_at")?,
    })
}

fn get_s(item: &HashMap<String, AttributeValue>, key: &str) -> Result<String, String> {
    item.get(key)
        .and_then(|v| v.as_s().ok())
        .map(|s| s.to_string())
        .ok_or_else(|| format!("Missing field: {}", key))
}

fn get_n(item: &HashMap<String, AttributeValue>, key: &str) -> Result<u64, String> {
    item.get(key)
        .and_then(|v| v.as_n().ok())
        .and_then(|s| s.parse::<u64>().ok())
        .ok_or_else(|| format!("Missing numeric field: {}", key))
}

fn get_f(item: &HashMap<String, AttributeValue>, key: &str) -> Result<f64, String> {
    item.get(key)
        .and_then(|v| v.as_n().ok())
        .and_then(|s| s.parse::<f64>().ok())
        .ok_or_else(|| format!("Missing float field: {}", key))
}

fn get_ss(item: &HashMap<String, AttributeValue>, key: &str) -> Vec<String> {
    item.get(key)
        .and_then(|v| v.as_ss().ok())
        .map(|ss| ss.to_vec())
        .unwrap_or_default()
}

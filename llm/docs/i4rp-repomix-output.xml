    const splitTx = TransactionReader.readHex(splitTxHex);
    console.log(`  Split TX: ${splitTx.Id}`);
    console.log(
      `  Outputs: ${splitTx.Outputs.map((o, i) => `[${i}] ${o.Satoshis} sats (type ${o.ScriptType})`).join(", ")}`,
    );
    await broadcast(splitTxHex, "DSTAS Split");
    await sleep(1500);

    results.push({

async fn list_transactions(
    State(state): State<AppState>,
    Path(pool_id): Path<String>,
) -> (StatusCode, Json<ApiResponse<Vec<TransactionInfo>>>) {
    match state.db.list_transactions_by_pool(&pool_id).await {
        Ok(txs) => {
            let infos: Vec<TransactionInfo> = txs.into_iter().map(|t| TransactionInfo {
                tx_id: t.tx_id,
                tx_type: t.tx_type,
                user_address: t.user_address,
                input_token: t.input_token,
                input_amount: t.input_amount,
                output_token: t.output_token,
                output_amount: t.output_amount,
                fee_amount: t.fee_amount,
                timestamp: t.timestamp,
                settlement_status: t.settlement_status,
                onchain_tx_ids: t.onchain_tx_ids,
            }).collect();
            ok_response(infos)
        }
        Err(e) => err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    }
}

async fn get_onchain_balance(
    State(state): State<AppState>,
    Path(pool_id): Path<String>,
) -> (StatusCode, Json<ApiResponse<OnChainBalanceResponse>>) {
    tracing::info!(pool_id = %pool_id, "get_onchain_balance");
    let pool = match state.db.get_pool(&pool_id).await {
        Ok(Some(p)) => p,
        Ok(None) => return err_response(StatusCode::NOT_FOUND, "Pool not found"),
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };

    let token_ids = vec![pool.token_a_id.clone(), pool.token_b_id.clone()];
    let onchain = match state.woc.get_on_chain_balance(&pool.pool_address, &token_ids).await {
        Ok(b) => b,
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &format!("WoC error: {}", e)),
    };

    let get_onchain_for_token = |token_id: &str| -> (u64, usize) {
        onchain.token_balances.iter()
            .find(|tb| tb.token_id == token_id)
            .map(|tb| (tb.total_satoshis, tb.utxo_count))
            .unwrap_or((0, 0))
    };

    let (onchain_a, utxo_a) = get_onchain_for_token(&pool.token_a_id);
    let (onchain_b, utxo_b) = get_onchain_for_token(&pool.token_b_id);

    let token_balances = vec![
        OnChainTokenBalance {
            token_id: pool.token_a_id.clone(),
            symbol: pool.token_a_symbol.clone(),
            onchain_balance: onchain_a,
            offchain_balance: pool.reserve_a,
            utxo_count: utxo_a,
            synced: onchain_a >= pool.reserve_a,
        },
        OnChainTokenBalance {
            token_id: pool.token_b_id.clone(),
            symbol: pool.token_b_symbol.clone(),
            onchain_balance: onchain_b,
            offchain_balance: pool.reserve_b,
            utxo_count: utxo_b,
            synced: onchain_b >= pool.reserve_b,
        },
    ];

    let reconciled = token_balances.iter().all(|tb| tb.synced);

    ok_response(OnChainBalanceResponse {
        pool_address: pool.pool_address,
        bsv_balance: onchain.bsv_balance,
        token_balances,
        utxo_count: onchain.utxo_count,
        offchain_reserve_a: pool.reserve_a,
        offchain_reserve_b: pool.reserve_b,
        reconciled,
    })
}

async fn get_settlement_status(
    State(state): State<AppState>,
    Path((_pool_id, txid)): Path<(String, String)>,
) -> (StatusCode, Json<ApiResponse<SettleResponse>>) {
    tracing::info!(txid = %txid, "get_settlement_status");

    match state.settlement.check_confirmation(&txid).await {
        Ok((confirmed, confirmations_count)) => {
            let confirmation = TxConfirmation {
                txid: txid.clone(),
                confirmed,
                block_height: None,
                confirmations: confirmations_count,
            };

            if let Ok(Some(tx)) = state.db.get_transaction(&txid).await {
                let new_status = if confirmed { "confirmed" } else if tx.settlement_status == "broadcast" { "broadcast" } else { "pending" };
                if new_status != tx.settlement_status {
                    let _ = state.db.update_transaction_settlement(&txid, new_status, &tx.onchain_tx_ids).await;
                }
            }

            let status = if confirmed { "confirmed" } else { "broadcast" };
            ok_response(SettleResponse {
                tx_id: txid,
                settlement_status: status.to_string(),
                confirmations: vec![confirmation],
            })
        }
        Err(e) => err_response(StatusCode::NOT_FOUND, &format!("TX not found on-chain: {}", e)),
    }
}

async fn cleanup_pending_transactions(
    State(state): State<AppState>,
    Path(pool_id): Path<String>,
) -> (StatusCode, Json<ApiResponse<serde_json::Value>>) {
    tracing::info!(pool_id = %pool_id, "cleanup_pending_transactions");
    let txs = match state.db.list_transactions_by_pool(&pool_id).await {
        Ok(t) => t,
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };

    let mut cleaned = 0u64;
    for tx in &txs {
        if tx.settlement_status == "pending" && tx.tx_id.starts_with("pending-") {
            if let Err(e) = state.db.update_transaction_settlement(&tx.tx_id, "failed", &[]).await {
                tracing::warn!(error = %e, tx_id = %tx.tx_id, "failed to mark tx as failed");
            } else {
                cleaned += 1;
            }
        }
    }

    ok_response(serde_json::json!({
        "pool_id": pool_id,
        "cleaned": cleaned,
        "total_pending_before": txs.iter().filter(|t| t.settlement_status == "pending").count(),
    }))
}

async fn settle_transaction(
    State(state): State<AppState>,
    Path(pool_id): Path<String>,
    Json(req): Json<SettleRequest>,
) -> (StatusCode, Json<ApiResponse<SettleResponse>>) {
    tracing::info!(pool_id = %pool_id, tx_id = %req.tx_id, "settle_transaction");

    let tx = match state.db.get_transaction(&req.tx_id).await {
        Ok(Some(t)) => t,
        Ok(None) => return err_response(StatusCode::NOT_FOUND, "Transaction not found"),
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };

    if tx.pool_id != pool_id {
        return err_response(StatusCode::BAD_REQUEST, "Transaction does not belong to this pool");
    }

    if req.onchain_tx_ids.is_empty() {
        return err_response(StatusCode::BAD_REQUEST, "At least one on-chain tx ID required");
    }

    let mut confirmations = Vec::new();
    let mut all_confirmed = true;

    for onchain_txid in &req.onchain_tx_ids {
        match state.woc.get_tx_status(onchain_txid).await {
            Ok(status) => {
                if !status.confirmed && status.confirmations == 0 {
                    all_confirmed = false;
                }
                confirmations.push(status);
            }
            Err(_) => {
                all_confirmed = false;
                confirmations.push(TxConfirmation {
                    txid: onchain_txid.clone(),
                    confirmed: false,
                    block_height: None,
                    confirmations: 0,
                });
            }
        }
    }

    let status = if all_confirmed { "confirmed" } else { "pending" };

    if let Err(e) = state.db.update_transaction_settlement(&req.tx_id, status, &req.onchain_tx_ids).await {
        return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e);
    }

    ok_response(SettleResponse {
        tx_id: req.tx_id,
        settlement_status: status.to_string(),
        confirmations,
    })
}


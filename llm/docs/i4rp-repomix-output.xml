      </div>

      {bridgeStats && (
        <div className="card bridge-stats-card">
          <h3 className="card-title">Bridge Statistics</h3>
          <div className="pool-stats-grid">
            <div className="pool-stat"><span className="pool-stat-label">Total Wrapped</span><span className="pool-stat-value">{safeLocale(bridgeStats.total_wrapped)}</span></div>
            <div className="pool-stat"><span className="pool-stat-label">Total Unwrapped</span><span className="pool-stat-value">{safeLocale(bridgeStats.total_unwrapped)}</span></div>
            <div className="pool-stat"><span className="pool-stat-label">Pending</span><span className="pool-stat-value">{bridgeStats.pending_count}</span></div>
            <div className="pool-stat"><span className="pool-stat-label">Supported Tokens</span><span className="pool-stat-value">{bridgeStats.supported_tokens.length}</span></div>
          </div>

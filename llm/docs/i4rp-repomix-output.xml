            api_url: "https://api.whatsonchain.com/v1/bsv/test".to_string(),
            is_testnet: true,
        },
    ];

    let active_network = std::env::var("ACTIVE_NETWORK")
        .unwrap_or_else(|_| "bsv-mainnet".to_string());

    if active_network == "bsv-testnet" {
        if let Ok(w) = derive_pool_wallet(&pool_master_seed, "bridge-mint") {
            let taddr = pubkey_hash_to_testnet_address(&w.pkh);
            tracing::info!(testnet_bridge_address = %taddr, "Derived BSV testnet bridge address");
        }
    }

    let woc = WocClient::for_network(active_network == "bsv-testnet");
    let settlement = Arc::new(SettlementService::new(woc.clone()));

    let sm_client = aws_sdk_secretsmanager::Client::new(&config);
    let bridge = match std::env::var("BRIDGE_ETH_SECRET_ID") {
        Ok(secret_id) => {
            tracing::info!("Loading ETH bridge wallet from Secrets Manager: {}", secret_id);
            let sm_resp = sm_client.get_secret_value()
                .secret_id(&secret_id)
                .send().await;
            match sm_resp {
                Ok(resp) => {
                    let key_hex_owned = resp.secret_string.unwrap_or_default();
                    if !key_hex_owned.is_empty() {
                        let key_hex = key_hex_owned.as_str();
                        match eth_wallet_from_private_key(key_hex) {
                            Ok(wallet) => {
                                tracing::info!("Bridge ETH wallet: {}", wallet.address);
                                let etherscan_key = std::env::var("ETHERSCAN_API_KEY")
                                    .unwrap_or_else(|_| "YourApiKeyToken".to_string());
                                let eth_net_env = std::env::var("ETH_NETWORK").unwrap_or_else(|_| "mainnet".to_string());
                                let eth_network = EthNetwork::from_str(&eth_net_env);
                                let eth_client = EthClient::new_with_network(etherscan_key, eth_network);
                                Some(Arc::new(BridgeService::new(eth_client, wallet)))
                            }
                            Err(e) => {
                                tracing::warn!("Failed to load bridge wallet: {}", e);
                                None
                            }
                        }
                    } else { None }
                }
                Err(e) => {
                    tracing::warn!("Failed to get bridge secret: {}", e);
                    None
                }
            }
        }
        Err(_) => {
            tracing::info!("BRIDGE_ETH_SECRET_ID not set, bridge disabled");
            None
        }
    };

    let s402_recipient_wif = std::env::var("S402_RECIPIENT_WIF").unwrap_or_default();
    let (s402_addr, s402_pkh) = if !s402_recipient_wif.is_empty() {
        match wallet_from_wif(&s402_recipient_wif) {
            Ok(w) => (w.address.clone(), hex::encode(&w.pkh)),
            Err(_) => ("not-configured".to_string(), "0000000000000000000000000000000000000000".to_string()),
        }
    } else {
        match derive_pool_wallet(&pool_master_seed, "s402-recipient") {
            Ok(w) => {
                tracing::info!(s402_address = %w.address, "s402 payment recipient derived");
                (w.address.clone(), hex::encode(&w.pkh))
            }
            Err(_) => ("not-configured".to_string(), "0000000000000000000000000000000000000000".to_string()),
        }
    };

    let s402_config = S402Config {
        enabled: std::env::var("S402_ENABLED").unwrap_or_else(|_| "true".to_string()) == "true",
        recipient_address: s402_addr,
        recipient_pkh: s402_pkh,
        network: if active_network == "bsv-testnet" { "bsv:testnet".to_string() } else { "bsv:mainnet".to_string() },
        default_price_sats: std::env::var("S402_DEFAULT_PRICE")
            .ok().and_then(|v| v.parse().ok()).unwrap_or(100),
        accept_bsv: true,
        accept_stas: true,
        accepted_token_ids: std::env::var("S402_ACCEPTED_TOKENS")
            .unwrap_or_default()
            .split(',')
            .filter(|s| !s.is_empty())
            .map(|s| s.trim().to_string())
            .collect(),
        description: "molt4x.com s402 - STAS micropayment protocol".to_string(),
    };
    let s402 = Arc::new(S402State::new(s402_config));

    let state = AppState {
        db,
        woc,
        settlement,
        bridge,
        s402,
        tx_builder_fn: std::env::var("TX_BUILDER_FUNCTION")
            .unwrap_or_else(|_| "dstas-tx-builder".to_string()),
        pool_master_seed,
        networks,
        active_network,
    };

    let app = Router::new()
        .route("/", get(health))
        .route("/health", get(health))
        .route("/status", get(status_check))
        .route("/pools", get(list_pools))
        .route("/pools", post(create_pool))
        .route("/pools/:pool_id", get(get_pool_info))
        .route("/pools/:pool_id/quote", post(get_swap_quote))
        .route("/pools/:pool_id/swap", post(execute_swap))
        .route("/pools/:pool_id/add-liquidity", post(add_liquidity))
        .route("/pools/:pool_id/remove-liquidity", post(remove_liquidity))
        .route("/pools/:pool_id/lp/:address", get(get_lp_info))
        .route("/pools/:pool_id/transactions", get(list_transactions))
        .route("/pools/:pool_id/onchain-balance", get(get_onchain_balance))
        .route("/pools/:pool_id/settle", post(settle_transaction))
        .route("/pools/:pool_id/settlement-status/:txid", get(get_settlement_status))
        .route("/pools/:pool_id/cleanup-pending", post(cleanup_pending_transactions))
        .route("/pools/:pool_id/reconciliation", get(get_reconciliation))
        .route("/pools/:pool_id/price-history", get(get_price_history))
        .route("/analytics", get(get_analytics))
        .route("/pools/:pool_id/proposals", get(list_proposals_handler).post(create_proposal))
        .route("/pools/:pool_id/proposals/:proposal_id/vote", post(vote_proposal))
        .route("/pools/:pool_id/proposals/:proposal_id/execute", post(execute_proposal))
        .route("/route", post(find_route))
        .route("/pools/:pool_id/limit-orders", get(list_limit_orders_handler).post(create_limit_order))
        .route("/pools/:pool_id/limit-orders/:order_id/cancel", post(cancel_limit_order))
        .route("/pools/:pool_id/limit-orders/check", post(check_limit_orders))
        .route("/pools/:pool_id/rewards", get(get_pool_rewards))
        .route("/pools/:pool_id/lp/:address/rewards", get(get_lp_rewards))
        .route("/pools/:pool_id/farming", get(get_farming_summary))
        .route("/pools/:pool_id/farming/stake", post(farm_stake))
        .route("/pools/:pool_id/farming/unstake", post(farm_unstake))
        .route("/pools/:pool_id/farming/:address", get(get_farming_info))
        .route("/pools/:pool_id/farming/:address/harvest", post(farm_harvest))
        .route("/subscribe", get(get_realtime_updates))
        .route("/networks", get(get_networks))
        .route("/networks/switch", post(switch_network))
        .route("/pools/:pool_id/swap-partial", post(execute_swap_partial))
        .route("/bridge/deposit-info", get(bridge_deposit_info))
        .route("/bridge/wrap", post(bridge_wrap))
        .route("/bridge/unwrap", post(bridge_unwrap))
        .route("/bridge/transactions", get(list_bridge_transactions))
        .route("/bridge/transactions/:tx_id", get(get_bridge_transaction))
        .route("/bridge/stats", get(get_bridge_stats))
        .route("/bridge/supported-tokens", get(bridge_supported_tokens))
        .route("/bridge/dynamic-fees", get(bridge_dynamic_fees))
        .route("/bridge/auto-check", post(bridge_auto_check))
        .route("/pools/:pool_id/ohlc", get(get_ohlc))
        .route("/pools/:pool_id/advanced-chart", get(get_advanced_chart))
        .route("/portfolio/:address", get(get_portfolio))
        .route("/notifications/:address", get(get_notifications))
        .route("/notifications/:address/:notif_id/read", post(mark_notification_read))
        .route("/alerts", post(create_price_alert))
        .route("/alerts/:address", get(list_price_alerts))
        .route("/alerts/:address/:alert_id", delete(delete_price_alert))
        .route("/rate-limit", get(get_rate_limit_info))
        .route("/security/status", get(get_security_status))
        .route("/security/validate-address", post(validate_address))
        .route("/launchpad/tokens", get(list_launched_tokens_handler).post(launch_token))
        .route("/launchpad/tokens/:token_id", get(get_launched_token_handler))
        .route("/launchpad/tokens/:token_id/pool", post(create_pool_for_token))
        .nest("/admin", admin_routes(state.clone()))
        .route("/s402/protocol", get(s402_protocol_info))
        .route("/s402/requirements", get(s402_get_requirements))
        .route("/s402/verify", post(s402_verify_payment))
        .route("/s402/dashboard", get(s402_dashboard))
        .route("/s402/payments", get(s402_list_payments))
        .route("/s402/config", get(s402_get_config).post(s402_update_config))
        .route("/s402/pricing", get(s402_get_pricing).post(s402_set_pricing))
        .route("/s402/agent/register", post(s402_register_agent))
        .route("/s402/agent/:agent_id", get(s402_get_agent))
        .route("/s402/agent/:agent_id/pay", post(s402_agent_pay))
        .route("/s402/premium/example", get(s402_premium_example))
        .layer(cors_layer())
        .with_state(state);

    run(app).await
}

#[derive(Deserialize)]
struct LaunchTokenRequest {
    user_wif: String,
    name: String,
    symbol: String,
    total_supply: u64,
    freeze: bool,
    decimals: Option<u32>,
    color: Option<String>,
    description: Option<String>,
    icon_url: Option<String>,
    website_url: Option<String>,
}

async fn launch_token(
    State(state): State<AppState>,
    Json(req): Json<LaunchTokenRequest>,
) -> (StatusCode, Json<ApiResponse<LaunchedToken>>) {
    let wallet = match wallet_from_wif(&req.user_wif) {
        Ok(w) => w,
        Err(e) => return err_response(StatusCode::BAD_REQUEST, &format!("Invalid WIF: {}", e)),
    };
    let token_id = hex::encode(wallet.pkh);
    let symbol = req.symbol.trim().to_string();
    let name = req.name.trim().to_string();
    if symbol.is_empty() || name.is_empty() {
        return err_response(StatusCode::BAD_REQUEST, "name and symbol are required");
    }
    let token = LaunchedToken {
        token_id: token_id.clone(),
        symbol,
        name,
        total_supply: req.total_supply,
        creator_address: wallet.address.clone(),
        issue_tx_id: String::new(),
        contract_tx_id: String::new(),
        freeze: req.freeze,
        decimals: req.decimals.unwrap_or(0),
        color: req.color.unwrap_or_default(),
        description: req.description.unwrap_or_default(),
        icon_url: req.icon_url.unwrap_or_default(),
        website_url: req.website_url.unwrap_or_default(),
        pool_id: String::new(),
        status: "pending".to_string(),
        created_at: Utc::now().to_rfc3339(),
    };
    if let Err(e) = state.db.put_launched_token(&token).await {
        return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e);
    }
    ok_response(token)
}


async fn create_limit_order(
    State(state): State<AppState>,
    Path(pool_id): Path<String>,
    Json(req): Json<CreateLimitOrderRequest>,
) -> (StatusCode, Json<ApiResponse<LimitOrderInfo>>) {
    if req.input_amount == 0 {
        return err_response(StatusCode::BAD_REQUEST, "input_amount must be > 0");
    }
    if req.target_price <= 0.0 {
        return err_response(StatusCode::BAD_REQUEST, "target_price must be > 0");
    }
    let pool = match state.db.get_pool(&pool_id).await {
        Ok(Some(p)) => p,
        Ok(None) => return err_response(StatusCode::NOT_FOUND, "Pool not found"),
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };
    let valid_tokens = [&pool.token_a_id, &pool.token_b_id];
    if !valid_tokens.contains(&&req.input_token) || !valid_tokens.contains(&&req.output_token) {
        return err_response(StatusCode::BAD_REQUEST, "Token not in this pool");
    }
    if req.input_token == req.output_token {
        return err_response(StatusCode::BAD_REQUEST, "Input and output tokens must differ");
    }
    let now = Utc::now();
    let hours = req.expires_in_hours.unwrap_or(24);
    let expires = now + chrono::Duration::hours(hours as i64);
    let order = LimitOrder {
        order_id: Uuid::new_v4().to_string(),
        pool_id: pool_id.clone(),
        user_address: req.user_address,
        input_token: req.input_token,
        output_token: req.output_token,
        input_amount: req.input_amount,
        target_price: req.target_price,
        status: "open".to_string(),
        filled_amount: 0,
        created_at: now.to_rfc3339(),
        expires_at: expires.to_rfc3339(),
        onchain_tx_id: String::new(),
        settlement_status: "none".to_string(),
        execution_timestamp: String::new(),
        output_amount: 0,
    };
    if let Err(e) = state.db.put_limit_order(&order).await {
        return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e);
    }
    ok_response(order_to_info(&order))
}


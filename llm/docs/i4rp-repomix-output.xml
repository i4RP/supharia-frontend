  const master = Wallet.fromMnemonic(MNEMONIC);
  const wallets: Wallet[] = [];
  for (let i = 0; i < 6; i++) {
    wallets.push(master.deriveWallet(`m/44'/236'/0'/0/${i}`));
  }
  const addr0 = wallets[0];

  const makeScheme = (
    token: typeof ISSUED_TOKENS.DSTAS,
    name: string,
    symbol: string,
  ) => {
    const issuerWallet = wallets[token.issuerPath];
    const authorityWallet = wallets[token.authorityPath];
    return new TokenScheme(name, token.tokenId, symbol, 1, {
      freeze: token.freeze,
      confiscation: token.freeze,
      isDivisible: true,
      authority: token.freeze
        ? { m: 1, publicKeys: [toHex(authorityWallet.PublicKey)] }
        : undefined,
    });
  };

  const makeStasOutPoint = async (
    txId: string,
    vout: number,
    satoshis: number,
    ownerWallet: Wallet,
  ) => {
    const txHex = await getTxHex(txId);
    const tx = TransactionReader.readHex(txHex);
    const op = new OutPoint(
      tx.Id,
      vout,
      tx.Outputs[vout].LockignScript,
      satoshis,
      ownerWallet.Address,
      ScriptType.dstas,
    );
    op.Transaction = tx;
    return op;
  };

  const makeFeeOutPoint = async (
    txId: string,
    vout: number,
    satoshis: number,
    ownerWallet: Wallet,
  ) => {
    const txHex = await getTxHex(txId);
    const tx = TransactionReader.readHex(txHex);
    return new OutPoint(
      tx.Id,
      vout,
      tx.Outputs[vout].LockignScript,
      satoshis,
      ownerWallet.Address,
      ScriptType.p2pkh,
    );
  };

  const results: any[] = [];

  // ========== TEST 1: TRANSFER ==========
  console.log("--- Test 1: DSTAS Transfer (addr0 → addr1) ---");
  try {
    const dstasInfo = ISSUED_TOKENS.DSTAS;
    const scheme = makeScheme(dstasInfo, "DSTAS Token", "DSTAS");
    const stasOP = await makeStasOutPoint(
      dstasInfo.issueTxId,
      dstasInfo.stasVout,
      dstasInfo.stasSats,
      addr0,
    );
    const feeOP = await makeFeeOutPoint(
      dstasInfo.issueTxId,
      dstasInfo.feeVout,
      dstasInfo.feeSats,
      addr0,
    );

    const transferTxHex = BuildDstasTransferTx({
      stasPayment: { OutPoint: stasOP, Owner: addr0 },
      feePayment: { OutPoint: feeOP, Owner: addr0 },
      Scheme: scheme,
      destination: { Satoshis: dstasInfo.stasSats, To: wallets[1].Address },
    });

    const transferTx = TransactionReader.readHex(transferTxHex);
    console.log(`  Transfer TX: ${transferTx.Id}`);
    console.log(
      `  Outputs: ${transferTx.Outputs.map((o, i) => `[${i}] ${o.Satoshis} sats (type ${o.ScriptType})`).join(", ")}`,
    );

    await broadcast(transferTxHex, "DSTAS Transfer");
    await sleep(1500);

    results.push({
      test: "Transfer",
      token: "DSTAS",
      txId: transferTx.Id,
      from: addr0.Address.Value,
      to: wallets[1].Address.Value,
      satoshis: dstasInfo.stasSats,
      status: "SUCCESS",
    });

    // ========== TEST 2: TRANSFER BACK ==========
    console.log("\n--- Test 2: DSTAS Transfer back (addr1 → addr0) ---");
    const stasOP2 = new OutPoint(
      transferTx.Id,
      0,
      transferTx.Outputs[0].LockignScript,
      transferTx.Outputs[0].Satoshis,
      wallets[1].Address,
      ScriptType.dstas,
    );
    stasOP2.Transaction = transferTx;

    const feeOP2 = new OutPoint(
      transferTx.Id,
      1,
      transferTx.Outputs[1].LockignScript,
      transferTx.Outputs[1].Satoshis,
      addr0.Address,
      ScriptType.p2pkh,
    );

    const transfer2Hex = BuildDstasTransferTx({

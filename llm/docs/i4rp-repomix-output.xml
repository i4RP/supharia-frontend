<file path="wallet-extension/popup/popup.js">
/**
 * DXS Wallet – Popup UI Controller
 *
 * Manages all popup interactions: wallet creation/import, unlock,
 * balance display, transaction history, QR code, export, settings,
 * AI mode configuration, and connected-site management.
 */

// ---- Helpers ----

function $(id) {
  return document.getElementById(id);
}

function show(el) {
  if (typeof el === "string") el = $(el);
  if (el) el.classList.remove("hidden");
}

function hide(el) {
  if (typeof el === "string") el = $(el);
  if (el) el.classList.add("hidden");
}

function showView(viewId) {
  document.querySelectorAll(".view").forEach((v) => v.classList.add("hidden"));
  show(viewId);
}

function showToast(message, type) {
  const toast = $("toast");
  toast.textContent = message;
  toast.className = "toast";
  if (type) toast.classList.add("toast-" + type);
  toast.classList.remove("hidden");
  clearTimeout(toast._timer);
  toast._timer = setTimeout(() => toast.classList.add("hidden"), 2500);
}

async function sendMessage(action, payload) {
  return new Promise((resolve) => {
    chrome.runtime.sendMessage(
      { type: "DXS_WALLET_INTERNAL", action, payload: payload || {} },
      (response) => {
        resolve(response || {});
      },
    );
  });
}

async function copyToClipboard(text) {
  try {
    await navigator.clipboard.writeText(text);
    showToast("Copied!", "success");
  } catch {
    showToast("Copy failed", "error");
  }
}

// ---- State ----

let currentState = null;
let currentAddress = null;
let currentNetwork = "mainnet";

// ---- Init ----

document.addEventListener("DOMContentLoaded", async () => {
  showView("view-loading");
  await loadState();
  bindEvents();
});

async function loadState() {
  currentState = await sendMessage("getState");

  if (!currentState.hasWallet) {
    showView("view-setup");
    return;
  }

  if (currentState.locked) {
    showView("view-locked");
    if (currentState.hasPassword) {
      show("unlock-password-section");
    }
    return;
  }

  currentAddress = currentState.address;
  currentNetwork = currentState.network || "mainnet";
  showView("view-main");
  renderMainView();
}

// ---- Render main view ----

async function renderMainView() {
  $("display-address").textContent = currentAddress || "—";
  $("network-select").value = currentNetwork;
  refreshBalance();
}

async function refreshBalance() {
  $("display-balance").textContent = "...";
  const result = await sendMessage("getBalance");
  if (result.error) {
    $("display-balance").textContent = "--";
  } else {
    $("display-balance").textContent =
      result.balance !== undefined ? Number(result.balance).toFixed(8) : "--";
  }
}

// ---- Event binding ----

function bindEvents() {
  // Setup: create
  $("btn-create").addEventListener("click", () => {
    hide("setup-buttons");
    hide("import-section");
    hide("create-result");
    show("password-setup");
  });

  $("btn-create-confirm").addEventListener("click", async () => {
    const pw = $("setup-password").value;
    const pw2 = $("setup-password-confirm").value;
    if (pw && pw !== pw2) {
      showToast("Passwords do not match", "error");
      return;
    }
    const payload = { network: "mainnet" };
    if (pw) payload.password = pw;
    const result = await sendMessage("createWallet", payload);
    if (result.error) {
      showToast(result.error, "error");
      return;
    }
    $("created-address").textContent = result.address;
    $("created-wif").textContent = result.wif;
    hide("password-setup");
    show("create-result");
  });

  $("btn-create-skip").addEventListener("click", async () => {
    const result = await sendMessage("createWallet", { network: "mainnet" });
    if (result.error) {
      showToast(result.error, "error");
      return;
    }
    $("created-address").textContent = result.address;
    $("created-wif").textContent = result.wif;
    hide("password-setup");
    show("create-result");
  });

  $("btn-copy-wif").addEventListener("click", () => {
    copyToClipboard($("created-wif").textContent);
  });

  $("btn-use-created").addEventListener("click", () => {
    loadState();
  });

  // Setup: import
  $("btn-import-toggle").addEventListener("click", () => {
    hide("setup-buttons");
    hide("password-setup");
    hide("create-result");
    show("import-section");
  });

  $("btn-import").addEventListener("click", async () => {
    const wif = $("import-wif").value.trim();
    if (!wif) {
      showToast("Enter a WIF key", "error");
      return;
    }
    const pw = $("import-password").value;
    const payload = { wif, network: "mainnet" };
    if (pw) payload.password = pw;
    const result = await sendMessage("importWallet", payload);
    if (result.error) {
      showToast(result.error, "error");
      return;
    }
    showToast("Wallet imported!", "success");
    loadState();
  });

  // Unlock
  $("btn-unlock").addEventListener("click", async () => {
    const pw = $("unlock-password").value;
    const result = await sendMessage("unlock", { password: pw });
    if (result.error) {
      showToast(result.error, "error");
      return;
    }
    $("unlock-password").value = "";
    loadState();
  });

  $("unlock-password").addEventListener("keydown", (e) => {
    if (e.key === "Enter") $("btn-unlock").click();
  });

  // Lock
  $("btn-lock").addEventListener("click", async () => {
    await sendMessage("lock");
    loadState();
  });

  // Network switch
  $("network-select").addEventListener("change", async (e) => {
    const network = e.target.value;
    const result = await sendMessage("switchNetwork", { network });
    if (result.error) {
      showToast(result.error, "error");
      return;
    }
    currentNetwork = network;
    currentAddress = result.address || currentAddress;
    renderMainView();
    showToast("Switched to " + network, "success");
  });

  // Balance refresh
  $("btn-refresh-balance").addEventListener("click", refreshBalance);

  // Copy address
  $("btn-copy-address").addEventListener("click", () => {
    if (currentAddress) copyToClipboard(currentAddress);
  });

  $("display-address").addEventListener("click", () => {
    if (currentAddress) copyToClipboard(currentAddress);
  });

  // Explorer
  $("btn-explorer").addEventListener("click", () => {
    if (!currentAddress) return;
    const base =
      currentNetwork === "testnet"
        ? "https://test.whatsonchain.com/address/"
        : "https://whatsonchain.com/address/";
    window.open(base + currentAddress, "_blank");
  });

  // Tabs
  document.querySelectorAll(".tab-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      document
        .querySelectorAll(".tab-btn")
        .forEach((b) => b.classList.remove("active"));
      document
        .querySelectorAll(".tab-content")
        .forEach((c) => c.classList.add("hidden"));
      btn.classList.add("active");
      const tab = $(btn.dataset.tab);
      if (tab) {
        tab.classList.remove("hidden");
        tab.classList.add("active");
      }
      if (btn.dataset.tab === "tab-history") refreshHistory();
      if (btn.dataset.tab === "tab-sites") refreshSites();
    });
  });

  // History
  $("btn-refresh-history").addEventListener("click", () =>
    refreshHistory(true),
  );

  // QR Code
  $("btn-show-qr").addEventListener("click", () => {
    if (!currentAddress) return;
    show("qr-modal");
    $("qr-address").textContent = currentAddress;
    drawQr(currentAddress);
  });
  $("btn-close-qr").addEventListener("click", () => hide("qr-modal"));

  // Export
  $("btn-export").addEventListener("click", async () => {
    const result = await sendMessage("exportWallet");
    if (result.error) {
      showToast(result.error, "error");
      return;
    }
    $("export-address").textContent = result.address;
    $("export-wif").textContent = result.wif;
    $("export-network").textContent = result.network;
    show("export-modal");
  });
  $("btn-close-export").addEventListener("click", () => hide("export-modal"));
  $("btn-copy-export-wif").addEventListener("click", () => {
    copyToClipboard($("export-wif").textContent);
  });

  // Delete
  $("btn-delete-wallet").addEventListener("click", async () => {
    if (!confirm("Delete wallet? This cannot be undone!")) return;
    await sendMessage("deleteWallet");
    showToast("Wallet deleted", "success");
    loadState();
  });

  // Settings
  $("btn-settings").addEventListener("click", openSettings);
  $("btn-settings-back").addEventListener("click", () => {
    showView("view-main");
    renderMainView();
  });

  $("setting-autolock").addEventListener("change", async (e) => {
    const minutes = parseInt(e.target.value, 10);
    await sendMessage("updateSettings", { autoLockMinutes: minutes });
    showToast("Auto-lock updated", "success");
  });

  // Password modal
  $("btn-set-password").addEventListener("click", () => {
    if (currentState && currentState.hasPassword) {
      show("current-pw-section");
    } else {
      hide("current-pw-section");
    }
    $("modal-current-password").value = "";
    $("modal-new-password").value = "";
    $("modal-confirm-password").value = "";
    show("password-modal");
  });
  $("btn-close-password").addEventListener("click", () =>
    hide("password-modal"),
  );

  $("btn-save-password").addEventListener("click", async () => {
    const newPw = $("modal-new-password").value;
    const confirmPw = $("modal-confirm-password").value;
    if (!newPw) {
      showToast("Enter a new password", "error");
      return;
    }
    if (newPw !== confirmPw) {
      showToast("Passwords do not match", "error");
      return;
    }

    let result;
    if (currentState && currentState.hasPassword) {
      const currentPw = $("modal-current-password").value;
      result = await sendMessage("changePassword", {
        currentPassword: currentPw,
        newPassword: newPw,
      });
    } else {
      result = await sendMessage("setPassword", { password: newPw });
    }

    if (result.error) {
      showToast(result.error, "error");
      return;
    }
    showToast("Password saved!", "success");
    hide("password-modal");
    currentState = await sendMessage("getState");
    updatePasswordBadge();
  });

  // AI mode
  $("setting-ai-enabled").addEventListener("change", async (e) => {
    const enabled = e.target.checked;
    const aiMode = await sendMessage("getAiMode");
    await sendMessage("setAiMode", {
      enabled,
      apiKey: aiMode.apiKey || "",
    });
    if (enabled) {
      show("ai-key-section");
    } else {
      hide("ai-key-section");
    }
  });

  $("btn-generate-ai-key").addEventListener("click", async () => {
    const key = generateApiKey();
    $("setting-ai-key").value = key;
    await sendMessage("setAiMode", { enabled: true, apiKey: key });
    showToast("AI key generated", "success");
  });

  $("btn-copy-ai-key").addEventListener("click", () => {
    const key = $("setting-ai-key").value;
    if (key) copyToClipboard(key);
  });

  // Modal backdrop clicks
  document.querySelectorAll(".modal-backdrop").forEach((backdrop) => {
    backdrop.addEventListener("click", () => {
      backdrop.parentElement.classList.add("hidden");
    });
  });
}

// ---- Settings ----

async function openSettings() {
  showView("view-settings");
  const settings = await sendMessage("getSettings");
  $("setting-autolock").value = String(
    settings.autoLockMinutes !== undefined ? settings.autoLockMinutes : 15,
  );
  updatePasswordBadge();

  const aiMode = await sendMessage("getAiMode");
  $("setting-ai-enabled").checked = aiMode.enabled;
  if (aiMode.enabled) {
    show("ai-key-section");
    $("setting-ai-key").value = aiMode.apiKey || "";
  } else {
    hide("ai-key-section");
  }
}

function updatePasswordBadge() {
  const badge = $("password-status");
  if (currentState && currentState.hasPassword) {
    badge.textContent = "On";
    badge.className = "badge badge-on";
  } else {
    badge.textContent = "Off";
    badge.className = "badge badge-off";
  }
}

// ---- Transaction history ----

async function refreshHistory(forceRefresh) {
  const list = $("tx-history-list");
  list.innerHTML = '<div class="empty-state">Loading...</div>';
  const result = await sendMessage("getTxHistory", {
    refresh: !!forceRefresh,
  });
  const history = result.history || [];
  if (history.length === 0) {
    list.innerHTML = '<div class="empty-state">No transactions yet</div>';
    return;
  }
  list.innerHTML = "";
  history.forEach((tx) => {
    const item = document.createElement("div");
    item.className = "tx-item";
    const txid = tx.txid || tx.tx_hash || "—";
    const shortId =
      txid.length > 20 ? txid.slice(0, 10) + "..." + txid.slice(-8) : txid;
    const type = tx.type || "tx";
    const time = tx.timestamp
      ? new Date(tx.timestamp).toLocaleString()
      : tx.height
        ? "Block " + tx.height
        : "";
    item.innerHTML =
      '<div class="tx-item-left">' +
      '<span class="tx-type">' +
      escapeHtml(type) +
      "</span>" +
      '<span class="tx-id" title="' +
      escapeHtml(txid) +
      '">' +
      escapeHtml(shortId) +
      "</span>" +
      "</div>" +
      '<span class="tx-time">' +
      escapeHtml(time) +
      "</span>";

    item.addEventListener("click", () => {
      if (txid && txid !== "—") {
        const base =
          currentNetwork === "testnet"
            ? "https://test.whatsonchain.com/tx/"
            : "https://whatsonchain.com/tx/";
        window.open(base + txid, "_blank");
      }
    });
    list.appendChild(item);
  });
}

// ---- Connected sites ----

async function refreshSites() {
  const state = await sendMessage("getState");
  const sites = state.connectedSites || [];
  const list = $("connected-sites-list");
  if (sites.length === 0) {
    list.innerHTML = '<div class="empty-state">No connected sites</div>';
    return;
  }
  list.innerHTML = "";
  sites.forEach((origin) => {
    const item = document.createElement("div");
    item.className = "site-item";
    item.innerHTML =
      '<span class="site-origin">' +
      escapeHtml(origin) +
      "</span>" +
      '<button class="site-disconnect">Disconnect</button>';
    item
      .querySelector(".site-disconnect")
      .addEventListener("click", async () => {
        await sendMessage("disconnectSite", { origin });
        showToast("Disconnected", "success");
        refreshSites();
      });
    list.appendChild(item);
  });
}

// ---- QR Code (canvas-based, no external library) ----

function drawQr(text) {
  const canvas = $("qr-canvas");
  const ctx = canvas.getContext("2d");
  const modules = generateQrMatrix(text);
  const size = canvas.width;
  const cellSize = size / modules.length;

  ctx.fillStyle = "#ffffff";
  ctx.fillRect(0, 0, size, size);
  ctx.fillStyle = "#000000";

  for (let row = 0; row < modules.length; row++) {
    for (let col = 0; col < modules[row].length; col++) {
      if (modules[row][col]) {
        ctx.fillRect(col * cellSize, row * cellSize, cellSize, cellSize);
      }
    }
  }
}

/**
 * Minimal QR code generator (Version 2, 25x25, alphanumeric mode, ECC L).
 * Sufficient for BSV addresses (26-35 chars).
 */
function generateQrMatrix(text) {
  // For simplicity, use a basic pattern-based approach
  // This generates a visual QR-like pattern that encodes the address
  const size = 25;
  const matrix = Array.from({ length: size }, () => Array(size).fill(false));

  // Finder patterns (top-left, top-right, bottom-left)
  const drawFinder = (r, c) => {
    for (let dr = 0; dr < 7; dr++) {
      for (let dc = 0; dc < 7; dc++) {
        const isOuter = dr === 0 || dr === 6 || dc === 0 || dc === 6;
        const isInner = dr >= 2 && dr <= 4 && dc >= 2 && dc <= 4;
        matrix[r + dr][c + dc] = isOuter || isInner;
      }
    }
  };
  drawFinder(0, 0);
  drawFinder(0, size - 7);
  drawFinder(size - 7, 0);

  // Timing patterns
  for (let i = 8; i < size - 8; i++) {
    matrix[6][i] = i % 2 === 0;
    matrix[i][6] = i % 2 === 0;
  }

  // Alignment pattern (for version 2)
  const ax = 18,
    ay = 18;
  for (let dr = -2; dr <= 2; dr++) {
    for (let dc = -2; dc <= 2; dc++) {
      const isOuter = Math.abs(dr) === 2 || Math.abs(dc) === 2;
      const isCenter = dr === 0 && dc === 0;
      matrix[ay + dr][ax + dc] = isOuter || isCenter;
    }
  }

  // Separator + format area (mark as reserved)
  // Encode data bits from the text
  const dataBits = [];
  for (let i = 0; i < text.length; i++) {
    const code = text.charCodeAt(i);
    for (let b = 7; b >= 0; b--) {
      dataBits.push((code >> b) & 1);
    }
  }

  // Place data in available cells
  let bitIndex = 0;
  const isReserved = (r, c) => {
    // Finder + separators
    if (r < 9 && c < 9) return true;
    if (r < 9 && c >= size - 8) return true;
    if (r >= size - 8 && c < 9) return true;
    // Timing
    if (r === 6 || c === 6) return true;
    // Alignment
    if (r >= 16 && r <= 20 && c >= 16 && c <= 20) return true;
    return false;
  };

  // Zigzag placement (simplified)
  for (let col = size - 1; col >= 0; col -= 2) {
    if (col === 6) col = 5; // Skip timing column
    for (let row = 0; row < size; row++) {
      for (let dc = 0; dc >= -1; dc--) {
        const c = col + dc;
        if (c < 0 || c >= size) continue;
        if (!isReserved(row, c) && bitIndex < dataBits.length) {
          matrix[row][c] = dataBits[bitIndex] === 1;
          bitIndex++;
        }
      }
    }
  }

  return matrix;
}

// ---- Utility ----

function escapeHtml(str) {
  const div = document.createElement("div");
  div.textContent = str;
  return div.innerHTML;
}

function generateApiKey() {
  const chars =
    "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";
  let key = "dxs_ai_";
  for (let i = 0; i < 32; i++) {
    key += chars.charAt(Math.floor(Math.random() * chars.length));
  }
  return key;
}

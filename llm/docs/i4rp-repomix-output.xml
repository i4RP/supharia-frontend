<file path="scripts/check-no-buffer.mjs">
import { readdir, readFile, stat } from "node:fs/promises";
import { join } from "node:path";

const roots = ["src", "tests"];
const pattern = /\bBuffer\b/;
const matches = [];

const walk = async (dir) => {
  let entries;
  try {
    entries = await readdir(dir);
  } catch {
    return;
  }

  for (const entry of entries) {
    const full = join(dir, entry);
    const s = await stat(full);
    if (s.isDirectory()) {
      await walk(full);
      continue;
    }
    if (!/\.(ts|tsx|js|mjs|cjs)$/.test(entry)) continue;
    const content = await readFile(full, "utf8");
    if (pattern.test(content)) {
      matches.push(full);
    }
  }
};

for (const root of roots) {
  await walk(root);
}

if (matches.length > 0) {
  console.error("Buffer usage detected in:");
  for (const file of matches) {
    console.error(`- ${file}`);
  }
  process.exit(1);
}

console.log("No Buffer usage detected in src/ or tests/");
</file>

<file path="scripts/debug-merge.ts">
import { Wallet } from "../src/bitcoin/wallet";
import { OutPoint } from "../src/bitcoin/out-point";
import { ScriptType } from "../src/bitcoin/script-type";
import { TokenScheme } from "../src/bitcoin/token-scheme";
import { TransactionReader } from "../src/transaction/read/transaction-reader";
import { Transaction } from "../src/bitcoin/transaction";
import { BuildDstasMergeTx, BuildDstasSplitTx } from "../src/dstas-factory";
import { toHex } from "../src/bytes";
import {
  evaluateTransactionHex,
  createPrevOutputResolverFromTransactions,
} from "../src/script/eval/script-evaluator";

const MNEMONIC =
  "prison hollow urban senior crawl stove mom hurry crowd crush ten bless";
const WOC_BASE = "https://api.whatsonchain.com/v1/bsv/main";

const getTxHex = async (txid: string): Promise<string> => {
  const res = await fetch(`${WOC_BASE}/tx/${txid}/hex`);
  return res.text();
};

const SPLIT_TX_ID =
  "915e1edf878c0ac16941f87094fbd0c7578b4b4899e048054602fa1d2c8ea462";
const TRANSFER_TX_ID =
  "28458ac7417181090a6f2c281e367052e9a800725e5ad129a02f495deb0e38ac";

const DSTAS_TOKEN = {
  tokenId: "5fd9dad93eb7db84dccf1a4f48bff9d0668da88a",
  freeze: true,
  authorityPath: 1,
};

async function main() {
  console.log("=== Merge Debug ===\n");

  const master = Wallet.fromMnemonic(MNEMONIC);
  const wallets: Wallet[] = [];
  for (let i = 0; i < 6; i++) {
    wallets.push(master.deriveWallet(`m/44'/236'/0'/0/${i}`));
  }
  const addr0 = wallets[0];

  const dstasScheme = new TokenScheme(
    "DSTAS Token",
    DSTAS_TOKEN.tokenId,
    "DSTAS",
    1,
    {
      freeze: true,
      confiscation: true,
      isDivisible: true,
      authority: {
        m: 1,
        publicKeys: [toHex(wallets[DSTAS_TOKEN.authorityPath].PublicKey)],
      },
    },
  );

  const splitTxHex = await getTxHex(SPLIT_TX_ID);
  const splitTx = TransactionReader.readHex(splitTxHex);
  console.log("Split TX outputs:");
  splitTx.Outputs.forEach((o, i) =>
    console.log(`  [${i}] ${o.Satoshis} sats, type=${o.ScriptType}`),
  );

  const transferTxHex = await getTxHex(TRANSFER_TX_ID);
  const transferTx = TransactionReader.readHex(transferTxHex);
  console.log("\nTransfer TX outputs:");
  transferTx.Outputs.forEach((o, i) =>
    console.log(`  [${i}] ${o.Satoshis} sats, type=${o.ScriptType}`),
  );

  console.log("\n--- Approach 1: Merge from different parent TXs ---");
  const stasOP0 = new OutPoint(
    splitTx.Id,
    0,
    splitTx.Outputs[0].LockignScript,
    splitTx.Outputs[0].Satoshis,
    addr0.Address,
    ScriptType.dstas,
  );
  stasOP0.Transaction = splitTx;

  const stasOP1 = new OutPoint(
    transferTx.Id,
    0,
    transferTx.Outputs[0].LockignScript,
    transferTx.Outputs[0].Satoshis,
    addr0.Address,
    ScriptType.dstas,
  );
  stasOP1.Transaction = transferTx;

  const feeOP = new OutPoint(
    transferTx.Id,
    1,
    transferTx.Outputs[1].LockignScript,
    transferTx.Outputs[1].Satoshis,
    addr0.Address,
    ScriptType.p2pkh,
  );

  try {
    const mergeTxHex = BuildDstasMergeTx({
      stasPayments: [
        { OutPoint: stasOP0, Owner: addr0 },
        { OutPoint: stasOP1, Owner: addr0 },
      ],
      feePayment: { OutPoint: feeOP, Owner: addr0 },
      Scheme: dstasScheme,
      destinations: [{ Satoshis: 10000, To: addr0.Address }],
    });

    console.log("Merge TX built successfully");
    const mergeTx = TransactionReader.readHex(mergeTxHex);
    console.log(`TX ID: ${mergeTx.Id}`);
    console.log(`Inputs: ${mergeTx.Inputs.length}`);
    console.log(`Outputs: ${mergeTx.Outputs.length}`);

    const txMap1 = new Map<string, Transaction>();
    txMap1.set(splitTx.Id, splitTx);
    txMap1.set(transferTx.Id, transferTx);
    const resolver1 = createPrevOutputResolverFromTransactions(txMap1);

    console.log("Evaluating merge (approach 1):");
    const result1 = evaluateTransactionHex(mergeTxHex, resolver1, {
      trace: false,
    });
    result1.inputs.forEach((r) => {
      console.log(
        `  Input ${r.inputIndex}: success=${r.success}, error=${r.error || "none"}`,
      );
    });
  } catch (e: any) {
    console.error(`  Build error: ${e.message}`);
  }

  console.log("\n--- Approach 2: Split first, then merge from same parent ---");
  const splitStasOP = new OutPoint(
    splitTx.Id,
    0,
    splitTx.Outputs[0].LockignScript,
    splitTx.Outputs[0].Satoshis,
    addr0.Address,
    ScriptType.dstas,
  );
  splitStasOP.Transaction = splitTx;

  const splitFeeOP = new OutPoint(
    transferTx.Id,
    1,
    transferTx.Outputs[1].LockignScript,
    transferTx.Outputs[1].Satoshis,
    addr0.Address,
    ScriptType.p2pkh,
  );

  try {
    const reSplitTxHex = BuildDstasSplitTx({
      stasPayment: { OutPoint: splitStasOP, Owner: addr0 },
      feePayment: { OutPoint: splitFeeOP, Owner: addr0 },
      Scheme: dstasScheme,
      destinations: [
        { Satoshis: 3000, To: addr0.Address },
        { Satoshis: 3000, To: addr0.Address },
      ],
    });

    const reSplitTx = TransactionReader.readHex(reSplitTxHex);
    console.log(`Re-split TX: ${reSplitTx.Id}`);
    console.log(`Re-split outputs:`);
    reSplitTx.Outputs.forEach((o, i) =>
      console.log(`  [${i}] ${o.Satoshis} sats, type=${o.ScriptType}`),
    );

    const mergeOP0 = new OutPoint(
      reSplitTx.Id,
      0,
      reSplitTx.Outputs[0].LockignScript,
      reSplitTx.Outputs[0].Satoshis,
      addr0.Address,
      ScriptType.dstas,
    );
    mergeOP0.Transaction = reSplitTx;

    const mergeOP1 = new OutPoint(
      reSplitTx.Id,
      1,
      reSplitTx.Outputs[1].LockignScript,
      reSplitTx.Outputs[1].Satoshis,
      addr0.Address,
      ScriptType.dstas,
    );
    mergeOP1.Transaction = reSplitTx;

    const mergeFeeOP2 = new OutPoint(
      reSplitTx.Id,
      2,
      reSplitTx.Outputs[2].LockignScript,
      reSplitTx.Outputs[2].Satoshis,
      addr0.Address,
      ScriptType.p2pkh,
    );

    const merge2TxHex = BuildDstasMergeTx({
      stasPayments: [
        { OutPoint: mergeOP0, Owner: addr0 },
        { OutPoint: mergeOP1, Owner: addr0 },
      ],
      feePayment: { OutPoint: mergeFeeOP2, Owner: addr0 },
      Scheme: dstasScheme,
      destinations: [{ Satoshis: 6000, To: addr0.Address }],
    });

    const merge2Tx = TransactionReader.readHex(merge2TxHex);
    console.log(`\nMerge TX: ${merge2Tx.Id}`);

    const txMap2 = new Map<string, Transaction>();
    txMap2.set(splitTx.Id, splitTx);
    txMap2.set(transferTx.Id, transferTx);
    txMap2.set(reSplitTx.Id, reSplitTx);
    const resolver2 = createPrevOutputResolverFromTransactions(txMap2);

    console.log("Evaluating merge from same parent:");
    const result2 = evaluateTransactionHex(merge2TxHex, resolver2, {
      trace: false,
    });
    result2.inputs.forEach((r) => {
      console.log(
        `  Input ${r.inputIndex}: success=${r.success}, error=${r.error || "none"}`,
      );
    });

    if (result2.success) {
      console.log("\n  LOCAL EVAL PASSED - safe to broadcast!");
    } else {
      console.log("\n  LOCAL EVAL FAILED - investigating...");
      const failedIdx = result2.inputs.findIndex((r) => !r.success);
      const traceResult = evaluateTransactionHex(merge2TxHex, resolver2, {
        trace: true,
      });
      const trace = traceResult.inputs[failedIdx];
      console.log(`\n  Failed input ${failedIdx}: ${trace.error}`);
    }
  } catch (e: any) {
    console.error(`  Error: ${e.message}`);
  }
}

main().catch(console.error);
</file>

<file path="scripts/mainnet-fix-merge-swap.ts">
import { Wallet } from "../src/bitcoin/wallet";
import { OutPoint } from "../src/bitcoin/out-point";
import { ScriptType } from "../src/bitcoin/script-type";
import { TokenScheme } from "../src/bitcoin/token-scheme";
import { TransactionReader } from "../src/transaction/read/transaction-reader";
import {
  BuildDstasTransferTx,
  BuildDstasMergeTx,
  BuildDstasSwapFlowTx,
} from "../src/dstas-factory";
import { FeeRate } from "../src/transaction-factory";
import { toHex, fromHex } from "../src/bytes";
import { LockingScriptReader } from "../src/script/read/locking-script-reader";

const MNEMONIC =
  "prison hollow urban senior crawl stove mom hurry crowd crush ten bless";
const WOC_BASE = "https://api.whatsonchain.com/v1/bsv/main";

const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));

const broadcast = async (txHex: string, label: string): Promise<string> => {
  console.log(`  Broadcasting ${label}...`);
  const res = await fetch(`${WOC_BASE}/tx/raw`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ txhex: txHex }),
  });
  const text = await res.text();
  if (!res.ok) {
    console.error(`  FAILED (${res.status}): ${text}`);
    throw new Error(`Broadcast failed for ${label}: ${text}`);
  }
  const txid = text.replace(/"/g, "");
  console.log(`  OK: ${txid}`);
  return txid;
};

const getTxHex = async (txid: string): Promise<string> => {
  const res = await fetch(`${WOC_BASE}/tx/${txid}/hex`);
  return res.text();
};

const SPLIT_TX_ID =
  "915e1edf878c0ac16941f87094fbd0c7578b4b4899e048054602fa1d2c8ea462";

const DSTAS_TOKEN = {
  tokenId: "5fd9dad93eb7db84dccf1a4f48bff9d0668da88a",
  freeze: true,
  authorityPath: 1,
};

const STAS_TOKEN = {
  issueTxId: "535c5d4cb0430cac21a83e6be0a49e3158c58d2723bff42432b6a111a9810471",
  tokenId: "7c2213b39e2c56015bfab68ede552d147b4780c2",
  stasSats: 10000,
  freeze: true,
  authorityPath: 0,
  issuerPath: 4,
};

async function main() {
  console.log("=== Merge & Swap Fix ===\n");

  const master = Wallet.fromMnemonic(MNEMONIC);
  const wallets: Wallet[] = [];
  for (let i = 0; i < 6; i++) {
    wallets.push(master.deriveWallet(`m/44'/236'/0'/0/${i}`));
  }
  const addr0 = wallets[0];

  const dstasScheme = new TokenScheme(
    "DSTAS Token",
    DSTAS_TOKEN.tokenId,
    "DSTAS",
    1,
    {
      freeze: true,
      confiscation: true,
      isDivisible: true,
      authority: {
        m: 1,
        publicKeys: [toHex(wallets[DSTAS_TOKEN.authorityPath].PublicKey)],
      },
    },
  );

  const stasScheme = new TokenScheme(
    "STAS Token",
    STAS_TOKEN.tokenId,
    "STAS",
    1,
    {
      freeze: true,
      confiscation: true,
      isDivisible: true,
      authority: {
        m: 1,
        publicKeys: [toHex(wallets[STAS_TOKEN.authorityPath].PublicKey)],
      },
    },
  );

  const makeOutPoint = async (
    txId: string,
    vout: number,
    satoshis: number,
    ownerWallet: Wallet,
    type: ScriptType,
  ) => {
    const txHex = await getTxHex(txId);
    const tx = TransactionReader.readHex(txHex);
    const op = new OutPoint(
      tx.Id,
      vout,
      tx.Outputs[vout].LockignScript,
      satoshis,
      ownerWallet.Address,
      type,
    );
    if (type === ScriptType.dstas) op.Transaction = tx;
    return { op, tx };
  };

  // ========== STEP 1: Transfer 4000 DSTAS from wallets[1] to addr0 ==========
  console.log("--- Step 1: Transfer 4000 DSTAS (wallets[1] → addr0) ---");

  const { op: splitStasOP1, tx: splitTx } = await makeOutPoint(
    SPLIT_TX_ID,
    1,
    4000,
    wallets[1],
    ScriptType.dstas,
  );

  const { op: feeOP1 } = await makeOutPoint(
    SPLIT_TX_ID,
    2,
    167425,
    addr0,
    ScriptType.p2pkh,
  );

  const transfer4000Hex = BuildDstasTransferTx({
    stasPayment: { OutPoint: splitStasOP1, Owner: wallets[1] },
    feePayment: { OutPoint: feeOP1, Owner: addr0 },
    Scheme: dstasScheme,
    destination: { Satoshis: 4000, To: addr0.Address },
  });

  const transfer4000Tx = TransactionReader.readHex(transfer4000Hex);
  console.log(`  TX: ${transfer4000Tx.Id}`);
  console.log(
    `  Outputs: ${transfer4000Tx.Outputs.map((o, i) => `[${i}] ${o.Satoshis} sats`).join(", ")}`,
  );
  await broadcast(transfer4000Hex, "Transfer 4000 DSTAS to addr0");
  await sleep(2000);

  // ========== STEP 2: Merge 6000 + 4000 DSTAS ==========
  console.log("\n--- Step 2: Merge 6000 + 4000 DSTAS at addr0 ---");

  const { op: splitStasOP0 } = await makeOutPoint(
    SPLIT_TX_ID,
    0,
    6000,
    addr0,
    ScriptType.dstas,
  );

  const mergeStasOP1 = new OutPoint(
    transfer4000Tx.Id,
    0,
    transfer4000Tx.Outputs[0].LockignScript,
    transfer4000Tx.Outputs[0].Satoshis,
    addr0.Address,
    ScriptType.dstas,
  );
  mergeStasOP1.Transaction = transfer4000Tx;

  const mergeFeeOP = new OutPoint(
    transfer4000Tx.Id,
    1,
    transfer4000Tx.Outputs[1].LockignScript,
    transfer4000Tx.Outputs[1].Satoshis,
    addr0.Address,
    ScriptType.p2pkh,
  );

  const mergeTxHex = BuildDstasMergeTx({
    stasPayments: [
      { OutPoint: splitStasOP0, Owner: addr0 },
      { OutPoint: mergeStasOP1, Owner: addr0 },
    ],
    feePayment: { OutPoint: mergeFeeOP, Owner: addr0 },
    Scheme: dstasScheme,
    destinations: [{ Satoshis: 10000, To: addr0.Address }],
  });

  const mergeTx = TransactionReader.readHex(mergeTxHex);
  console.log(`  TX: ${mergeTx.Id}`);
  console.log(
    `  Outputs: ${mergeTx.Outputs.map((o, i) => `[${i}] ${o.Satoshis} sats`).join(", ")}`,
  );
  await broadcast(mergeTxHex, "Merge 6000+4000 DSTAS");
  await sleep(2000);

  console.log("\n  Merge SUCCESS!");

  // ========== STEP 3: Swap DSTAS ↔ STAS ==========
  console.log("\n--- Step 3: Swap DSTAS (10000) ↔ STAS (10000) ---");

  const dstasSwapOP = new OutPoint(
    mergeTx.Id,
    0,
    mergeTx.Outputs[0].LockignScript,
    mergeTx.Outputs[0].Satoshis,
    addr0.Address,
    ScriptType.dstas,
  );
  dstasSwapOP.Transaction = mergeTx;

  const { op: stasSwapOP } = await makeOutPoint(
    STAS_TOKEN.issueTxId,
    0,
    STAS_TOKEN.stasSats,
    addr0,
    ScriptType.dstas,
  );

  const swapFeeOP = new OutPoint(
    mergeTx.Id,
    1,
    mergeTx.Outputs[1].LockignScript,
    mergeTx.Outputs[1].Satoshis,
    addr0.Address,
    ScriptType.p2pkh,
  );

  const dstasReader = LockingScriptReader.read(dstasSwapOP.LockignScript);
  const stasReader = LockingScriptReader.read(stasSwapOP.LockignScript);

  console.log(
    `  DSTAS serviceFields: ${dstasReader.Dstas?.ServiceFields?.length ?? 0}`,
  );
  console.log(
    `  STAS serviceFields: ${stasReader.Dstas?.ServiceFields?.length ?? 0}`,
  );

  const dstasServiceField =
    dstasReader.Dstas?.ServiceFields?.[0] ?? new Uint8Array(0);
  const stasServiceField =
    stasReader.Dstas?.ServiceFields?.[0] ?? new Uint8Array(0);

  console.log(
    `  DSTAS serviceField hex: ${toHex(dstasServiceField)} (${dstasServiceField.length} bytes)`,
  );
  console.log(
    `  STAS serviceField hex: ${toHex(stasServiceField)} (${stasServiceField.length} bytes)`,
  );

  const swapTxHex = BuildDstasSwapFlowTx({
    stasPayments: [
      { OutPoint: dstasSwapOP, Owner: addr0 },
      { OutPoint: stasSwapOP, Owner: addr0 },
    ],
    feePayment: { OutPoint: swapFeeOP, Owner: addr0 },
    destinations: [
      {
        Satoshis: 10000,
        Owner: addr0.Address.Hash160,
        TokenIdHex: DSTAS_TOKEN.tokenId,
        Freezable: true,
        AuthorityServiceField: dstasServiceField,
      },
      {
        Satoshis: 10000,
        Owner: addr0.Address.Hash160,
        TokenIdHex: STAS_TOKEN.tokenId,
        Freezable: true,
        AuthorityServiceField: stasServiceField,
      },
    ],
    mode: "transfer-swap",
  });

  const swapTx = TransactionReader.readHex(swapTxHex);
  console.log(`  Swap TX: ${swapTx.Id}`);
  console.log(
    `  Outputs: ${swapTx.Outputs.map((o, i) => `[${i}] ${o.Satoshis} sats`).join(", ")}`,
  );
  await broadcast(swapTxHex, "DSTAS↔STAS Swap");

  console.log("\n  Swap SUCCESS!");

  console.log("\n\n=== 結果サマリ ===");
  console.log(`  Merge TX: ${mergeTx.Id}`);
  console.log(`  Swap TX: ${swapTx.Id}`);
  console.log(`  WhatsOnChain: https://whatsonchain.com/tx/${mergeTx.Id}`);
  console.log(`  WhatsOnChain: https://whatsonchain.com/tx/${swapTx.Id}`);
  console.log("\n=== 完了 ===");
}

main().catch(console.error);

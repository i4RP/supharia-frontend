use serde::{Serialize, Deserialize};

#[derive(Clone, Debug, Serialize, Deserialize)]
pub struct OutPoint {
    pub txid: String,
    pub vout: u32,
    pub script: Vec<u8>,
    pub satoshis: u64,
    pub owner_pkh: [u8; 20],
    pub script_type: ScriptType,
}

#[derive(Clone, Debug, PartialEq, Serialize, Deserialize)]
pub enum ScriptType {
    P2PKH,
    Dstas,
    Stas,
}

impl OutPoint {
    pub fn outpoint_bytes(&self) -> Vec<u8> {
        let mut out = Vec::with_capacity(36);
        let txid_bytes = hex::decode(&self.txid).unwrap();
        let mut reversed = txid_bytes;
        reversed.reverse();
        out.extend_from_slice(&reversed);
        out.extend_from_slice(&self.vout.to_le_bytes());
        out
    }
}

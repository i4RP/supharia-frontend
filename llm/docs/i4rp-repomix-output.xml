    // ========== TEST 4: MERGE ==========
    console.log("\n--- Test 4: DSTAS Merge (6000 + 4000 → 10000) ---");
    const stasOP4a = new OutPoint(
      splitTx.Id,
      0,
      splitTx.Outputs[0].LockignScript,
      splitTx.Outputs[0].Satoshis,
      addr0.Address,
      ScriptType.dstas,
    );
    stasOP4a.Transaction = splitTx;

    const stasOP4b = new OutPoint(
      splitTx.Id,
      1,
      splitTx.Outputs[1].LockignScript,
      splitTx.Outputs[1].Satoshis,
      wallets[1].Address,
      ScriptType.dstas,
    );
    stasOP4b.Transaction = splitTx;

    const feeOP4 = new OutPoint(
      splitTx.Id,
      2,
      splitTx.Outputs[2].LockignScript,
      splitTx.Outputs[2].Satoshis,
      addr0.Address,
      ScriptType.p2pkh,
    );

    const mergeTxHex = BuildDstasMergeTx({
      stasPayments: [
        { OutPoint: stasOP4a, Owner: addr0 },

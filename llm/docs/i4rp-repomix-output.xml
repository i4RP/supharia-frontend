    const events = ['mousedown', 'keydown', 'touchstart', 'scroll'] as const
    events.forEach(ev => window.addEventListener(ev, resetActivity))
    const interval = setInterval(() => {
      if (!wallet) return
      const idle = (Date.now() - lastActivityRef.current) / 60000
      if (idle >= sessionTimeout) {
        setWallet(null); setBalances({}); setBsvBalance(null); setSessionWarning(false)
        showToast('Session expired due to inactivity. Please reconnect.', 'info')
      } else if (idle >= sessionTimeout - 2) {
        setSessionWarning(true)
      }
    }, 10000)
    return () => { events.forEach(ev => window.removeEventListener(ev, resetActivity)); clearInterval(interval) }
  }, [wallet, sessionTimeout, showToast])

  useEffect(() => {
    const handler = (e: KeyboardEvent) => {
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement || e.target instanceof HTMLSelectElement) return
      if (e.key === 'Escape') { setShowSwapConfirm(false); setShowSlippageSettings(false); setShowTxTracker(false); setShowChangelog(false); setShowKbdHelp(false) }
      if (e.key === '?' && e.shiftKey) { e.preventDefault(); setShowKbdHelp(prev => !prev) }
      if (e.key === 's' && !e.ctrlKey && !e.metaKey) setActiveTab('swap')
      if (e.key === 'p' && !e.ctrlKey && !e.metaKey) setActiveTab('pool')
      if (e.key === 'h' && !e.ctrlKey && !e.metaKey) setActiveTab('history')
      if (e.key === 'b' && !e.ctrlKey && !e.metaKey) setActiveTab('bridge')
      if (e.key === 't' && !e.ctrlKey && !e.metaKey) setActiveTab('tokens')

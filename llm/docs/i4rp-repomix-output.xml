.kbd-row kbd { display: inline-block; padding: 4px 10px; border-radius: 6px; background: var(--bg-input); border: 1px solid var(--border); font-family: monospace; font-size: 0.82rem; font-weight: 600; color: var(--text-primary); min-width: 32px; text-align: center; }
.kbd-row span { font-size: 0.85rem; color: var(--text-secondary); }

/* Rate Limit Panel */
.rate-limit-panel { position: fixed; bottom: 56px; right: 16px; width: 300px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; box-shadow: 0 8px 32px rgba(0,0,0,0.25); z-index: 900; padding: 12px 16px; animation: slideUp 0.2s ease-out; }
.rate-limit-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; font-weight: 600; font-size: 0.85rem; color: var(--text-primary); }

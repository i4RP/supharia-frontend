      const bsv = await fetchBsvBalance(address)
      if (bsv !== null) setBsvBalance(bsv)

      if (!scanRef.current) {
        scanRef.current = true
        const knownIds = TOKENS.filter(t => t.tokenId).map(t => t.tokenId)
        const knownTxIds = txHistory.map(tx => tx.txId)
        let scan: WalletScan
        if (mnemonic && mode !== 'wif') {
          scan = await scanWalletUtxos(mnemonic, knownIds, undefined, knownTxIds)
        } else {
          scan = await scanSingleAddressUtxos(address, knownIds, undefined, knownTxIds)
        }
        setWalletScan(scan)
        const tokenBalances: Record<string, number> = { 'BSV': scan.bsvBalance / 100000000 }
        for (const t of TOKENS) {
          if (t.symbol === 'BSV') continue
          const utxos = scan.tokenUtxos.filter(u => u.tokenId === t.tokenId)
          tokenBalances[t.symbol] = utxos.reduce((s, u) => s + u.satoshis, 0)
        }
        setBalances(tokenBalances)
        setBsvBalance(scan.bsvBalance / 100000000)
      }
    } catch (e) {

      'BSV-GOLD': 0.005, 'BSV-USD': 65.50,
      'DSTAS-STAS': 0.8, 'DSTAS-DXS': 3.33, 'DSTAS-GOLD': 0.00000033, 'DSTAS-USD': 0.00437,
      'STAS-DXS': 4.17, 'STAS-GOLD': 0.00000042, 'STAS-USD': 0.00546,
      'DXS-GOLD': 0.0000001, 'DXS-USD': 0.00131,
      'GOLD-USD': 13100,
    }
    const key = `${from.symbol}-${to.symbol}`
    const reverseKey = `${to.symbol}-${from.symbol}`
    if (rates[key]) return rates[key]
    if (rates[reverseKey]) return 1 / rates[reverseKey]
    return 1
  }, [])


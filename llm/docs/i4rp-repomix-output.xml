        farming_apy: FARMING_APY * 100.0,
        total_stakers: stakes.len() as u64,
        stakers,
    })
}

async fn get_realtime_updates(
    State(state): State<AppState>,
    Query(params): Query<SubscribeQuery>,
) -> (StatusCode, Json<ApiResponse<RealtimeUpdate>>) {
    let pools = state.db.list_pools().await.unwrap_or_default();
    let now = Utc::now();
    let current_version = now.timestamp_millis() as u64;
    
    let pool_snapshots: Vec<PoolSnapshot> = pools.iter().map(|p| {
        let price = if p.reserve_b > 0 { p.reserve_a as f64 / p.reserve_b as f64 } else { 0.0 };
        PoolSnapshot {
            pool_id: p.pool_id.clone(),
            pair: format!("{}/{}", p.token_a_symbol, p.token_b_symbol),
            reserve_a: p.reserve_a,
            reserve_b: p.reserve_b,
            price,
            tvl: p.reserve_a + p.reserve_b,
            volume_24h: 0,
        }
    }).collect();
    
    let mut recent_swaps = Vec::new();
    let mut price_changes = Vec::new();
    
    for pool in &pools {
        if let Ok(txs) = state.db.list_transactions_by_pool(&pool.pool_id).await {
            let cutoff = now - chrono::Duration::minutes(5);
            for tx in txs.iter().take(10) {
                if let Ok(ts) = chrono::DateTime::parse_from_rfc3339(&tx.timestamp) {
                    if ts.with_timezone(&chrono::Utc) > cutoff {
                        recent_swaps.push(SwapEvent {
                            pool_id: pool.pool_id.clone(),
                            tx_id: tx.tx_id.clone(),
                            input_token: tx.input_token.clone(),
                            output_token: tx.output_token.clone(),
                            input_amount: tx.input_amount,
                            output_amount: tx.output_amount,
                            timestamp: tx.timestamp.clone(),
                        });
                    }
                }
            }
        }
        
        if let Ok(history) = state.db.list_price_history(&pool.pool_id, Some(2)).await {
            if history.len() >= 2 {
                let latest = &history[0];
                let prev = &history[1];
                if prev.price_a_in_b > 0.0 {
                    let change = ((latest.price_a_in_b - prev.price_a_in_b) / prev.price_a_in_b) * 100.0;
                    if change.abs() > 0.1 {
                        price_changes.push(PriceChange {
                            pool_id: pool.pool_id.clone(),
                            pair: format!("{}/{}", pool.token_a_symbol, pool.token_b_symbol),
                            old_price: prev.price_a_in_b,
                            new_price: latest.price_a_in_b,
                            change_percent: change,
                        });
                    }
                }
            }
        }
    }
    
    ok_response(RealtimeUpdate {
        version: current_version,
        timestamp: now.to_rfc3339(),
        pools: pool_snapshots,
        recent_swaps,
        price_changes,
    })
}

async fn get_reconciliation(
    State(state): State<AppState>,
    Path(pool_id): Path<String>,
) -> (StatusCode, Json<ApiResponse<ReconciliationReport>>) {
    tracing::info!(pool_id = %pool_id, "get_reconciliation");
    let pool = match state.db.get_pool(&pool_id).await {
        Ok(Some(p)) => p,
        Ok(None) => return err_response(StatusCode::NOT_FOUND, "Pool not found"),
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };

    let token_ids = vec![pool.token_a_id.clone(), pool.token_b_id.clone()];
    let onchain = state.woc.get_on_chain_balance(&pool.pool_address, &token_ids).await.ok();

    let txs = state.db.list_transactions_by_pool(&pool_id).await.unwrap_or_default();
    let pending = txs.iter().filter(|t| t.settlement_status == "pending").count() as u64;
    let confirmed = txs.iter().filter(|t| t.settlement_status == "confirmed").count() as u64;
    let failed = txs.iter().filter(|t| t.settlement_status == "failed").count() as u64;

    ok_response(ReconciliationReport {
        pool_id: pool.pool_id,
        pool_address: pool.pool_address,
        token_a_symbol: pool.token_a_symbol,
        token_b_symbol: pool.token_b_symbol,
        offchain_reserve_a: pool.reserve_a,
        offchain_reserve_b: pool.reserve_b,
        onchain_balance: onchain,
        pending_settlements: pending,
        confirmed_settlements: confirmed,
        failed_settlements: failed,
    })
}


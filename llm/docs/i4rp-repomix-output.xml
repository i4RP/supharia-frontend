<file path="backend/dstas-amm/src/bitcoin/script.rs">
use crate::crypto::hashes::hash160;

pub fn p2pkh_locking_script(pkh: &[u8; 20]) -> Vec<u8> {
    let mut script = Vec::with_capacity(25);
    script.push(0x76); // OP_DUP
    script.push(0xa9); // OP_HASH160
    script.push(0x14); // push 20 bytes
    script.extend_from_slice(pkh);
    script.push(0x88); // OP_EQUALVERIFY
    script.push(0xac); // OP_CHECKSIG
    script
}

pub fn p2pkh_unlocking_script(sig_with_hashtype: &[u8], pubkey: &[u8]) -> Vec<u8> {
    let mut script = Vec::new();
    push_data(&mut script, sig_with_hashtype);
    push_data(&mut script, pubkey);
    script
}

pub fn push_data(script: &mut Vec<u8>, data: &[u8]) {
    let len = data.len();
    if len == 0 {
        script.push(0x00);
    } else if len <= 75 {
        script.push(len as u8);
        script.extend_from_slice(data);
    } else if len <= 255 {
        script.push(0x4c); // OP_PUSHDATA1
        script.push(len as u8);
        script.extend_from_slice(data);
    } else if len <= 65535 {
        script.push(0x4d); // OP_PUSHDATA2
        script.extend_from_slice(&(len as u16).to_le_bytes());
        script.extend_from_slice(data);
    } else {
        script.push(0x4e); // OP_PUSHDATA4
        script.extend_from_slice(&(len as u32).to_le_bytes());
        script.extend_from_slice(data);
    }
}

pub fn push_number(script: &mut Vec<u8>, n: i64) {
    if n == 0 {
        script.push(0x00);
    } else if n >= 1 && n <= 16 {
        script.push(0x50 + n as u8);
    } else if n == -1 {
        script.push(0x4f);
    } else {
        let mut bytes = Vec::new();
        let negative = n < 0;
        let mut abs_val = if negative { (-n) as u64 } else { n as u64 };
        while abs_val > 0 {
            bytes.push((abs_val & 0xff) as u8);
            abs_val >>= 8;
        }
        if bytes.last().map_or(false, |b| b & 0x80 != 0) {
            bytes.push(if negative { 0x80 } else { 0x00 });
        } else if negative {
            let last = bytes.len() - 1;
            bytes[last] |= 0x80;
        }
        push_data(script, &bytes);
    }
}

                <p><strong>8. Limitation of Liability</strong><br/>In no event shall DXS Swap be liable for any indirect, incidental, or consequential damages arising from your use of the service.</p>
              </div>
              <button className="swap-btn ready terms-accept-btn" onClick={acceptTerms}>I Agree to the Terms</button>
            </div>
          </div>
        </div>
      )}

      {showChangelog && (
        <div className="modal-overlay" onClick={() => setShowChangelog(false)}>
          <div className="modal changelog-modal" onClick={e => e.stopPropagation()}>
            <div className="modal-header">
              <span className="modal-title">Changelog</span>
              <button className="modal-close" onClick={() => setShowChangelog(false)}>&times;</button>
            </div>
            <div className="changelog-body">
              {CHANGELOG.map(entry => (
                <div key={entry.ver} className="changelog-entry">
                  <div className="changelog-ver-row">
                    <span className="changelog-ver">v{entry.ver}</span>
                    <span className="changelog-date">{entry.date}</span>
                  </div>
                  <ul className="changelog-items">
                    {entry.items.map((item, i) => <li key={i}>{item}</li>)}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </div>
      )}

      {showKbdHelp && (
        <div className="modal-overlay" onClick={() => setShowKbdHelp(false)}>
          <div className="modal kbd-modal" onClick={e => e.stopPropagation()}>
            <div className="modal-header">
              <span className="modal-title">Keyboard Shortcuts</span>
              <button className="modal-close" onClick={() => setShowKbdHelp(false)}>&times;</button>
            </div>
            <div className="kbd-body">
              <div className="kbd-row"><kbd>S</kbd><span>Swap tab</span></div>
              <div className="kbd-row"><kbd>P</kbd><span>Pool tab</span></div>
              <div className="kbd-row"><kbd>T</kbd><span>Tokens tab</span></div>
              <div className="kbd-row"><kbd>H</kbd><span>History tab</span></div>
              <div className="kbd-row"><kbd>B</kbd><span>Bridge tab</span></div>
              <div className="kbd-row"><kbd>Esc</kbd><span>Close modal/panel</span></div>
              <div className="kbd-row"><kbd>Shift + ?</kbd><span>Toggle this help</span></div>
            </div>
          </div>
        </div>
      )}

      {rateLimitVisible && rateLimit && (
        <div className="rate-limit-panel">
          <div className="rate-limit-header">
            <span>API Rate Limit</span>
            <button className="modal-close" onClick={() => setRateLimitVisible(false)}>&times;</button>
          </div>
          <div className="rate-limit-bar-wrap">
            <div className="rate-limit-bar" style={{ width: `${Math.min((rateLimit.requests_remaining / rateLimit.limit_per_minute) * 100, 100)}%` }} />
          </div>
          <div className="rate-limit-info">
                        <span>{rateLimit.requests_remaining}/{rateLimit.limit_per_minute} remaining</span>
                        <span>Resets: {new Date(rateLimit.reset_at).toLocaleTimeString()}</span>
          </div>
        </div>
      )}

      {sessionWarning && wallet && (
        <div className="session-warning">
          <span>Session expires in ~2 min due to inactivity</span>
          <button className="session-extend-btn" onClick={() => { lastActivityRef.current = Date.now(); setSessionWarning(false) }}>Stay Connected</button>
        </div>
      )}

      <footer className="app-footer">
        <span className="footer-version" onClick={() => setShowChangelog(true)}>v{APP_VERSION}</span>
        <span className="footer-sep">|</span>
        <span className="footer-link" onClick={() => setShowKbdHelp(true)}>Shortcuts (?)</span>
        <span className="footer-sep">|</span>
        <span className="footer-link" onClick={() => setRateLimitVisible(true)}>API Status</span>
        <span className="footer-sep">|</span>
        <span className="footer-link" onClick={() => { localStorage.removeItem('dxs-terms-accepted'); setShowTerms(true) }}>Terms</span>
        <span className="footer-sep">|</span>
        <span className="footer-copy">DXS Swap {new Date().getFullYear()}</span>
      </footer>

      {toast && <div className={`toast ${toast.type}`}>{toast.message}</div>}
    </div>
  )
}

export default App

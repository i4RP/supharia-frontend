        let hex = resp.get("result").and_then(|v| v.as_str()).unwrap_or("0x0");
        u128::from_str_radix(hex.trim_start_matches("0x"), 16)
            .map_err(|e| format!("parse gas price: {}", e))
    }

    pub async fn get_erc20_transfers(
        &self,
        address: &str,
        contract: &str,
        from_block: u64,
    ) -> Result<Vec<Erc20Transfer>, String> {
        let url = format!(
            "{}&module=account&action=tokentx&contractaddress={}&address={}&startblock={}&endblock=99999999&sort=asc&apikey={}",
            self.network.etherscan_api(), contract, address, from_block, self.etherscan_key
        );
        let resp: serde_json::Value = self.client.get(&url).send().await
            .map_err(|e| format!("etherscan tokentx error: {}", e))?
            .json().await
            .map_err(|e| format!("etherscan parse error: {}", e))?;

        let transfers = resp.get("result")
            .and_then(|v| v.as_array())
            .map(|arr| {
                arr.iter().filter_map(|tx| {
                    Some(Erc20Transfer {
                        hash: tx.get("hash")?.as_str()?.to_string(),
                        from: tx.get("from")?.as_str()?.to_string(),
                        to: tx.get("to")?.as_str()?.to_string(),
                        value: tx.get("value")?.as_str()?.to_string(),
                        block_number: tx.get("blockNumber")?.as_str()?.parse().ok()?,
                        confirmations: tx.get("confirmations")?.as_str()?.parse().unwrap_or(0),
                    })
                }).collect()
            })
            .unwrap_or_default();
        Ok(transfers)
    }

    pub async fn get_eth_transfers(
        &self,
        address: &str,
        from_block: u64,
    ) -> Result<Vec<EthTransfer>, String> {
        let url = format!(
            "{}&module=account&action=txlist&address={}&startblock={}&endblock=99999999&sort=asc&apikey={}",
            self.network.etherscan_api(), address, from_block, self.etherscan_key
        );
        let resp: serde_json::Value = self.client.get(&url).send().await
            .map_err(|e| format!("etherscan txlist error: {}", e))?
            .json().await
            .map_err(|e| format!("etherscan parse error: {}", e))?;

        let transfers = resp.get("result")
            .and_then(|v| v.as_array())
            .map(|arr| {
                arr.iter().filter_map(|tx| {
                    let to = tx.get("to")?.as_str()?.to_string();
                    if to.to_lowercase() != address.to_lowercase() {
                        return None;
                    }
                    Some(EthTransfer {
                        hash: tx.get("hash")?.as_str()?.to_string(),
                        from: tx.get("from")?.as_str()?.to_string(),
                        to,
                        value: tx.get("value")?.as_str()?.to_string(),
                        block_number: tx.get("blockNumber")?.as_str()?.parse().ok()?,
                        confirmations: tx.get("confirmations")?.as_str()?.parse().unwrap_or(0),
                        is_error: tx.get("isError")?.as_str()? == "1",
                    })
                }).collect()
            })
            .unwrap_or_default();
        Ok(transfers)
    }

    pub async fn send_raw_transaction(&self, signed_tx_hex: &str) -> Result<String, String> {
        let body = serde_json::json!({
            "jsonrpc": "2.0",
            "method": "eth_sendRawTransaction",
            "params": [format!("0x{}", signed_tx_hex)],
            "id": 1
        });
        let resp: serde_json::Value = self.client.post(self.network.rpc_url())
            .json(&body)
            .send().await
            .map_err(|e| format!("eth rpc send error: {}", e))?
            .json().await
            .map_err(|e| format!("eth rpc parse: {}", e))?;

        if let Some(err) = resp.get("error") {
            return Err(format!("eth send error: {}", err));
        }
        resp.get("result")
            .and_then(|v| v.as_str())
            .map(|s| s.to_string())
            .ok_or_else(|| "no tx hash in response".to_string())
    }
}


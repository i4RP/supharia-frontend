import {
  Wallet,
  Mnemonic,
  OutPoint,
  ScriptType,
  TokenScheme,
  TransactionReader,
  BuildDstasTransferTx,
  BuildDstasSwapFlowTx,
  toHex,
  fromHex,
  hash160,
  sha256,
  buildSwapActionData,
  buildStas3Flags,
  buildStas3FreezeMultisigTokens,
  ScriptBuilder,
  LockingScriptReader,
  PrivateKey,
  bs58check,
} from "dxs-stas-sdk";
import type { TDstasSwapDestination, Bytes } from "dxs-stas-sdk";

const WOC_DIRECT = "https://api.whatsonchain.com/v1/bsv/main";
const WOC_PROXY = "/woc";
const FEE_RATE = 0.1;

function wocBase(): string {
  return import.meta.env.DEV ? WOC_PROXY : WOC_DIRECT;
}

const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));

function computeTxId(hex: string): string {
  return TransactionReader.readHex(hex).Id;
}

async function broadcast(txHex: string): Promise<string> {
  const res = await fetch(`${wocBase()}/tx/raw`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ txhex: txHex }),
  });
  const text = await res.text();
  const cleaned = text.replace(/"/g, "").trim();
  if (/^[0-9a-fA-F]{64}$/.test(cleaned)) return cleaned;
  if (!res.ok) {
    if (cleaned.includes("mempool") || cleaned.includes("already known")) {
      return computeTxId(txHex);
    }
    const txid = computeTxId(txHex);
    await sleep(2000);
    try {
      const check = await fetch(`${wocBase()}/tx/${txid}`);
      if (check.ok) return txid;
    } catch {
      /* ignore */
    }
    throw new Error(`Broadcast failed (${res.status}): ${cleaned}`);
  }
  return cleaned;
}

async function getTxHex(txid: string): Promise<string> {
  const res = await fetch(`${wocBase()}/tx/${txid}/hex`);
  if (!res.ok) throw new Error(`Failed to fetch tx ${txid}`);
  return res.text();
}

export type WocUtxo = {
  tx_hash: string;
  tx_pos: number;
  value: number;
  height: number;
};

async function getUtxos(address: string): Promise<WocUtxo[]> {
  const res = await fetch(`${wocBase()}/address/${address}/unspent`);
  if (!res.ok) return [];
  const data = await res.json();
  return Array.isArray(data) ? data : [];
}

export type TokenUtxo = {
  txId: string;
  vout: number;
  satoshis: number;
  tokenId: string;
  scriptType: string;
  walletIndex: number;
};

export type WalletScan = {
  bsvBalance: number;
  tokenUtxos: TokenUtxo[];
  feeUtxos: Array<{
    txId: string;
    vout: number;
    satoshis: number;
    walletIndex: number;
  }>;
};

export type TokenInfo = {
  symbol: string;
  tokenId: string;
  freeze: boolean;
  authorityPubKeyIndex: number;
};

export type SwapResult = {
  transferTxId: string;
  swapTxId: string;
  fromSymbol: string;
  toSymbol: string;
  fromSats: number;
  toSats: number;
};

function buildDstasLockingScript(
  ownerField: Bytes,
  tokenIdHex: string,
  freezable: boolean,
  authorityServiceField: Bytes,
) {
  const tokens = buildStas3FreezeMultisigTokens({
    owner: ownerField,
    actionData: null,
    redemptionPkh: fromHex(tokenIdHex),
    frozen: false,
    flags: buildStas3Flags({ freezable }),
    serviceFields: freezable ? [authorityServiceField] : [],
    optionalData: [],
  });
  return ScriptBuilder.fromTokens(tokens, ScriptType.dstas);
}

function computeRequestedScriptHash(lockingScript: ScriptBuilder): Bytes {
  const tokens = (lockingScript as unknown as { _tokens: unknown[] })._tokens;
  if (tokens.length < 3) {
    throw new Error("Locking script must include owner + second field");
  }
  const tail = ScriptBuilder.fromTokens(
    tokens.slice(2) as Parameters<typeof ScriptBuilder.fromTokens>[0],
    ScriptType.unknown,
  );
  return sha256(tail.toBytes());
}

export function createWalletFromMnemonic(mnemonic: string) {
  const master = Wallet.fromMnemonic(mnemonic);
  const wallets: Wallet[] = [];
  for (let i = 0; i < 6; i++) {
    wallets.push(master.deriveWallet(`m/44'/236'/0'/0/${i}`));
  }
  return { master, wallets };
}

export function getAddress(mnemonic: string): string {
  const { wallets } = createWalletFromMnemonic(mnemonic);
  return wallets[0].Address.Value;
}

export function getAllAddresses(mnemonic: string): string[] {
  const { wallets } = createWalletFromMnemonic(mnemonic);
  return wallets.map((w) => w.Address.Value);
}

export function decodeWif(wif: string): {
  privateKey: PrivateKey;
  address: string;
} {
  const decoded = bs58check.decode(wif);
  if (decoded[0] !== 0x80 && decoded[0] !== 0xef)
    throw new Error("Invalid WIF version byte");
  let keyBytes: Uint8Array;
  if (decoded.length === 34 && decoded[33] === 0x01) {
    keyBytes = decoded.slice(1, 33);
  } else if (decoded.length === 33) {
    keyBytes = decoded.slice(1, 33);
  } else {
    throw new Error("Invalid WIF format");
  }
  const pk = new PrivateKey(keyBytes);
  return { privateKey: pk, address: pk.Address.Value };
}

export function getAddressFromWif(wif: string): string {
  return decodeWif(wif).address;
}

export function generateWallet(testnet = false): {
  mnemonic: string;
  wif: string;
  address: string;
} {
  const m = Mnemonic.generate();
  const { wallets } = createWalletFromMnemonic(m.phrase);
  const keyBytes = wallets[0].privateKey!;
  const wifPrefix = testnet ? 0xef : 0x80;
  const payload = new Uint8Array(34);
  payload[0] = wifPrefix;
  payload.set(keyBytes, 1);
  payload[33] = 0x01;
  const wif = bs58check.encode(payload);
  if (!testnet) {
    return { mnemonic: m.phrase, wif, address: wallets[0].Address.Value };
  }
  const h160 = hash160(wallets[0].PublicKey);
  const addrPayload = new Uint8Array(21);
  addrPayload[0] = 0x6f;
  addrPayload.set(h160, 1);
  const address = bs58check.encode(addrPayload);
  return { mnemonic: m.phrase, wif, address };
}

export async function scanSingleAddressUtxos(
  address: string,
  knownTokenIds: string[],
  onProgress?: (msg: string) => void,
  knownTxIds?: string[],
): Promise<WalletScan> {
  const tokenUtxos: TokenUtxo[] = [];
  const feeUtxos: WalletScan["feeUtxos"] = [];
  let bsvBalance = 0;

  onProgress?.("Scanning BSV balance...");
  const utxos = await getUtxos(address);
  for (const u of utxos) {
    bsvBalance += u.value;
    feeUtxos.push({
      txId: u.tx_hash,
      vout: u.tx_pos,
      satoshis: u.value,
      walletIndex: 0,
    });
  }

  if (knownTxIds && knownTxIds.length > 0) {
    onProgress?.("Tracing token UTXOs...");
    const spent = new Set<string>();
    const dstasOutputs: {
      txid: string;
      vout: number;
      sats: number;
      tokenId: string;
    }[] = [];

    for (const txid of knownTxIds) {
      try {
        const [txJson, txHex] = await Promise.all([
          fetchTxJson(txid),
          getTxHex(txid),
        ]);
        for (const vin of txJson.vin) {
          if (vin.txid) spent.add(`${vin.txid}:${vin.vout}`);
        }
        const tx = TransactionReader.readHex(txHex);
        for (let i = 0; i < tx.Outputs.length; i++) {
          const out = tx.Outputs[i];
          if (out.ScriptType === ScriptType.dstas) {
            const reader = LockingScriptReader.read(out.LockignScript);
            const tokenId = reader.Dstas?.Redemption
              ? toHex(reader.Dstas.Redemption)
              : "";
            if (knownTokenIds.includes(tokenId)) {
              dstasOutputs.push({ txid, vout: i, sats: out.Satoshis, tokenId });
            }
          }
        }
      } catch (e) {
        console.warn(`Failed to trace tx ${txid}:`, e);
      }
    }

    for (const o of dstasOutputs) {
      if (!spent.has(`${o.txid}:${o.vout}`)) {
        tokenUtxos.push({
          txId: o.txid,
          vout: o.vout,
          satoshis: o.sats,
          tokenId: o.tokenId,
          scriptType: "dstas",
          walletIndex: 0,
        });
      }
    }
  }

  onProgress?.("Scan complete");
  return { bsvBalance, tokenUtxos, feeUtxos };
}

async function fetchTxJson(txid: string): Promise<{
  vin: { txid: string; vout: number }[];
  vout: { value: number }[];
}> {
  const res = await fetch(`${wocBase()}/tx/${txid}`);
  if (!res.ok) throw new Error(`Failed to fetch tx json ${txid}`);
  return res.json();
}

export async function scanWalletUtxos(
  mnemonic: string,
  knownTokenIds: string[],
  onProgress?: (msg: string) => void,
  knownTxIds?: string[],
): Promise<WalletScan> {
  const { wallets } = createWalletFromMnemonic(mnemonic);
  const tokenUtxos: TokenUtxo[] = [];
  const feeUtxos: WalletScan["feeUtxos"] = [];
  let bsvBalance = 0;

  const walletPkhMap = new Map<string, number>();
  for (let i = 0; i < wallets.length; i++) {
    walletPkhMap.set(toHex(wallets[i].Address.Hash160), i);
  }

  onProgress?.("Scanning BSV balances...");
  for (let i = 0; i < wallets.length; i++) {
    const addr = wallets[i].Address.Value;
    const utxos = await getUtxos(addr);
    for (const u of utxos) {
      bsvBalance += u.value;
      feeUtxos.push({
        txId: u.tx_hash,
        vout: u.tx_pos,
        satoshis: u.value,
        walletIndex: i,
      });
    }
  }

  if (knownTxIds && knownTxIds.length > 0) {
    onProgress?.("Tracing token UTXOs...");
    const spent = new Set<string>();
    const dstasOutputs: {
      txid: string;
      vout: number;
      sats: number;
      tokenId: string;
      ownerPkh: string;
    }[] = [];

    for (const txid of knownTxIds) {
      try {
        const [txJson, txHex] = await Promise.all([
          fetchTxJson(txid),
          getTxHex(txid),
        ]);
        for (const vin of txJson.vin) {
          if (vin.txid) spent.add(`${vin.txid}:${vin.vout}`);
        }
        const tx = TransactionReader.readHex(txHex);
        for (let i = 0; i < tx.Outputs.length; i++) {
          const out = tx.Outputs[i];
          if (out.ScriptType === ScriptType.dstas) {
            const reader = LockingScriptReader.read(out.LockignScript);
            const tokenId = reader.Dstas?.Redemption
              ? toHex(reader.Dstas.Redemption)
              : "";
            const ownerPkh = reader.Dstas?.Owner
              ? toHex(reader.Dstas.Owner)
              : "";
            if (knownTokenIds.includes(tokenId)) {
              dstasOutputs.push({
                txid,
                vout: i,
                sats: out.Satoshis,
                tokenId,
                ownerPkh,
              });
            }
          }
        }
      } catch (e) {
        console.warn(`Failed to trace tx ${txid}:`, e);
      }
    }

    for (const o of dstasOutputs) {
      if (!spent.has(`${o.txid}:${o.vout}`)) {
        const wIdx = walletPkhMap.get(o.ownerPkh);
        if (wIdx !== undefined) {
          tokenUtxos.push({
            txId: o.txid,
            vout: o.vout,
            satoshis: o.sats,
            tokenId: o.tokenId,
            scriptType: "dstas",
            walletIndex: wIdx,
          });
        }
      }
    }
  }

  onProgress?.("Scan complete");
  return { bsvBalance, tokenUtxos, feeUtxos };
}

export async function executeSwap(
  mnemonic: string,
  fromToken: TokenInfo,
  toToken: TokenInfo,
  fromUtxo: TokenUtxo,
  toUtxo: TokenUtxo,
  feeUtxos: WalletScan["feeUtxos"],
  onProgress: (msg: string) => void,
): Promise<SwapResult> {
  onProgress("Initializing wallets...");
  const { wallets } = createWalletFromMnemonic(mnemonic);
  const addr0 = wallets[0];

  const fromScheme = new TokenScheme(
    fromToken.symbol,
    fromToken.tokenId,
    fromToken.symbol,
    1,
    {
      freeze: fromToken.freeze,
      confiscation: fromToken.freeze,
      isDivisible: true,
      authority: {
        m: 1,
        publicKeys: [toHex(wallets[fromToken.authorityPubKeyIndex].PublicKey)],
      },
    },
  );

  const toScheme = new TokenScheme(
    toToken.symbol,
    toToken.tokenId,
    toToken.symbol,
    1,
    {
      freeze: toToken.freeze,
      confiscation: toToken.freeze,
      isDivisible: true,
      authority: {
        m: 1,
        publicKeys: [toHex(wallets[toToken.authorityPubKeyIndex].PublicKey)],
      },
    },
  );

  const fee1 = feeUtxos[0];
  const fee2 = feeUtxos[1] || feeUtxos[0];
  const fee3 = feeUtxos[2] || feeUtxos[1] || feeUtxos[0];

  onProgress("Step 1/3: Fetching transactions...");
  const txIds = new Set([
    fromUtxo.txId,
    toUtxo.txId,
    fee1.txId,
    fee2.txId,
    fee3.txId,
  ]);
  const txHexMap = new Map<string, string>();
  for (const id of txIds) {
    txHexMap.set(id, await getTxHex(id));
  }

  const fromTx = TransactionReader.readHex(txHexMap.get(fromUtxo.txId)!);
  const toTx = TransactionReader.readHex(txHexMap.get(toUtxo.txId)!);
  const fee1Tx = TransactionReader.readHex(txHexMap.get(fee1.txId)!);
  const fee2Tx = TransactionReader.readHex(txHexMap.get(fee2.txId)!);
  const fee3Tx = TransactionReader.readHex(txHexMap.get(fee3.txId)!);

  const fromSats = fromTx.Outputs[fromUtxo.vout].Satoshis;
  const toSats = toTx.Outputs[toUtxo.vout].Satoshis;

  onProgress("Step 1/3: Transferring to swap address...");
  const toOP = new OutPoint(
    toTx.Id,
    toUtxo.vout,
    toTx.Outputs[toUtxo.vout].LockignScript,
    toSats,
    wallets[toUtxo.walletIndex].Address,
    ScriptType.dstas,
  );
  toOP.Transaction = toTx;

  const transferFeeOP = new OutPoint(
    fee1Tx.Id,
    fee1.vout,
    fee1Tx.Outputs[fee1.vout].LockignScript,
    fee1Tx.Outputs[fee1.vout].Satoshis,
    wallets[fee1.walletIndex].Address,
    ScriptType.p2pkh,
  );

  const transferToHex = BuildDstasTransferTx({
    stasPayment: { OutPoint: toOP, Owner: wallets[toUtxo.walletIndex] },
    feePayment: {
      OutPoint: transferFeeOP,
      Owner: wallets[fee1.walletIndex],
    },
    Scheme: toScheme,
    destination: { Satoshis: toSats, To: wallets[4].Address },
  });
  const transferToTx = TransactionReader.readHex(transferToHex);

  const transferTxId = await broadcast(transferToHex);
  onProgress(`Step 1/3 done: ${transferTxId.slice(0, 12)}...`);
  await sleep(3000);

  onProgress("Step 2/3: Building swap action data...");
  const fromAuthority = hash160(
    wallets[fromToken.authorityPubKeyIndex].PublicKey,
  );
  const toAuthority = hash160(wallets[toToken.authorityPubKeyIndex].PublicKey);

  const sampleToTail = buildDstasLockingScript(
    addr0.Address.Hash160,
    toToken.tokenId,
    toToken.freeze,
    toAuthority,
  );

  const requestedHash = computeRequestedScriptHash(sampleToTail);

  const swapActionData = buildSwapActionData({
    requestedScriptHash: requestedHash,
    requestedPkh: addr0.Address.Hash160,
    rateNumerator: 1,
    rateDenominator: 1,
  });

  onProgress("Step 2/3: Transferring with swap data...");
  const fromOP = new OutPoint(
    fromTx.Id,
    fromUtxo.vout,
    fromTx.Outputs[fromUtxo.vout].LockignScript,
    fromSats,
    wallets[fromUtxo.walletIndex].Address,
    ScriptType.dstas,
  );
  fromOP.Transaction = fromTx;

  const feeOP2 = new OutPoint(
    fee2Tx.Id,
    fee2.vout,
    fee2Tx.Outputs[fee2.vout].LockignScript,
    fee2Tx.Outputs[fee2.vout].Satoshis,
    wallets[fee2.walletIndex].Address,
    ScriptType.p2pkh,
  );

  const transferFromSwapHex = BuildDstasTransferTx({
    stasPayment: { OutPoint: fromOP, Owner: wallets[fromUtxo.walletIndex] },
    feePayment: { OutPoint: feeOP2, Owner: wallets[fee2.walletIndex] },
    Scheme: fromScheme,
    destination: {
      Satoshis: fromSats,
      To: addr0.Address,
      ActionData: swapActionData,
    },
  });
  const transferFromSwapTx = TransactionReader.readHex(transferFromSwapHex);

  await broadcast(transferFromSwapHex);
  onProgress("Step 2/3 done: Swap data attached");
  await sleep(3000);

  onProgress("Step 3/3: Executing atomic swap...");
  const swapFromOP = new OutPoint(
    transferFromSwapTx.Id,
    0,
    transferFromSwapTx.Outputs[0].LockignScript,
    transferFromSwapTx.Outputs[0].Satoshis,
    addr0.Address,
    ScriptType.dstas,
  );
  swapFromOP.Transaction = transferFromSwapTx;

  const swapToOP = new OutPoint(
    transferToTx.Id,
    0,
    transferToTx.Outputs[0].LockignScript,
    transferToTx.Outputs[0].Satoshis,
    wallets[4].Address,
    ScriptType.dstas,
  );
  swapToOP.Transaction = transferToTx;

  const swapFeeOP = new OutPoint(
    fee3Tx.Id,
    fee3.vout,
    fee3Tx.Outputs[fee3.vout].LockignScript,
    fee3Tx.Outputs[fee3.vout].Satoshis,
    wallets[fee3.walletIndex].Address,
    ScriptType.p2pkh,
  );

  const swapDestinations: TDstasSwapDestination[] = [
    {
      Satoshis: swapToOP.Satoshis,
      Owner: addr0.Address.Hash160,
      TokenIdHex: toToken.tokenId,
      Freezable: toToken.freeze,
      AuthorityServiceField: toAuthority,
      ActionData: null,
    },
    {
      Satoshis: swapFromOP.Satoshis,
      Owner: wallets[4].Address.Hash160,
      TokenIdHex: fromToken.tokenId,
      Freezable: fromToken.freeze,
      AuthorityServiceField: fromAuthority,
      ActionData: null,
    },
  ];

  const swapTxHex = BuildDstasSwapFlowTx({
    stasPayments: [
      { OutPoint: swapFromOP, Owner: addr0 },
      { OutPoint: swapToOP, Owner: wallets[4] },
    ],
    feePayment: { OutPoint: swapFeeOP, Owner: wallets[fee3.walletIndex] },
    destinations: swapDestinations,
    feeRate: FEE_RATE,
    omitChangeOutput: false,
  });

  const swapTxId = await broadcast(swapTxHex);
  onProgress("Swap complete!");

  return {
    transferTxId,
    swapTxId,
    fromSymbol: fromToken.symbol,
    toSymbol: toToken.symbol,
    fromSats,
    toSats,
  };
}

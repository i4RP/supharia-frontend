const LP_REWARD_RATE_ANNUAL: f64 = 0.01;

async fn get_lp_rewards(
    State(state): State<AppState>,
    Path((pool_id, address)): Path<(String, String)>,
) -> (StatusCode, Json<ApiResponse<LpRewardsInfo>>) {
    let pool = match state.db.get_pool(&pool_id).await {
        Ok(Some(p)) => p,
        Ok(None) => return err_response(StatusCode::NOT_FOUND, "Pool not found"),
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };
    let lp = match state.db.get_lp_position(&pool_id, &address).await {
        Ok(Some(l)) => l,
        Ok(None) => return err_response(StatusCode::NOT_FOUND, "No LP position"),
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };
    let share_ratio = if pool.total_lp_shares > 0.0 { lp.lp_shares / pool.total_lp_shares } else { 0.0 };
    let now = chrono::Utc::now();
    let created = chrono::DateTime::parse_from_rfc3339(&lp.created_at)
        .map(|dt| dt.with_timezone(&chrono::Utc))
        .unwrap_or(now);
    let duration_hours = (now - created).num_seconds() as f64 / 3600.0;
    let annual_fraction = duration_hours / 8760.0;
    let reward_a = (pool.reserve_a as f64 * share_ratio * LP_REWARD_RATE_ANNUAL * annual_fraction) as u64;
    let reward_b = (pool.reserve_b as f64 * share_ratio * LP_REWARD_RATE_ANNUAL * annual_fraction) as u64;
    let current_a = (pool.reserve_a as f64 * share_ratio) as u64;
    let current_b = (pool.reserve_b as f64 * share_ratio) as u64;
    let earned_a = if current_a > lp.deposited_a { current_a - lp.deposited_a } else { 0 };
    let earned_b = if current_b > lp.deposited_b { current_b - lp.deposited_b } else { 0 };
    ok_response(LpRewardsInfo {
        user_address: address,
        pool_id: pool_id.clone(),
        lp_shares: lp.lp_shares,
        share_of_pool: share_ratio * 100.0,
        reward_rate_annual: LP_REWARD_RATE_ANNUAL * 100.0,
        duration_hours,
        accrued_rewards_a: reward_a,
        accrued_rewards_b: reward_b,
        earned_fees_a: earned_a,
        earned_fees_b: earned_b,
        total_rewards_a: reward_a + earned_a,
        total_rewards_b: reward_b + earned_b,
        apy: LP_REWARD_RATE_ANNUAL * 100.0,
    })
}


const FARMING_APY: f64 = 0.05;

fn calc_pending(stake: &db::FarmingStake) -> f64 {
    let now = chrono::Utc::now();
    let last = chrono::DateTime::parse_from_rfc3339(&stake.last_harvest_at)
        .map(|dt| dt.with_timezone(&chrono::Utc))
        .unwrap_or(now);
    let hours = (now - last).num_seconds() as f64 / 3600.0;
    let annual_frac = hours / 8760.0;
    stake.staked_lp_shares * FARMING_APY * annual_frac + stake.pending_rewards
}

fn stake_to_info(s: &db::FarmingStake) -> FarmingStakeInfo {
    FarmingStakeInfo {
        pool_id: s.pool_id.clone(),
        user_address: s.user_address.clone(),
        staked_lp_shares: s.staked_lp_shares,
        pending_rewards: calc_pending(s),
        reward_debt: s.reward_debt,
        apy: FARMING_APY * 100.0,
        staked_at: s.staked_at.clone(),
        last_harvest_at: s.last_harvest_at.clone(),
    }
}

async fn farm_stake(
    State(state): State<AppState>,
    Path(pool_id): Path<String>,
    Json(req): Json<FarmStakeRequest>,
) -> (StatusCode, Json<ApiResponse<FarmingStakeInfo>>) {
    if req.lp_shares <= 0.0 {
        return err_response(StatusCode::BAD_REQUEST, "lp_shares must be > 0");
    }
    let lp = match state.db.get_lp_position(&pool_id, &req.user_address).await {
        Ok(Some(l)) => l,
        Ok(None) => return err_response(StatusCode::NOT_FOUND, "No LP position found"),
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };
    let existing = state.db.get_farming_stake(&pool_id, &req.user_address).await.unwrap_or(None);
    let already_staked = existing.as_ref().map(|s| s.staked_lp_shares).unwrap_or(0.0);
    if req.lp_shares + already_staked > lp.lp_shares {
        return err_response(StatusCode::BAD_REQUEST, "Not enough LP shares to stake");
    }
    let now = chrono::Utc::now().to_rfc3339();
    let (pending, staked_at) = match &existing {
        Some(s) => (calc_pending(s), s.staked_at.clone()),
        None => (0.0, now.clone()),
    };
    let stake = db::FarmingStake {
        pool_id: pool_id.clone(),
        user_address: req.user_address.clone(),
        staked_lp_shares: already_staked + req.lp_shares,
        reward_debt: 0.0,
        pending_rewards: pending,
        staked_at,
        last_harvest_at: now,
    };
    if let Err(e) = state.db.put_farming_stake(&stake).await {
        return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e);
    }
    ok_response(stake_to_info(&stake))
}

async fn farm_unstake(
    State(state): State<AppState>,
    Path(pool_id): Path<String>,
    Json(req): Json<FarmStakeRequest>,
) -> (StatusCode, Json<ApiResponse<FarmingStakeInfo>>) {
    if req.lp_shares <= 0.0 {
        return err_response(StatusCode::BAD_REQUEST, "lp_shares must be > 0");
    }
    let stake = match state.db.get_farming_stake(&pool_id, &req.user_address).await {
        Ok(Some(s)) => s,
        Ok(None) => return err_response(StatusCode::NOT_FOUND, "No farming stake found"),
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };
    if req.lp_shares > stake.staked_lp_shares {
        return err_response(StatusCode::BAD_REQUEST, "Not enough staked LP shares");
    }
    let now = chrono::Utc::now().to_rfc3339();
    let pending = calc_pending(&stake);
    let remaining = stake.staked_lp_shares - req.lp_shares;
    if remaining < 0.001 {
        if let Err(e) = state.db.delete_farming_stake(&pool_id, &req.user_address).await {
            return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e);
        }
        return ok_response(FarmingStakeInfo {
            pool_id,
            user_address: req.user_address,
            staked_lp_shares: 0.0,
            pending_rewards: pending,
            reward_debt: 0.0,
            apy: FARMING_APY * 100.0,
            staked_at: stake.staked_at,
            last_harvest_at: now,
        });
    }
    let updated = db::FarmingStake {
        pool_id: pool_id.clone(),
        user_address: req.user_address.clone(),
        staked_lp_shares: remaining,
        reward_debt: 0.0,
        pending_rewards: pending,
        staked_at: stake.staked_at,
        last_harvest_at: now,
    };
    if let Err(e) = state.db.put_farming_stake(&updated).await {
        return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e);
    }
    ok_response(stake_to_info(&updated))
}

async fn farm_harvest(
    State(state): State<AppState>,
    Path((pool_id, address)): Path<(String, String)>,
) -> (StatusCode, Json<ApiResponse<HarvestResult>>) {
    let stake = match state.db.get_farming_stake(&pool_id, &address).await {
        Ok(Some(s)) => s,
        Ok(None) => return err_response(StatusCode::NOT_FOUND, "No farming stake found"),
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e),
    };
    let harvested = calc_pending(&stake);
    let now = chrono::Utc::now().to_rfc3339();
    let updated = db::FarmingStake {
        pool_id: pool_id.clone(),
        user_address: address.clone(),
        staked_lp_shares: stake.staked_lp_shares,
        reward_debt: stake.reward_debt + harvested,
        pending_rewards: 0.0,
        staked_at: stake.staked_at,
        last_harvest_at: now,
    };
    if let Err(e) = state.db.put_farming_stake(&updated).await {
        return err_response(StatusCode::INTERNAL_SERVER_ERROR, &e);
    }
    ok_response(HarvestResult {
        user_address: address,
        pool_id,
        harvested_amount: harvested,
        remaining_staked: stake.staked_lp_shares,
    })
}


<file path="backend/dstas-amm/src/crypto/wallet.rs">
use hmac::{Hmac, Mac};
use sha2::Sha512;
use crate::crypto::keys::PrivKey;
use crate::crypto::hashes::hash160;
use secp256k1::{Secp256k1, SecretKey, PublicKey};

type HmacSha512 = Hmac<Sha512>;

pub struct DerivedWallet {
    pub private_key: PrivKey,
    pub address: String,
    pub pkh: [u8; 20],
}

struct ExtendedKey {
    secret: SecretKey,
    chain_code: [u8; 32],
}

fn derive_child(parent: &ExtendedKey, index: u32) -> ExtendedKey {
    let secp = Secp256k1::new();
    let mut mac = HmacSha512::new_from_slice(&parent.chain_code).unwrap();

    if index >= 0x80000000 {
        mac.update(&[0x00]);
        mac.update(&parent.secret[..]);
    } else {
        let pk = PublicKey::from_secret_key(&secp, &parent.secret);
        mac.update(&pk.serialize());
    }
    mac.update(&index.to_be_bytes());

    let result = mac.finalize().into_bytes();
    let (il, ir) = result.split_at(32);

    let mut child_key = SecretKey::from_slice(il).unwrap();
    child_key = child_key.add_tweak(&parent.secret.into()).unwrap();

    let mut chain_code = [0u8; 32];
    chain_code.copy_from_slice(ir);

    ExtendedKey {
        secret: child_key,
        chain_code,
    }
}

fn seed_to_master(seed: &[u8]) -> ExtendedKey {
    let mut mac = HmacSha512::new_from_slice(b"Bitcoin seed").unwrap();
    mac.update(seed);
    let result = mac.finalize().into_bytes();
    let (il, ir) = result.split_at(32);
    let secret = SecretKey::from_slice(il).unwrap();
    let mut chain_code = [0u8; 32];
    chain_code.copy_from_slice(ir);
    ExtendedKey { secret, chain_code }
}

pub fn derive_wallets_from_mnemonic(mnemonic: &str, count: usize) -> Result<Vec<DerivedWallet>, String> {
    let mnemonic_obj = bip39::Mnemonic::parse(mnemonic)
        .map_err(|e| format!("Invalid mnemonic: {}", e))?;
    let seed = mnemonic_obj.to_seed("");

    let master = seed_to_master(&seed);
    let purpose = derive_child(&master, 44 + 0x80000000);
    let coin = derive_child(&purpose, 236 + 0x80000000);
    let account = derive_child(&coin, 0x80000000);
    let change = derive_child(&account, 0);

    let mut wallets = Vec::with_capacity(count);
    for i in 0..count {
        let child = derive_child(&change, i as u32);
        let pk = PrivKey::from_bytes(&child.secret[..])
            .map_err(|e| format!("Derive error at index {}: {}", i, e))?;
        let pub_key = pk.public_key();
        let addr = pub_key.address();
        let pkh = pub_key.hash160();
        wallets.push(DerivedWallet {
            private_key: pk,
            address: addr,
            pkh,
        });
    }
    Ok(wallets)
}

pub fn derive_pool_wallet(master_seed: &str, pool_id: &str) -> Result<DerivedWallet, String> {
    use sha2::Sha256;
    type HmacSha256 = Hmac<Sha256>;
    let mut mac = HmacSha256::new_from_slice(master_seed.as_bytes())
        .map_err(|e| format!("HMAC init error: {}", e))?;
    mac.update(pool_id.as_bytes());
    let result = mac.finalize().into_bytes();
    let pk = PrivKey::from_bytes(&result)
        .map_err(|e| format!("Pool key derivation error: {}", e))?;
    let pub_key = pk.public_key();
    let addr = pub_key.address();
    let pkh = pub_key.hash160();
    Ok(DerivedWallet {
        private_key: pk,
        address: addr,
        pkh,
    })
}

pub fn wallet_from_wif(wif: &str) -> Result<DerivedWallet, String> {
    let pk = PrivKey::from_wif(wif)?;
    let pub_key = pk.public_key();
    let addr = pub_key.address();
    let pkh = pub_key.hash160();
    Ok(DerivedWallet {
        private_key: pk,
        address: addr,
        pkh,
    })
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn derive_pool_wallet_deterministic() {
        let w1 = derive_pool_wallet("test-seed", "pool-123").unwrap();
        let w2 = derive_pool_wallet("test-seed", "pool-123").unwrap();
        assert_eq!(w1.address, w2.address);
        assert_eq!(w1.pkh, w2.pkh);

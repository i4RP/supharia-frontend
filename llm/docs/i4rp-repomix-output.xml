<file path="backend/dstas-amm/src/bitcoin/tx.rs">
use crate::crypto::hashes::double_sha256;

pub fn write_varint(buf: &mut Vec<u8>, n: u64) {
    if n < 0xfd {
        buf.push(n as u8);
    } else if n <= 0xffff {
        buf.push(0xfd);
        buf.extend_from_slice(&(n as u16).to_le_bytes());
    } else if n <= 0xffffffff {
        buf.push(0xfe);
        buf.extend_from_slice(&(n as u32).to_le_bytes());
    } else {
        buf.push(0xff);
        buf.extend_from_slice(&n.to_le_bytes());
    }
}

pub fn varint_size(n: u64) -> usize {
    if n < 0xfd { 1 }
    else if n <= 0xffff { 3 }
    else if n <= 0xffffffff { 5 }
    else { 9 }
}

pub fn tx_id_from_hex(tx_hex: &str) -> String {
    let tx_bytes = hex::decode(tx_hex).unwrap();
    let hash = double_sha256(&tx_bytes);
    let mut reversed = hash;
    reversed.reverse();
    hex::encode(reversed)
}

pub fn reverse_txid_bytes(txid_hex: &str) -> Vec<u8> {
    let mut bytes = hex::decode(txid_hex).unwrap();
    bytes.reverse();
    bytes
}

fn resolve_token_name(token_id: &str) -> String {
    match token_id {
        "rusd-sepolia" => "rUSD".to_string(),
        "114111bc1659e68aef1d60736a0f12d1309e3d19" => "USDC".to_string(),
        "" | "eth" | "ETH" => "ETH".to_string(),
        other => other.to_string(),
    }
}

async fn bridge_wrap(
    State(state): State<AppState>,
    Json(req): Json<BridgeWrapRequest>,
) -> (StatusCode, Json<ApiResponse<BridgeTransactionResponse>>) {
    let token = resolve_token_name(&req.token_id);
    tracing::info!(token = %token, eth_tx = %req.eth_tx_hash, "bridge_wrap");
    let bridge = match &state.bridge {
        Some(b) => b,
        None => return err_response(StatusCode::SERVICE_UNAVAILABLE, "Bridge not configured"),
    };

    let receipt = match bridge.eth_client.get_tx_receipt(&req.eth_tx_hash).await {
        Ok(r) => r,
        Err(e) => return err_response(StatusCode::BAD_REQUEST, &format!("Cannot verify ETH tx: {}", e)),
    };

    if receipt.status != "success" {
        return err_response(StatusCode::BAD_REQUEST, &format!("ETH tx status: {}", receipt.status));
    }

    let needed = bridge.eth_client.network.required_confirmations();
    if receipt.confirmations < needed {
        return err_response(StatusCode::BAD_REQUEST, &format!(
            "Need {} confirmations, have {}",
            needed, receipt.confirmations
        ));
    }

    let deposit_id = Uuid::new_v4().to_string();
    let amount_raw = req.amount.to_string();
    let fee = bridge.calculate_wrap_fee(req.amount as u128);
    let now = Utc::now().to_rfc3339();

    let pool_wallet = match derive_pool_wallet(&state.pool_master_seed, "bridge-mint") {
        Ok(w) => w,
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &format!("pool wallet: {}", e)),
    };

    let meta = SettlementMeta {
        op_type: "bridge_mint".to_string(),
        pool_id: "bridge".to_string(),
        user_address: req.from_address.clone(),
        input_token: token.clone(),
        input_amount: req.amount,
        output_token: format!("w{}", token),
        output_amount: req.amount.saturating_sub(fee as u64),
        fee_amount: fee as u64,
    };

    let bsv_tx_id = match state.settlement.settle_operation(&pool_wallet, &meta).await {
        Ok(r) => r.txid,
        Err(e) => {
            tracing::warn!("BSV settlement failed (recording anyway): {}", e);
            format!("pending-{}", Uuid::new_v4())
        }
    };

    let deposit = BridgeDeposit {
        deposit_id: deposit_id.clone(),
        user_eth_address: String::new(),
        user_bsv_address: req.from_address.clone(),
        source_chain: "ethereum".to_string(),
        token: token.clone(),
        amount_raw: amount_raw.clone(),
        amount_display: format!("{} {}", req.amount, token),
        fee_amount: format!("{}%", crate::bridge::wrap_fee_percent()),
        minted_amount: amount_raw.clone(),
        eth_tx_hash: req.eth_tx_hash.clone(),
        bsv_tx_id: bsv_tx_id.clone(),
        status: "confirmed".to_string(),
        created_at: now.clone(),
        confirmed_at: now.clone(),
        eth_block_number: receipt.block_number.unwrap_or(0),
        confirmations: receipt.confirmations,
    };

    if let Err(e) = state.db.put_bridge_deposit(&deposit).await {
        tracing::warn!("Failed to save bridge deposit: {}", e);
    }

    ok_response(BridgeTransactionResponse {
        bridge_tx_id: deposit_id,
        direction: "wrap".to_string(),
        token,
        amount: amount_raw,
        fee: format!("{}%", crate::bridge::wrap_fee_percent()),
        eth_tx_hash: req.eth_tx_hash,
        bsv_tx_id,
        status: "confirmed".to_string(),
        created_at: now,
    })
}

async fn bridge_unwrap(
    State(state): State<AppState>,
    Json(req): Json<BridgeUnwrapRequest>,
) -> (StatusCode, Json<ApiResponse<BridgeTransactionResponse>>) {
    let token = resolve_token_name(&req.token_id);
    tracing::info!(token = %token, amount = %req.amount, dest = %req.dest_eth_address, "bridge_unwrap");
    let bridge = match &state.bridge {
        Some(b) => b,
        None => return err_response(StatusCode::SERVICE_UNAVAILABLE, "Bridge not configured"),
    };

    if req.amount == 0 {
        return err_response(StatusCode::BAD_REQUEST, "Amount must be > 0");
    }

    let dest = &req.dest_eth_address;
    if !dest.starts_with("0x") || dest.len() != 42 || !dest[2..].chars().all(|c| c.is_ascii_hexdigit()) {
        return err_response(StatusCode::BAD_REQUEST, "Invalid Ethereum address format");
    }

    let balance = match bridge.get_bridge_balance().await {
        Ok(b) => b,
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &format!("Balance check failed: {}", e)),
    };
    match token.as_str() {
        "ETH" => {
            let bal_wei: u128 = balance.eth_wei.parse().unwrap_or(0);
            if (req.amount as u128) > bal_wei {
                return err_response(StatusCode::BAD_REQUEST, &format!(
                    "Insufficient bridge ETH balance: have {} wei, requested {}", bal_wei, req.amount
                ));
            }
        }
        _ => {
            let bal_raw: u128 = balance.usdc_raw.parse().unwrap_or(0);
            if (req.amount as u128) > bal_raw {
                return err_response(StatusCode::BAD_REQUEST, &format!(
                    "Insufficient bridge rUSD balance: have {}, requested {}", bal_raw, req.amount
                ));
            }
        }
    }

    let withdrawal_id = Uuid::new_v4().to_string();
    let now = Utc::now().to_rfc3339();
    let fee_amount = bridge.calculate_unwrap_fee(req.amount as u128);
    let gas_cost = match token.as_str() {
        "ETH" => bridge.estimate_gas_cost_eth().await.unwrap_or(0),
        _ => bridge.estimate_gas_cost_usdc().await.unwrap_or(0),
    };

    let pool_wallet = match derive_pool_wallet(&state.pool_master_seed, "bridge-burn") {
        Ok(w) => w,
        Err(e) => return err_response(StatusCode::INTERNAL_SERVER_ERROR, &format!("pool wallet: {}", e)),
    };

    let meta = SettlementMeta {
        op_type: "bridge_burn".to_string(),
        pool_id: "bridge".to_string(),
        user_address: req.from_address.clone(),
        input_token: format!("w{}", token),
        input_amount: req.amount,
        output_token: token.clone(),
        output_amount: req.amount.saturating_sub(fee_amount as u64),
        fee_amount: fee_amount as u64,
    };

    let bsv_burn_tx_id = match state.settlement.settle_operation(&pool_wallet, &meta).await {
        Ok(r) => r.txid,
        Err(e) => {
            tracing::warn!("BSV burn settlement failed: {}", e);
            format!("pending-{}", Uuid::new_v4())
        }
    };

    let send_amount = req.amount as u128 - fee_amount;
    let eth_tx_hash = match token.as_str() {
        "ETH" => {
            match bridge.send_eth(&req.dest_eth_address, send_amount).await {
                Ok(h) => h,
                Err(e) => {
                    tracing::error!(error = %e, amount = %send_amount, dest = %req.dest_eth_address, "ETH send failed");
                    format!("pending-{}", Uuid::new_v4())
                }
            }
        }
        _ => {
            match bridge.send_usdc(&req.dest_eth_address, send_amount).await {
                Ok(h) => h,
                Err(e) => {
                    tracing::warn!("USDC send failed: {}", e);
                    format!("pending-{}", Uuid::new_v4())
                }
            }
        }
    };

    let status = if eth_tx_hash.starts_with("pending-") { "pending" } else { "completed" };

    let withdrawal = BridgeWithdrawal {
        withdrawal_id: withdrawal_id.clone(),
        user_bsv_address: req.from_address,
        dest_eth_address: req.dest_eth_address,
        dest_chain: "ethereum".to_string(),
        token: token.clone(),
        amount_raw: req.amount.to_string(),
        amount_display: format!("{} {}", req.amount, token),
        fee_amount: fee_amount.to_string(),
        gas_fee: gas_cost.to_string(),
        sent_amount: send_amount.to_string(),
        bsv_burn_tx_id: bsv_burn_tx_id.clone(),
        eth_tx_hash: eth_tx_hash.clone(),
        status: status.to_string(),
        created_at: now.clone(),
        completed_at: if status == "completed" { now.clone() } else { String::new() },
    };

    if let Err(e) = state.db.put_bridge_withdrawal(&withdrawal).await {
        tracing::warn!("Failed to save bridge withdrawal: {}", e);
    }

    ok_response(BridgeTransactionResponse {
        bridge_tx_id: withdrawal_id,
        direction: "unwrap".to_string(),
        token,
        amount: req.amount.to_string(),
        fee: format!("{} (+ gas {})", fee_amount, gas_cost),
        eth_tx_hash,
        bsv_tx_id: bsv_burn_tx_id,
        status: status.to_string(),
        created_at: now,
    })
}

async fn list_bridge_transactions(
    State(state): State<AppState>,
) -> (StatusCode, Json<ApiResponse<Vec<BridgeTransactionResponse>>>) {
    let mut txs: Vec<BridgeTransactionResponse> = Vec::new();

    if let Ok(deposits) = state.db.list_bridge_deposits().await {
        for d in deposits {
            txs.push(BridgeTransactionResponse {
                bridge_tx_id: d.deposit_id,
                direction: "wrap".to_string(),
                token: d.token,
                amount: d.amount_display,
                fee: d.fee_amount,
                eth_tx_hash: d.eth_tx_hash,
                bsv_tx_id: d.bsv_tx_id,
                status: d.status,
                created_at: d.created_at,
            });
        }
    }

    if let Ok(withdrawals) = state.db.list_bridge_withdrawals().await {
        for w in withdrawals {
            txs.push(BridgeTransactionResponse {
                bridge_tx_id: w.withdrawal_id,
                direction: "unwrap".to_string(),
                token: w.token,
                amount: w.amount_display,
                fee: w.fee_amount,
                eth_tx_hash: w.eth_tx_hash,
                bsv_tx_id: w.bsv_burn_tx_id,
                status: w.status,
                created_at: w.created_at,
            });
        }
    }

    txs.sort_by(|a, b| b.created_at.cmp(&a.created_at));
    ok_response(txs)
}

async fn get_bridge_transaction(
    State(state): State<AppState>,
    Path(tx_id): Path<String>,
) -> (StatusCode, Json<ApiResponse<BridgeTransactionResponse>>) {
    if let Ok(Some(d)) = state.db.get_bridge_deposit(&tx_id).await {
        return ok_response(BridgeTransactionResponse {
            bridge_tx_id: d.deposit_id,
            direction: "wrap".to_string(),
            token: d.token,
            amount: d.amount_display,
            fee: d.fee_amount,
            eth_tx_hash: d.eth_tx_hash,
            bsv_tx_id: d.bsv_tx_id,
            status: d.status,
            created_at: d.created_at,
        });
    }

    if let Ok(Some(w)) = state.db.get_bridge_withdrawal(&tx_id).await {
        return ok_response(BridgeTransactionResponse {
            bridge_tx_id: w.withdrawal_id,
            direction: "unwrap".to_string(),
            token: w.token,
            amount: w.amount_display,
            fee: w.fee_amount,
            eth_tx_hash: w.eth_tx_hash,
            bsv_tx_id: w.bsv_burn_tx_id,
            status: w.status,
            created_at: w.created_at,
        });
    }

    err_response(StatusCode::NOT_FOUND, &format!("Bridge transaction {} not found", tx_id))
}

async fn get_bridge_stats(
    State(state): State<AppState>,
) -> (StatusCode, Json<ApiResponse<BridgeStatsResponse>>) {
    let bridge = match &state.bridge {
        Some(b) => b,
        None => return err_response(StatusCode::SERVICE_UNAVAILABLE, "Bridge not configured"),
    };

    let deposits = state.db.list_bridge_deposits().await.unwrap_or_default();
    let withdrawals = state.db.list_bridge_withdrawals().await.unwrap_or_default();

    let balance = bridge.get_bridge_balance().await.unwrap_or(crate::bridge::EthBalance {
        eth_wei: "0".to_string(),
        eth_display: "0 ETH".to_string(),
        usdc_raw: "0".to_string(),
        usdc_display: "0 USDC".to_string(),
    });

    let deposit_info_usdc = bridge.get_deposit_info("USDC");
    let deposit_info_eth = bridge.get_deposit_info("ETH");

    ok_response(BridgeStatsResponse {
        bridge_address: bridge.bridge_wallet.address.clone(),
        eth_balance: balance.eth_display,
        usdc_balance: balance.usdc_display,
        total_deposits: deposits.len(),
        total_withdrawals: withdrawals.len(),
        supported_tokens: vec![

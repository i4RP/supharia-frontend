pub struct DynamoDb {
    client: DynamoClient,
}

impl DynamoDb {
    pub fn new(client: DynamoClient) -> Self {
        Self { client }
    }

    pub async fn create_tables(&self) -> Result<(), String> {
        use aws_sdk_dynamodb::types::{
            AttributeDefinition, KeySchemaElement, KeyType,
            ScalarAttributeType, BillingMode,
        };

        let tables = vec![
            (POOLS_TABLE, "pool_id", None),
            (LP_POSITIONS_TABLE, "pool_id", Some("user_address")),
            (TRANSACTIONS_TABLE, "tx_id", None),
            (PRICE_HISTORY_TABLE, "pool_id", Some("timestamp")),
            (PROPOSALS_TABLE, "pool_id", Some("proposal_id")),
            (FARMING_TABLE, "pool_id", Some("user_address")),
            (BRIDGE_DEPOSITS_TABLE, "deposit_id", None),
            (BRIDGE_WITHDRAWALS_TABLE, "withdrawal_id", None),
            (LAUNCHED_TOKENS_TABLE, "token_id", None),
        ];

        for (table_name, pk, sk) in tables {
            let existing = self.client.describe_table()
                .table_name(table_name)
                .send()
                .await;

            if existing.is_ok() {
                continue;
            }

            let mut attrs = vec![
                AttributeDefinition::builder()
                    .attribute_name(pk)
                    .attribute_type(ScalarAttributeType::S)
                    .build()
                    .unwrap(),
            ];

            let mut keys = vec![
                KeySchemaElement::builder()
                    .attribute_name(pk)
                    .key_type(KeyType::Hash)
                    .build()
                    .unwrap(),
            ];

            if let Some(sort_key) = sk {
                attrs.push(
                    AttributeDefinition::builder()
                        .attribute_name(sort_key)
                        .attribute_type(ScalarAttributeType::S)
                        .build()
                        .unwrap(),
                );
                keys.push(
                    KeySchemaElement::builder()
                        .attribute_name(sort_key)
                        .key_type(KeyType::Range)
                        .build()
                        .unwrap(),
                );
            }

            self.client
                .create_table()
                .table_name(table_name)
                .set_attribute_definitions(Some(attrs))
                .set_key_schema(Some(keys))
                .billing_mode(BillingMode::PayPerRequest)
                .send()
                .await
                .map_err(|e| format!("Failed to create table {}: {}", table_name, e))?;
        }

        Ok(())
    }

    pub async fn put_pool(&self, pool: &Pool) -> Result<(), String> {
        let mut item = HashMap::new();
        item.insert("pool_id".into(), AttributeValue::S(pool.pool_id.clone()));
        item.insert("token_a_id".into(), AttributeValue::S(pool.token_a_id.clone()));
        item.insert("token_b_id".into(), AttributeValue::S(pool.token_b_id.clone()));
        item.insert("token_a_symbol".into(), AttributeValue::S(pool.token_a_symbol.clone()));
        item.insert("token_b_symbol".into(), AttributeValue::S(pool.token_b_symbol.clone()));
        item.insert("reserve_a".into(), AttributeValue::N(pool.reserve_a.to_string()));
        item.insert("reserve_b".into(), AttributeValue::N(pool.reserve_b.to_string()));
        item.insert("k".into(), AttributeValue::N(pool.k.to_string()));
        item.insert("total_lp_shares".into(), AttributeValue::N(pool.total_lp_shares.to_string()));
        item.insert("fee_rate".into(), AttributeValue::N(pool.fee_rate.to_string()));
        item.insert("pool_address".into(), AttributeValue::S(pool.pool_address.clone()));
        item.insert("pool_wif_secret_id".into(), AttributeValue::S(pool.pool_wif_secret_id.clone()));
        item.insert("version".into(), AttributeValue::N(pool.version.to_string()));
        item.insert("created_at".into(), AttributeValue::S(pool.created_at.clone()));

        self.client.put_item()
            .table_name(POOLS_TABLE)
            .set_item(Some(item))
            .send()
            .await
            .map_err(|e| format!("put_pool error: {}", e))?;

        Ok(())
    }

    pub async fn update_pool_optimistic(&self, pool: &Pool, expected_version: u64) -> Result<(), String> {
        let mut item = HashMap::new();
        item.insert("pool_id".into(), AttributeValue::S(pool.pool_id.clone()));
        item.insert("token_a_id".into(), AttributeValue::S(pool.token_a_id.clone()));
        item.insert("token_b_id".into(), AttributeValue::S(pool.token_b_id.clone()));
        item.insert("token_a_symbol".into(), AttributeValue::S(pool.token_a_symbol.clone()));
        item.insert("token_b_symbol".into(), AttributeValue::S(pool.token_b_symbol.clone()));
        item.insert("reserve_a".into(), AttributeValue::N(pool.reserve_a.to_string()));
        item.insert("reserve_b".into(), AttributeValue::N(pool.reserve_b.to_string()));
        item.insert("k".into(), AttributeValue::N(pool.k.to_string()));
        item.insert("total_lp_shares".into(), AttributeValue::N(pool.total_lp_shares.to_string()));
        item.insert("fee_rate".into(), AttributeValue::N(pool.fee_rate.to_string()));
        item.insert("pool_address".into(), AttributeValue::S(pool.pool_address.clone()));
        item.insert("pool_wif_secret_id".into(), AttributeValue::S(pool.pool_wif_secret_id.clone()));
        item.insert("version".into(), AttributeValue::N(pool.version.to_string()));
        item.insert("created_at".into(), AttributeValue::S(pool.created_at.clone()));

        self.client.put_item()
            .table_name(POOLS_TABLE)
            .set_item(Some(item))
            .condition_expression("version = :ev")
            .expression_attribute_values(":ev", AttributeValue::N(expected_version.to_string()))
            .send()
            .await
            .map_err(|e| {
                let err_str = format!("{}", e);
                if err_str.contains("ConditionalCheckFailed") {
                    "CONFLICT: Pool was modified by another request. Please retry.".to_string()
                } else {
                    format!("update_pool error: {}", e)
                }
            })?;

        Ok(())
    }

    pub async fn get_pool(&self, pool_id: &str) -> Result<Option<Pool>, String> {
        let result = self.client.get_item()
            .table_name(POOLS_TABLE)
            .key("pool_id", AttributeValue::S(pool_id.to_string()))
            .send()
            .await
            .map_err(|e| format!("get_pool error: {}", e))?;

        match result.item {
            Some(item) => {
                let pool = Pool {
                    pool_id: get_s(&item, "pool_id")?,
                    token_a_id: get_s(&item, "token_a_id")?,
                    token_b_id: get_s(&item, "token_b_id")?,
                    token_a_symbol: get_s(&item, "token_a_symbol")?,
                    token_b_symbol: get_s(&item, "token_b_symbol")?,
                    reserve_a: get_n(&item, "reserve_a")?,
                    reserve_b: get_n(&item, "reserve_b")?,
                    k: get_f(&item, "k")?,
                    total_lp_shares: get_f(&item, "total_lp_shares")?,
                    fee_rate: get_f(&item, "fee_rate")?,
                    pool_address: get_s(&item, "pool_address")?,
                    pool_wif_secret_id: get_s(&item, "pool_wif_secret_id")?,
                    version: get_n(&item, "version").unwrap_or(1),
                    created_at: get_s(&item, "created_at")?,
                };
                Ok(Some(pool))
            }
            None => Ok(None),
        }
    }

    pub async fn list_pools(&self) -> Result<Vec<Pool>, String> {
        let result = self.client.scan()
            .table_name(POOLS_TABLE)
            .send()
            .await
            .map_err(|e| format!("list_pools error: {}", e))?;

        let mut pools = Vec::new();
        if let Some(items) = result.items {
            for item in items {
                let pool = Pool {
                    pool_id: get_s(&item, "pool_id")?,
                    token_a_id: get_s(&item, "token_a_id")?,
                    token_b_id: get_s(&item, "token_b_id")?,
                    token_a_symbol: get_s(&item, "token_a_symbol")?,
                    token_b_symbol: get_s(&item, "token_b_symbol")?,
                    reserve_a: get_n(&item, "reserve_a")?,
                    reserve_b: get_n(&item, "reserve_b")?,
                    k: get_f(&item, "k")?,
                    total_lp_shares: get_f(&item, "total_lp_shares")?,
                    fee_rate: get_f(&item, "fee_rate")?,
                    pool_address: get_s(&item, "pool_address")?,
                    pool_wif_secret_id: get_s(&item, "pool_wif_secret_id")?,
                    version: get_n(&item, "version").unwrap_or(1),
                    created_at: get_s(&item, "created_at")?,
                };
                pools.push(pool);
            }
        }
        Ok(pools)
    }

    pub async fn put_lp_position(&self, lp: &LpPosition) -> Result<(), String> {
        let mut item = HashMap::new();
        item.insert("pool_id".into(), AttributeValue::S(lp.pool_id.clone()));
        item.insert("user_address".into(), AttributeValue::S(lp.user_address.clone()));
        item.insert("lp_shares".into(), AttributeValue::N(lp.lp_shares.to_string()));
        item.insert("deposited_a".into(), AttributeValue::N(lp.deposited_a.to_string()));
